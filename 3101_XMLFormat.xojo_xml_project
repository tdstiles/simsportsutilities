 </Method>
 <Method>
  <ItemName>ImpactRatingCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1665736703</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ImpactRatingCalc(x as double, impact as string) As double</SourceLine>
   <SourceLine>//CACLULATE IMPACT SCORE</SourceLine>
   <SourceLine>return  (((15-((256-x)*.05859375))*wordtonum(impact))/225)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>x as double, impact as string</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>LocalRatingCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>714563583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LocalRatingCalc(prefconference as integer, local as string, region as string) As double</SourceLine>
   <SourceLine>dim nLocalRatingTmp as double</SourceLine>
   <SourceLine>dim nlocalaTmp as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CALCULATE LOCAL SCORE</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>nlocalaTMP=wordtonum(local)-7.5</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if nlocalaTmp&gt;0 then //wants to stay home</SourceLine>
   <SourceLine>IF ABS(val(Region)-(prefConference))=2 OR ABS(val(Region)-(prefConference))=30 THEN</SourceLine>
   <SourceLine>nlocalratingtmp=.8*(nlocalaTmp/15)+.5</SourceLine>
   <SourceLine>elseif ABS(val(Region)-(PrefConference))=1 OR ABS(val(Region)-(prefConference))=31THEN</SourceLine>
   <SourceLine>nlocalratingTmp=.9*(nlocalaTmp/15)+.5</SourceLine>
   <SourceLine>elseif ABS(val(Region)-(PrefConference))=0 THEN</SourceLine>
   <SourceLine>nlocalratingTmp=(nlocalaTmp/15)+.5</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//not local, so inverse</SourceLine>
   <SourceLine>nlocalratingTmp=1-((nlocalaTmp/15)+.5)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else //locala&lt;0, wants to leave conference</SourceLine>
   <SourceLine>//close to home, so inverse</SourceLine>
   <SourceLine>IF ABS(val(Region)-(prefConference))&lt;=2 THEN</SourceLine>
   <SourceLine>nlocalratingTmp=1-(ABS(nlocalaTmp/15)+.5)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//far away, desire to go</SourceLine>
   <SourceLine>nlocalratingTmp=ABS(nlocalaTmp/15)+.5</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return nLocalRatingTmp</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>prefconference as integer, local as string, region as string</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>WinRatingCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1435252735</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function WinRatingCalc(win as string, x as double) As double</SourceLine>
   <SourceLine>//CALCULATE WIN SCORE</SourceLine>
   <SourceLine>return  ((((8-(x*.05859375))*wordtonum(win))/240)+0.5)</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
