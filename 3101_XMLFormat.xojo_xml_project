 <Method>
  <ItemName>PopDBWithNewInfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1501448191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PopDBWithNewInfo()</SourceLine>
   <SourceLine>//need to create one from scratch</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, create the file and set up the tables for it</SourceLine>
   <SourceLine>CreateDBFile</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then, let's add in the new information</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefTeamNum=gTeams.indexof(efteamname.text)+1</SourceLine>
   <SourceLine>//load in the main team info</SourceLine>
   <SourceLine>'TeamInfo (rowID INTEGER PRIMARY KEY autoincrement, TeamName varchar, League Integer, Region Integer, lastPR Integer, PR2 Integer, PR3 Integer, TeamID Integer, Season integer)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO TeamInfo (TeamName, League, Region, LastPR, PR2, PR3, TeamID, Season) VALUES ('"+efteamname.text+"', '"+efleague.text+"', '"+efconference.text+"', '"+efpr.text+"', '"+eflastpr.text+"', '"+efpr2.text+"', '"+str(prefTeamNum)+"', '"+efSeason.text+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update the DB Version into mykeys so we can track which version we have</SourceLine>
   <SourceLine>sqlstring="INSERT INTO MyKeys (Key, Value) VALUES ('DBVersion', '10')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's deal with the name and/or password issues here</SourceLine>
   <SourceLine>if efID.text&lt;&gt;"" and efPassword.text&lt;&gt;"" then</SourceLine>
   <SourceLine>prefUserName=efID.text</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefPassword=efPassword.text</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO MyKeys (Key, Value) VALUES ('UserName', '"+prefUserName+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO MyKeys (Key, Value) VALUES ('Password', '"+prefPassword+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>wndMain.LoadTotalSeasonPopup</SourceLine>
   <SourceLine>UpdateMainAfterFileLoaded</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
