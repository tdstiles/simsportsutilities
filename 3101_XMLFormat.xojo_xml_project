 <Method>
  <ItemName>PlayerOverviewText</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1594275839</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PlayerOverviewText() As string</SourceLine>
   <SourceLine>//this method generates clipboard text of the player for posting on the messageboard</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, we do the player's average stats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpString as string</SourceLine>
   <SourceLine>//total stats</SourceLine>
   <SourceLine>tmpstring="[i]Totals:[/i]  "</SourceLine>
   <SourceLine>tmpString=tmpstring+str(games)+" gm, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(minutes,"#,##0")+" min, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(pts,"#,##0")+" pts, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(reb,"#,##0")+" reb, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(ast,"#,##0")+" ast, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(stl,"#,##0")+" stl, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(tos,"#,##0")+" tos, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(blk,"#,##0")+" blk "+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//average stats</SourceLine>
   <SourceLine>tmpstring=tmpstring+"[i]Averages:[/i]  "</SourceLine>
   <SourceLine>tmpString=tmpString+format(minutes/Divisor,formater)+"min, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(pts/Divisor,formater)+"pts, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(reb/Divisor,formater)+"reb, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(ast/Divisor,formater)+"ast, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(stl/Divisor,formater)+"stl, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(tos/Divisor,formater)+"tos, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(blk/Divisor,formater)+"blk "+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//percentages</SourceLine>
   <SourceLine>tmpString=tmpString+FGPCT+" FG%,  "+FG3PCT+" 3FG%,  "+ FTPCT+" FT%,  "+tsp+" TSP"+EndOfLine</SourceLine>
   <SourceLine>tmpString=tmpString+format(apts/Divisor,formater)+"aPts, "</SourceLine>
   <SourceLine>tmpString=tmpString+aFGPCT+" aFG%, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(crTO/Divisor,formater)+"crTO, "</SourceLine>
   <SourceLine>tmpString=tmpString+format(oReb/Divisor,formater)+"oReb"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//efficiency</SourceLine>
   <SourceLine>divisor=minutes/30</SourceLine>
   <SourceLine>tmpString=tmpString+"[i]Efficiency Stats per 30:[/i]  "+sPlusMinus+" +/-,  "</SourceLine>
   <SourceLine>tmpString=tmpString+svx+" SVx,  "</SourceLine>
   <SourceLine>tmpString=tmpString+nbs+" NBS, "</SourceLine>
   <SourceLine>tmpString=tmpString+WinScore+"  WS,  "</SourceLine>
   <SourceLine>tmpString=tmpString+gs+" GS"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get awards</SourceLine>
   <SourceLine>tmpString=tmpString+mthAwards</SourceLine>
   <SourceLine>return tmpString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mthAwards</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>919554047</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthAwards() As String</SourceLine>
   <SourceLine>//this looks to see if the player has won any awards.  If so, they're added on</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim tmpstring as string</SourceLine>
   <SourceLine>dim tmpName as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set up so we have search for initial and first name</SourceLine>
   <SourceLine>tmpName=mthNameAndInitialForSQL(szName)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Award, Season FROM PlayerAwards WHERE Name LIKE '"+tmpName+"' ORDER BY Season ASC"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.eof=false and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>tmpstring=tmpstring+endofline+"[i]Awards:[/i]"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>tmpstring=tmpstring+"S"+rs.IdxField(2).StringValue+" "+rs.IdxField(1).StringValue+EndOfLine</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return tmpstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>String</ItemResult>
 </Method>
