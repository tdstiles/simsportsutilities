  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AlertMsg(MsgTitle As String, Msg As String, Expl As String, MsgIcon As String, ActionBtn As String, CancelBtn As Boolean, AltBtn As Boolean, AltCaption As String)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Dim dlg as New MessageDialog  // Declare the MessageDialog object</SourceLine>
   <SourceLine>Dim btn as MessageDialogButton // For handling the result</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If MsgIcon = "None" Then</SourceLine>
   <SourceLine>dlg.Icon = -1   //display no icon</SourceLine>
   <SourceLine>ElseIf MsgIcon = "Note"  Then</SourceLine>
   <SourceLine>dlg.Icon = 0   //display the Note icon</SourceLine>
   <SourceLine>ElseIf MsgIcon = "Caution" Then</SourceLine>
   <SourceLine>dlg.Icon = 1   //display Caution/Warning Triange icon</SourceLine>
   <SourceLine>ElseIf MsgIcon = "Stop" Then</SourceLine>
   <SourceLine>dlg.Icon = 2   //display Caution/Warning icon</SourceLine>
   <SourceLine>ElseIf MsgIcon = "Question" Then</SourceLine>
   <SourceLine>dlg.Icon = 3   //display Caution/Warning icon</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dlg.Title = MsgTitle</SourceLine>
   <SourceLine>dlg.ActionButton.Caption = ActionBtn</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dlg.CancelButton.Visible = CancelBtn     //show the Cancel button</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If AltBtn = True Then</SourceLine>
   <SourceLine>dlg.AlternateActionButton.Visible = AltBtn   //show the Dont Save button</SourceLine>
   <SourceLine>dlg.AlternateActionButton.Caption = AltCaption</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dlg.Message = Msg</SourceLine>
   <SourceLine>dlg.Explanation = Expl</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>btn =dlg.ShowModal     //display the dialog</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Select Case btn //determine which button was pressed.</SourceLine>
   <SourceLine>Case dlg.ActionButton //user pressed the Action Button</SourceLine>
   <SourceLine>MsgBtn = 1</SourceLine>
   <SourceLine>Case dlg.CancelButton  //user pressed Cancel</SourceLine>
   <SourceLine>MsgBtn = 2</SourceLine>
   <SourceLine>Case dlg.AlternateActionButton //user pressed Alternate Action Button</SourceLine>
   <SourceLine>MsgBtn = 3</SourceLine>
   <SourceLine>End select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
