 <Method>
  <ItemName>LoadGameList</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>670517247</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadGameList()</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim list as listbox</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim season as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if popup(2).ListIndex=0 then //offensive stats</SourceLine>
   <SourceLine>sqlstring="SELECT stats.season as thisseason, stats.game as game, stats.aposition as aposition, stats.mins as mins, stats.fgm as fgm, stats.fga as fga, stats.ftm as ftm, stats.fta as fta, stats.fg3m as fg3m, stats.fg3a as fg3a, stats.ftm as ftm, stats.fta as fta, stats.reb as reb, stats.ast as ast, stats.stl as stl, stats.fouls as fouls, stats.blk as blk, stats.tos as tos, stats.pts as pts, stats.POG as POG, stats.Settings_Sub as Subs, stats.Settings_Shot as shot, stats.Settings_3Pt as pt3 FROM "+clause(1)+" WHERE Stats.Name LIKE '"+PlayersName+"'" + clause(0) + clause(2)+ clause(3)+ " ORDER BY Stats.Season, Stats.Game ASC"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>List=lbBoxScores</SourceLine>
   <SourceLine>List.DeleteAllRows</SourceLine>
   <SourceLine>While rs&lt;&gt;Nil and rs.EOF=false</SourceLine>
   <SourceLine>List.AddRow rs.field("Game").stringValue, rs.field("APosition").StringValue, rs.field("Mins").stringValue, rs.field("FGM").stringValue, rs.field("FGA").stringValue, rs.field("FG3M").stringValue, rs.field("FG3A").stringValue, rs.field("FTM").stringValue, rs.field("FTA").stringValue, rs.field("Reb").stringValue, rs.field("Ast").stringValue, rs.field("Blk").stringValue, rs.field("Stl").stringValue, rs.field("TOs").stringValue, rs.field("fouls").stringValue, rs.field("pts").stringValue, rs.Field("Subs").StringValue, rs.Field("Shot").StringValue, rs.Field("pt3").StringValue,  rs.Field("POG").StringValue, rs.field("thisseason").StringValue</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //defensive stats</SourceLine>
   <SourceLine>sqlstring="SELECT Stats.Season as season, Stats.Game as game, Stats.Aposition as Position, Stats.Mins as Mins, Stats.aFGM as aFGM, Stats.aFGA as aFGA, Stats.aF3M as aF3M, Stats.aF3A as aF3A, Stats.aPts as aPts, Stats.crTO as crTO, Stats.TP as TP, Stats.POG as POG FROM "+clause(1)+" WHERE Stats.Name LIKE '"+PlayersName+"'" + clause(0) + clause(2)+ clause(3)+ " ORDER BY Stats.Season, Stats.Game ASC"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>list=lbBoxScores</SourceLine>
   <SourceLine>list.DeleteAllRows</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.eof=false</SourceLine>
   <SourceLine>list.addrow rs.field("Game").StringValue, rs.Field("position").StringValue, rs.field("mins").StringValue, rs.field("afgm").StringValue, rs.field("afga").StringValue, rs.field("af3m").StringValue, rs.field("af3a").StringValue, rs.field("apts").StringValue, rs.field("crTO").StringValue, format(rs.field("aPts").IntegerValue/rs.field("TP").IntegerValue, "0.00"), rs.field("POG").StringValue, rs.field("season").StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>fbLoading=false</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
