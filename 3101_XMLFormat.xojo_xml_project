   <SourceLine>Sub AddtoDB(Season as String)</SourceLine>
   <SourceLine>dim r as DatabaseRecord</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if DBConnect then</SourceLine>
