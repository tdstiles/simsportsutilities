  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>TimeSecondstoMinutes</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>50577407</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TimeSecondstoMinutes() As string</SourceLine>
   <SourceLine>dim minutesdisplayed as integer</SourceLine>
   <SourceLine>dim secondsdisplayed as integer</SourceLine>
   <SourceLine>dim floorseconds as integer</SourceLine>
   <SourceLine>dim minmod as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim seconds as integer=MyAction.Time</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this takes the seconds from (ExtractData.iAction.Time) and turns them into countdown minutes as well as the half time indicator</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if seconds&gt;2400 then</SourceLine>
   <SourceLine>minmod=5</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>minmod=20</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, determine which half we're in</SourceLine>
   <SourceLine>if seconds=1200 then</SourceLine>
   <SourceLine>if HalfTimePausedHappen=0 then</SourceLine>
   <SourceLine>HalfTimePausedHappen=1</SourceLine>
   <SourceLine>elseif HalfTimePausedHappen=1 then</SourceLine>
   <SourceLine>if fWatchPBP then //we pause at halftime</SourceLine>
   <SourceLine>fRunning=2</SourceLine>
   <SourceLine>MainTimer.Enabled=false</SourceLine>
   <SourceLine>startorpause.caption="Resume"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>half.text="2"</SourceLine>
   <SourceLine>seconds=seconds-1200</SourceLine>
   <SourceLine>Stats.FinalSubstitute</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fWatchPBP then //only show if we're watching the game</SourceLine>
   <SourceLine>wndInGameStats.Show</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>//deal with fouls--reset to zero for halftime</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Sum(Fouls) FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>FoulMinus(n)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>UpdateTeamMethods("0", 3)</SourceLine>
   <SourceLine>HalfTimePausedHappen=2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif seconds&gt;1200 and seconds&lt;=2400 then</SourceLine>
   <SourceLine>seconds=seconds-1200</SourceLine>
   <SourceLine>elseif seconds&gt;2400 and seconds&lt;=2700 then</SourceLine>
   <SourceLine>half.text="OT"</SourceLine>
   <SourceLine>seconds=seconds-2400</SourceLine>
   <SourceLine>elseif seconds&gt;2700 and seconds&lt;=3000 then</SourceLine>
   <SourceLine>half.text="2OT"</SourceLine>
   <SourceLine>seconds=seconds-2700</SourceLine>
   <SourceLine>elseif seconds&gt;3000 and seconds&lt;=3300 then</SourceLine>
   <SourceLine>half.text="3OT"</SourceLine>
   <SourceLine>seconds=seconds-3000</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//next, figure out how many minutes are left</SourceLine>
   <SourceLine>minutesdisplayed=minmod-ceil(seconds/60)</SourceLine>
   <SourceLine>floorseconds=floor(seconds/60)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>secondsdisplayed=60-(seconds-floorseconds*60)</SourceLine>
   <SourceLine>if secondsdisplayed=60 then</SourceLine>
   <SourceLine>secondsdisplayed=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return format(minutesdisplayed, "#0")+":"+format(secondsdisplayed, "00")</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
