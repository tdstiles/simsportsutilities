 <Method>
  <ItemName>OpenFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1845305343</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub OpenFile(file as folderitem)</SourceLine>
   <SourceLine>dim db as new REALSQLDatabase</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim x as new folderitem</SourceLine>
   <SourceLine>dim y as new FolderItem</SourceLine>
   <SourceLine>dim l,n,m,o as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If file &lt;&gt; Nil and file.Exists then</SourceLine>
   <SourceLine>l=file.AbsolutePath</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>m=menuitems(0).AbsolutePath</SourceLine>
   <SourceLine>n=menuitems(1).AbsolutePath</SourceLine>
   <SourceLine>o=menuitems(2).AbsolutePath</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if l&lt;&gt;m AND l&lt;&gt;n AND l&lt;&gt;o then</SourceLine>
   <SourceLine>x=new FolderItem(m)</SourceLine>
   <SourceLine>y=new FolderItem(n)</SourceLine>
   <SourceLine>menuitems(2)=y</SourceLine>
   <SourceLine>menuitems(1)=x</SourceLine>
   <SourceLine>menuitems(0)=new FolderItem(l)</SourceLine>
   <SourceLine>elseif l=m then</SourceLine>
   <SourceLine>//is already at the top of the list, so do nothing</SourceLine>
   <SourceLine>elseif l=n then</SourceLine>
   <SourceLine>x=new FolderItem(m)</SourceLine>
   <SourceLine>menuitems(1)=x</SourceLine>
   <SourceLine>menuitems(0)=new FolderItem(l)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif l=o then</SourceLine>
   <SourceLine>x=new FolderItem(m)</SourceLine>
   <SourceLine>y=new FolderItem(n)</SourceLine>
   <SourceLine>menuitems(2)=y</SourceLine>
   <SourceLine>menuitems(1)=x</SourceLine>
   <SourceLine>menuitems(0)=new FolderItem(l)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>SavePrefs</SourceLine>
   <SourceLine>LoadRecentMenuItems</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>DBName=file.name</SourceLine>
   <SourceLine>DBPath=file.AbsolutePath</SourceLine>
   <SourceLine>DB.databasefile=file</SourceLine>
   <SourceLine>SDB=file</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim updated as Boolean=false</SourceLine>
   <SourceLine>while updated=false</SourceLine>
   <SourceLine>updated=DBCheckDatabaseSchema</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>DBLoaded=true</SourceLine>
   <SourceLine>EnablePrintAll=True</SourceLine>
   <SourceLine>UpdateMainAfterFileLoaded</SourceLine>
   <SourceLine>wndMain.EnableButtons=TRUE</SourceLine>
   <SourceLine>wndMain.mainpanel.Value=0</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>//User Cancelled</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
