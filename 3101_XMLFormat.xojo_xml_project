   <SourceLine>rs=db.SQLSelect("SELECT Count(WL) FROM TeamHistory WHERE Season= '"+str(GametoImport.Season)+"' AND Game&gt;='19' AND Game&lt;='24' AND WL='W'")</SourceLine>
