  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>728997887</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function FireUp() As string</SourceLine>
   <SourceLine>dim rs, rec as RecordSet</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string="SELECT WL, OurScore, Oppscore, Opponent FROM TeamHistory WHERE Game='"+str(GN)+"' AND Season='"+str(SN)+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GN&lt;19 then</SourceLine>
   <SourceLine>h=""</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT TeamHistory.Type FROM TeamHistory WHERE Game='"+str(GN)+"' AND Season='"+str(SN)+"'")</SourceLine>
   <SourceLine>h=" ("+rec.IdxField(1).StringValue+") "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iOpponent as integer=gTeams.indexof(rs.IdxField(4).StringValue)+1</SourceLine>
   <SourceLine>if prefTeamNum&lt;iOpponent then</SourceLine>
   <SourceLine>BoxScoreTeams(0)=gTeams(prefTeamNum-1)</SourceLine>
   <SourceLine>BoxScoreTeams(1)=gTeams(iOpponent-1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>BoxScoreTeams(1)=gTeams(prefTeamNum-1)</SourceLine>
   <SourceLine>BoxScoreTeams(0)=gTeams(iOpponent-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return "Season # "+str(SN)+ " Game # "+str(GN) + h+ " vs. " + rs.IdxField(4).value + " (" + rs.IdxField(1).Value+" " + rs.IdxField(2).Value+"-"+rs.IdxField(3).Value+")"</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>LoadBoxScore</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>655880191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadBoxScore(Optional Season as String, Optional GameNumber as String)</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim list as cShadedListbox</SourceLine>
   <SourceLine>dim rownum as integer</SourceLine>
   <SourceLine>dim TmpClause as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Set our variables</SourceLine>
   <SourceLine>if season&lt;&gt;"" AND GameNumber&lt;&gt;"" then</SourceLine>
   <SourceLine>SN=val(season)</SourceLine>
   <SourceLine>GN=val(GameNumber)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpClause="FROM Stats WHERE Game='"+str(GN)+"' AND Season='"+str(SN)+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>List=wndMain.lbBoxScoreStats</SourceLine>
   <SourceLine>wndMain.SetFocus</SourceLine>
   <SourceLine>wndMain.mainpanel.Value=9</SourceLine>
   <SourceLine>wndMain.staBoxScoreHeading.text=FireUp</SourceLine>
   <SourceLine>List.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 9</SourceLine>
   <SourceLine>list.addrow ""</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if typeselection=0 then //offense stats</SourceLine>
   <SourceLine>List.LoadHeader(split("Name,Pos,Min,FGM,FGA,3PM,3PA,FTM,FTA,Reb,Ast,Blk,Stl,TO,PF,Pts",","))</SourceLine>
   <SourceLine>List.ColumnWidths = "100,*"</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, APosition, Mins, FGM, FGA, FG3M, FG3A, FTM, FTA, Reb, Ast, Blk, Stl, TOs, fouls, pts "+TmpClause)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to rs.RecordCount</SourceLine>
   <SourceLine>rownum=BoxPositions.IndexOf(rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 15</SourceLine>
   <SourceLine>list.cell(rownum, j)=rs.IdxField(j+1).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//add in total stats</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(Mins), Sum(FGM), Sum(FGA), Sum(FG3M), Sum(FG3A),  Sum(FTM), Sum(FTA), Sum(Reb), Sum(Ast), Sum(Blk), Sum(Stl), Sum(TOS), Sum(Fouls), Sum(Pts), Sum(crTO) "+TmpClause)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>list.Addrow "Team", "--", str(rs.idxfield(1).IntegerValue), str(rs.idxfield(2).IntegerValue), str(rs.idxfield(3).IntegerValue), str(rs.idxfield(4).IntegerValue), str(rs.idxfield(5).IntegerValue), str(rs.idxfield(6).IntegerValue), str(rs.idxfield(7).IntegerValue), str(rs.idxfield(8).IntegerValue), str(rs.idxfield(9).IntegerValue), str(rs.idxfield(10).IntegerValue), str(rs.idxfield(11).IntegerValue), str(rs.idxfield(12).IntegerValue), str(rs.idxfield(13).IntegerValue), str(rs.idxfield(14).IntegerValue)</SourceLine>
   <SourceLine>end</SourceLine>
