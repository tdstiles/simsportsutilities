 <ControlBehavior>
  <Superclass>Canvas</Superclass>
  <HookInstance>
   <ItemName>Open</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>2119727103</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Open()</SourceLine>
    <SourceLine>'On open, we populate this canvas with all the info from the game chart</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim chart as new rhChart</SourceLine>
    <SourceLine>dim dataItem() as Double, dataLabel() as String, dataLegend() As String, dataColor() as Color</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//get the teamnames for the dataLegend</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>rs=svdb.SQLSelect("SELECT distinct(TeamName) FROM SVTable ORDER BY TeamNum ASC")</SourceLine>
    <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
    <SourceLine>dataLegend.Append rs.idxfield(1).stringvalue</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>dataColor = array(&amp;c17509F, &amp;cF27120)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//dataitem is an array of two different arrays:  first the team 1 array, and then the team2 array</SourceLine>
    <SourceLine>//for every tick, we add new events</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>'dim tmpI as integer=UBound(StatViewerGlobals.Team1Scores)</SourceLine>
    <SourceLine>'for i as integer=0 to tmpI</SourceLine>
    <SourceLine>'dataItem.append(StatViewerGlobals.Team1Scores(i))</SourceLine>
    <SourceLine>'next</SourceLine>
    <SourceLine>'</SourceLine>
    <SourceLine>'tmpI=UBound(StatViewerGlobals.Team2Scores)</SourceLine>
    <SourceLine>'for i as integer=0 to tmpI</SourceLine>
    <SourceLine>'dataItem.append(StatViewerGlobals.Team2Scores(i))</SourceLine>
    <SourceLine>'next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//test method to narrow this down</SourceLine>
    <SourceLine>redim dataItem(-1) </SourceLine>
    <SourceLine>redim dataLabel(-1)</SourceLine>
    <SourceLine>dim tmpArray(-1) as double</SourceLine>
    <SourceLine>dim tmpI as integer=UBound(StatViewerGlobals.Team1Scores)</SourceLine>
    <SourceLine>for i as integer=0 to tmpI</SourceLine>
    <SourceLine>if i mod 30=0 then</SourceLine>
    <SourceLine>dataItem.append(StatViewerGlobals.Team1Scores(i))</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>tmpI=UBound(StatViewerGlobals.Team2Scores)</SourceLine>
    <SourceLine>for i as integer=0 to tmpI</SourceLine>
    <SourceLine>if i mod 30=0 then</SourceLine>
    <SourceLine>dataItem.append(StatViewerGlobals.Team2Scores(i))</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim r as integer=1</SourceLine>
    <SourceLine>tmpI=ubound(dataItem)</SourceLine>
    <SourceLine>for n as integer=0 to tmpI</SourceLine>
    <SourceLine>if n mod 40=0 then</SourceLine>
    <SourceLine>if r=1 then</SourceLine>
    <SourceLine>datalabel.append "Tip"</SourceLine>
    <SourceLine>elseif r=5 then</SourceLine>
    <SourceLine>datalabel.append "Buzzer"</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>datalabel.append str(r)+"Qtr"</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>r=r+1</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>if n mod 2=0 then</SourceLine>
    <SourceLine>dataLabel.append ""</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>'figure out how to name the teams</SourceLine>
    <SourceLine>dim tmpHeader as string</SourceLine>
    <SourceLine>tmpHeader="Game "+str(StatViewerGlobals.GameToImport.Game)+" "+StatViewerGlobals.GameToImport.iTeams(0).TeamName+" vs. "+StatViewerGlobals.GameToImport.iTeams(1).TeamName</SourceLine>
