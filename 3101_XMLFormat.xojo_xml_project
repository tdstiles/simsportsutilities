 <Method>
  <ItemName>ImportHSCSV</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1796124671</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ImportHSCSV(teamarray(,) as string)</SourceLine>
   <SourceLine>dim sumhs as integer</SourceLine>
   <SourceLine>dim name, sqlstring, region,  sht, def, hnd, reb, ath as string</SourceLine>
   <SourceLine>dim avgheight as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM HSINFO")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>name=teamarray(n,0)</SourceLine>
   <SourceLine>sht=teamarray(n,1)</SourceLine>
   <SourceLine>def=teamarray(n,2)</SourceLine>
   <SourceLine>hnd=teamarray(n,4)</SourceLine>
   <SourceLine>reb=teamarray(n,3)</SourceLine>
   <SourceLine>ath=teamarray(n,5)</SourceLine>
   <SourceLine>region=str(ceil((n+1)/8))</SourceLine>
   <SourceLine>sumhs=wordtonum(sht)+wordtonum(def)+wordtonum(hnd)+wordtonum(reb)+wordtonum(ath)</SourceLine>
   <SourceLine>avgheight=str(HSHeight(teamarray(n,8)))</SourceLine>
   <SourceLine>sqlstring="INSERT INTO HSInfo (HSName, Region,HSSHT, HSDEF, HSHND, HSREB, HSATH,  SumHS, LastWL, ThisWL, AvgHeight) VALUES ('"+name+"','"+region+"','"+sht+"','"+def+"','"+hnd+"','"+reb+"','"+ath+"','"+str(sumhs)+"','"+teamarray(n,6)+"','"+teamarray(n,7)+"','"+avgheight+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>teamarray(,) as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ImportRecruitCSV</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1250267135</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ImportRecruitCSV()</SourceLine>
   <SourceLine>Dim TextIn As TextInputStream</SourceLine>
   <SourceLine>Dim line As String</SourceLine>
   <SourceLine>dim Recruit as cRecruit</SourceLine>
   <SourceLine>dim fInsert as Boolean</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If CSVfile.Exists Then // check to make sure the file exists</SourceLine>
   <SourceLine>TextIn = TextInputStream.Open( CSVFile )</SourceLine>
   <SourceLine>If TextIn &lt;&gt; NIL Then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we need to determine whether this is the first time or not</SourceLine>
   <SourceLine>fInsert=NeedtoInsert</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// read the heading line</SourceLine>
   <SourceLine>line = TextIn.ReadLine</SourceLine>
   <SourceLine>Do</SourceLine>
   <SourceLine>// read a line</SourceLine>
   <SourceLine>line = TextIn.ReadLine</SourceLine>
   <SourceLine>Recruit=new cRecruit(line)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fInsert then</SourceLine>
   <SourceLine>DBSQLExecute(Recruit.Insert)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>DBSQLExecute(recruit.Update)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Loop Until TextIn.EOF = True</SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>TextIn.Close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
