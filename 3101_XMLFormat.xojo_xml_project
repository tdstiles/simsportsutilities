  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateSVDB()</SourceLine>
   <SourceLine>SVDB=new REALSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if SVDB.Connect then</SourceLine>
   <SourceLine>SVDB.SQLExecute("CREATE Table SVTable (rowID Integer PRIMARY KEY autoincrement, Name varchar, PlayerNum integer, TeamName varchar, TeamNum integer, Pos varchar, MinutesPlayed integer, secondsplayed integer, secondswhenentering integer, FGM integer, fga integer, ftm integer, fta integer, fg3m integer, fg3a integer, ast integer, blk integer, stl integer, tos integer, fouls integer, pts integer, oreb integer, dreb integer, shrtm integer, shrta integer, medM integer, medA integer, longM integer, longA integer, aFGM integer, aFGA integer, aFG3M integer, aFG3A integer, aPts integer, crTO integer, TP integer, aOReb integer, aDReb integer, aTReb integer, lostP integer, lostD integer, PUs integer, touches integer, AR integer, shBlkd integer, plusminus integer, plusminuswhenentering integer, opponent integer, fd integer, initialpos varchar, Settings_Sub varchar, Settings_Shot integer, Settings_3Pt integer)")</SourceLine>
   <SourceLine>SVDB.SQLExecute("CREATE INDEX StatsIndex on SVTable(Name)")</SourceLine>
   <SourceLine>SVDB.SQLExecute("CREATE INDEX NumberIndex on SVTable(PlayerNum)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
