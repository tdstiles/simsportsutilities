  <PartID>1282492415</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateDefaultPrefFile()</SourceLine>
   <SourceLine>//this method starts up the default preference values, then runs the saveFile to save all the prefs</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefplayerpct=80</SourceLine>
   <SourceLine>prefScoutStat=5</SourceLine>
   <SourceLine>prefmyfactor=1.50</SourceLine>
   <SourceLine>prefoppfactor=2.90</SourceLine>
   <SourceLine>prefattfactor=0.80</SourceLine>
   <SourceLine>prefstatfactor=0.87</SourceLine>
   <SourceLine>prefLocal=3.0</SourceLine>
   <SourceLine>prefWin=2.0</SourceLine>
   <SourceLine>prefImpact=1.0</SourceLine>
   <SourceLine>prefstats(0)=1</SourceLine>
   <SourceLine>prefstats(1)=3</SourceLine>
   <SourceLine>prefstats(2)=3</SourceLine>
   <SourceLine>prefstats(3)=1</SourceLine>
   <SourceLine>prefstats(4)=2</SourceLine>
   <SourceLine>prefstats(5)=3</SourceLine>
   <SourceLine>prefstats(6)=2</SourceLine>
   <SourceLine>prefstats(7)=2</SourceLine>
   <SourceLine>prefstats(8)=1</SourceLine>
   <SourceLine>prefstats(9)=2</SourceLine>
   <SourceLine>prefstats(10)=3</SourceLine>
   <SourceLine>prefstats(11)=2</SourceLine>
   <SourceLine>prefstats(12)=2</SourceLine>
   <SourceLine>prefstats(13)=1</SourceLine>
   <SourceLine>prefstats(14)=2</SourceLine>
   <SourceLine>prefstats(15)=1</SourceLine>
   <SourceLine>prefstats(16)=2</SourceLine>
   <SourceLine>prefstats(17)=2</SourceLine>
   <SourceLine>prefstats(18)=3</SourceLine>
   <SourceLine>prefstats(19)=2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as FolderItem</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>f=new FolderItem</SourceLine>
   <SourceLine>f.name=". . ."</SourceLine>
   <SourceLine>MenuItems(n)=f</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefWindowColor="&amp;cF0E68C"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load up the possibility strings</SourceLine>
   <SourceLine>dim newpstring as cPossibilityString</SourceLine>
   <SourceLine>dim posstext(10) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>posstext(0)="5#hits,2#makes,2#sinks,1#nails,1#drains"</SourceLine>
   <SourceLine>posstext(1)="5#misses,2#bricks,1#clanks,1#airballs"</SourceLine>
   <SourceLine>posstext(2)="5#rebounds it,2#grabs the rebound,2#pulls down the rebound,1#tears down the rebound,1#grabs the board,1#cleans it off the glass"</SourceLine>
   <SourceLine>posstext(3)="5#picks up the loose ball,2#dives on the loose ball,1#loses some skin diving for the loose ball,1#fights for the loose ball and comes up with it"</SourceLine>
   <SourceLine>posstext(4)="6#passes to,2#tosses the ball to,2#bounce passes it to,1#lobs it to,1#hands it off to,1#slides off the pick and roll and passes it to,2#dishes to,1#tosses it to,1#deals it to"</SourceLine>
   <SourceLine>posstext(5)="5#dribbles,1#shows a wicked crossover,1#dribbles between his legs,2#makes a hard move toward the basket,3#dribbles off the pick,1#dribbles off the pick and roll,2#takes a look inside,1#scans the defense,1#hesitates at the top of the key"</SourceLine>
   <SourceLine>posstext(6)="5#dribbles upcourt,1#jogs it up the court,3#brings it up the court,1#gets the play from the coach,1#calls out the play,1#races up the court,1#eyes the defense,1#breaks it upcourt"</SourceLine>
   <SourceLine>posstext(7)="7#a short 2-pt field goal,2#a shot from close range,1#a shot from the block,1#a floater in the lane,1#a runner in the lane"</SourceLine>
   <SourceLine>posstext(8)="7#a midrange 2-pt field goal,2#a jumper from the elbow,2#a jumper from the top of the key,2#a midrange shot from the wing,1#a shot from 15 feet,1#a shot from 13 feet,1#a bucket from 12 feet"</SourceLine>
   <SourceLine>posstext(9)="7#a long range 2-pt field goal,2#a bucket from 18 feet,2#a tough shot from just inside the arc,1#a jumper from 21 feet,2#a fadeaway from the wing"</SourceLine>
