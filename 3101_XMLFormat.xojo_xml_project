   <SourceLine>sqlArray.append "CREATE TABLE PlayerInfo (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Name varchar, Region integer, HSName varchar, Height double, gpa varchar, test varchar, pos varchar, scout integer, sht integer, def integer, hnd integer, reb integer, ath integer, local integer, win integer, impact integer, ppg double, rpg double, apg double, spg double, tpg double, bpg double,  Tendex double, HSSOS double, NormTendex double, OppRatingPct double, StatPct double, AttPct double, FitPct double, MyRating double, MyRatingPct double, PlusMinusPct double, MyPosition varchar, estimatedattributes varchar, playerplusminus double , mratingpct double, t75rnk integer, Type varchar, RP integer, Maxt75rnk integer, StdDevPct double, BobbyRating double, BobbyRatingRank double, StdDevPctRank double, PlayerPlusMinusRank double, mratingpctrank double, BTPct double, BTPctRank double, BTAltPct double, BTAltPctRank double, PFPct double, PFPctRank double, MyRatingPctRank double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX PlayerNameIndex on PlayerInfo(Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX HSNameIndex on HSInfo(HSName)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Stats (rowID INTEGER PRIMARY KEY autoincrement, Name varchar, Season Integer, Game Integer, APosition varchar, FGM Integer, FGA Integer, FTM Integer, FTA Integer, FG3M Integer, FG3A Integer, Reb Integer, Ast Integer, Blk Integer, Stl Integer, TOs Integer, Fouls Integer, Pts Integer, Mins Integer, shrtM Integer, shrtA Integer, midM Integer, midA integer, longM integer, longA integer, aFGM integer, aFGA integer, aF3M Integer, aF3A integer, aPts Integer,OReb Integer, DReb Integer, aDReb Integer, aOReb Integer, aTREB Integer, lostP Integer, lostD Integer, crTO Integer, PUs Integer, touch Integer, TP Integer, FD Integer, AR Integer, shBlkd Integer, plusminus integer, POG varchar, Settings_Sub varchar, Settings_Shot integer, Settings_3Pt integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX NameIndex on Stats(Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE TeamHistory (rowID INTEGER PRIMARY KEY autoincrement, Season Integer, Game Integer, Type varchar, Opponent varchar,OurScore Integer, OppScore Integer, WL varchar, Featured varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX SeasonIndex on TeamHistory(Season)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE TeamInfo (rowID INTEGER PRIMARY KEY autoincrement, TeamName varchar, League Integer, Region Integer, lastPR Integer, PR2 Integer, PR3 Integer, TeamID Integer, Season integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Recruits (rowID INTEGER PRIMARY KEY autoincrement, Season Integer, atts Integer,Name varchar, Region integer, HSName varchar, Height varchar, gpa varchar, test varchar, pos varchar, scout integer, sht integer, def integer, hnd integer, reb integer, ath integer, local varchar, win varchar, impact varchar, ppg double, rpg double, apg double, spg double, tpg double, bpg double,  Tendex varchar, HSSOS varchar, NormTendex varchar, OppRatingPct double, StatPct varchar, AttPct varchar, FitPct double, MyRating double, MyRatingPct double, PlusminusPct double, sh integer, hw integer,estimatedattributes varchar, playerplusminus double , mratingpct double, stddevpct double, rSHT integer, rDEF integer, rHND integer, rREB integer, rINT integer, rATH integer, BobbyRating double, BobbyRatingRank double, StdDevPctRank double, PlayerPlusMinusRank double, mratingpctrank double, BTPct double, BTPctRank double, BTAltPct double, BTAltPctRank double, PFPct double, PFPctRank double, MyRatingPctRank double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE TotalTeam (rowID INTEGER PRIMARY KEY autoincrement, Season integer, ConfFinish Integer, ConfTournTitle varchar, Sweet16 varchar, FinalFour varchar, Champ varchar, PowerRanking integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PlayerAwards (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Name varchar, Award varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX NameAIndex on PlayerAwards(Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX RecruitsNameIndex on Recruits(Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PlayerAtts (rowID INTEGER PRIMARY KEY autoincrement, Name varchar, SHT varchar, HND varchar, DEF varchar, REB varchar, ATH varchar, HT varchar, INT varchar, FullName varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Scrimmage_Info (rowID INTEGER PRIMARY KEY autoincrement, Name varchar, ScrimMins varchar, ScrimFGM varchar, ScrimFGA varchar, ScrimFTM varchar, ScrimFTA varchar, ScrimREB varchar, ScrimAST varchar, ScrimBLK varchar, ScrimSTL varchar, ScrimTO varchar, ScrimPF varchar, ScrimPTS varchar, ScrimTenMin varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE MyKeys (rowID INTEGER PRIMARY KEY autoincrement, Key varchar, Value varchar)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f = New FolderItem(DBPath)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Database Object</SourceLine>
   <SourceLine>DB = New RealSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Set the Database File</SourceLine>
   <SourceLine>DB.DatabaseFile = f</SourceLine>
   <SourceLine>SDB = f</SourceLine>
   <SourceLine>DBName = f.name</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If DB.CreateDatabaseFile Then</SourceLine>
   <SourceLine>// Add Tables to the Database</SourceLine>
   <SourceLine>For i as integer= 0 To ubound(sqlArray)</SourceLine>
   <SourceLine>sqlString = sqlArray(i)</SourceLine>
   <SourceLine>dbsqlexecute(sqlString)</SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>// Error While Creating the Database</SourceLine>
   <SourceLine>//Alert Message with 1 OK button</SourceLine>
   <SourceLine>AlertMsg("Error","Database Error!","There was an error creating the new database " + DBName + ".","Stop","OK",False,False,"")</SourceLine>
   <SourceLine>//Alert Message with 1 OK button</SourceLine>
   <SourceLine>AlertMsg("Notice","The SimSports Console will now close." ,"","Note","OK",False,False,"")</SourceLine>
   <SourceLine>Quit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
