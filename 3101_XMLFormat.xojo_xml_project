 <Method>
  <ItemName>DownloadTeamPagesAndCalcScore</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1355970559</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub DownloadTeamPagesAndCalcScore()</SourceLine>
   <SourceLine>dim iMAx as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim k as double</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim r as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Win, Local, Impact, Region FROM PlayerInfo WHERE Name='"+szPlayerName+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>vpplayer.PlayerName=szPlayerName</SourceLine>
   <SourceLine>vpplayer.WinPref=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>vpplayer.LocalPref=rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>vpplayer.LocalPref=rs.IdxField(3).StringValue</SourceLine>
   <SourceLine>vpplayer.Region=rs.IdxField(4).stringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iMax=ubound(tied3)</SourceLine>
   <SourceLine>if iMax&gt;-1 then</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>dim thisteam as TiedTeamForEstimation</SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+prefleague,2)+"&amp;idno="+str(tied3(n))</SourceLine>
   <SourceLine>thisteam.PowerRanking=GetTeamPR(theurl)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//calculate tie chance for team</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>thisteam.TeamNum=tied3(n)</SourceLine>
   <SourceLine>thisteam.Conference=ceil(thisteam.TeamNum/8)</SourceLine>
   <SourceLine>r=FitPctCalcForTie(vpplayer.WinPref, vpplayer.LocalPref, vpplayer.ImpactPref, vpplayer.Region, thisteam.PowerRanking, thisteam.Conference)</SourceLine>
   <SourceLine>r=r*2</SourceLine>
   <SourceLine>thisteam.ChanceRaw=r</SourceLine>
   <SourceLine>vrgTiedTeamsTotal.append thisteam</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iMax=ubound(tied12)</SourceLine>
   <SourceLine>if iMax&gt;-1 then</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>dim thisteam as TiedTeamForEstimation</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+prefleague,2)+"&amp;idno="+str(tied3(n))</SourceLine>
   <SourceLine>thisteam.PowerRanking=GetTeamPR(theurl)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//calculate tie chance for team</SourceLine>
   <SourceLine>thisteam.TeamNum=tied12(n)</SourceLine>
   <SourceLine>thisteam.Conference=ceil(thisteam.TeamNum/8)</SourceLine>
   <SourceLine>thisteam.ChanceRaw=FitPctCalcForTie(vpplayer.WinPref, vpplayer.LocalPref, vpplayer.ImpactPref, vpplayer.Region, thisteam.PowerRanking, thisteam.Conference)</SourceLine>
   <SourceLine>vrgTiedTeamsTotal.append thisteam</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim cTmp as double</SourceLine>
   <SourceLine>iMax=ubound(vrgTiedTeamsTotal)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>cTmp=cTmp+vrgTiedTeamsTotal(n).ChanceRaw</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>vrgTiedTeamsTotal(n).ChanceRaw=vrgTiedTeamsTotal(n).ChanceRaw/cTmp</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>wndPrimary.ppPrimary.value=5</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>FitPctCalcForTie</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>601890815</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function FitPctCalcForTie(win as string, local as string, impact as string, region as string, teampr as double, myregion as integer) As double</SourceLine>
   <SourceLine>dim y,n,q,winrating, localrating,impactrating as double</SourceLine>
   <SourceLine>dim locala as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>locala=wordtonum(local)-7.5</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CALCULATE WIN SCORE</SourceLine>
   <SourceLine>winrating= WinRatingCalc(win,teampr)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CACLULATE IMPACT SCORE</SourceLine>
   <SourceLine>impactrating=ImpactRatingCalc(teampr,impact)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CALCULATE LOCAL SCORE</SourceLine>
   <SourceLine>localrating=LocalRatingCalc(myregion, local, region)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//EQUALIZE VARIABLES</SourceLine>
   <SourceLine>q=wordtonum(win)/15</SourceLine>
   <SourceLine>y=wordtonum(impact)/15</SourceLine>
   <SourceLine>n=abs(locala/7.5)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>localrating=localrating*preflocal</SourceLine>
   <SourceLine>winrating=winrating*prefwin</SourceLine>
   <SourceLine>impactrating=impactrating*prefimpact</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return (winrating*q+localrating*n+impactrating*y)/(preflocal*n+(prefwin*q)+prefimpact*y)</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>win as string, local as string, impact as string, region as string, teampr as double, myregion as integer</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>GetTeamPR</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1860509695</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetTeamPR(theurl as string) As double</SourceLine>
   <SourceLine>dim mysocket as new HTTPSocket</SourceLine>
   <SourceLine>dim szSocketReturn as string</SourceLine>
   <SourceLine>dim nrgPR(2) as integer</SourceLine>
   <SourceLine>dim rgszLines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>szSocketReturn=mysocket.Get(theurl, 45)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if szSocketReturn&lt;&gt;"" then</SourceLine>
   <SourceLine>szSocketReturn=CleanHTML(szSocketReturn)</SourceLine>
   <SourceLine>rgszlines=split(szSocketReturn, EndOfLine)</SourceLine>
   <SourceLine>nrgPR(0)=val(rgszLines(30))</SourceLine>
   <SourceLine>nrgPR(1)=val(rgszLines(32))</SourceLine>
   <SourceLine>nrgPR(2)=val(rgszLines(34))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim navgPRTmp as double</SourceLine>
   <SourceLine>navgPRTmp=PowerRanking(nrgpr(0), nrgpr(1), nrgpr(2))</SourceLine>
   <SourceLine>return navgPRTmp</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
