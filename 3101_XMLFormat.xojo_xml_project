 <Method>
  <ItemName>LoadUpPossibleAwards</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1092907007</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadUpPossibleAwards()</SourceLine>
   <SourceLine>//this method writes all the preferences that are saved in memory (in the Preferences Module) to a binary file</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as folderitem</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=SpecialFolder.Preferences</SourceLine>
   <SourceLine>f=f.child("SSC")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Awards.bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim b as binarystream</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if f&lt;&gt; nil then</SourceLine>
   <SourceLine>if f.Exists then</SourceLine>
   <SourceLine>//file exists, so we open it</SourceLine>
   <SourceLine>b=BinaryStream.Open(f, true)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>redim awdNames(-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>awdCreated=b.ReadInt16</SourceLine>
   <SourceLine>for n as integer=1 to awdCreated</SourceLine>
   <SourceLine>awdNames.append b.ReadPString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>dim stream as binarystream</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream=BinaryStream.Create(f, true)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream.WriteInt16 10</SourceLine>
   <SourceLine>stream.WritePString "1st All-Conf"</SourceLine>
   <SourceLine>stream.WritePString "2nd All-Conf"</SourceLine>
   <SourceLine>stream.WritePString "Conf FOY"</SourceLine>
   <SourceLine>stream.WritePString "Conf POY"</SourceLine>
   <SourceLine>stream.WritePString "1st All-League"</SourceLine>
   <SourceLine>stream.WritePString "2nd All-League"</SourceLine>
   <SourceLine>stream.WritePString "3rd All-League"</SourceLine>
   <SourceLine>stream.WritePString "4th All-League"</SourceLine>
   <SourceLine>stream.WritePString  "League FOY"</SourceLine>
   <SourceLine>stream.WritePString "League POY"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's close it out</SourceLine>
   <SourceLine>stream.close</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>LoadUpPossibleAwards</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
