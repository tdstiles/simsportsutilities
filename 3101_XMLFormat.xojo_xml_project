    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>redim awdNames(-1)</SourceLine>
    <SourceLine>dim a as string</SourceLine>
    <SourceLine>a=txtAwardsList.text</SourceLine>
    <SourceLine>a=RemoveBlankLines(a)</SourceLine>
    <SourceLine>a=ReplaceLineEndings(a,",")</SourceLine>
    <SourceLine>awdNames=split(a, ",")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>awdCreated=UBound(awdNames)+1</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim f as folderitem</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>f=SpecialFolder.Preferences</SourceLine>
    <SourceLine>f=f.child("SSC")</SourceLine>
    <SourceLine>if f.exists=false then</SourceLine>
    <SourceLine>f.CreateAsFolder</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>f=f.child("Awards.bin")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if f&lt;&gt; nil then</SourceLine>
    <SourceLine>dim stream as binarystream</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>stream=BinaryStream.Create(f, true)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>stream.WriteInt16 awdCreated</SourceLine>
    <SourceLine>dim j as integer=ubound(awdNames)</SourceLine>
    <SourceLine>for n as integer=0 to j</SourceLine>
    <SourceLine>stream.WritePString trim(awdNames(n))</SourceLine>
    <SourceLine>next</SourceLine>
