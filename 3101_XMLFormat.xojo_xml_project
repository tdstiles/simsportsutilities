  <PartID>1263044607</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Loadhistory()</SourceLine>
   <SourceLine>dim pr as string</SourceLine>
   <SourceLine>dim w, l as integer</SourceLine>
   <SourceLine>dim pct as double</SourceLine>
   <SourceLine>dim rs,ars as recordset</SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>dim brec as RecordSet</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim confw, confl, tournw, tournl as integer</SourceLine>
   <SourceLine>dim tourn as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>LoadPopTournList</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbAllSeasons.LoadHeader(split("Sn,Rec,Conf,Tourn,TournRecord,Finish,PR,Recruiting", ","))</SourceLine>
   <SourceLine>lbAllSeasons.ColumnWidths="0.5*,0.8*,0.8*,0.75*,1.25*,1.25*,0.8*,*"</SourceLine>
   <SourceLine>lbAllSeasons.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim S as cTeamSeason</SourceLine>
   <SourceLine>//get all seasons in order</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Distinct Season from TeamHistory ORDER BY Season DESC")</SourceLine>
   <SourceLine>while rs&lt;&gt;NIL and rs.EOF=False</SourceLine>
   <SourceLine>S=new cTeamSeason(rs.field("Season").StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//put variables into listbox</SourceLine>
   <SourceLine>'"Season,Rec,Conf,Tourn,TournRecord,Finish,PR,Recruiting", ","))</SourceLine>
   <SourceLine>lbAllSeasons.AddRow S.mSeason,str(S.w)+"-"+str(S.l), str(S.confw)+"-"+str(S.confl), S.tourn, str(S.tournw)+"-"+str(S.tournl), S.HowFar, S.pr,S.recruits</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
