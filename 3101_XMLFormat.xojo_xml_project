 <Method>
  <ItemName>CleanHTML</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1165684735</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CleanHTML(a as string) As string</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim j(6,1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j(0,0)="&lt;td.*&gt;"</SourceLine>
   <SourceLine>j(0,1)=EndOfLine</SourceLine>
   <SourceLine>j(1,0)="&lt;!-- BEGIN LINKEXCHANGE CODE SS--&gt;.*&lt;!-- END LINKEXCHANGE CODE --&gt;"</SourceLine>
   <SourceLine>j(1,1)=""</SourceLine>
   <SourceLine>j(2,0)="&lt;!--.*--&gt;"</SourceLine>
   <SourceLine>j(2,1)=""</SourceLine>
   <SourceLine>j(3,0)="&lt;style.*/style&gt;"</SourceLine>
   <SourceLine>j(3,1)=""</SourceLine>
   <SourceLine>j(4,0)="&lt;a.*/runtime/whoibbj.*idno=(.*)&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>j(4,1)="\1"</SourceLine>
   <SourceLine>j(5,0)="&lt;/center&gt;"</SourceLine>
   <SourceLine>j(5,1)=EndOfLine</SourceLine>
   <SourceLine>j(6,0)="&lt;.*&gt;"</SourceLine>
   <SourceLine>j(6,1)=""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine>for n as integer=0 to 6</SourceLine>
   <SourceLine>r.SearchPattern =j(n,0)</SourceLine>
   <SourceLine>r.ReplacementPattern = j(n,1)</SourceLine>
   <SourceLine>a=Trim(r.Replace(a))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=removetabs(a)</SourceLine>
   <SourceLine>a=removeblanklines(a)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>a as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
