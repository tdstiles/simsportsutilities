 <Method>
  <ItemName>GetPlayerdisplay</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1348493311</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetPlayerdisplay(PlayersName as String, fFormat as boolean=false) As string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim tmpname as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim displaystring as string</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim usualposition as string</SourceLine>
   <SourceLine>dim attstring as string</SourceLine>
   <SourceLine>dim iPosValue, iNegValue as integer</SourceLine>
   <SourceLine>dim AttsValue as string</SourceLine>
   <SourceLine>dim tmpValue as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get plusminus for window</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT SHT, DEF, HND, REB, INT, ATH, HT From PlayerAtts WHERE Name LIKE '"+PlayersName+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>//get +/-</SourceLine>
   <SourceLine>iPosValue=0</SourceLine>
   <SourceLine>iNegValue=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>h=InchestoHT(rs.IdxField(7).IntegerValue)</SourceLine>
   <SourceLine>for n as integer=1 to 6</SourceLine>
   <SourceLine>tmpValue=GetPlusMinus(rs.IdxField(n).StringValue)</SourceLine>
   <SourceLine>if tmpValue&gt;0 then</SourceLine>
   <SourceLine>iPosValue=iPosValue+tmpValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>iNegValue=iNegValue+tmpValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>attstring=attstring+left(rs.IdxField(n).StringValue, 1)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>AttsValue=""</SourceLine>
   <SourceLine>h=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim numbers(4),maxinum,thisone as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Stats WHERE Name LIKE '"+PlayersName+"' AND APosition LIKE '%"+positions(n)+"' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs.RecordCount&lt;&gt;0 and rs&lt;&gt;nil then</SourceLine>
   <SourceLine>numbers(n)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>maxinum=max(numbers(0), numbers(1), numbers(2), numbers(3),numbers(4))</SourceLine>
   <SourceLine>thisone=numbers.indexof(maxinum)</SourceLine>
   <SourceLine>if thisone&lt;&gt;-1 then</SourceLine>
   <SourceLine>usualposition= positions(thisone)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>usualposition=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("Select FullName FROM PlayerAtts WHERE Name LIKE '"+PlayersName+"'")</SourceLine>
   <SourceLine>if len(rs.IdxField(1).StringValue)&gt;0 then</SourceLine>
   <SourceLine>tmpname=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>tmpname=PlayersName</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fFormat then</SourceLine>
   <SourceLine>tmpname="[b][color=green]"+tmpname+"[/color][/b]"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iPosValue&gt;0 then</SourceLine>
   <SourceLine>attsvalue=format(iPosValue,"+##")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if iNegValue&lt;0 then</SourceLine>
   <SourceLine>attsvalue=attsvalue+"/"+format(iNegValue,"-##")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iPosValue=0 and iNegValue=0 then</SourceLine>
   <SourceLine>AttsValue="0"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>displaystring=tmpName+", "+h+"  "+usualposition+"  "+attstring+" ("+attsvalue+")"</SourceLine>
   <SourceLine>return displaystring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>PlayersName as String, fFormat as boolean=false</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
