   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TeamNumberFromName(TeamName as string) As Integer</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//try to remove team name, just get city name</SourceLine>
   <SourceLine>TeamName=trim(teamname)</SourceLine>
   <SourceLine>line=teamname</SourceLine>
   <SourceLine>k=instr(line," ")</SourceLine>
   <SourceLine>if k&lt;&gt;0 then</SourceLine>
   <SourceLine>line=left(line,k-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>j=gTeams.indexof(line)</SourceLine>
   <SourceLine>while j=-1 //only first part of name, need second half of city</SourceLine>
   <SourceLine>k=instr(k+1,TeamName," ")</SourceLine>
   <SourceLine>if k&lt;&gt;0 then</SourceLine>
