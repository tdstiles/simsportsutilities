 <Method>
  <ItemName>NastyRefreshIconsHack</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>123322367</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub NastyRefreshIconsHack()</SourceLine>
   <SourceLine>Declare Sub SHChangeNotify Lib "Shell32" (eventID as Integer, flags as Integer, item1 as Integer, item2 as Integer)</SourceLine>
   <SourceLine>dim SHCNE_ASSOCCHANGED, SHCNF_IDLIST, SHCNF_FLUSH as Integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Grabbed from ShlObj.h</SourceLine>
   <SourceLine>SHCNE_ASSOCCHANGED = &amp;h08000000</SourceLine>
   <SourceLine>SHCNF_IDLIST = &amp;h00000000</SourceLine>
   <SourceLine>SHCNF_FLUSH = &amp;h1000</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// We need to send the system a notification</SourceLine>
   <SourceLine>// to let it know it needs to flush the icon</SourceLine>
   <SourceLine>// cache so we can see our changes</SourceLine>
   <SourceLine>SHChangeNotify( SHCNE_ASSOCCHANGED, BitwiseOr(SHCNF_IDLIST, SHCNF_FLUSH), 0, 0 )</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>SavePrefs</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1556733951</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SavePrefs()</SourceLine>
   <SourceLine>//this method writes all the preferences that are saved in memory (in the Preferences Module) to a binary file</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as folderitem</SourceLine>
   <SourceLine>dim stream as binarystream</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=SpecialFolder.Preferences</SourceLine>
   <SourceLine>f=f.child("SSC")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Prefs.bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If f &lt;&gt; Nil then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream=BinaryStream.Create( f, true)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's write the menu items</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>stream.WritePString MenuItems(n).Name</SourceLine>
   <SourceLine>stream.WritePString MenuItems(n).AbsolutePath</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//do these in alphabetical order from the properties menu on the left</SourceLine>
   <SourceLine>stream.WriteDouble(prefattfactor)</SourceLine>
   <SourceLine>stream.WriteDouble(prefImpact)</SourceLine>
   <SourceLine>stream.WriteDouble(prefLocal)</SourceLine>
   <SourceLine>stream.WriteDouble(prefmyfactor)</SourceLine>
   <SourceLine>stream.WriteDouble(prefoppfactor)</SourceLine>
   <SourceLine>stream.WriteUInt8(prefplayerpct)</SourceLine>
   <SourceLine>stream.WriteUInt8(prefScoutStat)</SourceLine>
   <SourceLine>stream.WriteDouble(prefstatfactor)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 19</SourceLine>
   <SourceLine>stream.WriteDouble(prefstats(n))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream.WriteDouble(prefWin)</SourceLine>
   <SourceLine>stream.WritePString prefWindowColor</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//save the statviewer globals</SourceLine>
   <SourceLine>for n as integer=0 to 10</SourceLine>
   <SourceLine>stream.WritePString rgStatPossibilities(n).SaveAsString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's close it out</SourceLine>
   <SourceLine>stream.close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//write new preferences file for the custom stats</SourceLine>
   <SourceLine>f=SpecialFolder.Preferences.Child("SSC").Child("Stats.bin")</SourceLine>
   <SourceLine>if f&lt;&gt;nil then</SourceLine>
   <SourceLine>stream=BinaryStream.Create(f, true)</SourceLine>
   <SourceLine>stream.WriteUInt16 prefNumCustomFunctions</SourceLine>
   <SourceLine>for n as integer=1 to prefNumCustomFunctions</SourceLine>
   <SourceLine>stream.WritePString prefCustomStatFunctions(n-1)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Exception err as IOException</SourceLine>
   <SourceLine>MsgBox "an IO exception occurred"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
