  <PartID>184209407</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ParseName(fullname as string) As string</SourceLine>
   <SourceLine>dim firstname, lastname, initial as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>k=instr(fullname, " ")</SourceLine>
   <SourceLine>lastname=mid(fullname, k+1)</SourceLine>
   <SourceLine>initial=left(fullname, 1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return initial+" "+lastname</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>fullname as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mthCreateDBFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1899751423</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthCreateDBFile()</SourceLine>
   <SourceLine>Dim f As new FolderItem</SourceLine>
   <SourceLine>Dim sqlArray(-1),sqlString As String</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Recruits (rowID INTEGER PRIMARY KEY autoincrement, Season Integer, atts Integer,Name varchar, Region integer, HSName varchar, Height varchar, gpa varchar, test varchar, pos varchar, scout integer, sht integer, def integer, hnd integer, reb integer, ath integer, local varchar, win varchar, impact varchar, ppg double, rpg double, apg double, spg double, tpg double, bpg double,  Tendex varchar, HSSOS varchar, NormTendex varchar, OppRatingPct double, StatPct varchar, AttPct varchar, FitPct double, MyRating double, MyRatingPct double, PlusminusPct double, sh integer, hw integer,estimatedattributes varchar, playerplusminus double , mrating double, stddevpct double,rsht integer, rdef integer, rhnd integer, rreb integer, rint integer, rath integer)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f = SpecialFolder.Desktop.child("AttributeStudy.ydb")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Database Object</SourceLine>
   <SourceLine>aDB = New RealSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Set the Database File</SourceLine>
   <SourceLine>aDB.DatabaseFile = f</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If aDB.CreateDatabaseFile Then</SourceLine>
   <SourceLine>// Add Tables to the Database</SourceLine>
