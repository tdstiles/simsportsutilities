  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SetInitialPositionForSubs()</SourceLine>
   <SourceLine>Dim rs as RecordSeT</SourceLine>
   <SourceLine>Dim SQLString as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT PlayerNum, TeamNum, rowID FROM SVTable WHERE InitialPos ISNULL"</SourceLine>
