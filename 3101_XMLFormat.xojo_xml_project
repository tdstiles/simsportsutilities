 <Method>
  <ItemName>DecileCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1207650303</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function DecileCalc(Numbers() as Double) As Double()</SourceLine>
   <SourceLine>Dim x(10) as double</SourceLine>
   <SourceLine>Dim n as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>numbers.sort</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>x(0)=numbers(0)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for y as integer=1 to 9</SourceLine>
   <SourceLine>n=ceil((y/10)*ubound(Numbers))+1</SourceLine>
   <SourceLine>x(y)=numbers(n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>x(10)=numbers(ubound(numbers))</SourceLine>
   <SourceLine>return x</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Numbers() as Double</ItemParams>
  <ItemResult>Double()</ItemResult>
 </Method>
