   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadControls()</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim tmpTeamNum as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if DBLoaded then</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT * from TeamInfo")</SourceLine>
   <SourceLine>if DBConnect then</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>efteamname.text=rs.field("TeamName").StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'tmpTeamNum=rs.Field("TeamID").IntegerValue</SourceLine>
   <SourceLine>efTeamName.text=gTeams(rs.Field("TeamID").IntegerValue-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>efleague.text=str(rs.field("League").Value)</SourceLine>
   <SourceLine>efconference.Text=str(rs.field("Region").Value)</SourceLine>
   <SourceLine>efpr.text=str(rs.field("lastpr").IntegerValue)</SourceLine>
   <SourceLine>eflastpr.text=str(rs.field("pr2").IntegerValue)</SourceLine>
   <SourceLine>efpr2.text=str(rs.field("pr3").IntegerValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Value FROM MyKeys WHERE Key='Password'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>efPassword.text=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Value FROM MyKeys WHERE Key='UserName'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>efID.text=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
