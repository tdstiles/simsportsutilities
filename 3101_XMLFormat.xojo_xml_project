    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim fChecked as boolean</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for n as integer=0 to 9</SourceLine>
    <SourceLine>PosSetter(ceil((n+1)/5),popup(n).text, str(n+1-(5*floor(n/5))))</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>iBoxScore=popBoxScores.ListIndex</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if watchgame.value=true then</SourceLine>
    <SourceLine>fWatchPBP=true</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>fwatchPBP=false</SourceLine>
    <SourceLine>iBoxScore=0</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>Stats.SetInitialPositionForSubs</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//Now update the coaching settings</SourceLine>
    <SourceLine>LoadCoachingSettings</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>SVDB.Commit</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>fChecked=ErrorChecker(popup(1).text, popup(2).text, popup(3).text, popup(4).text, popup(0).text)</SourceLine>
    <SourceLine>if fChecked then</SourceLine>
    <SourceLine>fChecked=ErrorChecker(popup(5).text, popup(6).text, popup(7).text, popup(8).text, popup(9).text)</SourceLine>
    <SourceLine>if fChecked THEN</SourceLine>
    <SourceLine>//switch over to the new window</SourceLine>
    <SourceLine>SwitchtoViewPanel</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
