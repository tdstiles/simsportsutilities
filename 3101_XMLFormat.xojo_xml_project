   <PartID>1669308415</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub MouseMove(index as Integer, X As Integer, Y As Integer)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if lbCounter=4 then</SourceLine>
    <SourceLine>// Get row and column</SourceLine>
    <SourceLine>Dim row As Integer = Me.RowFromXY( x, y )</SourceLine>
    <SourceLine>if row=5 then //not bench</SourceLine>
    <SourceLine>me.HelpTag=""</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>Dim column As Integer = Me.ColumnFromXY( x, y )</SourceLine>
    <SourceLine>// Show the Help Tag</SourceLine>
    <SourceLine>If row &gt;= 0 And column &gt;= 0 Then</SourceLine>
    <SourceLine>'Dim s As string = Me.Cell( row, column )</SourceLine>
    <SourceLine>dim s as string</SourceLine>
    <SourceLine>dim rs as recordset</SourceLine>
    <SourceLine>dim sqlstring as string</SourceLine>
    <SourceLine>sqlstring="SELECT Pts, FGM, FGA, FG3M, FG3A, Oreb, Ast, Blk, Stl, TOs,Dreb FROM SVTable WHERE Name='"+me.cell(row,0)+"' AND TeamNum="+str(index+1)</SourceLine>
    <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>s=me.cell(row,0)+" "+format(rs.IdxField(1).integerValue, "#0")+" pts "+format(rs.IdxField(2).integerValue, "#0")+"/"+format(rs.IdxField(3).integerValue, "#0")+" fg ("+format(rs.IdxField(4).integerValue, "#0")+"/"+format(rs.IdxField(5).integerValue, "#0")+" fg3) "+format(rs.IdxField(6).integerValue+rs.idxfield(11).integervalue, "#0")+" reb "+format(rs.IdxField(7).integerValue, "#0")+" ast "+format(rs.IdxField(8).integerValue, "#0")+" blk "+format(rs.IdxField(9).integerValue, "#0")+" stl "+format(rs.IdxField(10).integerValue, "#0")+" tos"</SourceLine>
    <SourceLine>If Me.HelpTag &lt;&gt; s Then Me.HelpTag = s</SourceLine>
    <SourceLine>end if</SourceLine>
    <SourceLine>Else</SourceLine>
    <SourceLine>// Clear the Help Tag</SourceLine>
    <SourceLine>Me.HelpTag = ""</SourceLine>
    <SourceLine>End If</SourceLine>
    <SourceLine>end if</SourceLine>
    <SourceLine>lbCounter=0</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>lbCounter=lbCounter+1</SourceLine>
    <SourceLine>end if</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
