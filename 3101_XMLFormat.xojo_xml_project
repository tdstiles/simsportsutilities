 </Method>
 <Method>
  <ItemName>ExportStatstoSSC</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>415729663</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ExportStatstoSSC()</SourceLine>
   <SourceLine>//this method takes the stats from the SVDB (in-game database) and exports them over to the actual database</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim r as DatabaseRecord</SourceLine>
   <SourceLine>dim positionplayed as string</SourceLine>
   <SourceLine>dim playerposition as string</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we need to figure out which team is mine</SourceLine>
   <SourceLine>//for the time being, just write up a variable</SourceLine>
   <SourceLine>dim myteam as integer</SourceLine>
   <SourceLine>//let's see which team is ours</SourceLine>
   <SourceLine>if prefTeamNum=GameToImport.iTeams(0).TeamNumber then</SourceLine>
   <SourceLine>myteam=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>myteam=2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Name, initialpos, minutesplayed, FGM, fga, ftm, fta, fg3m, fg3a, ast, blk, stl, tos, fouls, pts, oreb, dreb, shrtm, shrta, medM, medA, longM, longA, aFGM, aFGA, aFG3M, aFG3A, aPts, crTO, TP, aOReb, aDReb, aTReb, lostP, lostD, PUs, touches, AR, shBlkd, plusminus, fd, Settings_Shot, Settings_3Pt, Settings_Sub FROM SVTable WHERE TeamNum='"+str(MyTeam)+"' AND MinutesPlayed&gt;'0'"</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.eof=false and rs.RecordCount&lt;&gt;0</SourceLine>
   <SourceLine>if rs.IdxField(3).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>dim tablecolumns(-1), tablevalues(-1) as string</SourceLine>
   <SourceLine>//set player's position</SourceLine>
   <SourceLine>playerposition=mthdplayerposition(rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set table columns</SourceLine>
   <SourceLine>tablecolumns=split("Name, reb, APosition, season, game, mins, FGM, fga, ftm, fta, fg3m, fg3a, ast, blk, stl, tos, fouls, pts, oreb, dreb, shrtm, shrta, midM, midA, longM, longA, aFGM, aFGA, aF3M, aF3A, aPts, crTO, TP, aOReb, aDReb, aTReb, lostP, lostD, PUs, touch, AR, shBlkd, plusminus, fd, Settings_Shot, Settings_3Pt, Settings_Sub", ", ")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's set up the tablecolumns</SourceLine>
   <SourceLine>tablevalues.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>tablevalues.append str(rs.field("oreb").integervalue+rs.field("dreb").integervalue)</SourceLine>
   <SourceLine>tablevalues.append playerposition</SourceLine>
   <SourceLine>tablevalues.append str(GametoImport.Season)</SourceLine>
   <SourceLine>tablevalues.append str(GametoImport.Game)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounter as integer=rs.FieldCount-3</SourceLine>
   <SourceLine>for n as integer=3 to iCounter</SourceLine>
   <SourceLine>tablevalues.append str(rs.IdxField(n).integerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'//rs.FieldCount-2 and rs.FieldCount-1 and rs.FieldCount -- these are the coaching settings.  if nothing entered, see if we can duplicate from previous game</SourceLine>
   <SourceLine>'if rs.IdxField(rs.FieldCount-2).integervalue&lt;&gt;0 then</SourceLine>
   <SourceLine>'//these are set, so we use them</SourceLine>
   <SourceLine>'tablevalues.append str(rs.IdxField(rs.fieldcount-2).integerValue)</SourceLine>
   <SourceLine>'tablevalues.append str(rs.IdxField(rs.fieldcount-1).integerValue)</SourceLine>
   <SourceLine>'tablevalues.append rs.IdxField(rs.FieldCount).StringValue</SourceLine>
   <SourceLine>'elseif GameToImport.Game&gt;1 and GameToImport.game&lt;25 then</SourceLine>
   <SourceLine>'dim rec as recordset</SourceLine>
   <SourceLine>'rec=db.SQLSelect("Select  Settings_Shot, Settings_3Pt, Settings_Sub FROM Stats WHERE Name='"+rs.IdxField(1).StringValue+"' AND Season='"+str(GameToImport.Season)+"' AND Game='"+str(GameToImport.Game-1)+"'")</SourceLine>
   <SourceLine>'if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>'tablevalues.append str(rec.IdxField(1).IntegerValue)</SourceLine>
   <SourceLine>'tablevalues.append str(rec.IdxField(2).IntegerValue)</SourceLine>
   <SourceLine>'tablevalues.append rec.IdxField(3).StringValue</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine>'else</SourceLine>
   <SourceLine>tablevalues.append str(rs.IdxField(rs.fieldcount-2).integerValue)</SourceLine>
   <SourceLine>tablevalues.append str(rs.IdxField(rs.fieldcount-1).integerValue)</SourceLine>
   <SourceLine>tablevalues.append rs.IdxField(rs.FieldCount).StringValue</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring=mthBuildSQLString("Stats",tablecolumns, tablevalues)</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if POG(0)=str(MyTeam) then</SourceLine>
   <SourceLine>//Player of the game is on my team, so put it into database</SourceLine>
   <SourceLine>sqlstring="UPDATE Stats SET POG='Y' WHERE Season='"+str(GametoImport.Season)+"' AND Game='"+str(GametoImport.Game)+"' AND Name='"+POG(1)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ExporttoHTML</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>668639231</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ExporttoHTML()</SourceLine>
   <SourceLine>dim tout as TextOutputStream</SourceLine>
   <SourceLine>dim k as FolderItem</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim thisseason as integer</SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>dim max as integer</SourceLine>
   <SourceLine>dim htmlstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>k= getfolderitem("")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>k=k.child("PBP").child("L"+prefleague+gTeams(prefTeamNum-1)).child("Sn"+str(prefSeason)).child("S"+str(GametoImport.Season)+"G"+str(GametoImport.Game)+""+trim(GameToImport.iTeams(0).TeamName)+"_v_"+trim(GameToImport.iTeams(1).TeamName)+".html")</SourceLine>
   <SourceLine>if k.exists=false then</SourceLine>
   <SourceLine>// Create Text File</SourceLine>
   <SourceLine>tout = TextOutputStream.Create( k )</SourceLine>
   <SourceLine>if tout = nil then</SourceLine>
   <SourceLine>MsgBox "Export Error" + EndOfLine + EndOfLine + "Could not create the game file."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//tout.writeline</SourceLine>
   <SourceLine>dim mycolumns(-1) as string</SourceLine>
   <SourceLine>htmlstring="&lt;h2&gt;"+trim(GameToImport.iTeams(0).TeamName)+" vs. "+trim(GameToImport.iTeams(1).TeamName)+" (Gm"+str(GametoImport.Game)+")&lt;/h2&gt;"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now loop through and set the rows</SourceLine>
   <SourceLine>dim j(1) as string</SourceLine>
   <SourceLine>j(0)=""</SourceLine>
   <SourceLine>j(1)="b"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim mystring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 2 //for each team</SourceLine>
   <SourceLine>mycolumns=split("Player,Pos,Min,FGM,FGA,3PM,3PA,FTM,FTA,REB,AST,BLK,STL,TOs,PFs,PTS", ",")</SourceLine>
   <SourceLine>htmlstring=htmlstring+TableGeneratorTitle(trim(GameToImport.iTeams(n-1).TeamName), mycolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for nn as Integer=0 to 1 //for starters and then backups</SourceLine>
   <SourceLine>for nnn as integer=0 to 4 //for each position</SourceLine>
   <SourceLine>sqlstring="SELECT Name, InitialPos, minutesplayed, FGM, fga, fg3m, fg3a, ftm, fta, oreb+dreb, ast, blk, stl, tos, fouls, pts FROM SVTable WHERE TeamNum="+str(n)+" AND MinutesPlayed&gt;0 AND InitialPos LIKE '"+j(nn)+str(nnn+1)+"'"</SourceLine>
   <SourceLine>rec=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rec.RecordCount&lt;&gt;0 and rec&lt;&gt;nil then</SourceLine>
   <SourceLine>//let's create a column for the player and add him</SourceLine>
   <SourceLine>mystring=rec.IdxField(1).StringValue+"*"+j(nn)+positions(nnn)</SourceLine>
   <SourceLine>for r as integer=3 to 16</SourceLine>
   <SourceLine>mystring=mystring+"*"+format(rec.IdxField(r).IntegerValue, "#0")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mycolumns=split(mystring, "*")</SourceLine>
   <SourceLine>htmlstring=htmlstring+ColumnGenerator(nnn,mycolumns)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>//now we want the stats for the entire team</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(minutesplayed), Sum(FGM), Sum(fga), Sum(fg3m), Sum(fg3a), Sum(ftm), Sum(fta), sum(oreb)+sum(dreb), Sum(ast), Sum(blk), Sum(stl), Sum(tos), Sum(fouls), Sum(pts) FROM SVTable WHERE TeamNum="+str(n)+" AND MinutesPlayed&gt;0 GROUP BY TeamNum"</SourceLine>
   <SourceLine>rec=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rec.RecordCount&lt;&gt;0 and rec&lt;&gt;nil then</SourceLine>
   <SourceLine>//let's create a column for the player and add him</SourceLine>
   <SourceLine>mystring="--*-- "</SourceLine>
   <SourceLine>for r as integer=1 to 14</SourceLine>
   <SourceLine>mystring=mystring+"*"+format(rec.IdxField(r).IntegerValue, "#0")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mycolumns=split(mystring, "*")</SourceLine>
   <SourceLine>htmlstring=htmlstring+ColumnGenerator(5,mycolumns)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>htmlstring=htmlstring+CloseTable</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tout.write htmlstring</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Close File</SourceLine>
   <SourceLine>tout.Close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ImportGameMethod</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>795672575</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ImportGameMethod()</SourceLine>
   <SourceLine>dim rs, rec as RecordSet</SourceLine>
   <SourceLine>dim oppconf as integer</SourceLine>
   <SourceLine>dim myconf as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>oppconf=GameToImport.iTeams(1).Conference</SourceLine>
   <SourceLine>myconf=GameToImport.iTeams(0).Conference</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//determine game type</SourceLine>
   <SourceLine>If GametoImport.Game&lt;= 15 THEN //reg season</SourceLine>
   <SourceLine>GameType.Addrow "Non-Conference"</SourceLine>
   <SourceLine>GameType.Addrow "Conference"</SourceLine>
   <SourceLine>if oppconf=myconf then //same conference</SourceLine>
   <SourceLine>GameType.ListIndex=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Gametype.ListIndex=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif GametoImport.Game&gt;15 and GametoImport.Game&lt;=18 THEN</SourceLine>
   <SourceLine>GameType.addrow "Conf. Tourney"</SourceLine>
   <SourceLine>Gametype.ListIndex=0</SourceLine>
   <SourceLine>elseif GametoImport.Game&gt;18 and GametoImport.Game&lt;=24 then</SourceLine>
   <SourceLine>GameType.Addrow "NTT"</SourceLine>
   <SourceLine>GameType.Addrow "PTT"</SourceLine>
   <SourceLine>GameType.Addrow "RTT"</SourceLine>
   <SourceLine>GameType.Addrow "DTT"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>GameType.Addrow "Exhibition"</SourceLine>
   <SourceLine>GameType.ListIndex=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GametoImport.Game&gt;24 then</SourceLine>
   <SourceLine>//exhibition games, so let's find current season</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select max(season) from TeamHistory") //select (likely) current season</SourceLine>
   <SourceLine>if rs&lt;&gt;nil then</SourceLine>
   <SourceLine>prefSeason=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT max(Game) from TeamHistory Where Season='"+str(prefSeason)+"'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil then</SourceLine>
   <SourceLine>if rec.IdxField(1).IntegerValue=24 or rec.idxfield(1).integervalue=23 then</SourceLine>
   <SourceLine>//this season is finished, we should move to the next one</SourceLine>
   <SourceLine>prefSeason=str(val(prefSeason)+1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif GametoImport.Game=1 then</SourceLine>
   <SourceLine>//first game, may need to update season</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select max(season) from TeamHistory") //select (likely) current season</SourceLine>
   <SourceLine>if rs&lt;&gt;nil then</SourceLine>
   <SourceLine>prefSeason=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT max(Game) from TeamHistory Where Game&lt;25 AND Season='"+str(prefSeason)+"'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil then</SourceLine>
   <SourceLine>if rec.IdxField(1).IntegerValue=24 then</SourceLine>
   <SourceLine>//this season is finished, we should move to the next one</SourceLine>
   <SourceLine>prefSeason=str(val(prefSeason)+1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//regular season</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select Season from TeamInfo") //select (likely) current season</SourceLine>
   <SourceLine>if rs&lt;&gt;nil then</SourceLine>
   <SourceLine>prefSeason=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's create a new folder for us</SourceLine>
   <SourceLine>dim f as FolderItem</SourceLine>
   <SourceLine>f = getfolderitem("")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("PBP")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=GetFolderItem("").child("PBP").child("L"+prefleague+gTeams(prefTeamNum-1))</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=GetFolderItem("").child("PBP").child("L"+prefleague+gTeams(prefTeamNum-1)).child("Sn"+str(prefSeason))</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GametoImport.Game&gt;18 and GametoImport.Game&lt;=24 THEN //tournament games</SourceLine>
   <SourceLine>//set the gametype listbox for the current tournament game</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT TYPE FROM TeamHistory WHERE Game='19' AND Season='"+str(prefSeason)+"'")</SourceLine>
   <SourceLine>select case rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>case "NTT"</SourceLine>
   <SourceLine>GameType.ListIndex=0</SourceLine>
   <SourceLine>case "PTT"</SourceLine>
   <SourceLine>GameType.ListIndex=1</SourceLine>
   <SourceLine>case "RTT"</SourceLine>
   <SourceLine>GameType.ListIndex=2</SourceLine>
   <SourceLine>case "DTT"</SourceLine>
   <SourceLine>GameType.ListIndex=3</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>season.text=str(prefSeason)</SourceLine>
   <SourceLine>gamenum.text=str(GametoImport.Game)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadCoachingSettings</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>401278975</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadCoachingSettings()</SourceLine>
   <SourceLine>//This method pulls from efSettings.text, parses that information, and then loads it into the SVDB database</SourceLine>
   <SourceLine>//Settings_Sub varchar, Settings_Shot integer, Settings_3Pt integer</SourceLine>
   <SourceLine>'sqlArray.append "CREATE TABLE Stats Settings_Sub varchar, Settings_Shot integer, Settings_3Pt integer)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if efSettings.text&lt;&gt;"" then</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim TmpString as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpString=ReplaceLineEndings(efSettings.text, EndOfLine)</SourceLine>
   <SourceLine>lines=split(TmpString, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iLine as integer=5</SourceLine>
   <SourceLine>dim TmpInstructions(-1) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim TmpName as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=iLine to 16</SourceLine>
   <SourceLine>TmpInstructions=split(lines(n), chr(9))</SourceLine>
   <SourceLine>TmpName=CheckNameforApos(TmpInstructions(0))</SourceLine>
   <SourceLine>l=instr(TmpName, " ")</SourceLine>
   <SourceLine>TmpName=left(TmpName,1)+" "+mid(TmpName, l+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this breaks it out into the tab separated values</SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET Settings_Sub='"+TmpInstructions(2)+"', Settings_Shot='"+TmpInstructions(3)+"', Settings_3Pt='"+TmpInstructions(4)+"' WHERE Name='"+TmpName+"'"</SourceLine>
   <SourceLine>SVDB.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadResultText</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1062318079</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadResultText()</SourceLine>
   <SourceLine>//this method adds the info "ResultText" to the top line of the scrolling window.  Then it bolds it.  Then we check to see if there are any runs or FG droughts.</SourceLine>
   <SourceLine>dim s as string</SourceLine>
   <SourceLine>dim starttime as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while UBound(Stats.ResultText)&gt;=0</SourceLine>
   <SourceLine>starttime=ticks</SourceLine>
   <SourceLine>s=stats.ResultText(0)</SourceLine>
   <SourceLine>Stats.ResultText.Remove 0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>scrollingwindow.insertrow(0,s)</SourceLine>
   <SourceLine>scrollingwindow.cell(0,1)=TimeString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>scrollingwindow.CellBold(0,0)=true</SourceLine>
   <SourceLine>if scrollingwindow.Listcount&gt;1 then</SourceLine>
   <SourceLine>scrollingwindow.CellBold(1,0)=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>GameText.append s+chr(9)+TimeString+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we wait</SourceLine>
   <SourceLine>'while ticks &lt; startTime + (tickstowait)  // wait between running again</SourceLine>
   <SourceLine>'wend</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>PosSetter</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1170431999</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PosSetter(Team as Integer, Field as String, Pos as String)</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET Pos='"+pos+"', InitialPos='"+pos+"' WHERE TeamNum='"+str(Team)+"' AND Name='"+field+"'"</SourceLine>
