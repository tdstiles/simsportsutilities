 <Method>
  <ItemName>LoadTeamList</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>261132287</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadTeamList() As integer()</SourceLine>
   <SourceLine>//This method looks at the iBoxScore value and creates an array of the teams that match this criteria</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if iBoxScore=1 then View all scores"</SourceLine>
   <SourceLine>//if 2 then View Top 25"</SourceLine>
   <SourceLine>//if 3 then "View Conf"</SourceLine>
   <SourceLine>//if 4 then  "View Top 25 and Conf"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rTeams(-1) as integer</SourceLine>
   <SourceLine>dim tmprTeams(-1) as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iBoxScore=1 then</SourceLine>
   <SourceLine>//pulling all teams</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>rTeams.append n</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif iBoxScore=2 then</SourceLine>
   <SourceLine>//Top 25 teams</SourceLine>
   <SourceLine>tmprTeams=LoadPR</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now take the first 25 teams</SourceLine>
   <SourceLine>for n as integer=0 to 24</SourceLine>
   <SourceLine>rTeams.append tmprTeams(n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif iBoxScore=3 then</SourceLine>
   <SourceLine>//conference teams</SourceLine>
   <SourceLine>rTeams=LoadConfTeams</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//top 25 and conference</SourceLine>
   <SourceLine>rTeams=LoadConfTeams</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Top 25 teams</SourceLine>
   <SourceLine>tmprTeams=LoadPR</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now take the first 25 teams</SourceLine>
   <SourceLine>for n as integer=0 to 24</SourceLine>
   <SourceLine>rTeams.append tmprTeams(n)</SourceLine>
   <SourceLine>next</SourceLine>
