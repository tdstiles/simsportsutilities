 <Method>
  <ItemName>SVxCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1062469631</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function SVxCalc(FGM as Integer, FG3M as Integer, Reb as Integer, Assists as Integer, Blocks as Integer, Steals as Integer, FTM as Integer, FTA as Integer, FGA as Integer, TOS as Integer, Fouls as Integer, Mins as Integer) As double</SourceLine>
   <SourceLine>dim x as double</SourceLine>
   <SourceLine>if mins&lt;&gt;0 then</SourceLine>
   <SourceLine>x= ((((FGM+(FG3M/2)+Reb+(Assists/1.5)+(blocks/1.5)+steals)+(FTM-(FTA/1.4))-(FGA-FGM)-TOS-fouls)/mins)*100)</SourceLine>
   <SourceLine>return x</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
