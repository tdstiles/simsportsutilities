 <Method>
  <ItemName>LoadFlashPage</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1325404159</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadFlashPage() As string()</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim myresult as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>myresult=thissocket.Get("http://www.drivethelane.com/bask/weekly/lg000"+right("0"+prefleague, 2)+"/flash2.asp", 15)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if myresult&lt;&gt;"" then</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim j(3,1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j(0,0)="&lt;td&gt;&lt;a href.*idno=(.*).&gt;(.*)&lt;/a&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>j(0,1)="\1"+EndOfLine+"\2"+EndOfLine</SourceLine>
   <SourceLine>j(1,0)="&lt;th.*&lt;/th&gt;"</SourceLine>
   <SourceLine>j(1,1)=""</SourceLine>
   <SourceLine>j(2,0)="&lt;td&gt;(.*)&lt;/td&gt;"</SourceLine>
   <SourceLine>j(2,1)="\1"</SourceLine>
   <SourceLine>j(3,0)="&lt;.*&gt;"</SourceLine>
   <SourceLine>j(3,1)=EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.options.Greedy=false</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>r.SearchPattern =j(n,0)</SourceLine>
   <SourceLine>r.ReplacementPattern = j(n,1)</SourceLine>
   <SourceLine>myresult=Trim(r.Replace(myresult))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>myresult=removeblanklines(myresult)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we go through and load the game scores</SourceLine>
   <SourceLine>dim flash(-1) as string</SourceLine>
   <SourceLine>flash=split(myresult, EndOfLine)</SourceLine>
   <SourceLine>flash.Remove(0)</SourceLine>
   <SourceLine>flash.Remove(0)</SourceLine>
   <SourceLine>flash.Remove(ubound(Flash))</SourceLine>
   <SourceLine>flash.Remove(ubound(flash))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return flash</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string()</ItemResult>
 </Method>
