  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1137147903</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadListBox()</SourceLine>
   <SourceLine>//first download team schedule and parse for games</SourceLine>
   <SourceLine>iGames=LoadTeamSchedule(prefTeamNum)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see which games are already loaded.  if already loaded, skip, if not saved already</SourceLine>
   <SourceLine>dim f as FolderItem</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f = getfolderitem("")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("PBP")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("L"+prefleague+gTeams(prefTeamNum-1))</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim max as string</SourceLine>
   <SourceLine>//get maximum season to set folderitem value</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Season FROM TeamInfo")</SourceLine>
   <SourceLine>max=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("Sn"+max)</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim j as integer=ubound(iGames)</SourceLine>
   <SourceLine>dim TmpName as string</SourceLine>
   <SourceLine>dim n as integer=0</SourceLine>
   <SourceLine>for TmpCount as integer=j downto 0</SourceLine>
   <SourceLine>TmpName=iGames(TmpCount).PBPString</SourceLine>
   <SourceLine>listbox1.addrow iGames(TmpCount).Display</SourceLine>
   <SourceLine>listbox1.cell(n, 1)=gTeams(iGames(TmpCount).iTeams(1).TeamNumber-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if f.child(tmpName).exists=false then</SourceLine>
   <SourceLine>listbox1.CellCheck(n,2)=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
