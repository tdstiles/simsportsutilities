 <Method>
  <ItemName>PrintRow</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1375645695</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PrintRow(g As Graphics, ps As PrinterSetup, lb As Listbox, Row As Integer) As Integer</SourceLine>
   <SourceLine>Dim startY, maxY, topY, xPos, contentWidth, AlignmentPad As Integer</SourceLine>
   <SourceLine>Dim Heading, CellContent As String</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>topY = vPos - TextHeight</SourceLine>
   <SourceLine>xPos = 1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(headers)</SourceLine>
   <SourceLine>for i as integer = 0 to l</SourceLine>
   <SourceLine>if Wrap then</SourceLine>
   <SourceLine>if ColumnWidths(i) &gt; 0 then maxY = Max(maxY, g.StringHeight( lb.Cell(Row, i), ColumnWidths(i)) + 4 )</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>maxY = TextHeight</SourceLine>
   <SourceLine>Exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if vPos + maxY &gt; PageHeight then</SourceLine>
   <SourceLine>NextPage(g)</SourceLine>
   <SourceLine>vPos = PrintHeader(g, ps, lb)</SourceLine>
   <SourceLine>topY = vPos - TextHeight</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for i as integer = 0 to UBound(Headers)</SourceLine>
   <SourceLine>xPos = DoCell(g, ps, lb, Row, i, xPos, topY, maxY)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return vPos + maxY</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>g As Graphics, ps As PrinterSetup, lb As Listbox, Row As Integer</ItemParams>
  <ItemResult>Integer</ItemResult>
 </Method>
 <Method>
  <ItemName>SetColumnWidths</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1006331903</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SetColumnWidths(ps As PrinterSetup, lb As Listbox)</SourceLine>
   <SourceLine>Dim colWidths, cws As String</SourceLine>
   <SourceLine>Dim cols(-1) As String</SourceLine>
   <SourceLine>DIm temp, dynamic_count, total_used, remainder, dyna_unit, space As Integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>colWidths = lb.ColumnWidths</SourceLine>
   <SourceLine>cols = Split(colWidths, ",")</SourceLine>
   <SourceLine>space = PixelScale( ps, Ubound(cols) * 4 )</SourceLine>
   <SourceLine>for each cws in cols</SourceLine>
   <SourceLine>if InStr(cws, "*") &gt; 0 OR Trim(cws) = "" then // Dynamic width</SourceLine>
   <SourceLine>ColumnWidths.Append( -1 )</SourceLine>
   <SourceLine>elseif InStr(cws, "%") &gt; 0 then // Percentage width</SourceLine>
   <SourceLine>temp = Val(Trim(ReplaceAll(cws, "%", "")))</SourceLine>
   <SourceLine>ColumnWidths.Append( (temp/100) * (PageWidth - space) )</SourceLine>
   <SourceLine>else // Explicit width</SourceLine>
   <SourceLine>if Trim(cws) = "0" then</SourceLine>
   <SourceLine>ColumnWidths.Append 0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ColumnWidths.Append( PixelScale(ps, Val(cws) + 4) )</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(ColumnWidths)</SourceLine>
   <SourceLine>for i as integer = 0 to l</SourceLine>
   <SourceLine>if ColumnWidths(i) &gt; -1 then</SourceLine>
   <SourceLine>total_used = total_used + ColumnWidths(i)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if Len(Trim(ReplaceAll(cols(i), "*", ""))) &lt; 1 then</SourceLine>
   <SourceLine>temp = 1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>temp = Val(Trim(ReplaceAll(cols(i), "*", "")))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>dynamic_count = dynamic_count + temp</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>remainder = PageWidth - total_used - space</SourceLine>
   <SourceLine>dyna_unit = remainder / dynamic_count</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for i as integer = 0 to l</SourceLine>
   <SourceLine>if ColumnWidths(i) = -1 then</SourceLine>
   <SourceLine>temp = Val(Trim(ReplaceAll(cols(i), "*", "")))</SourceLine>
   <SourceLine>temp = Max(temp, 1)</SourceLine>
   <SourceLine>ColumnWidths(i) = temp * dyna_unit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>ps As PrinterSetup, lb As Listbox</ItemParams>
  <ItemResult></ItemResult>
 </Method>
