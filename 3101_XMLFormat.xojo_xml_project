  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PopulatePanelControls()</SourceLine>
   <SourceLine>// If No Row Selected, Clear Fields and Return</SourceLine>
   <SourceLine>lblPlayerInfo(0).text=""</SourceLine>
   <SourceLine>lblPlayerInfo(1).Text=""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if lbPlayerList.ListIndex &gt; -1 then</SourceLine>
