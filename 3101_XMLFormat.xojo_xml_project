 <Method>
  <ItemName>CreateSQLQueryForCustomStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1998657535</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CreateSQLQueryForCustomStats() As string</SourceLine>
   <SourceLine>dim sql as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim h, j as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sql="SELECT Name"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to prefNumCustomFunctions</SourceLine>
   <SourceLine>k=instr(prefCustomStatFunctions(n-1), ":")</SourceLine>
   <SourceLine>h=left(prefCustomStatFunctions(n-1),k-1)</SourceLine>
   <SourceLine>j=mid(prefCustomStatFunctions(n-1), k+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we correct j for SUM and COUNT</SourceLine>
   <SourceLine>j=ReplaceAll(j, "Game", "(Count(Game)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aDReb", "(SUM(aDReb)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aOReb", "(SUM(aOReb)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "OReb", "(SUM(Oreb)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "DReb", "(SUM(DReb)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aTReb", "(SUM(aTReb)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FGM", "(SUM(FGM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FGA", "(SUM(FGA)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FTM", "(SUM(FTM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FTA", "(SUM(FTA)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FG3M", "(SUM(FG3M)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FG3A", "(SUM(FG3A)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "AST", "(SUM(AST)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "BLK", "(SUM(BLK)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "STL", "(SUM(STL)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "TOs", "(SUM(TOs)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "Fouls", "(SUM(Fouls)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "Pts", "(SUM(Pts)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "Mins", "(SUM(Mins)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "shrtM", "(SUM(shrtM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "shrtA", "(SUM(shrtA)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "midM", "(SUM(midM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "midA", "(SUM(midA)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "longM", "(SUM(longM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "longA", "(SUM(longA)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aFGM", "(SUM(aFGM)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aFGA", "(SUM(aFGa)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aF3M", "(SUM(aF3a)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "aPts", "(SUM(aPts)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "lostP", "(SUM(lostP)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "lostD", "(SUM(lostD)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "crTO", "(SUM(crTO)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "PUs", "(SUM(PUs)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "touch", "(SUM(touch)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "TP", "(SUM(TP)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "FD", "(SUM(FD)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "AR", "(SUM(AR)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "shBlkd", "(SUM(shBlkd)*1.0)")</SourceLine>
   <SourceLine>j=ReplaceAll(j, "plusminus", "(SUM(plusminus)*1.0)")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//need to deal with REB so we're not wiping out OReb, DReb, etc.</SourceLine>
   <SourceLine>dim r as new regex</SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine>r.SearchPattern ="[^aD|^aO|^O|^D|^aT]Reb"</SourceLine>
   <SourceLine>r.ReplacementPattern = "(SUM(REB)*1.0)"</SourceLine>
   <SourceLine>j=Trim(r.Replace(j))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sql=sql+", "+j+" as "+h</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sql</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
