 <Method>
  <ItemName>MedianCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1215510527</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function MedianCalc(Numbers() as Double) As Double</SourceLine>
   <SourceLine>dim median as double</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim medianelement, medianelementB as integer</SourceLine>
   <SourceLine>dim evengroup as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Numbers.sort</SourceLine>
   <SourceLine>evengroup=ubound(numbers) mod 2</SourceLine>
   <SourceLine>if evengroup&lt;&gt;0 then</SourceLine>
   <SourceLine>//odd number of elements, can find proper median</SourceLine>
   <SourceLine>medianelement=floor(ubound(numbers)/2)+1</SourceLine>
   <SourceLine>median=numbers(medianelement)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//even number of elements, must find avg median</SourceLine>
   <SourceLine>medianelement=floor(ubound(numbers)/2)</SourceLine>
   <SourceLine>medianelementB=Ceil(ubound(numbers)/2)</SourceLine>
   <SourceLine>median=(numbers(medianelement)+numbers(medianelementB))/2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return median</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Numbers() as Double</ItemParams>
  <ItemResult>Double</ItemResult>
