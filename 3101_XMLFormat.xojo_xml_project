  <Visible>1</Visible>
  <PartID>968191999</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Open()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim q as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.BackColor=prefWindowColor.ColorValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT SHT, DEF, HND, REB, INT, ATH, HT FROM PlayerAtts WHERE Name='"+Name+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>q=rs.IdxField(n+1).StringValue</SourceLine>
   <SourceLine>if q="Exc" then</SourceLine>
   <SourceLine>l=0</SourceLine>
   <SourceLine>elseif q="Good" then</SourceLine>
   <SourceLine>l=1</SourceLine>
   <SourceLine>elseif q="Fair" then</SourceLine>
   <SourceLine>l=2</SourceLine>
   <SourceLine>elseif q="Poor" then</SourceLine>
   <SourceLine>l=3</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>l=4</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>atts(n).ListIndex=l</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>efHeight.text=rs.IdxField(7).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
