 <Method>
  <ItemName>NeedtoInsert</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1365452799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function NeedtoInsert() As boolean</SourceLine>
   <SourceLine>//This method looks at the PlayerInfo records to determine whether we need to insert new records or just update the old ones</SourceLine>
   <SourceLine>//If insert, return true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT * From PlayerInfo")</SourceLine>
   <SourceLine>if rs.RecordCount&gt;0 then</SourceLine>
   <SourceLine>//we have records, so let's do the update</SourceLine>
   <SourceLine>return false</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>boolean</ItemResult>
 </Method>
 <Method>
  <ItemName>ReadfromTextFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1519036415</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ReadfromTextFile(result as string)</SourceLine>
   <SourceLine>dim teamarray(255,8) as string</SourceLine>
   <SourceLine>Dim n,i,r As Integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim short as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines = split(result,endOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=13</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=0</SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>for j as integer=0 to 24</SourceLine>
   <SourceLine>for k as integer=1 to 10</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//team name</SourceLine>
   <SourceLine>teamarray(n,0)=lines(r)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear team records and avg height</SourceLine>
   <SourceLine>short=lines(r+1)</SourceLine>
   <SourceLine>short=short+"-"+lines(r+2)</SourceLine>
   <SourceLine>teamarray(n,6)=short  ///last WL</SourceLine>
   <SourceLine>short=lines(r+3)</SourceLine>
   <SourceLine>short=short+"-"+lines(r+4)</SourceLine>
   <SourceLine>teamarray(n,7)=short  ///this WL</SourceLine>
   <SourceLine>teamarray(n,8)=lines(r+5)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=r+6</SourceLine>
   <SourceLine>for i=1 to 5</SourceLine>
   <SourceLine>teamarray(n,i)=lines(r)</SourceLine>
   <SourceLine>r=r+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>r=r+11</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//last 6 teams</SourceLine>
   <SourceLine>for k as integer=1 to 6</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//team name</SourceLine>
   <SourceLine>teamarray(n,0)=lines(r)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear team records and avg height</SourceLine>
   <SourceLine>short=lines(r+1)</SourceLine>
   <SourceLine>short=short+"-"+lines(r+2)</SourceLine>
   <SourceLine>teamarray(n,6)=short  ///last WL</SourceLine>
   <SourceLine>short=lines(r+3)</SourceLine>
   <SourceLine>short=short+"-"+lines(r+4)</SourceLine>
   <SourceLine>teamarray(n,7)=short  ///this WL</SourceLine>
   <SourceLine>teamarray(n,8)=lines(r+5)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=r+6</SourceLine>
   <SourceLine>for i=1 to 5</SourceLine>
   <SourceLine>teamarray(n,i)=lines(r)</SourceLine>
   <SourceLine>r=r+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ImportHSCSV(teamarray)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>result as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>MainMethod</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1528813567</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub MainMethod()</SourceLine>
   <SourceLine>lblUpdating.text="Importing Recruit Info"</SourceLine>
   <SourceLine>ImportRecruitCSV</SourceLine>
   <SourceLine>lblUpdating.text="Processing HS Info"</SourceLine>
   <SourceLine>//this loads in the info for each HS</SourceLine>
   <SourceLine>LoadPage(prefleague)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we'll add in the info from all the HS Teams</SourceLine>
   <SourceLine>lblUpdating.text="Calculating HS PR"</SourceLine>
   <SourceLine>dim updateHS as new cHSInfo</SourceLine>
   <SourceLine>//updateHS should, in its constructor, fire all the things we need fired.  The HSInfo table in the main database should now be up to date.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lblUpdating.Text="Updating Recruit Information"</SourceLine>
   <SourceLine>dim updateRecruit as new cRecruitMethod</SourceLine>
   <SourceLine>//similarly, in its updater, this should parse all the recruit information we need</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>DBSQLExecute("VACUUM")</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
