  <PartID>911261695</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TrimName(Name as String) As String</SourceLine>
   <SourceLine>dim w, x as integer</SourceLine>
   <SourceLine>dim y,z as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>w=Len(Name)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If w&gt;14 THEN</SourceLine>
   <SourceLine>x=Instr(name," ")</SourceLine>
   <SourceLine>y=Right(name, w-x)</SourceLine>
   <SourceLine>z=Left(name,1)</SourceLine>
   <SourceLine>return (z+"."+ y)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return name</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
