   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 9</SourceLine>
   <SourceLine>list.cell(rownum, j)=rs.IdxField(j+1).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>wndMain.st1.text=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
