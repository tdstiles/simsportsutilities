    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim divisor as double</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>prefLocal=txtlocal.IntValue</SourceLine>
    <SourceLine>prefwin = txtwin.IntValue</SourceLine>
    <SourceLine>prefimpact = txtimpact.IntValue</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>prefplayerpct=txtPlayerPct.IntValue</SourceLine>
    <SourceLine>prefscoutstat=statslider.value</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>prefmyfactor=txtMyCo.IntValue</SourceLine>
    <SourceLine>prefoppfactor=txtOppCo.IntValue</SourceLine>
    <SourceLine>prefattfactor=txtAttCo.IntValue</SourceLine>
    <SourceLine>prefstatfactor=txtStatCo.IntValue</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim TmpValue as double</SourceLine>
    <SourceLine>for n as integer=0 to 3</SourceLine>
    <SourceLine>dim tmptotal as double</SourceLine>
    <SourceLine>for nn as integer=0 to 4</SourceLine>
    <SourceLine>tmptotal=tmptotal+txtRating(5*n+nn).IntValue</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>divisor=TmpTotal/10</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for k as integer=0 to 4</SourceLine>
    <SourceLine>TmpValue=(txtRating(5*n+k).IntValue/divisor)</SourceLine>
    <SourceLine>txtRating(5*n+k).text=format(round(TmpValue*10)/10, "0.0")</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for n as integer=0 to 19</SourceLine>
    <SourceLine>prefstats(n)=txtRating(n).IntValue</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>SavePrefs</SourceLine>
    <SourceLine>LoadPrefs</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>wndPrimary.txtteamname.text=prefteamname+"    L"+prefleague+" C"+prefconference+"      AvgPR: "+str(PowerRanking(preflastpr, prefpr2, prefpr3))</SourceLine>
    <SourceLine>wndPrimary.Refresh</SourceLine>
    <SourceLine>Self.Close</SourceLine>
    <SourceLine>End Sub</SourceLine>
