 <HookInstance>
  <ItemName>Open</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1208815615</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Open()</SourceLine>
   <SourceLine>me.BackColor=prefWindowColor.ColorValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim recruits(767) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Select Max(Season) from Stats"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>TextField1.text=str(rs.IdxField(1).IntegerValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name FROM PlayerInfo")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>for x as integer=1 to 768</SourceLine>
   <SourceLine>recruits(x-1)=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>recruits.Sort</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>name(n).DeleteAllRows</SourceLine>
   <SourceLine>for x as integer=1 to 768</SourceLine>
   <SourceLine>name(n).addrow recruits(x-1)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "You must have recruits loaded into the console before you advance to the next season."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
 </HookInstance>
 <Method>
  <ItemName>AttsValue</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1633456127</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function AttsValue(Index as Integer) As Integer</SourceLine>
   <SourceLine>dim value as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>value=GetPlusMinus(sht(index).text)</SourceLine>
   <SourceLine>value=value+GetPlusMinus(def(index).text)</SourceLine>
   <SourceLine>value=value+GetPlusMinus(hnd(index).text)</SourceLine>
   <SourceLine>value=value+GetPlusMinus(reb(index).text)</SourceLine>
   <SourceLine>value=value+GetPlusMinus(ath(index).text)</SourceLine>
   <SourceLine>value=value+GetPlusMinus(int(index).text)</SourceLine>
   <SourceLine>return value</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Index as Integer</ItemParams>
  <ItemResult>Integer</ItemResult>
 </Method>
 <Method>
  <ItemName>copyplayerover</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>201025535</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub copyplayerover(rs as recordset, faDB as boolean=false)</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim y as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=1 to 3</SourceLine>
   <SourceLine>dim tablecolumns(-1), valuecolumns(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.Field("Name").StringValue=name(0).text then</SourceLine>
   <SourceLine>y=0</SourceLine>
   <SourceLine>elseif rs.field("Name").StringValue=name(1).text then</SourceLine>
   <SourceLine>y=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>y=2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tablecolumns=split("Name,Region,HSName,Height,GPA,Test,Pos,Scout,SHT,DEF,HND,REB,ATH,Local,Win,Impact,PPG,RPG,APG,SPG,TPG,BPG,Tendex,HSSOS,NormTendex,OppRatingPct,StatPct,AttPct,FitPct,MyRating,MyRatingPct,PlusMinusPct,PlayerPlusMinus,EstimatedAttributes,mratingpct,SH,HW,Atts,Season,StdDevPct,rSHT,rHND,rDEF,rREB,rINT,rATH,BobbyRating,BobbyRatingRank,StdDevPctRank,PlayerPlusMinusRank,mRatingPctRank,MyRatingPctRank,BTPct,BTPctRank,BTAltPct,BTAltPctRank,PFPct,PFPctRank", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounter as integer=ubound(tablecolumns)-24</SourceLine>
   <SourceLine>for n as integer=0 to iCounter</SourceLine>
   <SourceLine>valuecolumns.append rs.field(tablecolumns(n)).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>valuecolumns.append rs.field("mratingpct").StringValue</SourceLine>
   <SourceLine>valuecolumns.append sh.text</SourceLine>
   <SourceLine>valuecolumns.append hw.text</SourceLine>
   <SourceLine>valuecolumns.append str(AttsValue(y))</SourceLine>
   <SourceLine>valuecolumns.append TextField1.text</SourceLine>
   <SourceLine>valuecolumns.append rs.field("StdDevPct").StringValue</SourceLine>
   <SourceLine>',rSHT,rHND,rDEF,rREB,rATH,rINT</SourceLine>
   <SourceLine>valuecolumns.append str(wordtonum(sht(y).text))</SourceLine>
   <SourceLine>valuecolumns.append str(wordtonum(def(y).text))</SourceLine>
   <SourceLine>valuecolumns.append str(wordtonum(hnd(y).text))</SourceLine>
   <SourceLine>valuecolumns.Append str(wordtonum(reb(y).text))</SourceLine>
   <SourceLine>valuecolumns.Append str(wordtonum(int(y).text))</SourceLine>
   <SourceLine>valuecolumns.Append str(wordtonum(ath(y).text))</SourceLine>
   <SourceLine>valuecolumns.append rs.Field("BobbyRating").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("BobbyRatingRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("StdDevPctRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("PlayerPlusMinusRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("mRatingPctRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("MyRatingPctRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("BTPct").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("BTPctRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("BTAltPct").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("BTAltPctRank").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("PFPct").stringvalue</SourceLine>
   <SourceLine>valuecolumns.append rs.field("PFPctRank").StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring=mthBuildSQLString("Recruits",tablecolumns,valuecolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fadb then</SourceLine>
   <SourceLine>adb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>adb.Commit</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>rs as recordset, faDB as boolean=false</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
