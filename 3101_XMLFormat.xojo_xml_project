   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="INSERT INTO PlayerAtts (Name, SHT, DEF, HND, REB, ATH, INT, HT) VALUES ('"+Name+"','"+atts(0).text+"','"+atts(1).text+"','"+atts(2).text+"','"+atts(3).text+"','"+atts(5).text+"','"+atts(4).text+"','"+str(EditHeight(efHeight.text))+"')"</SourceLine>
