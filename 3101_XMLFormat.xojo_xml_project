 <Method>
  <ItemName>searchforplayer</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>439500799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function searchforplayer() As string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim elements(-1) as string</SourceLine>
   <SourceLine>dim stats(5),atts(5),rating(4) as string</SourceLine>
   <SourceLine>dim ht as integer</SourceLine>
   <SourceLine>dim sorter as string</SourceLine>
   <SourceLine>dim regioncheck as string</SourceLine>
   <SourceLine>dim myregions(-1) as string</SourceLine>
   <SourceLine>dim prefs(2) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefs(0)="Local"</SourceLine>
   <SourceLine>prefs(1)="Win"</SourceLine>
   <SourceLine>prefs(2)="Impact"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stats(0)="PPG"</SourceLine>
   <SourceLine>stats(1)="RPG"</SourceLine>
   <SourceLine>stats(2)="APG"</SourceLine>
   <SourceLine>stats(3)="SPG"</SourceLine>
   <SourceLine>stats(4)="BPG"</SourceLine>
   <SourceLine>stats(5)="TPG"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if txtHeight.text&lt;&gt;"" then</SourceLine>
   <SourceLine>ht=EditHeight(txtHeight.text)</SourceLine>
   <SourceLine>elements.append ("Height &gt;='"+str(ht)+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>atts(0)="SHT"</SourceLine>
   <SourceLine>atts(1)="DEF"</SourceLine>
   <SourceLine>atts(2)="HND"</SourceLine>
   <SourceLine>atts(3)="REB"</SourceLine>
   <SourceLine>atts(4)="ATH"</SourceLine>
   <SourceLine>atts(5)="Scout"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rating(0)="mRatingPct"</SourceLine>
   <SourceLine>rating(1)="bobbyrating"</SourceLine>
   <SourceLine>rating(2)="myratingpct"</SourceLine>
   <SourceLine>rating(3)="FitPct"</SourceLine>
   <SourceLine>rating(4)="Playerplusminus"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//start with names, work way down</SourceLine>
   <SourceLine>if player(0).text&lt;&gt;"" then</SourceLine>
   <SourceLine>Elements.append("Name LIKE '%"+player(0).text+"%'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if region.text&lt;&gt;"" then</SourceLine>
   <SourceLine>myregions.append region.text</SourceLine>
   <SourceLine>if chkRegion.Value=false then</SourceLine>
   <SourceLine>if val(region.text)&lt;30 then</SourceLine>
   <SourceLine>myregions.append str(val(region.text)+1)</SourceLine>
   <SourceLine>myregions.append str(val(region.text)+2)</SourceLine>
   <SourceLine>elseif val(region.text)=31 then</SourceLine>
   <SourceLine>myregions.append "32"</SourceLine>
   <SourceLine>myregions.append "1"</SourceLine>
   <SourceLine>else //is region 32</SourceLine>
   <SourceLine>myregions.append "1"</SourceLine>
   <SourceLine>myregions.append "2"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if val(region.text)&gt;2 then</SourceLine>
   <SourceLine>myregions.append str(val(region.text)-1)</SourceLine>
   <SourceLine>myregions.append str(val(region.text)-2)</SourceLine>
   <SourceLine>elseif val(region.text)=2 then</SourceLine>
   <SourceLine>myregions.append "1"</SourceLine>
   <SourceLine>myregions.append "32"</SourceLine>
   <SourceLine>else //is region 1</SourceLine>
   <SourceLine>myregions.append "32"</SourceLine>
   <SourceLine>myregions.append "31"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we deal with the regioncheck</SourceLine>
   <SourceLine>if chkRegion.value=false then</SourceLine>
   <SourceLine>regioncheck="(Region='"+myregions(0)+"' OR Region='"+myregions(1)+"' OR Region='"+myregions(2)+"' OR Region='"+myregions(3)+"' OR Region='"+myregions(4)+"')"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>regioncheck="(Region='"+myregions(0)+"')"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elements.append(regioncheck)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if position.text&lt;&gt;"" then</SourceLine>
   <SourceLine>if position.ListIndex&lt;=4 then</SourceLine>
   <SourceLine>elements.append("Pos='"+position.text+"'")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>elements.append("MyPosition='"+position.text+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>if txtStatMin(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>Elements.append(stats(n)+" &gt;= '"+txtStatMin(n).text+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if txtStatMax(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(stats(n)+" &lt;= '"+txtStatMax(n).text+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>if popAttMin(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(atts(n)+" &gt;= '"+str(wordtonum(popAttMin(n).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if popAttMax(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(atts(n)+" &lt;= '"+str(wordtonum(popAttMax(n).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if popscout(0).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(atts(5)+" &gt;= '"+str(wordtonum(popScout(0).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if popScout(1).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(atts(5)+" &lt;= '"+str(wordtonum(popScout(1).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>if txtMinRating(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(rating(n)+" &gt;= '"+str(val(txtMinRating(n).text)/100)+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if txtMaxRating(n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(rating(n)+" &lt;= '"+str(val(txtMaxRating(n).text)/100)+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if txtMinRating(4).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(rating(4)+" &gt;= '"+str(val(txtMinRating(4).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if txtMaxRating(4).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(rating(4)+" &lt;= '"+str(val(txtMaxRating(4).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now knock out the preferences</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>if pref(2*n).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(prefs(n)+" &gt;= '"+str(wordtonum(pref(2*n).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if pref(2*n+1).text&lt;&gt;"" then</SourceLine>
   <SourceLine>elements.append(prefs(n)+" &lt;= '"+str(wordtonum(pref(2*n+1).text))+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring=BaseSQL+" WHERE "+elements(0)</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(elements)</SourceLine>
   <SourceLine>for n as integer=1 to l</SourceLine>
   <SourceLine>sqlstring=sqlstring+" AND "+elements(n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sorter=c(0).text</SourceLine>
   <SourceLine>if sorter="Consensus" then</SourceLine>
   <SourceLine>sorter="MRatingPct"</SourceLine>
   <SourceLine>elseif sorter="Player +/-" then</SourceLine>
   <SourceLine>sorter="playerplusminus"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if sorter&lt;&gt;"" then</SourceLine>
   <SourceLine>sqlstring=sqlstring+" ORDER BY "+ sorter+ " "+c(1).text</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>return sqlstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
