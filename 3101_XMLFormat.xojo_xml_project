  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mImportExport()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim wlo as string</SourceLine>
   <SourceLine>dim us, them as integer</SourceLine>
