   <SourceLine>Function LoadPR() As integer()</SourceLine>
   <SourceLine>dim sDownload as new HTTPSocket</SourceLine>
   <SourceLine>dim szResult as string</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
