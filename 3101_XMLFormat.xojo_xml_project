  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CheckPR()</SourceLine>
   <SourceLine>dim r as DatabaseRecord</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT * FROM TotalTeam WHERE Season='"+str(GametoImport.Season)+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>//already exists, no need to create it</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//must create new</SourceLine>
   <SourceLine>r=new DatabaseRecord</SourceLine>
   <SourceLine>r.IntegerColumn("Season")=GametoImport.Season</SourceLine>
   <SourceLine>r.Column("ConfTournTitle")="N"</SourceLine>
   <SourceLine>r.Column("Sweet16")="N"</SourceLine>
   <SourceLine>r.Column("FinalFour")="N"</SourceLine>
   <SourceLine>r.Column("Champ")="N"</SourceLine>
   <SourceLine>r.Column("PowerRanking")="--"</SourceLine>
   <SourceLine>db.InsertRecord("TotalTeam",r)</SourceLine>
   <SourceLine>end</SourceLine>
