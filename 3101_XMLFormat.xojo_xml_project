   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function UpdateField(TeamNum as String, PlayerNum as String, Stat as String, Increase as Integer) As string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT rowid, "+stat+" FROM SVTable WHERE PlayerNum='"+PlayerNum+"' AND TeamNum='"+TeamNum+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET "+stat+"= '"+str(rs.IdxField(2).IntegerValue+increase)+"' WHERE rowid='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>return " ("+str(rs.IdxField(2).IntegerValue+increase)+") "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
