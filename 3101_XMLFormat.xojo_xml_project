  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>614473727</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function DBCheckDatabaseSchema() As boolean</SourceLine>
   <SourceLine>//this method checks to see if this is the most recent version of the database</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim updated as boolean=false</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim dbversion as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if DBConnect then</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Value FROM MyKeys WHERE Key LIKE 'DBVersion'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>'sqlArray.append "CREATE TABLE MyKeys (rowID INTEGER PRIMARY KEY autoincrement, Key varchar, Value varchar)"</SourceLine>
   <SourceLine>dbversion=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>dbversion=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this should equal 13 at this point</SourceLine>
   <SourceLine>while dbversion&lt;&gt;13</SourceLine>
   <SourceLine>if dbversion=3 then</SourceLine>
   <SourceLine>//we need to add in the HSSOS to HSInfo</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE HSInfo ADD COLUMN HSSOS double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='4' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=4</SourceLine>
   <SourceLine>elseif DBVersion=4 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN StdDevPct double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='5' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=5</SourceLine>
   <SourceLine>elseif dbversion=5 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN StdDevPct double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='6' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=6</SourceLine>
   <SourceLine>elseif dbversion=6 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rSHT integer")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rDEF integer")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rHND integer")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rREB integer")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rINT integer")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN rATH integer")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='7' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=7</SourceLine>
   <SourceLine>elseif dbversion=7 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BobbyRating double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='8' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=8</SourceLine>
   <SourceLine>elseif dbversion=8 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerAtts ADD COLUMN FullName varchar")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='9' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=9</SourceLine>
   <SourceLine>elseif dbversion=9 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BobbyRatingRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN StdDevPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN PlayerPlusMinusRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN mRatingPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN MyRatingPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BTPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BTPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='10' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=10</SourceLine>
   <SourceLine>elseif dbversion=10 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BTAltPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN BTAltPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='11' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=11</SourceLine>
   <SourceLine>elseif dbversion=11 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN PFPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PlayerInfo ADD COLUMN PFPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='12' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=12</SourceLine>
   <SourceLine>elseif dbversion=12 then</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BobbyRating double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BobbyRatingRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN StdDevPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN PlayerPlusMinusRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN mRatingPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN MyRatingPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BTPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BTPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BTAltPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN BTAltPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN PFPct double")</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE Recruits ADD COLUMN PFPctRank double")</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE MyKeys SET Value='13' WHERE Key='DBVersion'")</SourceLine>
   <SourceLine>dbversion=13</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>updated=true</SourceLine>
   <SourceLine>return updated</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
