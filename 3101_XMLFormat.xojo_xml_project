 <Method>
  <ItemName>TP</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>350531583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub TP(AorB as String)</SourceLine>
   <SourceLine>dim thisteamnumber as string</SourceLine>
   <SourceLine>dim TmpTeamNum as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if aorb="A" then</SourceLine>
   <SourceLine>thisteamnumber=iAction.Player(0).Team</SourceLine>
   <SourceLine>TmpTeamNum=val(iAction.Player(1).Team)-1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>thisteamnumber=iAction.Player(1).Team</SourceLine>
   <SourceLine>TmpTeamNum=val(iAction.Player(0).Team)-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT PlayerNum, TP, rowID FROM SVTable WHERE TeamNum='"+thisteamnumber+"' AND (Pos&gt;0 and Pos&lt;6)")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>svdb.SQLExecute("UPDATE SVTable SET TP='"+str(rs.IdxField(2).IntegerValue+1)+"' WHERE rowID='"+rs.IdxField(3).StringValue+"'")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's figure out whether we have to remove the opportunity for pts of TO's</SourceLine>
   <SourceLine>//if team 1 just started a new possession, then this clears out team 2's fOffTurnover</SourceLine>
   <SourceLine>fOffTurnover(TmpTeamNum)=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
