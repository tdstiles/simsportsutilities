 <Method>
  <ItemName>mthParseGame</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>96202751</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthParseGame()</SourceLine>
   <SourceLine>if UBound(PBPLines)&gt;0 and fRunning=1 then</SourceLine>
   <SourceLine>MyAction=Stats.MainActionMethod(PBPLines.Pop)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Set the picture</SourceLine>
   <SourceLine>SetPicture</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update the clock</SourceLine>
   <SourceLine>clock.text=TimeSecondstoMinutes</SourceLine>
   <SourceLine>clock.Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if we're watching the game, load the text</SourceLine>
   <SourceLine>TimeString=clock.text+chr(9)+str(MyAction.Scores(0))+"-"+str(MyAction.Scores(1))</SourceLine>
   <SourceLine>LoadResultText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//We want to update the StatViewerGlobals.TeamScoresForTracker(1) with the scores for both teams</SourceLine>
   <SourceLine>StatViewerGlobals.UpdateTeamScores(MyAction)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iBoxScore&gt;0 and BoxScoreViewerLoaded then</SourceLine>
   <SourceLine>BoxScores.UpdateScores</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif UBound(PBPLines)=0 and frunning=1 then</SourceLine>
   <SourceLine>fRunning=2</SourceLine>
   <SourceLine>//game is over</SourceLine>
   <SourceLine>//adjust for end of game</SourceLine>
   <SourceLine>stats.FinalSubstitute</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//make the timer stop firing</SourceLine>
   <SourceLine>MainTimer.Enabled=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fWatchPBP then //only show if we're watchin the game</SourceLine>
   <SourceLine>wndInGameStats.show</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>butSwitchViewer.Visible=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
