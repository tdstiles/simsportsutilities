  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadOverview()</SourceLine>
   <SourceLine>dim formatter,selectstatement as string</SourceLine>
   <SourceLine>dim games,i, divisorA as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim minutes as integer</SourceLine>
   <SourceLine>dim opponent as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbOverview.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>#pragma NilObjectChecking false</SourceLine>
   <SourceLine>#pragma disablebackgroundtasks</SourceLine>
   <SourceLine>#pragma disableautowaitcursor</SourceLine>
   <SourceLine>#pragma disableboundschecking</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set lbOverview headers</SourceLine>
   <SourceLine>if popup(2).ListIndex=0 then //offensive stats</SourceLine>
   <SourceLine>//load lbOverview game listing</SourceLine>
   <SourceLine>for x as integer=1 to 4</SourceLine>
   <SourceLine>selectstatement="SELECT Count(*) as Games, Sum(Stats.Mins) as Mins, Sum(Stats.Pts) as Pts, Sum(Stats.reb) as reb, Sum(Stats.Ast) as ast, Sum(Stats.Stl) as stl, Sum(Stats.TOS) as tos, Sum(Stats.Blk) as blk, sum(fga) as fga, sum(fgm) as fgm, sum(fg3a) as fg3a, sum(fg3m) as fg3m, sum(fta) as fta, sum(ftm) as ftm, Sum(POG='Y') as POG FROM "+clause(1)+" WHERE Stats.Name LIKE '"+PlayersName+"'"+ clause(0) + clause(2)+" AND Stats.Season="+str(val(snn)-1+x)</SourceLine>
   <SourceLine>rs=db.SQLSelect(selectstatement)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>if popup(3).listindex=0 then //career totals</SourceLine>
   <SourceLine>divisorA=1</SourceLine>
   <SourceLine>formatter="###"</SourceLine>
   <SourceLine>elseif popup(3).ListIndex=1 then</SourceLine>
   <SourceLine>divisorA=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>formatter="#0.0"</SourceLine>
   <SourceLine>elseif popup(3).ListIndex=2 then</SourceLine>
   <SourceLine>divisorA=rs.IdxField(2).IntegerValue</SourceLine>
