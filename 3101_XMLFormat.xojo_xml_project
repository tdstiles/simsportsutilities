 <Method>
  <ItemName>DetermineClauses</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1386495</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub DetermineClauses()</SourceLine>
   <SourceLine>dim positionA as string</SourceLine>
   <SourceLine>dim opponent as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>opponent=popup(1).text</SourceLine>
   <SourceLine>positionA=popup(0).text</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if positionA="Total" OR positionA="" then</SourceLine>
   <SourceLine>clause(0)=""</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>clause(0)=" AND Stats.APosition LIKE '%"+PositionA+"'"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if opponent="All" OR opponent="" then</SourceLine>
   <SourceLine>clause(1)="Stats"</SourceLine>
   <SourceLine>clause(2)=" AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>elseif opponent="NTT" OR opponent="PTT" OR opponent="RTT" OR opponent="DTT" OR opponent="Conference" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory"</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND TeamHistory.Type='"+opponent+"' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>elseif opponent="Regular Season" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory"</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND TeamHistory.Type LIKE '%Confe%' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>elseif opponent="Conf. Tourney" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory"</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND TeamHistory.Type LIKE 'Conf.%' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>elseif opponent="Postseason" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory"</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND TeamHistory.Type NOT LIKE '%Confe%' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>elseif opponent="Exhibition" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory "</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND Stats.Game&gt;24"</SourceLine>
   <SourceLine>elseif opponent="Inc. Exhibition" then</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory "</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>clause(1)="Stats, TeamHistory "</SourceLine>
   <SourceLine>clause(2)=" AND TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND TeamHistory.Opponent='"+Opponent+"' AND Stats.Game&lt;=24"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fInitialLoad&lt;&gt;TRUE then</SourceLine>
   <SourceLine>If lbOverview.cell(lbOverview.listindex,0)&lt;&gt;"TOT" and lbOverview.listindex&lt;&gt;-1 then</SourceLine>
   <SourceLine>clause(3)=" AND Stats.Season='"+lbOverview.cell(lbOverview.listindex,0)+"'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>clause(3)=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>clause(3)=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
