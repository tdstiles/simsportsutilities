 <Method>
  <ItemName>AddScrimmage</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>767690751</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AddScrimmage()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstatement as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Pull from playerInfo to generate player ID number</SourceLine>
   <SourceLine>sqlstatement="SELECT Name FROM Scrimmage_Info WHERE Name LIKE '"+popPlayerNames.text+"'"</SourceLine>
   <SourceLine>rs=DB.SQLSelect(sqlstatement)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if player is found in scrimmage database; update record</SourceLine>
   <SourceLine>rs.Edit // Make it Editable</SourceLine>
   <SourceLine>rs.Field("ScrimMins").StringValue = str(val(rs.Field("ScrimMins").StringValue)+val(playerfield(0).text))</SourceLine>
   <SourceLine>rs.Field("ScrimFGM").StringValue = str(val(rs.Field("ScrimFGM").StringValue)+val(playerfield(1).text))</SourceLine>
   <SourceLine>rs.Field("ScrimFGA").StringValue = str(val(rs.Field("ScrimFGA").StringValue)+val(playerfield(2).text))</SourceLine>
   <SourceLine>rs.Field("ScrimFTM").StringValue = str(val(rs.Field("ScrimFTM").StringValue)+val(playerfield(3).text))</SourceLine>
   <SourceLine>rs.Field("ScrimFTA").StringValue = str(val(rs.Field("ScrimFTA").StringValue)+val(playerfield(4).text))</SourceLine>
   <SourceLine>rs.Field("ScrimReb").StringValue =  str(val(rs.Field("ScrimREB").StringValue)+val(playerfield(5).text))</SourceLine>
   <SourceLine>rs.Field("ScrimAst").StringValue =  str(val(rs.Field("ScrimAst").StringValue)+val(playerfield(6).text))</SourceLine>
   <SourceLine>rs.Field("ScrimBlk").StringValue =  str(val(rs.Field("ScrimBLK").StringValue)+val(playerfield(7).text))</SourceLine>
   <SourceLine>rs.Field("ScrimStl").StringValue =  str(val(rs.Field("ScrimStl").StringValue)+val(playerfield(8).text))</SourceLine>
   <SourceLine>rs.Field("ScrimTO").StringValue =  str(val(rs.Field("ScrimTO").StringValue)+val(playerfield(9).text))</SourceLine>
   <SourceLine>rs.Field("ScrimPF").StringValue =  str(val(rs.Field("ScrimPF").StringValue)+val(playerfield(10).text))</SourceLine>
   <SourceLine>rs.Field("ScrimPTS").StringValue =  str(val(rs.Field("ScrimPTS").StringValue)+val(playerfield(11).text))</SourceLine>
   <SourceLine>rs.Update // Update the Database</SourceLine>
   <SourceLine>rs.Edit</SourceLine>
   <SourceLine>rs.Field("ScrimTenMin").DoubleValue = (((val(rs.Field("ScrimPTS").StringValue)+val(rs.Field("ScrimReb").StringValue)+1.25*val(rs.Field("ScrimAst").StringValue)+1.25*val(rs.Field("ScrimStl").StringValue)+val(rs.Field("ScrimBlk").StringValue)-(val(rs.Field("ScrimFGA").StringValue)-val(rs.Field("ScrimFGM").StringValue))-((val(rs.Field("ScrimFTA").StringValue)-val(rs.Field("ScrimFTM").StringValue))/2)-(val(rs.Field("ScrimPF").StringValue)/2)))/(val(rs.Field("ScrimMins").StringValue )))</SourceLine>
   <SourceLine>rs.Update // Update the Database</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstatement="INSERT INTO Scrimmage_Info (ScrimMins, ScrimFGM, ScrimFGA, ScrimFTM, ScrimFTA, ScrimReb, ScrimAst, ScrimBlk, ScrimStl, ScrimTO, ScrimPF, ScrimPts, ScrimTenMin, Name) VALUES ("</SourceLine>
