  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SortbyPos(index as integer)</SourceLine>
   <SourceLine>dim s as string</SourceLine>
   <SourceLine>dim insert as string</SourceLine>
   <SourceLine>dim fBase as boolean=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if index=0 then</SourceLine>
   <SourceLine>s=BaseSQL</SourceLine>
   <SourceLine>elseif index&lt;=5 then</SourceLine>
   <SourceLine>insert=popPosition.text</SourceLine>
   <SourceLine>s=BaseSQL+" WHERE Pos LIKE '%"+insert+"%'"</SourceLine>
   <SourceLine>elseif index&gt;5 and index&lt;=9 then</SourceLine>
   <SourceLine>insert=popPosition.text</SourceLine>
   <SourceLine>s=BaseSQL+" WHERE MyPosition LIKE '%"+insert+"%'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>s=MyBaseSQL</SourceLine>
   <SourceLine>fBase=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PlayerListUpdate(s,fbase)</SourceLine>
   <SourceLine>End Sub</SourceLine>
