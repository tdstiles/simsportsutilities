   <SourceLine>szResult=sDownload.Get(theurl, 30)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if szResult &lt;&gt; "" then</SourceLine>
   <SourceLine>szResult=CleanHTML(szResult)</SourceLine>
