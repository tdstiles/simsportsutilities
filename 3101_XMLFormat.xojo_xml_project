   <SourceLine>wndMain.st1.text="FG%: "+format(rs.idxfield(2).IntegerValue/rs.idxfield(3).IntegerValue, "#0.0%")+ "  TO:  "+ format(rs.idxfield(11).IntegerValue+rs.idxfield(15).IntegerValue-rs.idxfield(12).IntegerValue,"+#0")</SourceLine>
