 <Method>
  <ItemName>SwitchtoExportPanel</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1132902399</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SwitchtoExportPanel()</SourceLine>
   <SourceLine>ppMain.Value=2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rgPlayerStats(-1) as PlayerForPOG</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Name, TeamName, TeamNum, fgm, fga, ftm, fta, fg3m, fg3a, oreb, dreb, ast, stl, blk, plusminus, tos, fouls, pus FROM SVTable"</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
   <SourceLine>dim nPlayerScoreTmp as double</SourceLine>
   <SourceLine>dim PlayerHere as PlayerForPOG</SourceLine>
   <SourceLine>dim reb as integer</SourceLine>
   <SourceLine>reb=rs.Field("oreb").IntegerValue+rs.field("dreb").IntegerValue</SourceLine>
   <SourceLine>nPlayerScoreTmp=ninjabovinescore(rs.field("FGM").IntegerValue, rs.field("ftm").IntegerValue, rs.field("fg3m").IntegerValue, reb, rs.field("ast").IntegerValue, rs.field("stl").IntegerValue, rs.field("blk").IntegerValue, rs.field("Pus").IntegerValue, rs.field("plusminus").IntegerValue, rs.field("fga").IntegerValue, rs.field("fta").IntegerValue, rs.field("tos").IntegerValue, rs.field("fouls").IntegerValue)</SourceLine>
   <SourceLine>PlayerHere.Name=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>PlayerHere.TeamName=rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>PlayerHere.TeamNum=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>PlayerHere.Score=nPlayerScoreTmp*100</SourceLine>
   <SourceLine>rgPlayerStats.append PlayerHere</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim frgHighestScoreTmp(1) as double //(0)=player number, (1)=score</SourceLine>
   <SourceLine>dim iMax as integer</SourceLine>
   <SourceLine>iMax=ubound(rgPlayerStats)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>if rgPlayerStats(n).Score&gt;frgHighestScoreTmp(1) then</SourceLine>
   <SourceLine>frgHighestScoreTmp(0)=n</SourceLine>
   <SourceLine>frgHighestScoreTmp(1)=rgPlayerStats(n).Score</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>myPOG.text="Congrats to the SSC Player of the Game, "+rgPlayerStats(frgHighestScoreTmp(0)).Name+" of "+rgPlayerStats(frgHighestScoreTmp(0)).TeamName+"!"</SourceLine>
   <SourceLine>POG(0)=str(rgPlayerStats(frgHighestScoreTmp(0)).TeamNum)</SourceLine>
   <SourceLine>pog(1)=rgPlayerStats(frgHighestScoreTmp(0)).Name</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ImportGameMethod</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
