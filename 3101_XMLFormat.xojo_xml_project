   <SourceLine>Sub Constructor(PlayerName as String)</SourceLine>
   <SourceLine>//when the name is passed, we load up all the other variables</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>'BobbyRatingRank double, StdDevPctRank double, PlayerPlusMinusRank double, mratingpctrank double, BTPct double, BTPctRank double, BTAltPct double, BTAltPctRank double, PFPct double, PFPctRank double, MyRatingPctRank double)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//main stats</SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT Height, Pos, MRatingPct, mRatingPctRank, OppRatingPct, MyRatingPct, MyRatingPctRank, playerplusminus, PlayerPlusMinusRank, FitPct, PlusMinusPct,StdDevPct,StdDevPctRank, BobbyRating,BobbyRatingRank, BTPct, BTPctRank, BTAltPct, BTAltPctRank, PFPct, PFPctRank FROM PlayerInfo WHERE Name LIKE '%" + PlayerName + "%'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>Name=PlayerName</SourceLine>
   <SourceLine>Height=InchestoHt(rs.idxfield(1).IntegerValue)</SourceLine>
   <SourceLine>Position=rs.field("pos").StringValue</SourceLine>
   <SourceLine>mRatingPct=format(rs.Field("mRatingPct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>MRatingPctRank=rs.Field("mRatingPctRank").StringValue</SourceLine>
   <SourceLine>OppRatingPct=Format(rs.field("oppratingpct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>MyRatingPct=Format(rs.field("myratingpct").doublevalue,"##0.0%")</SourceLine>
   <SourceLine>MyRatingPctRank=rs.Field("MyRatingPctRank").StringValue</SourceLine>
   <SourceLine>PlayerPlusminus=Format(rs.field("playerplusminus").DoubleValue, "+#0.0")</SourceLine>
   <SourceLine>FitPct=format(rs.field("fitpct").DoubleValue,"###0.0%")</SourceLine>
   <SourceLine>PlusminusPct=Format(rs.field("plusminuspct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>PlusMinusPctRank=rs.Field("PlayerPlusMinusRank").StringValue</SourceLine>
   <SourceLine>StdDevPct=Format(rs.field("stddevpct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>StdDevPctRank=rs.Field("stddevpctrank").StringValue</SourceLine>
   <SourceLine>BobbyRating=Format(rs.field("bobbyrating").DoubleValue,"##0.0%")</SourceLine>
   <SourceLine>BobbyRatingRank=rs.Field("BobbyRatingRank").StringValue</SourceLine>
   <SourceLine>BTPct=format(rs.Field("btpct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>BTPctRank=rs.Field("btpctrank").StringValue</SourceLine>
   <SourceLine>BTAltPct=format(rs.Field("btaltpct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>BTAltPctRank=rs.Field("btaltpctrank").StringValue</SourceLine>
   <SourceLine>PFPct=format(rs.Field("PFpct").DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>PFPctRank=rs.Field("PFpctrank").StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT PlayerInfo.PPG, PlayerInfo.RPG, PlayerInfo.APG, PlayerInfo.SPG, PlayerInfo.BPG, PlayerInfo.TPG, PlayerInfo.Tendex, PlayerInfo.HSSOS, PlayerInfo.NormTendex, PlayerInfo.GPA, Playerinfo.Test FROM PlayerInfo WHERE PlayerInfo.Name LIKE '" + PlayerName + "'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>PPG=Format(rs.idxField(1).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>RPG=Format(rs.idxField(2).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>APG=Format(rs.idxField(3).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>SPG=Format(rs.idxField(4).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>BPG=Format(rs.idxField(5).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>TPG=Format(rs.idxfield(6).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>Tendex= Format(rs.idxField(7).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>HSSOS=Format((rs.idxField(8).DoubleValue/100)-1, "+#0.0%")</SourceLine>
   <SourceLine>NormTendex=Format(rs.idxField(9).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>GPA=rs.idxField(10).stringValue</SourceLine>
   <SourceLine>Test=rs.idxField(11).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT PlayerInfo.SHT, PlayerInfo.DEF, PlayerInfo.HND, PlayerInfo.REB, PlayerInfo.ATH FROM PlayerInfo WHERE PlayerInfo.Name LIKE '%" + PlayerName + "%'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>SHT= numtoword(rs.idxField(1).integerValue, true)</SourceLine>
   <SourceLine>DEF=numtoword(rs.idxField(2).integerValue, true)</SourceLine>
   <SourceLine>HND=numtoword(rs.idxField(3).integerValue, true)</SourceLine>
   <SourceLine>REB=numtoword(rs.idxField(4).integerValue, true)</SourceLine>
   <SourceLine>ATH=numtoword(rs.idxField(5).integerValue, true)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//atts/prefs</SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT PlayerInfo.Scout, HSInfo.PowerRanking, HSInfo.Ranking, HSInfo.HSSHT, HSInfo.HSDEF, HSInfo.HSREB, HSInfo.HSHND, HSInfo.HSATH FROM PlayerInfo, HSInfo WHERE PlayerInfo.HSName = HSInfo.HSName AND PlayerInfo.Name LIKE '%" + PlayerName + "%'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>Scout=numtoword(rs.idxField(1).integerValue, true)</SourceLine>
   <SourceLine>HSPowerRanking= format(rs.idxfield(2).doubleValue, "###.0")</SourceLine>
   <SourceLine>HSRanking=rs.idxfield(3).StringValue</SourceLine>
   <SourceLine>HSSHT=ShortenWords(rs.idxField(4).StringValue)</SourceLine>
   <SourceLine>HSDEF= ShortenWords(rs.idxField(5).StringValue)</SourceLine>
   <SourceLine>HSREB= ShortenWords(rs.idxField(6).StringValue)</SourceLine>
   <SourceLine>HSHND=ShortenWords(rs.idxField(7).StringValue)</SourceLine>
   <SourceLine>HSATH=ShortenWords(rs.idxField(8).StringValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT HSInfo.HSName, HSInfo.Region, PlayerInfo.Local, PlayerInfo.Win, PlayerInfo.Impact, HSInfo.ThisWL, HSInfo.LastWL, HSInfo.AvgHeight, PlayerInfo.MyRatingPct, PlayerInfo.OppRatingPct, PlayerInfo.AttPct, PlayerInfo.StatPct, PlayerInfo.PlayerPlusMinus, PlayerInfo.EstimatedAttributes FROM PlayerInfo, HSInfo WHERE PlayerInfo.HSName = HSInfo.HSName AND PlayerInfo.Name LIKE '%" + PlayerName + "%'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>HSName=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>Region=rs.idxfield(2).stringvalue</SourceLine>
   <SourceLine>Local=numtoword(rs.idxfield(3).integerValue)</SourceLine>
   <SourceLine>Win=numtoword(rs.idxfield(4).integerValue)</SourceLine>
   <SourceLine>Impact=numtoword(rs.idxfield(5).integerValue)</SourceLine>
   <SourceLine>HSWL=rs.idxfield(6).StringValue</SourceLine>
   <SourceLine>HSPrevWL=rs.idxfield(7).StringValue</SourceLine>
   <SourceLine>HSAvgHeight=InchestoHT(rs.idxfield(8).IntegerValue)</SourceLine>
   <SourceLine>RecIdx=format(RecruitIndexCalc(rs.idxfield(9).DoubleValue, rs.idxfield(10).DoubleValue, rs.idxfield(11).DoubleValue, rs.idxfield(12).DoubleValue),"##0.0")</SourceLine>
   <SourceLine>ETies= format(EstTies(rs.idxfield(9).DoubleValue, rs.idxfield(10).DoubleValue, rs.idxfield(11).DoubleValue, rs.idxfield(12).DoubleValue),"#0.0")</SourceLine>
   <SourceLine>EstValue=format(rs.idxfield(13).doublevalue, "+#0.0")</SourceLine>
   <SourceLine>EstAtts=rs.idxfield(14).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>SetTeamPct</SourceLine>
   <SourceLine>End Sub</SourceLine>
