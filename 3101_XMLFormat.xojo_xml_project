 <Method>
  <ItemName>ReadfromTextFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1624893439</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ReadfromTextFile(result as string) As integer()</SourceLine>
   <SourceLine>Dim n,k As Integer</SourceLine>
   <SourceLine>dim szName as string</SourceLine>
   <SourceLine>dim line, lines(-1) as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>dim rTeams(-1) as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines = split(result,endOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=10</SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>for j as integer=0 to 255</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>line=lines(n)</SourceLine>
   <SourceLine>szName=lines(n)</SourceLine>
   <SourceLine>k=instr(szName, "  ")</SourceLine>
   <SourceLine>szName=left(szName,k-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>l=CheckAgainstTeam(szName)</SourceLine>
   <SourceLine>while l=-1 //only first part of name, need second half of city</SourceLine>
   <SourceLine>k=instr(k+1,line," ")</SourceLine>
   <SourceLine>szName=left(line,k-1)</SourceLine>
   <SourceLine>l=CheckAgainstTeam(szName)</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have the team name</SourceLine>
   <SourceLine>//let's append the team num</SourceLine>
   <SourceLine>k=gTeams.indexof(szname)+1</SourceLine>
   <SourceLine>rTeams.Append k</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if j&lt;25 then</SourceLine>
   <SourceLine>Ranking(j)=k</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+7</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return rTeams</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>result as string</ItemParams>
  <ItemResult>integer()</ItemResult>
 </Method>
 <Method>
  <ItemName>ReturnTeamList</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>592549887</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ReturnTeamList() As cSVboxTeams()</SourceLine>
   <SourceLine>//now, we need to load up the GameScores</SourceLine>
   <SourceLine>//it all depends on what games we're pulling from iBoxScore</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim TeamList(-1) as cSVBoxTeams</SourceLine>
   <SourceLine>dim flash(-1) as string</SourceLine>
   <SourceLine>dim fToLoad as boolean=false</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>flash=LoadFlashPage</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's get the team list</SourceLine>
   <SourceLine>SVTeams=LoadTeamList</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we're set</SourceLine>
   <SourceLine>//ID, TeamName, Score  OppId, OppTM, OppScore</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim szScoreString(1) as string</SourceLine>
   <SourceLine>dim l as cSVBoxTeams</SourceLine>
   <SourceLine>j=ubound(flash)/6</SourceLine>
   <SourceLine>for n as integer=0 to (j*6) step 6</SourceLine>
   <SourceLine>l =new cSVBoxTeams</SourceLine>
   <SourceLine>l.TeamID.append val(flash(n))</SourceLine>
   <SourceLine>l.TeamID.append val(flash(n+3))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's see if either team is ranked</SourceLine>
   <SourceLine>for r as integer=0 to 1</SourceLine>
   <SourceLine>k=Ranking.IndexOf(l.TeamID(r))</SourceLine>
   <SourceLine>if k&gt;-1 then</SourceLine>
   <SourceLine>szScoreString(r)="No. "+str(k+1)+" "+flash(n+1+3*r)+" "+flash(n+2+3*r)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>szScoreString(r)=flash(n+1+3*r)+" "+flash(n+2+3*r)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>l.ScoreString=szScoreString(0)+" "+szScoreString(1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's see if either of these are on our teamlist</SourceLine>
   <SourceLine>fToLoad=false</SourceLine>
   <SourceLine>k=SVTeams.IndexOf(l.TeamID(0))</SourceLine>
   <SourceLine>if k&gt;-1 then</SourceLine>
   <SourceLine>fToLoad=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>k=SVTeams.IndexOf(l.TeamID(1))</SourceLine>
   <SourceLine>if k&gt;-1 then</SourceLine>
   <SourceLine>fToLoad=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fToLoad then</SourceLine>
   <SourceLine>TeamList.append l</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return TeamList</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>cSVboxTeams()</ItemResult>
 </Method>
