  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Pts as Integer, FGA as Integer, TOS as Integer</ItemParams>
  <ItemResult>Double</ItemResult>
 </Method>
 <Method>
  <ItemName>NewTendexCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>176510975</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function NewTendexCalc(pts as integer, fgm as integer, fga as integer, fg3m as integer, stl as integer, blk as integer, reb as integer, tos as integer, fouls as integer, fta as integer, ftm as integer, mins as integer, ast as integer) As double</SourceLine>
   <SourceLine>if mins&lt;&gt;0 then</SourceLine>
   <SourceLine>return ((PTS - (FGA-FGM) -(FTA-FTM)/2 + 0.5*fg3m + 1.25*stl + 1.25*ast + blk + reb - 1.25*tos - fouls/2)/mins*30)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>pts as integer, fgm as integer, fga as integer, fg3m as integer, stl as integer, blk as integer, reb as integer, tos as integer, fouls as integer, fta as integer, ftm as integer, mins as integer, ast as integer</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>ninjabovinescore</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1326403583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ninjabovinescore(FGM as integer, FTM as integer, FG3M as integer, reb as integer, ast as integer, stl as integer, blk as integer, ballsrecovered as integer, plusminus as integer, fga as integer, fta as integer, tos as integer, fouls as integer) As double</SourceLine>
   <SourceLine>return (2*fgm)+(1.2*ftm)+(1.6*fg3m)+(0.9*reb)+(1.5*ast)+(3*stl)+(2*blk)+(0.9*ballsrecovered)+(0.2*PlusMinus)-(fga-fgm)-(fta-ftm)-(1.5*tos)-(0.4*fouls)</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
