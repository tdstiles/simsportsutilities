  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TruncateString(g As Graphics, str As String, cellWidth As Integer, original As Boolean = false) As String</SourceLine>
   <SourceLine>if original then</SourceLine>
   <SourceLine>if g.StringWidth(str) &gt;= cellWidth - 4 then</SourceLine>
   <SourceLine>Return TruncateString(g, Left(str, Len(str)-3), cellWidth)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Return str</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if Len(str) = 0 then Return "..."</SourceLine>
   <SourceLine>if g.StringWidth(str + "...") &gt;= cellWidth - 4 then</SourceLine>
   <SourceLine>Return TruncateString(g, Left(str, Len(str)-1), cellWidth)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Return str + "..."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
