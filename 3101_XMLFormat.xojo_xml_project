 <Method>
  <ItemName>EstTies</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1110988799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function EstTies(my as double, opp as double, att as double, stat as double) As double</SourceLine>
   <SourceLine>dim allfactors, myoppatt, myopp, myoppstat as double</SourceLine>
   <SourceLine>dim final as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>allfactors=(-.1367548044+(my*-0.011628)+(opp*.0629368)+(att*.050361)+(stat*.036816))</SourceLine>
   <SourceLine>myoppstat=(-.12176972+(my*.0429861)+(opp*.069246)+(stat*.011450))</SourceLine>
   <SourceLine>myopp=(-.1198282477+(.051629*my)+(opp*.070715162))</SourceLine>
   <SourceLine>myoppatt=(-.1225893438+(my*.042463053)+(att*.013014808)+(opp*.069925765))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>final=((allfactors+myoppatt+myopp+myoppstat)*25)-1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if final&lt;0 then</SourceLine>
   <SourceLine>final=0</SourceLine>
   <SourceLine>return final</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return final</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>my as double, opp as double, att as double, stat as double</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>RecruitIndexCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1597497343</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function RecruitIndexCalc(my as double, opp as double, att as double, stat as double) As double</SourceLine>
   <SourceLine>dim x as double</SourceLine>
   <SourceLine>x=my*100*prefmyfactor</SourceLine>
   <SourceLine>x=x+opp*100*prefoppfactor</SourceLine>
   <SourceLine>x=x+att*100*prefattfactor</SourceLine>
   <SourceLine>x=x+stat*100*prefstatfactor</SourceLine>
   <SourceLine>x=x-500</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if x&gt;0 then</SourceLine>
   <SourceLine>return x</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>my as double, opp as double, att as double, stat as double</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>SetTeamPct</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1198757887</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SetTeamPct()</SourceLine>
   <SourceLine>//this method loads teampts, teamreb, teamast, teamblk, teamstl, and teamTOs, which is the percentage of each this guy does</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Select Sum(PPG), Sum(APG), Sum(RPG), Sum(BPG), Sum(SPG), Sum(TPG) FROM PlayerInfo WHERE HSName='"+HSName+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.recordcount&lt;&gt;0 then</SourceLine>
   <SourceLine>teampts=val(ppg)/rs.idxfield(1).doublevalue</SourceLine>
   <SourceLine>teamast=val(apg)/rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>teamreb=val(rpg)/rs.IdxField(3).DoubleValue</SourceLine>
   <SourceLine>TeamBlk=val(BPG)/rs.IdxField(4).DoubleValue</SourceLine>
   <SourceLine>TeamStl=val(spg)/rs.IdxField(5).DoubleValue</SourceLine>
   <SourceLine>TeamTOs=val(tpg)/rs.IdxField(6).DoubleValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get teammate positions for string</SourceLine>
   <SourceLine>sqlstring="Select Pos FROM PlayerInfo WHERE HSName='"+HSName+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.recordcount&lt;&gt;0 then</SourceLine>
   <SourceLine>Teammates=rs.IdxField(1).StringValue+", "</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>teammates=Teammates+rs.IdxField(1).StringValue+", "</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>Teammates=Teammates+rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
