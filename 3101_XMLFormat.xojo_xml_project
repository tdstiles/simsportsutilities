   <PartID>1427189759</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Function ConstructContextualMenu(base as MenuItem, x as Integer, y as Integer) As Boolean</SourceLine>
    <SourceLine>Dim mItem as menuitem</SourceLine>
    <SourceLine>mItem = New MenuItem("Add 17 RPs")</SourceLine>
    <SourceLine>base.Append( mItem )</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mItem=New MenuItem( "Add 1 RP")</SourceLine>
    <SourceLine>base.Append(mitem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mItem=New MenuItem( "Remove 1 RP")</SourceLine>
    <SourceLine>base.Append(mitem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mitem=new MenuItem("Clear RPs")</SourceLine>
    <SourceLine>base.Append(mItem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>base.append(New MenuItem(MenuItem.TextSeparator))</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mitem=new MenuItem("Estimate Ties")</SourceLine>
    <SourceLine>base.Append(mItem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mitem=new MenuItem("Messageboard Text")</SourceLine>
    <SourceLine>base.append(mitem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mitem=new MenuItem("View Teammates")</SourceLine>
    <SourceLine>base.append(mItem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>return true</SourceLine>
    <SourceLine>End Function</SourceLine>
   </ItemSource>
  </HookInstance>
