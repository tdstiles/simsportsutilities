 <Method>
  <ItemName>CreateCheckBoxes</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>924508159</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateCheckBoxes(lb As ListBox)</SourceLine>
   <SourceLine>Dim c1,c2 As Group2D</SourceLine>
   <SourceLine>Dim f1 As New FigureShape</SourceLine>
   <SourceLine>Dim f2 As New FigureShape</SourceLine>
   <SourceLine>Dim f3 As New FigureShape</SourceLine>
   <SourceLine>Dim f4 As New FigureShape</SourceLine>
   <SourceLine>Dim f5 As New FigureShape</SourceLine>
   <SourceLine>Dim scale As Double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>scale = TextHeight * (1 / (lb.TextSize*4))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Check Mark</SourceLine>
   <SourceLine>f1.BorderWidth = 0</SourceLine>
   <SourceLine>f1.FillColor = &amp;c000000</SourceLine>
   <SourceLine>f1.Fill = 100</SourceLine>
   <SourceLine>f1.AddLine 12,-12,-4,4</SourceLine>
   <SourceLine>f1.AddLine -4,4,-12,-4</SourceLine>
   <SourceLine>f1.AddLine -12,-4,-12,6</SourceLine>
   <SourceLine>f1.AddLine -12,6,-4,12</SourceLine>
   <SourceLine>f1.AddLine -4,12,12,-6</SourceLine>
   <SourceLine>f1.AddLine 12,-6,12,-12</SourceLine>
   <SourceLine>f1.X = 0</SourceLine>
   <SourceLine>f1.Y = 0</SourceLine>
   <SourceLine>// Box</SourceLine>
   <SourceLine>f2.BorderWidth = 0</SourceLine>
   <SourceLine>f2.FillColor = &amp;c808080</SourceLine>
   <SourceLine>f2.Fill = 100</SourceLine>
   <SourceLine>f2.AddLine -16,16,16,16</SourceLine>
   <SourceLine>f2.AddLine 16,16,16,-16</SourceLine>
   <SourceLine>f2.AddLine 16,-16,-16,-16</SourceLine>
   <SourceLine>f2.AddLine -16,-16,-16,16</SourceLine>
   <SourceLine>f2.X = 0</SourceLine>
   <SourceLine>f2.Y = 0</SourceLine>
   <SourceLine>// Box Fill</SourceLine>
   <SourceLine>f3.BorderWidth = 0</SourceLine>
   <SourceLine>f3.FillColor = &amp;cFFFFFF</SourceLine>
   <SourceLine>f3.Fill = 100</SourceLine>
   <SourceLine>f3.AddLine -14,14,14,14</SourceLine>
   <SourceLine>f3.AddLine 14,14,14,-14</SourceLine>
   <SourceLine>f3.AddLine 14,-14,-14,-14</SourceLine>
   <SourceLine>f3.AddLine -14,-14,-14,14</SourceLine>
   <SourceLine>f3.X = 0</SourceLine>
   <SourceLine>f3.Y = 0</SourceLine>
   <SourceLine>// Box</SourceLine>
   <SourceLine>f4.BorderWidth = 0</SourceLine>
   <SourceLine>f4.FillColor = &amp;c808080</SourceLine>
   <SourceLine>f4.Fill = 100</SourceLine>
   <SourceLine>f4.AddLine -16,16,16,16</SourceLine>
   <SourceLine>f4.AddLine 16,16,16,-16</SourceLine>
   <SourceLine>f4.AddLine 16,-16,-16,-16</SourceLine>
   <SourceLine>f4.AddLine -16,-16,-16,16</SourceLine>
   <SourceLine>f4.X = 0</SourceLine>
   <SourceLine>f4.Y = 0</SourceLine>
   <SourceLine>// Box Fill</SourceLine>
   <SourceLine>f5.BorderWidth = 0</SourceLine>
   <SourceLine>f5.FillColor = &amp;cFFFFFF</SourceLine>
   <SourceLine>f5.Fill = 100</SourceLine>
   <SourceLine>f5.AddLine -14,14,14,14</SourceLine>
   <SourceLine>f5.AddLine 14,14,14,-14</SourceLine>
   <SourceLine>f5.AddLine 14,-14,-14,-14</SourceLine>
   <SourceLine>f5.AddLine -14,-14,-14,14</SourceLine>
   <SourceLine>f5.X = 0</SourceLine>
   <SourceLine>f5.Y = 0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>c1 = New Group2D</SourceLine>
   <SourceLine>c1.Append f4</SourceLine>
   <SourceLine>c1.Append f5</SourceLine>
   <SourceLine>c1.Scale = scale</SourceLine>
   <SourceLine>CheckBoxes(0) = c1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>c2 = New Group2D</SourceLine>
   <SourceLine>c2.Append f2</SourceLine>
   <SourceLine>c2.Append f3</SourceLine>
   <SourceLine>c2.Append f1</SourceLine>
   <SourceLine>c2.Scale = scale</SourceLine>
   <SourceLine>CheckBoxes(1) = c2</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>lb As ListBox</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>DoCell</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1375451135</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function DoCell(g As Graphics, ps As PrinterSetup, lb As ListBox, Row As Integer, Column As Integer, xPos As Integer, topY As Integer, maxY As Integer) As Integer</SourceLine>
   <SourceLine>Dim cw, ContentWidth, AlignmentPad As Integer</SourceLine>
   <SourceLine>Dim CellContent As String</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if ColumnWidths(Column) &gt; 0 then</SourceLine>
   <SourceLine>// First, draw the cell background</SourceLine>
   <SourceLine>g.ForeColor = &amp;cFFFFFF</SourceLine>
   <SourceLine>g.FillRect(xPos, topY, ColumnWidths(Column) + PixelScale(ps, 4), maxY)</SourceLine>
   <SourceLine>// Next, draw the cell border</SourceLine>
   <SourceLine>g.ForeColor = &amp;cC0C0C0</SourceLine>
   <SourceLine>g.DrawRect(xPos, topY, ColumnWidths(Column) + PixelScale(ps, 4), maxY)</SourceLine>
   <SourceLine>// Next, draw the text</SourceLine>
   <SourceLine>g.ForeColor = &amp;c000000</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if lb.CellType(Row, Column) = 2 then</SourceLine>
   <SourceLine>cw = ColumnWidths(Column)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>cw = ColumnWidths(Column) - TextHeight - PixelScale(ps, 2)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if Wrap then</SourceLine>
   <SourceLine>CellContent = lb.Cell(Row, Column)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>CellContent = TruncateString(g, lb.Cell(Row, Column), cw, true)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ContentWidth = g.StringWidth(CellContent)</SourceLine>
   <SourceLine>Select Case lb.ColumnAlignment(Column)</SourceLine>
   <SourceLine>Case 2 // Center</SourceLine>
   <SourceLine>AlignmentPad = (cw - ContentWidth) / 2</SourceLine>
   <SourceLine>Case 3 // Right</SourceLine>
   <SourceLine>if lb.CellType(Row, Column) = 2 then</SourceLine>
   <SourceLine>AlignmentPad = cw - TextHeight - PixelScale(ps, 1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>AlignmentPad = cw - ContentWidth - PixelScale(ps, 1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>Else // Left, Default is Left, Decimal not supported</SourceLine>
   <SourceLine>AlignmentPad = PixelScale(ps, 2)</SourceLine>
   <SourceLine>End Select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if lb.CellType(Row, Column) = 2 OR lb.ColumnType(Column) = 2 Then</SourceLine>
   <SourceLine>DrawCheckBox(g, xPos + AlignmentPad+ PixelScale(ps, 4), vPos - PixelScale(ps, 4), lb.CellCheck(Row,Column))</SourceLine>
   <SourceLine>g.DrawString( CellContent, xPos + AlignmentPad + TextHeight + PixelScale(ps, 2), vPos - PixelScale(ps, 2), ColumnWidths(Column) )</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>g.DrawString( CellContent, xPos + AlignmentPad, vPos - PixelScale(ps, 2), ColumnWidths(Column) )</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>xPos = xPos + ColumnWidths(Column) + PixelScale(ps, 4)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return xPos</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>g As Graphics, ps As PrinterSetup, lb As ListBox, Row As Integer, Column As Integer, xPos As Integer, topY As Integer, maxY As Integer</ItemParams>
  <ItemResult>Integer</ItemResult>
 </Method>
