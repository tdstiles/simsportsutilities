  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>total as double, highest as double, plusminus as integer, mag1 as integer, mag2 as integer</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
