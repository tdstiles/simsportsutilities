 <Method>
  <ItemName>EffectivenessCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>449511423</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function EffectivenessCalc(OReb as Integer, DReb as Integer, Ast as Integer, Stl as Integer, Blk as Integer, pts as Integer, FGA as Integer, FTA as Integer, TOS as Integer, Mins as Integer) As double</SourceLine>
   <SourceLine>dim gs as double</SourceLine>
   <SourceLine>gs=(.75*Oreb+.25*Dreb+.5*Ast+Stl+.33*blk)+pts</SourceLine>
   <SourceLine>if (1.5*(FGA+(.44*FTA)+TOS+gs/2+mins/4))&lt;&gt;0 then</SourceLine>
   <SourceLine>return gs/(1.5*(FGA+(.44*FTA)+TOS+gs/2+mins/4))</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>OReb as Integer, DReb as Integer, Ast as Integer, Stl as Integer, Blk as Integer, pts as Integer, FGA as Integer, FTA as Integer, TOS as Integer, Mins as Integer</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
