   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GameScore(pts as integer, fgm as integer, fga as integer, fta as integer, ftm as integer, oreb as integer, dreb as integer, stl as integer, ast as integer, blk as integer, fouls as integer, tos as integer) As double</SourceLine>
   <SourceLine>return (Pts * 1.0) + (FGM * 0.4) + (FGA * -0.7) + ((FTA-FTM) * -0.4) + (OREB * 0.7) + (DREB * 0.3) + (STL * 1.0) + (AST* 0.7) + (BLK * 0.7) + (Fouls * -0.4) + (TOs * -1.0)</SourceLine>
