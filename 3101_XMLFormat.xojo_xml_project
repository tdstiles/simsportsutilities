   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun("My%:  ",true)</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun(p.MyRatingPct+"  (#"+p.myRatingPctRank+")")</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun("   StdDev%:  ", true)</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
