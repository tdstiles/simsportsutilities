  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function MeanCalc(numbers() as double) As double</SourceLine>
   <SourceLine>dim value as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(numbers)</SourceLine>
   <SourceLine>for x as integer=0 to l</SourceLine>
   <SourceLine>value=value+numbers(x)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return value/l</SourceLine>
   <SourceLine>End Function</SourceLine>
