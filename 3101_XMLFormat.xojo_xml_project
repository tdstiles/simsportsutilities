 <Method>
  <ItemName>FG</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1742088191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub FG(distance as integer, made as boolean, optional distancename as string)</SourceLine>
   <SourceLine>dim mm, ds, assisted as string</SourceLine>
   <SourceLine>dim thisvalue as integer</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>mm=rgStatPossibilities(0).text</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mm=rgStatPossibilities(1).text</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update pts off turnovers</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>if distance&lt;3 then</SourceLine>
   <SourceLine>UpdatePtsOffTO(val(iAction.Player(0).Team)-1,2)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>UpdatePtsOffTO(val(iAction.Player(0).Team)-1,3)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//fga/aFGA</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGA", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGA", 1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//determine distance</SourceLine>
   <SourceLine>if distance=0 then</SourceLine>
   <SourceLine>//shrtFG</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "shrtA", 1) //shrtFGA</SourceLine>
   <SourceLine>ds=rgStatPossibilities(7).Text</SourceLine>
   <SourceLine>//determine if make or miss</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aPts", 2)</SourceLine>
   <SourceLine>StatReturn=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "Pts", 2)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "shrtM", 1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif distance=1 then</SourceLine>
   <SourceLine>ds=rgStatPossibilities(8).text</SourceLine>
   <SourceLine>//midFG</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "medA", 1) //midFGA</SourceLine>
   <SourceLine>//determine if make or miss</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aPts", 2)</SourceLine>
   <SourceLine>StatReturn=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "Pts", 2)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "medM", 1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif distance=2 then</SourceLine>
   <SourceLine>ds=rgStatPossibilities(9).Text</SourceLine>
   <SourceLine>//longFG</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "longA", 1)</SourceLine>
   <SourceLine>//determine if make or miss</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aPts", 2)</SourceLine>
   <SourceLine>StatReturn=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "Pts", 2)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "longM", 1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ds="a 3-pt field goal"</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFG3A", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FG3A", 1)</SourceLine>
   <SourceLine>//determine if make or miss</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGM", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFG3M", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FG3M", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aPts", 3)</SourceLine>
   <SourceLine>StatReturn=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "Pts", 3)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//add up assist</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>If iAction.Player(2).Number&lt;&gt;"0" then</SourceLine>
   <SourceLine>assisted=" (assisted by "+iAction.Player(2).Name+")"</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(2).Team, iAction.Player(2).Number, "Ast", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "AR", 1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if distancename="dunk" then</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" dunks the ball"+StatReturn+assisted</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" misses a dunk"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif distancename="layup" then</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" lays it in"+StatReturn+assisted</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" misses a layup"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif distancename="block" then</SourceLine>
   <SourceLine>statreturn=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "Blk", 1)</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "shBlkd", 1)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" has "+ds+" blocked by "+iAction.Player(1).Name+StatReturn</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" "+mm+" "+ds+StatReturn+assisted</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" "+mm+" "+ds</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if watching the game, we need to update the team stats</SourceLine>
   <SourceLine>wndS.UpdateTeamMethods(iAction.Player(0).Team,1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>//if viewing, update the player's pts</SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT Pts, Pos FROM SVTable WHERE TeamNum='"+iAction.Player(0).Team+"' AND PlayerNum='"+iAction.Player(0).Number+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//what position is he?</SourceLine>
   <SourceLine>wndS.UpdateLbTeamsCell(iAction.Player(0).Team,rs.IdxField(2).IntegerValue-1,1,rs.IdxField(1).StringValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//determine for RunCalculation</SourceLine>
   <SourceLine>if made then</SourceLine>
   <SourceLine>if distance&lt;3 then</SourceLine>
   <SourceLine>//2pt</SourceLine>
   <SourceLine>wndS.CalcRun(iAction.Player(0).Team, 2)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//3pt</SourceLine>
   <SourceLine>wndS.CalcRun(iAction.Player(0).Team, 3)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>distance as integer, made as boolean, optional distancename as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>FinalSubstitute</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1849362431</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub FinalSubstitute()</SourceLine>
   <SourceLine>dim pos,name as string</SourceLine>
   <SourceLine>dim time as integer=iAction.Time</SourceLine>
   <SourceLine>dim  x as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim brs as recordset</SourceLine>
   <SourceLine>dim nrgfinalmargin(1) as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT Sum(Pts) FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>nrgfinalmargin(n)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>nrgfinalmargin(0)=nrgfinalmargin(0)-nrgfinalmargin(1)</SourceLine>
   <SourceLine>nrgfinalmargin(1)=nrgfinalmargin(0)*-1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT PlayerNum, SecondsPlayed, SecondsWhenEntering, Pos, TeamNum, PlusMinus, PlusMinusWhenEntering, rowID, name FROM SVTable WHERE Pos=1 or Pos=2 or Pos=3 or Pos=4 or Pos=5")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
   <SourceLine>x=time-rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//initial plusminus listed</SourceLine>
   <SourceLine>dim nCurrentPtsMargin as integer</SourceLine>
   <SourceLine>nCurrentPtsMargin=rs.IdxField(6).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//difference between plusminuswhenentering and final plusminus</SourceLine>
   <SourceLine>nCurrentPtsMargin=nrgfinalmargin(rs.IdxField(5).IntegerValue-1)-rs.IdxField(7).IntegerValue</SourceLine>
   <SourceLine>nCurrentPtsMargin=nCurrentPtsMargin+rs.IdxField(6).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Update SVTable SET PlusMinus='"+str(nCurrentPtsMargin)+"', PlusMinusWhenEntering='"+str(nCurrentPtsMargin)+"', SecondsPlayed='"+str(rs.IdxField(2).IntegerValue+x)+"', SecondsWhenEntering="+str(iAction.Time)+" WHERE rowID="+rs.IdxField(8).StringValue</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//divide time by 60 to set minutes</SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT PlayerNum, TeamNum, secondsplayed FROM SVTable")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.eof=false and rs.RecordCount&lt;&gt;0</SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET MinutesPlayed='"+format(rs.IdxField(3).IntegerValue/60, "#####0")+"' WHERE PlayerNum='"+rs.IdxField(1).StringValue+"' AND TeamNum='"+rs.IdxField(2).StringValue+"'"</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>svdb.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
