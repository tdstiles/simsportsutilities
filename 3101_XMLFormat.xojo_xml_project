   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadHeaders()</SourceLine>
   <SourceLine>//set game boxscore headers</SourceLine>
   <SourceLine>if popup(2).ListIndex=0 then</SourceLine>
   <SourceLine>lbBoxScores.LoadHeader(split("G,Pos,Mins,FGM,FGA,3PM,3PA,FTM,FTA,Reb,Ast,Blk,Stl,TO,PF,Pts,Sub,Sht,3Pt,POG,SSN", ","))</SourceLine>
   <SourceLine>lbBoxScores.column(lbBoxScores.ColumnCount-1).WidthExpression="0%"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>lbBoxScores.LoadHeader(split("G,Pos,Mins,aFGM,aFGA,aF3M,aF3A,aPts,crTO,aPt/TP,POG,SSN", ","))</SourceLine>
