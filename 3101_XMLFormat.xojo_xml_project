   <SourceLine>Sub CalculateHOFScore()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim counter as double</SourceLine>
   <SourceLine>dim w as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//create inmemdb that has each player's stats</SourceLine>
   <SourceLine>PHDB=new REALSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if phdb.Connect then</SourceLine>
   <SourceLine>phdb.SQLExecute("CREATE Table PHTable (Player varchar, Score double)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//select all the players</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT Distinct(Name) FROM Stats")</SourceLine>
   <SourceLine>while rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 and rec.EOF=false</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(FGM), Sum(FTM), Sum(FG3M), Sum(REB), Sum(Ast), Sum(Stl), Sum(Blk), Sum(PUs), Sum(plusminus), Sum(FGA), Sum(FTA), SUm(TOS), Sum(Fouls) FROM Stats WHERE Name='"+rec.IdxField(1).StringValue+"' GROUP BY Name"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get ninjabovinescore</SourceLine>
   <SourceLine>counter=ninjabovinescore(rs.IdxField(1).IntegerValue, rs.IdxField(2).IntegerValue, rs.IdxField(3).IntegerValue, rs.IdxField(4).IntegerValue, rs.IdxField(5).IntegerValue, rs.IdxField(6).IntegerValue, rs.IdxField(7).IntegerValue, rs.IdxField(8).IntegerValue, rs.IdxField(9).IntegerValue, rs.IdxField(10).IntegerValue, rs.IdxField(11).IntegerValue, rs.IdxField(12).IntegerValue, rs.IdxField(13).IntegerValue)</SourceLine>
   <SourceLine>counter=counter/10</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get team wins</SourceLine>
   <SourceLine>sqlstring="Select Sum(TeamHistory.WL='W') FROM TeamHistory, Stats WHERE TeamHistory.Season=Stats.Season AND TeamHistory.Game=Stats.Game AND Stats.Name='"+rec.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 THEN</SourceLine>
   <SourceLine>w=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>w=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>counter=counter+w</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get honors</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Award LIKE '%1st All-Conf'), Sum(Award LIKE '%2nd All-Conf'), Sum(Award LIKE '%Conf FOY'), Sum(Award LIKE '%Conf POY'), Sum(Award LIKE '%All-League'), Sum(Award LIKE 'League FOY'), Sum(Award LIKE 'League POY')  FROM PlayerAwards WHERE Name='"+PlayerNameToInitial(rec.IdxField(1).StringValue)+"' OR Name='"+rec.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>counter=counter+7*rs.IdxField(1).IntegerValue+3*rs.IdxField(2).IntegerValue+5*rs.IdxField(3).IntegerValue+12*rs.IdxField(4).IntegerValue+15*rs.IdxField(5).IntegerValue+15*rs.IdxField(6).IntegerValue+25*rs.IdxField(7).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get player of the game</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(POG='Y') FROM Stats WHERE Name='"+rec.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>counter=counter+rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>phdb.SQLExecute("INSERT INTO PHTable (Player, Score) VALUES ('"+rec.IdxField(1).StringValue+"', '"+str(counter)+"')")</SourceLine>
   <SourceLine>rec.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//sort and load LB</SourceLine>
   <SourceLine>lbHallofFame.DeleteAllRows</SourceLine>
   <SourceLine>rs=phdb.SQLSelect("SELECT Player, Score FROM PHTable ORDER BY Score DESC")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>lbHallofFame.addrow rs.IdxField(1).StringValue, format(rs.IdxField(2).DoubleValue, "###0")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
