 <Method>
  <ItemName>LoadPrefs</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>719927295</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPrefs()</SourceLine>
   <SourceLine>dim f, fi as folderitem</SourceLine>
   <SourceLine>dim b as binarystream</SourceLine>
   <SourceLine>dim tmp as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rand=new random</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=SpecialFolder.Preferences</SourceLine>
   <SourceLine>f=f.child("SSC")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Prefs.bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if f&lt;&gt; nil then</SourceLine>
   <SourceLine>if f.Exists then</SourceLine>
   <SourceLine>//file exists, so we open it</SourceLine>
   <SourceLine>b=BinaryStream.Open(f, true)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's read the menu items</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>fi= new FolderItem</SourceLine>
   <SourceLine>dim aname as string=b.ReadPString</SourceLine>
   <SourceLine>fi=GetFolderItem(b.ReadPString, FolderItem.PathTypeAbsolute)</SourceLine>
   <SourceLine>fi.Name=aname</SourceLine>
   <SourceLine>MenuItems(n)=fi</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//do these in alphabetical order from the properties menu on the left</SourceLine>
   <SourceLine>prefattfactor=b.ReadDouble</SourceLine>
   <SourceLine>prefImpact=b.ReadDouble</SourceLine>
   <SourceLine>prefLocal=b.ReadDouble</SourceLine>
   <SourceLine>prefmyfactor=b.ReadDouble</SourceLine>
   <SourceLine>prefoppfactor=b.ReadDouble</SourceLine>
   <SourceLine>prefplayerpct=b.ReadUInt8</SourceLine>
   <SourceLine>prefScoutStat=b.ReadUInt8</SourceLine>
   <SourceLine>prefstatfactor=b.ReadDouble</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 19</SourceLine>
   <SourceLine>prefstats(n)=b.ReadDouble</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>prefWin=b.ReadDouble</SourceLine>
   <SourceLine>prefWindowColor=b.ReadPString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now load up the possibilities for the stat viewer</SourceLine>
   <SourceLine>dim pstring as cPossibilityString</SourceLine>
   <SourceLine>for n as integer=0 to 10</SourceLine>
   <SourceLine>pstring=new cPossibilityString(b.ReadPString)</SourceLine>
   <SourceLine>rgStatPossibilities(n)=pstring</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefNumCustomFunctions=b.ReadUInt16</SourceLine>
   <SourceLine>if prefNumCustomFunctions&gt;0 then</SourceLine>
   <SourceLine>for n as integer=1 to prefNumCustomFunctions</SourceLine>
   <SourceLine>prefCustomStatFunctions.append b.ReadPString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>b.close</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get the custom functions</SourceLine>
   <SourceLine>//write new preferences file for the custom stats</SourceLine>
   <SourceLine>f=SpecialFolder.Preferences.Child("SSC").Child("Stats.bin")</SourceLine>
   <SourceLine>if f&lt;&gt;nil then</SourceLine>
   <SourceLine>if f.exists then</SourceLine>
   <SourceLine>b=BinaryStream.Open(f, true)</SourceLine>
   <SourceLine>prefNumCustomFunctions=b.ReadUInt16</SourceLine>
   <SourceLine>if prefNumCustomFunctions&gt;0 then</SourceLine>
   <SourceLine>for n as integer=1 to prefNumCustomFunctions</SourceLine>
   <SourceLine>prefCustomStatFunctions.append b.ReadPString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//doesn't exist, so we need to create it or something</SourceLine>
   <SourceLine>prefNumCustomFunctions=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>b.close</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//file doesn't exist, so let's create the default</SourceLine>
   <SourceLine>#if TargetWin32 then</SourceLine>
   <SourceLine>IconstoRegistry</SourceLine>
   <SourceLine>#endif</SourceLine>
   <SourceLine>CreateDefaultPrefFile</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>LoadTeamArray</SourceLine>
   <SourceLine>LoadBoxPositions</SourceLine>
   <SourceLine>LoadRecentMenuItems</SourceLine>
   <SourceLine>RegisterFileTypes</SourceLine>
   <SourceLine>LoadRecentMenuItems</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
