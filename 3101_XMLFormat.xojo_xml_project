 <Method>
  <ItemName>LoadRecruitingHistoryOverview</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1432518655</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadRecruitingHistoryOverview()</SourceLine>
   <SourceLine>dim rs, rec, alphaset as RecordSet</SourceLine>
   <SourceLine>dim w,l, sn as integer</SourceLine>
   <SourceLine>dim rating, maxrating as string</SourceLine>
   <SourceLine>dim list as cShadedListbox</SourceLine>
   <SourceLine>list=lbRecruitOverview</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>list.LoadHeader(split("Sn,Rank,Total,High,+/-,HW,SH,W,L",","))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>list.DeleteAllRows</SourceLine>
   <SourceLine>alphaset=db.SQLSelect("SELECT Distinct Season FROM Recruits ORDER BY Season DESC")</SourceLine>
   <SourceLine>dim iCounter as integer=alphaset.RecordCount</SourceLine>
   <SourceLine>For y as integer=1 to iCounter</SourceLine>
   <SourceLine>sn=alphaset.IdxField(1).Value</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Season, Sum(MyRatingPct), Max(MyRatingPct),  sum(atts), avg(hw), avg(sh), sum(PlayerPlusMinus), max(PlayerPlusMinus) FROM Recruits WHERE Season='"+str(sn)+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>for x as integer =1 to rs.RecordCount</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.idxfield(7).stringvalue&lt;&gt;"" then</SourceLine>
   <SourceLine>rating=format(rs.idxfield(7).DoubleValue, "+#0.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>rating=format((rs.idxField(2).DoubleValue-3), "+#0.0%")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.idxfield(8).stringvalue&lt;&gt;"" then</SourceLine>
   <SourceLine>maxrating=format(rs.idxfield(8).DoubleValue, "+#0.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>maxrating=format((rs.idxfield(3).DoubleValue-1),"+#0.0%")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rank as double</SourceLine>
   <SourceLine>rank=rankcalc(rs.idxfield(2).DoubleValue, rs.idxfield(3).DoubleValue, rs.idxfield(4).IntegerValue, rs.idxfield(5).IntegerValue, rs.idxfield(6).IntegerValue)</SourceLine>
   <SourceLine>list.addrow str(sn), format(rank, "0.0"), rating, maxrating, format(rs.idxfield(4).IntegerValue,"+0"), format(rs.idxfield(5).integervalue, "###"), format(rs.idxfield(6).integerValue, "###")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rec=db.SQLSelect("Select Count(*) as Result FROM TeamHistory WHERE WL LIKE 'W' AND (Season-'"+str(sn)+"'&gt;0) AND (Season-'"+str(sn)+"'&lt;=4) AND Game&lt;=24")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 THEN</SourceLine>
   <SourceLine>w=rec.field("Result").IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>w=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rec=db.SQLSelect("Select Count(*) as Result FROM TeamHistory WHERE WL LIKE 'L' AND (Season-'"+str(sn)+"'&gt;0) AND (Season-'"+str(sn)+"'&lt;=4) AND Game&lt;=24")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 THEN</SourceLine>
   <SourceLine>l=rec.field("Result").IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>l=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>list.cell(list.LastIndex,7)=str(w)</SourceLine>
   <SourceLine>list.cell(list.LastIndex,8)=str(l)</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>alphaset.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
