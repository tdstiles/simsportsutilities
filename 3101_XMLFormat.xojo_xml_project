  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadConfTeams() As integer()</SourceLine>
   <SourceLine>//This method returns an array of the teams in our conference</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iMin, iMax as integer</SourceLine>
   <SourceLine>dim rTeams(-1) as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iMin=((val(prefconference)-1)*8)+1</SourceLine>
   <SourceLine>iMax=iMin+7</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=iMin to iMax</SourceLine>
   <SourceLine>rTeams.append n</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return rTeams</SourceLine>
   <SourceLine>End Function</SourceLine>
