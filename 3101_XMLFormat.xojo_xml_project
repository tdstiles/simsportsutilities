   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if export(0).Value then</SourceLine>
   <SourceLine>//clear old data to prevent duplicates</SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM TeamHistory WHERE Game='"+str(GameToImport.Game)+"' AND Season='"+str(GametoImport.Season)+"'")</SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM Stats WHERE Game='"+str(GameToImport.Game)+"' AND Season='"+str(GametoImport.Season)+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//finished with game, so time to import this on in</SourceLine>
   <SourceLine>//import into SSC</SourceLine>
   <SourceLine>ExportStatstoSSC</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update w/l and scores</SourceLine>
   <SourceLine>//put in game w/l</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select Sum(Pts), Sum(aPts) FROM Stats WHERE Season='"+str(GametoImport.Season)+"' AND Game='"+str(GameToImport.Game)+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>//determine our score, their score, w/</SourceLine>
   <SourceLine>us=rs.IdxField(1).Value</SourceLine>
   <SourceLine>them=rs.IdxField(2).value</SourceLine>
   <SourceLine>If us&gt;them then</SourceLine>
   <SourceLine>wlo="W"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>wlo="L"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//continue with process</SourceLine>
   <SourceLine>dim r as new DatabaseRecord</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load stats into TeamHistory, then update player stats</SourceLine>
   <SourceLine>r.Column("Type")=GametoImport.Type</SourceLine>
   <SourceLine>r.IntegerColumn("Game")=GameToImport.Game</SourceLine>
   <SourceLine>r.IntegerColumn("Season")=GametoImport.Season</SourceLine>
   <SourceLine>if export(1).value=true then</SourceLine>
   <SourceLine>//save as featuredgame</SourceLine>
   <SourceLine>r.column("Featured")="Y"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.InsertRecord("TeamHistory",r)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE TeamHistory SET OurScore='"+rs.idxfield(1).stringvalue+"', Opponent='"+gTeams(GameToImport.iTeams(iOpponentTeam-1).TeamNumber-1)+"', WL='"+wlo+"', OppScore='"+rs.idxfield(2).stringvalue+"' WHERE Season='"+str(GametoImport.Season)+"' AND Game='"+str(GameToImport.Game)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now export text file</SourceLine>
   <SourceLine>ExportToText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and the HTML file</SourceLine>
   <SourceLine>ExporttoHTML</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>SeasonCheck</SourceLine>
   <SourceLine>End Sub</SourceLine>
