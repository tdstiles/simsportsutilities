   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadPR() As integer()</SourceLine>
   <SourceLine>dim sockHTTP as new HTTPSocket</SourceLine>
   <SourceLine>dim tmpString as string</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/weekly/lg000"+right("0"+prefleague,2)+"/rank.html"</SourceLine>
   <SourceLine>tmpString=sockHTTP.Get(theurl, 30)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if tmpString &lt;&gt; "" then</SourceLine>
   <SourceLine>tmpString=CleanHTML(tmpString)</SourceLine>
   <SourceLine>ReadfromTextFile(tmpString)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>MsgBox "Error downloading.  Please check your internet connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return rTeams</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
