  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>RankCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1661722623</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function RankCalc(total as double, highest as double, plusminus as integer, mag1 as integer, mag2 as integer) As double</SourceLine>
   <SourceLine>return (3*(((total-3)*100)/70)+(((highest-1)*100)/50)+2*(plusminus/15)+2*((256-mag1)/256)+2*((256-mag2)/256))</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
