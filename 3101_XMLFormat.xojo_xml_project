  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function FileExportPlayerInfo() As Boolean</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Distinct(Name) FROM Stats WHERE Season='"+prefCurrentSeason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>sbstring.append CreatePlayerExportText(rs.IdxField(1).StringValue, prefCurrentSeason)</SourceLine>
   <SourceLine>sbstring.Append EndOfLine+EndOfLine</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim c as new Clipboard</SourceLine>
   <SourceLine>c.text=sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>msgbox "Copied to Clipboard"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return True</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
