 <Method>
  <ItemName>SortNames</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>551720959</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function SortNames() As string(,)</SourceLine>
   <SourceLine>//this method goes through the svdb and returns a string array with the sorted team names</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim startofname, restofname as string</SourceLine>
   <SourceLine>dim wholename as string</SourceLine>
   <SourceLine>dim namelength as Integer</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim SortedNames(1,11) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 2</SourceLine>
   <SourceLine>//load adjusted names (CornwellM)</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Name FROM SVTable WHERE TeamNum='"+str(n)+"'")</SourceLine>
   <SourceLine>for j as integer=1 to 12</SourceLine>
   <SourceLine>wholename=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>Startofname=left(wholename,2)</SourceLine>
   <SourceLine>restofname=mid(wholename,3)</SourceLine>
   <SourceLine>SortedNames(n-1,j-1)=restofname+startofname</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>dim sorts(-1) as string</SourceLine>
   <SourceLine>for j as integer=0 to 11</SourceLine>
   <SourceLine>sorts.append SortedNames(n,j)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sorts.Sort</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now load back up</SourceLine>
   <SourceLine>for j as integer=0 to 11</SourceLine>
   <SourceLine>SortedNames(n,j)=sorts(j)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>for j as integer=0 to 11</SourceLine>
   <SourceLine>wholename=SortedNames(n,j)</SourceLine>
   <SourceLine>startofname=right(wholename,2)</SourceLine>
   <SourceLine>namelength=len(wholename)</SourceLine>
   <SourceLine>restofname=left(wholename,namelength-2)</SourceLine>
   <SourceLine>SortedNames(n,j)=startofname+restofname</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return SortedNames</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string(,)</ItemResult>
 </Method>
 <Method>
  <ItemName>Substitute</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>913672191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Substitute()</SourceLine>
   <SourceLine>dim pos, name, backuppos as string</SourceLine>
   <SourceLine>dim prevplusminus, newplusminus as integer</SourceLine>
   <SourceLine>dim positions(4),j as string</SourceLine>
   <SourceLine>dim firstplayerstats(2) as string</SourceLine>
   <SourceLine>dim subsspot as integer</SourceLine>
   <SourceLine>dim rs, rec as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Name, InitialPos, rowID, pos FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(0).Number)+"'"</SourceLine>
   <SourceLine>rec=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>backuppos=rec.IdxField(4).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//switch positions</SourceLine>
   <SourceLine>sqlstring="SELECT Name, InitialPos, rowID, pos FROM SVTable WHERE TeamNum='"+str(iAction.Player(2).Team)+"' AND PlayerNum='"+str(iAction.Player(2).Number)+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>pos=rs.IdxField(4).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set initial position in memory</SourceLine>
   <SourceLine>if rs.idxfield(2).stringvalue="0" then</SourceLine>
   <SourceLine>svdb.SQLExecute("Update SVTable SET InitialPos='"+pos+"'  WHERE rowID='"+rs.IdxField(3).StringValue+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Update SVTable SET Pos="+backuppos+"  WHERE rowID='"+rs.IdxField(3).StringValue+"'"</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim myspot as string</SourceLine>
   <SourceLine>myspot=rec.IdxField(2).StringValue</SourceLine>
   <SourceLine>if myspot&lt;&gt;"1" and myspot&lt;&gt;"2" and myspot&lt;&gt;"3" and myspot&lt;&gt;"4" and myspot&lt;&gt;"5" then //not a starter</SourceLine>
   <SourceLine>subsspot=instr(str(myspot),"b")</SourceLine>
   <SourceLine>if subsspot=0 then</SourceLine>
   <SourceLine>//started the game as a sub</SourceLine>
   <SourceLine>svdb.SQLExecute("Update SVTable SET InitialPos='b"+pos+"' WHERE rowID='"+rec.IdxField(3).StringValue+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Update SVTable SET Pos='"+pos+"'  WHERE rowID="+rec.IdxField(3).StringValue</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//count time for sub out</SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT SecondsPlayed, SecondsWhenEntering, rowID FROM SVTable WHERE TeamNum='"+str(iAction.Player(2).Team)+"' AND PlayerNum='"+str(iAction.Player(2).Number)+"'")</SourceLine>
   <SourceLine>sqlstring="Update SVTable SET SecondsPlayed='"+str(rs.idxfield(1).integervalue+iAction.Time-rs.idxfield(2).integervalue)+"', SecondsWhenEntering=0 WHERE rowID="+rs.IdxField(3).StringValue</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set time for sub in</SourceLine>
   <SourceLine>sqlstring="SELECT Name, rowID FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(0).Number)+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLselect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="Update SVTable SET SecondsWhenEntering='"+str(iAction.Time)+"' WHERE rowID="+rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>pos=str(val(pos)-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//change the listbox on the wndStatViewer</SourceLine>
   <SourceLine>wndS.SwitchPlayerPositions(val(pos), val(backuppos), val(iAction.Player(0).Team))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get +/- when entering/leaving</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Pts) FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"'"  //team points for entering</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="SELECT "+format(rs.IdxField(1).integerValue,"##0")+"-Sum(Pts) FROM SVTable WHERE TeamNum&lt;&gt;'"+str(iAction.Player(0).Team)+"'"   //+/- pt differential</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>dim nPtsDifferentialTmp as integer</SourceLine>
   <SourceLine>nPtsDifferentialTmp=rs.IdxField(1).integerValue // +/-pt differential at this point in the game</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//for the guy leaving</SourceLine>
   <SourceLine>sqlstring="SELECT PlusMinusWhenEntering, rowID FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(2).Number)+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>dim nLeavingPlayerPtsDifferentialTmp as integer</SourceLine>
   <SourceLine>nLeavingPlayerPtsDifferentialTmp=nPtsDifferentialTmp-rs.IdxField(1).IntegerValue  //how much points have changed since he has been in the game</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT PlusMinus, rowID FROM SVTable WHERE rowID='"+rs.IdxField(2).StringValue+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>nLeavingPlayerPtsDifferentialTmp=rs.IdxField(1).IntegerValue+nLeavingPlayerPtsDifferentialTmp</SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET PlusMinus='"+str(nLeavingPlayerPtsDifferentialTmp)+"', PlusMinusWhenEntering='0' WHERE rowID='"+rs.idxfield(2).stringvalue+"'" //corrected points</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE SVTable SET PlusMinusWhenEntering='"+str(nPtsDifferentialTmp)+"' WHERE  TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(0).Number)+"'"</SourceLine>
   <SourceLine>svdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
