 </Method>
 <Method>
  <ItemName>methPullStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1402771455</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub methPullStats(Name as string, clause as string, listname as string)</SourceLine>
   <SourceLine>//this method is passed the player name and sqlstring, then populates the lbPlayerStats listbox</SourceLine>
   <SourceLine>dim a,b,c,d,e as double</SourceLine>
   <SourceLine>dim divisor as integer</SourceLine>
   <SourceLine>dim formater as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim games, minutes, possessions as integer</SourceLine>
   <SourceLine>dim TmpMins as String</SourceLine>
   <SourceLine>dim p as cPlayerOverview</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if name&lt;&gt;"Team" then</SourceLine>
   <SourceLine>sqlstring="Select Count(*) as Games, Sum(Mins) as Mins, Sum(FGM) as FGM, Sum(FGA) as FGA, Sum(FG3M) as FG3M, Sum(FG3A) as FG3A,  Sum(FTM) as FTM, Sum(FTA) as FTA, Sum(Reb) as Reb, Sum(Blk) as Blk, Sum(Stl) as Stl, Sum(Ast) as Ast, Sum(Fouls) as Fouls, Sum(Pts) as Pts, Sum(TOs) as TOs, Sum(shrtM) as shrtM, Sum(shrtA) as shrtA, Sum(midM) as midM, Sum(midA) as MidA, Sum(longM) as longM, Sum(longA) as LongA, Sum(aFGM) as aFGM, Sum(aFGA) as aFGA, Sum(aF3M) as aF3M, Sum(aF3A) as aF3A, Sum(aPts) as aPts, Sum(FD) as FD, Sum(Touch) as Touch, Sum(Ar) as Ar, Sum(shblkd) as shblkd, sum(PlusMinus) as PlusMinus, Sum(Oreb) as OReb, Sum(DReb) as DReb, Sum(aOReb) as aOReb, Sum(aDReb) as aDReb, Sum(aTReb) as aTReb, Sum(LostD) as LostD, Sum(LostP) as LostP, sum(crTO) as crTO, Sum(PUs) as PUs, Sum(TP) as TP, Name FROM STATS " + clause+" AND Name='"+name+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>p=new cPlayerOverview(rs)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else //pulling for team</SourceLine>
   <SourceLine>sqlstring="Select (SELECT Distinct(Count(Game)) FROM TeamHistory "+clause+") as Games, Sum(Mins) as Mins, Sum(FGM) as FGM, Sum(FGA) as FGA, Sum(FG3M) as FG3M, Sum(FG3A) as FG3A,  Sum(FTM) as FTM, Sum(FTA) as FTA, Sum(Reb) as Reb, Sum(Blk) as Blk, Sum(Stl) as Stl, Sum(Ast) as Ast, Sum(Fouls) as Fouls, Sum(Pts) as Pts, Sum(TOs) as TOs, Sum(shrtM) as shrtM, Sum(shrtA) as shrtA, Sum(midM) as midM, Sum(midA) as MidA, Sum(longM) as longM, Sum(longA) as LongA, Sum(aFGM) as aFGM, Sum(aFGA) as aFGA, Sum(aF3M) as aF3M, Sum(aF3A) as aF3A, Sum(aPts) as aPts, Sum(FD) as FD, Sum(Touch) as Touch, Sum(Ar) as Ar, Sum(shblkd) as shblkd, sum(PlusMinus) as PlusMinus, Sum(Oreb) as OReb, Sum(DReb) as DReb, Sum(aOReb) as aOReb, Sum(aDReb) as aDReb, Sum(aTReb) as aTReb, Sum(LostD) as LostD, Sum(LostP) as LostP, sum(crTO) as crTO, Sum(PUs) as PUs, Sum(TP) as TP, Name FROM STATS " + clause</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>p=new cPlayerOverview(rs)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If Selection=0 THEN //total</SourceLine>
   <SourceLine>p.divisor=1</SourceLine>
   <SourceLine>p.formater="###"</SourceLine>
   <SourceLine>elseif selection=1 then //per game</SourceLine>
   <SourceLine>p.divisor=p.games</SourceLine>
   <SourceLine>p.formater="0.0"</SourceLine>
   <SourceLine>elseif Selection=2 then //per 30 mins</SourceLine>
   <SourceLine>if Name="Team" then</SourceLine>
   <SourceLine>p.divisor=p.minutes/150</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>p.divisor=p.minutes/30</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>p.formater="0.0"</SourceLine>
   <SourceLine>else //per possession</SourceLine>
   <SourceLine>p.divisor=p.Possessions</SourceLine>
   <SourceLine>p.formater="0.000"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case listname</SourceLine>
   <SourceLine>case "Box Score"</SourceLine>
   <SourceLine>//deal with making sure minutes doesn't get messed up with selection of per 30 min stats</SourceLine>
   <SourceLine>if selection=2 then</SourceLine>
   <SourceLine>tmpMins="30"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>tmpMins= format(divchk(p.Minutes,p.divisor),p.formater)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lbPlayerStats.AddRow Name, str(p.Games),tmpMins, p.stat("FGM"), p.stat("FGA"), p.FGPCT, p.stat("FG3M"), p.stat("FG3A"), p.fg3pct, p.stat("FTM"), p.stat("FTA"), p.ftpct, p.stat("Reb"), p.stat("Ast"),p.stat("Blk"), p.stat("Stl"), p.stat("TOs"), p.stat("Fouls"), p.stat("Pts")</SourceLine>
   <SourceLine>case "Shooting"</SourceLine>
   <SourceLine>lbPlayerStats.AddRow Name, p.stat("shrtM"), p.stat("shrtA"),p.shrtPct, p.stat("midM"),p.stat("MidA"), p.midpct, p.stat("LongM"), p.stat("LongA"), p.longPct, p.TSP</SourceLine>
   <SourceLine>case "Efficiency"</SourceLine>
   <SourceLine>lbPlayerStats.AddRow Name, p.stat("FD"), format(DivChk(p.touch,p.fd),"#0.0"), format(DivChk(p.fta,p.fd),"#0.0"), p.stat("AR"), format(DivChk(p.ar,p.fgm),"#0.00"), p.stat("shblkd"), format(DivChk(p.shblkd, p.fga), "#0.0%"), format(DivChk(p.Touch,p.tos),"#0.0"), format(DivChk(p.Ast, p.tos),"0.0"),format(divchk(p.fga, p.possessions),"#0.0%")</SourceLine>
   <SourceLine>case "Ball Control"</SourceLine>
   <SourceLine>lbPlayerStats.AddRow Name, p.stat("OReb"), p.stat("Dreb"), p.stat("aOreb"), p.stat("aDReb"), p.stat("aTReb"), p.rebpct, p.stat("lostP"), p.stat("lostD"), p.stat("PUs"), p.stat("Touch") </SourceLine>
   <SourceLine>case "Defense"</SourceLine>
   <SourceLine>lbPlayerStats.addrow Name, p.stat("aFGM"), p.stat("aFGA"), p.afgpct, p.stat("aF3M"), p.stat("aF3A"), p.af3pct, p.stat("blk"), p.stat("Stl"), p.stat("crTO"), p.stat("aPts")</SourceLine>
   <SourceLine>case "Analysis"</SourceLine>
   <SourceLine>lbPlayerStats.addrow Name,format(p.OffensiveEfficiency, "#0.00"), format(p.DefensiveEfficiency, "#0.00"), format(p.OffensiveEfficiency-p.DefensiveEfficiency, "+#0.00"), p.Tendex, p.SecondaryTendex, p.sPlusMinus, p.SVx, p.Effectiveness, p.NBS, p.WinScore, p.GS</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Name as string, clause as string, listname as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
