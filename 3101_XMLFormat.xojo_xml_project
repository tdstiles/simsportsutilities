   <SourceLine>list.LoadHeader(split("Name,Pos,Min,aFGM,aFGA,aPts,crTO,PUs,OReb,DReb,aTReb,+/-",","))</SourceLine>
   <SourceLine>list.ColumnWidths = "100,*"</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, APosition, Mins, aFGM, aFGA, aPts, crTO, PUs, OReb, DReb, aTReb, PlusMinus "+TmpClause)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to rs.RecordCount</SourceLine>
   <SourceLine>rownum=BoxPositions.IndexOf(rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine>for j as integer=0 to 10</SourceLine>
   <SourceLine>list.cell(rownum, j)=rs.IdxField(j+1).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>list.cell(rownum, 11)=format(rs.IdxField(12).IntegerValue, "+#0")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(Mins), Sum(aFGM), Sum(aFGA), Sum(aPts), Sum(crTO),  Sum(PUs), Sum(OReb), Sum(DReb), Sum(aTReb), Sum(plusminus) "+TmpClause)</SourceLine>
