 <Method>
  <ItemName>UpdateTeamScores</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1006524415</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdateTeamScores(myAction as cAction)</SourceLine>
   <SourceLine>//this method adds to the team1 and Team2Scores arrays</SourceLine>
   <SourceLine>//it takes the action, pulls out the score for each team and the time</SourceLine>
   <SourceLine>//for every second between this and the previous time, we repeat the last element</SourceLine>
   <SourceLine>//then add on the new one</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCurrentTime as integer=myaction.Time</SourceLine>
   <SourceLine>dim iPreviousTime as integer=UBound(Team1Scores)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iPreviousTime&gt;-1 then</SourceLine>
   <SourceLine>dim iDifference as integer=iCurrentTime-iPreviousTime</SourceLine>
   <SourceLine>dim iCurrentTeam1 as double=Team1Scores(iPreviousTime)</SourceLine>
   <SourceLine>dim iCurrentTeam2 as double=Team2Scores(iPreviousTime)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to iDifference</SourceLine>
   <SourceLine>Team1Scores.append iCurrentTeam1</SourceLine>
   <SourceLine>Team2Scores.append iCurrentTeam2</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//okay, now we add in the new data</SourceLine>
   <SourceLine>Team1Scores.append myaction.Scores(0)</SourceLine>
   <SourceLine>Team2Scores.append myAction.Scores(1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Team1Scores.append(0)</SourceLine>
   <SourceLine>Team2Scores.append(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>1</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>myAction as cAction</ItemParams>
  <ItemResult></ItemResult>
 </Method>
