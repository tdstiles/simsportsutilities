 <Method>
  <ItemName>NormalizeSet</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1490966527</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function NormalizeSet(Variances() as double, BaseLine as double, StandardDeviation as double) As double()</SourceLine>
   <SourceLine>dim iCounter as double</SourceLine>
   <SourceLine>dim iMax as integer=ubound(variances)</SourceLine>
   <SourceLine>for r as integer=0 to iMax</SourceLine>
   <SourceLine>iCounter=iCounter+variances(r)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim mean as double</SourceLine>
   <SourceLine>mean=iCounter/(iMax+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now for the StD</SourceLine>
   <SourceLine>//Std=SQRT(1/N*Value1-Mean^2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>icounter=0</SourceLine>
   <SourceLine>for r as integer=0 to iMax</SourceLine>
   <SourceLine>iCounter=iCounter+(variances(r)-mean)^2</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iCounter=iCounter/(iMax+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim StD as double</SourceLine>
   <SourceLine>StD=SQRT(ICounter)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now go back through the initial set and set the new, normalized values</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>variances(n)=BaseLine+((Variances(n)-mean)/std)*StandardDeviation</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return variances</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Variances() as double, BaseLine as double, StandardDeviation as double</ItemParams>
  <ItemResult>double()</ItemResult>
 </Method>
