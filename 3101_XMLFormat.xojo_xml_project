   <Visible>1</Visible>
   <PartID>840914943</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Change()</SourceLine>
    <SourceLine>if me.Value=2 then</SourceLine>
    <SourceLine>//load up scrimmage window</SourceLine>
    <SourceLine>dim rs as recordset</SourceLine>
    <SourceLine>dim recruits(767) as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Name FROM PlayerInfo")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>for x as integer=0 to 767</SourceLine>
    <SourceLine>recruits(x)=rs.field("Name").StringValue</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>Recruits.sort</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for x as integer=0 to 767</SourceLine>
    <SourceLine>popPlayerNames.AddRow recruits(x)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>elseif me.value=3 then</SourceLine>
    <SourceLine>//data</SourceLine>
    <SourceLine>dim statsarray() as double</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>dim profile() as double</SourceLine>
    <SourceLine>lbData.LoadHeader(split("Percentile,+/-", ","))</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=db.SQLSelect("Select PlayerPlusMinus FROM PlayerInfo")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>dim iCounter as integer=rs.RecordCount</SourceLine>
    <SourceLine>for x as integer=1 to iCounter</SourceLine>
    <SourceLine>profile.Append rs.IdxField(1).Value</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>statsarray=DecileCalc(profile)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim list as listbox</SourceLine>
    <SourceLine>list=lbData</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>list.deleteallrows</SourceLine>
    <SourceLine>list.addrow "Min"</SourceLine>
    <SourceLine>list.AddRow "10th"</SourceLine>
    <SourceLine>list.AddRow "20th"</SourceLine>
    <SourceLine>list.AddRow "30th"</SourceLine>
    <SourceLine>list.AddRow "40th"</SourceLine>
    <SourceLine>list.AddRow "50th"</SourceLine>
    <SourceLine>list.AddRow "60th"</SourceLine>
    <SourceLine>list.AddRow "70th"</SourceLine>
    <SourceLine>list.AddRow "80th"</SourceLine>
    <SourceLine>list.AddRow "90th"</SourceLine>
    <SourceLine>list.AddRow "99th"</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for x as integer=0 to 10</SourceLine>
    <SourceLine>list.cell(x, 1)=format(statsarray(x),"+#0.0")</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>elseif me.Value=4 then</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>dim w,l,lw, ll as string</SourceLine>
    <SourceLine>dim k,length as integer</SourceLine>
    <SourceLine>dim naming as string</SourceLine>
    <SourceLine>dim list as listbox</SourceLine>
    <SourceLine>list=lbHSInfo</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>list.LoadHeader(split("Name,Reg,WL,LstWL,SHT,DEF,HND,REB,ATH,Rtg", ","))</SourceLine>
    <SourceLine>list.ColumnWidths="2.13*,*,*,*,*,*"</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT HSName, Region, ThisWL, LastWL, HSSHT, HSDEF, HSHND, HSREB, HSATH, PowerRanking FROM HSInfo")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>while rs.eof=false</SourceLine>
    <SourceLine>list.addrow rs.IdxField(1).StringValue, str(rs.IdxField(2).integerValue), rs.idxfield(3).stringvalue, rs.idxfield(4).stringvalue, rs.IdxField(5).StringValue, rs.IdxField(6).StringValue, rs.IdxField(7).StringValue, rs.IdxField(8).StringValue, rs.IdxField(9).StringValue, format(rs.IdxField(10).DoubleValue,"###.0")</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>elseif me.value=5 then</SourceLine>
    <SourceLine>//estimated ties</SourceLine>
    <SourceLine>dim list as listbox</SourceLine>
    <SourceLine>list=lbEstimatedTies</SourceLine>
    <SourceLine>list.columncount = 2</SourceLine>
    <SourceLine>list.hasheading = TRUE</SourceLine>
    <SourceLine>list.heading(0) = "Team"</SourceLine>
    <SourceLine>list.heading(1) = "Chance"</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim iMax as integer</SourceLine>
    <SourceLine>iMax=ubound(vrgTiedTeamsTotal)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for cTmp as integer=0 to iMax</SourceLine>
    <SourceLine>list.addrow gTeams(vrgTiedTeamsTotal(cTmp).TeamNum-1), format(vrgTiedTeamsTotal(cTmp).ChanceRaw, "##0.0%")</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
