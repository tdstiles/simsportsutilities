  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>672620543</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>//this method checks to see if the timer is currently running. </SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if startorpause.caption="Start" then</SourceLine>
    <SourceLine>startorpause.caption="Pause"</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//we deal with some things before we can get started viewing this</SourceLine>
    <SourceLine>//first, reverse the order of PBPLines</SourceLine>
    <SourceLine>dim rTmp(-1) as string</SourceLine>
    <SourceLine>while UBound(PBPLines)&gt;-1</SourceLine>
    <SourceLine>rTmp.Append PBPLines.Pop</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>redim PBPLines(-1)</SourceLine>
    <SourceLine>for n as integer=0 to (UBound(rTmp)-26)</SourceLine>
    <SourceLine>PBPLines.Append rTmp(n)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if fWatchPBP then</SourceLine>
    <SourceLine>//set up the box score window</SourceLine>
    <SourceLine>//number of lines to show before we flash the next box score</SourceLine>
    <SourceLine>BoxScores.SetMax(UBound(PBPLines))</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if iBoxScore&gt;0 and  BoxScoreViewerLoaded then</SourceLine>
    <SourceLine>BoxScores.UpdateScores</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now we can fire off</SourceLine>
    <SourceLine>fRunning=1</SourceLine>
    <SourceLine>MainTimer.Enabled=true</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>elseif startorpause.caption="Pause" then</SourceLine>
    <SourceLine>startorpause.caption="Resume"</SourceLine>
    <SourceLine>fRunning=2</SourceLine>
    <SourceLine>MainTimer.Enabled=false</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>startorpause.caption="Pause"</SourceLine>
    <SourceLine>fRunning=1</SourceLine>
    <SourceLine>MainTimer.Enabled=true</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
 </ControlBehavior>
