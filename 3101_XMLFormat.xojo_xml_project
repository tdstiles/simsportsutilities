 <Method>
  <ItemName>DetermineAction</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1987868671</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub DetermineAction()</SourceLine>
   <SourceLine>dim d, p as string</SourceLine>
   <SourceLine>d="D"</SourceLine>
   <SourceLine>p="P"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iAction.Action=1 then</SourceLine>
   <SourceLine>//(P1) tips to (P2)</SourceLine>
   <SourceLine>TP("A")</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" tips to "+iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=2 then</SourceLine>
   <SourceLine>//, (P1) inbounds to (P2)</SourceLine>
   <SourceLine>TP("A")</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " inbounds to "+iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=3 then</SourceLine>
   <SourceLine>//, (P1) calls timeout trying to inbound</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" calls timeout trying to inbound"</SourceLine>
   <SourceLine>elseif iAction.Action=4 then</SourceLine>
   <SourceLine>//, (P1) throws inbound pass away</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " throws the inbound pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=5 then</SourceLine>
   <SourceLine>//, (P1) cannot inbound - 5 sec. violation</SourceLine>
   <SourceLine>Turnover("O",False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" cannot inbound--5 second violation"</SourceLine>
   <SourceLine>elseif iAction.Action=6 then</SourceLine>
   <SourceLine>//, (P1) has inbound pass stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(P, True)</SourceLine>
   <SourceLine>elseif iAction.Action=7 then</SourceLine>
   <SourceLine>//, Shot clock violation</SourceLine>
   <SourceLine>ResultText.append "Shot clock violation"</SourceLine>
   <SourceLine>elseif iAction.Action=8 then</SourceLine>
   <SourceLine>//, (P1) passes to (P2)</SourceLine>
   <SourceLine>passes</SourceLine>
   <SourceLine>elseif iAction.Action=9 then</SourceLine>
   <SourceLine>//, (P1) has ball stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(D, True)</SourceLine>
   <SourceLine>elseif iAction.Action=10 then</SourceLine>
   <SourceLine>//, (P1) throws the pass away</SourceLine>
   <SourceLine>Turnover(P,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " throws the pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=11 then</SourceLine>
   <SourceLine>//, (P1) travels</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ "  travels"</SourceLine>
   <SourceLine>elseif iAction.Action=12 then</SourceLine>
   <SourceLine>//, (P1) loses the ball out of bounds</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " loses the ball out of bounds"</SourceLine>
   <SourceLine>elseif iAction.Action=13 then</SourceLine>
   <SourceLine>//, (P1) double dribbles</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ "  double dribbles"</SourceLine>
   <SourceLine>elseif iAction.Action=14 then</SourceLine>
   <SourceLine>//, (P1) is called for over-and-back</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ "  is called for over-and-back"</SourceLine>
   <SourceLine>elseif iAction.Action=15 then</SourceLine>
   <SourceLine>//, (P1) called for 5 sec. violation - closely guarded</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " called for 5 second violation--closely guarded"</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>elseif iAction.Action=16 then</SourceLine>
   <SourceLine>//, (P1) hits a deep 2-point field goal (A?)</SourceLine>
   <SourceLine>FG(2,True)</SourceLine>
   <SourceLine>elseif iAction.Action=17 then</SourceLine>
   <SourceLine>//, (P1) misses a deep 2-point field goal</SourceLine>
   <SourceLine>FG(2,False)</SourceLine>
   <SourceLine>elseif iAction.Action=18 then</SourceLine>
   <SourceLine>//, (P1) hits a 3-point field goal (A?)</SourceLine>
   <SourceLine>FG(3,True)</SourceLine>
   <SourceLine>elseif iAction.Action=19 then</SourceLine>
   <SourceLine>//, (P1) misses a 3-point field goal</SourceLine>
   <SourceLine>FG(3,False)</SourceLine>
   <SourceLine>elseif iAction.Action=20 then</SourceLine>
   <SourceLine>//, (P1) hits a free throw</SourceLine>
   <SourceLine>FT(true)</SourceLine>
   <SourceLine>elseif iAction.Action=21 then</SourceLine>
   <SourceLine>//, (P1) misses a free throw</SourceLine>
   <SourceLine>FT(false)</SourceLine>
   <SourceLine>elseif iAction.Action=22 then</SourceLine>
   <SourceLine>//, (P1) grabs the rebound</SourceLine>
   <SourceLine>Rebound</SourceLine>
   <SourceLine>elseif iAction.Action=23 then</SourceLine>
   <SourceLine>//, (P1) dunks the ball (A?)</SourceLine>
   <SourceLine>FG(0,True, "dunk")</SourceLine>
   <SourceLine>elseif iAction.Action=24 then</SourceLine>
   <SourceLine>//, (P1) lays the ball in (A?)</SourceLine>
   <SourceLine>FG(0,True, "layup")</SourceLine>
   <SourceLine>elseif iAction.Action=25 then</SourceLine>
   <SourceLine>//, (P1) misses a dunk</SourceLine>
   <SourceLine>FG(0,False, "dunk")</SourceLine>
   <SourceLine>elseif iAction.Action=26 then</SourceLine>
   <SourceLine>//, (P1) misses a layup</SourceLine>
   <SourceLine>FG(0,False, "layup")</SourceLine>
   <SourceLine>elseif iAction.Action=27 then</SourceLine>
   <SourceLine>//, (P1) dribbles</SourceLine>
   <SourceLine>dribbles(false)</SourceLine>
   <SourceLine>elseif iAction.Action=28 then</SourceLine>
   <SourceLine>//, (P1) has 2-point field goal blocked by (P2-opp)</SourceLine>
   <SourceLine>FG(1,False, "block")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif iAction.Action=29 then</SourceLine>
   <SourceLine>//, (P1) has 3-point field goal blocked by (P2-opp)</SourceLine>
   <SourceLine>FG(3,False, "block")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif iAction.Action=30 then</SourceLine>
   <SourceLine>//, (P1) picks up the loose ball</SourceLine>
   <SourceLine>PUs</SourceLine>
   <SourceLine>elseif iAction.Action=31 then</SourceLine>
   <SourceLine>//, (P1) fouled by (P2-opp)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" is fouled by "+iAction.Player(1).Name</SourceLine>
   <SourceLine>foul(false)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif iAction.Action=32 then</SourceLine>
   <SourceLine>//, (P1) fouls out</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " fouls out"</SourceLine>
   <SourceLine>elseif iAction.Action=33 then</SourceLine>
   <SourceLine>//, (P1) substitutes for (P2)</SourceLine>
   <SourceLine>Substitute</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" substitutes for "+iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=34 then</SourceLine>
   <SourceLine>//, (P1) shoots a long-range airball</SourceLine>
   <SourceLine>FG(2,False)</SourceLine>
   <SourceLine>elseif iAction.Action=35 then</SourceLine>
   <SourceLine>//, (P1) called for offensive foul against (P2-opp)</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" is called for an offensive foul against "+iAction.Player(1).Name</SourceLine>
   <SourceLine>Foul(True)</SourceLine>
   <SourceLine>elseif iAction.Action=36 then</SourceLine>
   <SourceLine>//, ---reserved---</SourceLine>
   <SourceLine>elseif iAction.Action=37 then</SourceLine>
   <SourceLine>//, (P1) hits a midrange 2-pt field goal (A?)</SourceLine>
   <SourceLine>FG(1,True)</SourceLine>
   <SourceLine>elseif iAction.Action=38 then</SourceLine>
   <SourceLine>//, (P1) dribbles all the way upcourt</SourceLine>
   <SourceLine>dribbles(true)</SourceLine>
   <SourceLine>elseif iAction.Action=39 then</SourceLine>
   <SourceLine>//, ---reserved---</SourceLine>
   <SourceLine>elseif iAction.Action=40 then</SourceLine>
   <SourceLine>//, (P1) shoots an airball from midrange</SourceLine>
   <SourceLine>FG(1,False)</SourceLine>
   <SourceLine>elseif iAction.Action=41 then</SourceLine>
   <SourceLine>//, (P1) misses a midrange 2-pt field goal</SourceLine>
   <SourceLine>FG(1,False)</SourceLine>
   <SourceLine>elseif iAction.Action=42 then</SourceLine>
   <SourceLine>//, (P1) hits a short 2-pt field goal (A?)</SourceLine>
   <SourceLine>FG(0,True)</SourceLine>
   <SourceLine>elseif iAction.Action=43 then</SourceLine>
   <SourceLine>//, (P1) has short 2-pt fg blocked by (P2-opp)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>FG(0,False, "block")</SourceLine>
   <SourceLine>elseif iAction.Action=44 then</SourceLine>
   <SourceLine>//, (P1) misses a short 2-pt field goal</SourceLine>
   <SourceLine>FG(0,False)</SourceLine>
   <SourceLine>elseif iAction.Action=45 then</SourceLine>
   <SourceLine>//, (P1) has ball stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(D, True)</SourceLine>
   <SourceLine>elseif iAction.Action=46 then</SourceLine>
   <SourceLine>//, (P1) passes upcourt to (P2)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" passes upcourt to " +iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=47 then</SourceLine>
   <SourceLine>//, (P1) has upcourt pass stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(P, True)</SourceLine>
   <SourceLine>elseif iAction.Action=48 then</SourceLine>
   <SourceLine>//, (P1) throws the upcourt pass away</SourceLine>
   <SourceLine>Turnover(P,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws the upcourt pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=49 then</SourceLine>
   <SourceLine>//, (P1) passes to (P2)</SourceLine>
   <SourceLine>passes</SourceLine>
   <SourceLine>elseif iAction.Action=50 then</SourceLine>
   <SourceLine>//, (P1) has pass stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(P, True)</SourceLine>
   <SourceLine>elseif iAction.Action=51 then</SourceLine>
   <SourceLine>//, (P1) throws the pass away</SourceLine>
   <SourceLine>Turnover(P,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws the pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=52 then</SourceLine>
   <SourceLine>//, (P1) hits a short 2-pt field goal (A?)</SourceLine>
   <SourceLine>FG(0,True)</SourceLine>
   <SourceLine>elseif iAction.Action=53 then</SourceLine>
   <SourceLine>//, (P1) hits a midrange 2-pt field goal (A?)</SourceLine>
   <SourceLine>FG(1,True)</SourceLine>
   <SourceLine>elseif iAction.Action=54 then</SourceLine>
   <SourceLine>//, (P1) hits a long 2-pt field goal (A?)</SourceLine>
   <SourceLine>FG(2,True)</SourceLine>
   <SourceLine>elseif iAction.Action=55 then</SourceLine>
   <SourceLine>//, (P1) misses a short 2-pt field goal</SourceLine>
   <SourceLine>FG(0,False)</SourceLine>
   <SourceLine>elseif iAction.Action=56 then</SourceLine>
   <SourceLine>//, (P1) misses a midrange 2-pt field goal</SourceLine>
   <SourceLine>FG(1,False)</SourceLine>
   <SourceLine>elseif iAction.Action=57 then</SourceLine>
   <SourceLine>//, (P1) misses a long 2-pt field goal</SourceLine>
   <SourceLine>FG(2,false)</SourceLine>
   <SourceLine>elseif iAction.Action=58 then</SourceLine>
   <SourceLine>//, (P1) hits a 3-point field goal (A?)</SourceLine>
   <SourceLine>FG(3,True)</SourceLine>
   <SourceLine>elseif iAction.Action=59 then</SourceLine>
   <SourceLine>//, (P1) misses a 3-point field goal</SourceLine>
   <SourceLine>FG(3,false)</SourceLine>
   <SourceLine>elseif iAction.Action=60 then</SourceLine>
   <SourceLine>//, (P1) dribbles upcourt</SourceLine>
   <SourceLine>dribbles(true)</SourceLine>
   <SourceLine>elseif iAction.Action=61 then</SourceLine>
   <SourceLine>//, (P1) has ball stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(D, True)</SourceLine>
   <SourceLine>elseif iAction.Action=62 then</SourceLine>
   <SourceLine>//, (P1) travels</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" travels"</SourceLine>
   <SourceLine>elseif iAction.Action=63 then</SourceLine>
   <SourceLine>//, (P1) loses the ball out of bounds</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" loses the ball out of bounds"</SourceLine>
   <SourceLine>elseif iAction.Action=64 then</SourceLine>
   <SourceLine>//, (P1) double dribbles</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" double dribbles"</SourceLine>
   <SourceLine>elseif iAction.Action=65 then</SourceLine>
   <SourceLine>//, (P1) is called for over-and-back</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" is called for over-and-back"</SourceLine>
   <SourceLine>elseif iAction.Action=66 then</SourceLine>
   <SourceLine>//, (P1) called for 5 sec. violation - closely guarded</SourceLine>
   <SourceLine>Turnover(D,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " is called for a 5 second violation--closely guarded"</SourceLine>
   <SourceLine>elseif iAction.Action=67 then</SourceLine>
   <SourceLine>//, (P1) passes upcourt to (P2)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" passes upcourt to " +iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=68 then</SourceLine>
   <SourceLine>//, (P1) throws long pass upcourt to (P2)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws long pass upcourt to "+iAction.Player(2).Name</SourceLine>
   <SourceLine>elseif iAction.Action=69 then</SourceLine>
   <SourceLine>//, (P1) has upcourt pass stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(P, True)</SourceLine>
   <SourceLine>elseif iAction.Action=70 then</SourceLine>
   <SourceLine>//, (P1) throws the upcourt pass away</SourceLine>
   <SourceLine>Turnover(P,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws the upcourt pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=71 then</SourceLine>
   <SourceLine>//, (P1) throws the long upcourt pass away</SourceLine>
   <SourceLine>Turnover(P,False)</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws the long upcourt pass away"</SourceLine>
   <SourceLine>elseif iAction.Action=72 then</SourceLine>
   <SourceLine>//, (P1) has long upcourt pass stolen by (P2-opp)</SourceLine>
   <SourceLine>Turnover(P, True)</SourceLine>
   <SourceLine>elseif iAction.Action=73 then</SourceLine>
   <SourceLine>//, (P1) throws up a shot from around half-court</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" throws up a shot from around half-court"</SourceLine>
   <SourceLine>elseif iAction.Action=74 then</SourceLine>
   <SourceLine>//, ...And it's good!</SourceLine>
   <SourceLine>LastSecondFG(true)</SourceLine>
   <SourceLine>elseif iAction.Action=75 then</SourceLine>
   <SourceLine>//, ...And it misses!</SourceLine>
   <SourceLine>LastSecondFG(false)</SourceLine>
   <SourceLine>elseif iAction.Action=76 then</SourceLine>
   <SourceLine>//, (P1) switches position with (P2)</SourceLine>
   <SourceLine>SwitchPosition</SourceLine>
   <SourceLine>wndS.SwitchPosition</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " switches position with "+iAction.Player(2).Name</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
