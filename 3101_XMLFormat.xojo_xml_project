 <Method>
  <ItemName>CalcRun</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1072789503</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalcRun(TeamNum as String, Pts as Integer)</SourceLine>
   <SourceLine>dim activeteam, otherteam as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if teamnum="1" then</SourceLine>
   <SourceLine>activeteam=0</SourceLine>
   <SourceLine>otherteam=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>activeteam=1</SourceLine>
   <SourceLine>otherteam=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set the time for the last FG (so we can check for drought)</SourceLine>
   <SourceLine>if pts&gt;1 then</SourceLine>
   <SourceLine>LastFG(activeteam)=MyAction.Time</SourceLine>
   <SourceLine>FGDroughts(activeteam,0)=false</SourceLine>
   <SourceLine>FGDroughts(activeteam,1)=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//adjust the points in a row</SourceLine>
   <SourceLine>SVPtsInARow(activeteam)=SVPtsInARow(activeteam)+Pts</SourceLine>
   <SourceLine>SVPtsInARow(otherteam)=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's adjust the currentRun (if it's active)</SourceLine>
   <SourceLine>CurrentRun(activeteam)=CurrentRun(activeteam)+Pts</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if a team has scored 7 or more in a row, start a run for them and stop for opponent</SourceLine>
   <SourceLine>If SVPtsInARow(activeteam)&gt;=7 then</SourceLine>
   <SourceLine>if InRun(otherteam) then</SourceLine>
   <SourceLine>//we kill other team's run</SourceLine>
   <SourceLine>InRun(otherteam)=false</SourceLine>
   <SourceLine>CurrentRun(otherteam)=0</SourceLine>
   <SourceLine>CurrentRun(activeteam)=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if InRun(activeteam)=false then</SourceLine>
   <SourceLine>//if we're not on one before, we're on one now</SourceLine>
   <SourceLine>InRun(activeteam)=true</SourceLine>
   <SourceLine>//load up initial run stats</SourceLine>
   <SourceLine>CurrentRun(activeteam)=SVPtsInARow(activeteam)</SourceLine>
   <SourceLine>CurrentRun(otherteam)=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's point out that we're on a run now</SourceLine>
   <SourceLine>RunStarted=true</SourceLine>
   <SourceLine>RunTeam=activeteam</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Stats.ResultText.Append teamname(runteam).text+" is on a run!"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>//loop for each team</SourceLine>
   <SourceLine>lblRuns(n).Visible=false</SourceLine>
   <SourceLine>dim oppn as integer</SourceLine>
   <SourceLine>if n=0 then</SourceLine>
   <SourceLine>oppn=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>oppn=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if InRun(n) then</SourceLine>
   <SourceLine>//we're in run.  see if we still need it</SourceLine>
   <SourceLine>if CurrentRun(n)&gt;=CurrentRun(oppn)*3 then</SourceLine>
   <SourceLine>//still in run</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//do we view it (&gt;7, &lt;9) or not?</SourceLine>
   <SourceLine>if CurrentRun(oppn)&gt;9 then</SourceLine>
   <SourceLine>//opponent has too many points, so clear out run</SourceLine>
   <SourceLine>//no longer in run, so clear 'em out</SourceLine>
   <SourceLine>inrun(n)=false</SourceLine>
   <SourceLine>CurrentRun(n)=0</SourceLine>
   <SourceLine>CurrentRun(oppn)=0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//if over 7 pts, let's view our run</SourceLine>
   <SourceLine>if CurrentRun(n)&gt;=7 then</SourceLine>
   <SourceLine>lblRuns(n).Visible=true</SourceLine>
   <SourceLine>lblRuns(n).text=str(CurrentRun(n))+"-"+str(CurrentRun(oppn))+" run"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//no longer in run, so clear 'em out</SourceLine>
   <SourceLine>inrun(n)=false</SourceLine>
   <SourceLine>CurrentRun(n)=0</SourceLine>
   <SourceLine>CurrentRun(oppn)=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//not in run, so clear currentrun info</SourceLine>
   <SourceLine>'CurrentRun(n)=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lblRuns(n).Refresh</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's see if we have a field goal drought for either team</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>if MyAction.Time-lastfg(n)&gt;240 and FGDroughts(n,0)=false then</SourceLine>
   <SourceLine>//we have a 4.00 field goal drought</SourceLine>
   <SourceLine>FGDroughts(n,0)=true</SourceLine>
   <SourceLine>Stats.ResultText.Append teamname(n).text+" hasn't scored a field goal in the last four minutes!"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif MyAction.Time-lastfg(n)&gt;480 and FGDroughts(n,1)=false then</SourceLine>
   <SourceLine>//we have a 8.00 field goal drought</SourceLine>
   <SourceLine>FGDroughts(n,1)=true</SourceLine>
   <SourceLine>Stats.ResultText.Append teamname(n).text+" hasn't scored a field goal in the last eight minutes!"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>TeamNum as String, Pts as Integer</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1478541311</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>// Calling the overridden superclass constructor.</SourceLine>
   <SourceLine>Super.Window</SourceLine>
   <SourceLine>stats=new cStats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.BackColor=prefWindowColor</SourceLine>
   <SourceLine>me.Title="Stat Viewer"</SourceLine>
   <SourceLine>ppMain.Value=0</SourceLine>
   <SourceLine>GameText=new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//This sorts out the names for our PopupMenu</SourceLine>
   <SourceLine>SortedNames=stats.SortNames</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for p as integer=0 to 9</SourceLine>
   <SourceLine>//for each popup menu</SourceLine>
   <SourceLine>for n as integer=0 to 11</SourceLine>
   <SourceLine>//add for each player</SourceLine>
   <SourceLine>popup(p).addrow SortedNames(floor(p/5),n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//need to set the team name</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>text1(n).text=GameToImport.iTeams(n).TeamName</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Set the starters</SourceLine>
   <SourceLine>SetStarters(GameToImport.GetStarters)</SourceLine>
   <SourceLine>SVDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if we're just importing, not wacthing, then we change the property here</SourceLine>
   <SourceLine>if fWatchPBP=false then</SourceLine>
   <SourceLine>watchgame.Value=false </SourceLine>
   <SourceLine>butSetLineup.Push //assume the lineup is correct</SourceLine>
   <SourceLine>MainTimer.Period=0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we don't want the timer to start until you hit go</SourceLine>
   <SourceLine>watchgame.value=true</SourceLine>
   <SourceLine>MainTimer.Enabled=False</SourceLine>
   <SourceLine>MainTimer.Period=TicksToWait</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ErrorChecker</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1154684927</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ErrorChecker(A as string, B as string, C as string, D as string, E as string) As boolean</SourceLine>
   <SourceLine>If (A="") or (B="") or (C="") or (D="") or (E="") THEN</SourceLine>
   <SourceLine>Msgbox "You must select a player for each position in order to continue."</SourceLine>
   <SourceLine>Return False</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>If (A=B) or (A=C) or (A=D) or (A=E) or (B=C) or (B=D) or (B=E) or (C=D) or (C=E) or (D=E) THEN</SourceLine>
   <SourceLine>Msgbox "You cannot select a player for more than one position."</SourceLine>
   <SourceLine>Return False</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>Return True</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
