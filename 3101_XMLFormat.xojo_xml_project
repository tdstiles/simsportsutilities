 <HookInstance>
  <ItemName>CompareRows</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>452947967</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CompareRows(row1 as Integer, row2 as Integer, column as Integer, ByRef result as Integer) As Boolean</SourceLine>
   <SourceLine>#Pragma DisableBackgroundTasks</SourceLine>
   <SourceLine>#pragma NilObjectChecking false</SourceLine>
   <SourceLine>#pragma BoundsChecking false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if CompareType=0 then</SourceLine>
   <SourceLine>dim ins1, ins2 as integer</SourceLine>
   <SourceLine>dim name1, name2 as string</SourceLine>
   <SourceLine>dim difference as Double</SourceLine>
   <SourceLine>If column &gt;0 then</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>Return true</SourceLine>
   <SourceLine>elseif column=0 then</SourceLine>
   <SourceLine>ins1=instr(me.cell(row1,column)," ")</SourceLine>
   <SourceLine>name1=mid(me.cell(row1,column), ins1)</SourceLine>
   <SourceLine>ins2=instr(me.cell(row2,column)," ")</SourceLine>
   <SourceLine>name2=mid(me.cell(row2,column), ins2)</SourceLine>
   <SourceLine>result=Strcomp(name1, name2,1)</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>Return false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif CompareType=1 then</SourceLine>
   <SourceLine>dim ins1, ins2 as integer</SourceLine>
   <SourceLine>dim name1, name2 as string</SourceLine>
   <SourceLine>dim difference as Double</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>Return true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif CompareType=2 then</SourceLine>
   <SourceLine>dim ins1, ins2 as integer</SourceLine>
   <SourceLine>dim name1, name2 as string</SourceLine>
   <SourceLine>dim difference as Double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//sort by number, but keep the last row in place</SourceLine>
   <SourceLine>if me.Cell(row1, 0)="Team" then</SourceLine>
   <SourceLine>// Row 1 is our total list</SourceLine>
   <SourceLine>if me.ColumnSortDirection(column)=me.SortAscending then</SourceLine>
   <SourceLine>result=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>result=-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif me.Cell(row2, 0)="Team" then</SourceLine>
   <SourceLine>// Row 2 is our total ist</SourceLine>
   <SourceLine>if me.ColumnSortDirection(column)=me.SortAscending then</SourceLine>
   <SourceLine>result=-1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>result=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//not a total, so do regular sorting</SourceLine>
   <SourceLine>If column &gt;0 then</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>elseif column=0 then</SourceLine>
   <SourceLine>ins1=instr(me.cell(row1,column)," ")</SourceLine>
   <SourceLine>name1=mid(me.cell(row1,column), ins1)</SourceLine>
   <SourceLine>ins2=instr(me.cell(row2,column)," ")</SourceLine>
   <SourceLine>name2=mid(me.cell(row2,column), ins2)</SourceLine>
   <SourceLine>result=Strcomp(name1, name2,1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif CompareType=3 then</SourceLine>
   <SourceLine>dim difference as Double</SourceLine>
   <SourceLine>If column =0 or column=3 or column=4 then</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>Return true</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>Return false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif CompareType=4 then</SourceLine>
   <SourceLine>dim difference as Double</SourceLine>
   <SourceLine>dim feet1, inches1, feet2, inches2, ins1, ins2 as integer</SourceLine>
   <SourceLine>dim name1, name2 as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If column &lt;&gt;0 and column &lt;&gt;1 and column &lt;&gt;3 and column &lt;&gt;8 then</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>Return true</SourceLine>
   <SourceLine>Elseif column=1 then</SourceLine>
   <SourceLine>feet1=val(left(me.cell(row1, column),2))</SourceLine>
   <SourceLine>inches1=val(mid(me.cell(row1, column),4))+(feet1*12)</SourceLine>
   <SourceLine>feet2=val(left(me.cell(row2, column),2))</SourceLine>
   <SourceLine>inches2=val(mid(me.cell(row2, column),4))+(feet2*12)</SourceLine>
   <SourceLine>difference = inches1-inches2</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>elseif column=0 then</SourceLine>
   <SourceLine>ins1=instr(me.cell(row1,column)," ")</SourceLine>
   <SourceLine>name1=mid(me.cell(row1,column), ins1)</SourceLine>
   <SourceLine>ins2=instr(me.cell(row2,column)," ")</SourceLine>
   <SourceLine>name2=mid(me.cell(row2,column), ins2)</SourceLine>
   <SourceLine>result=Strcomp(name1, name2,1)</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>elseif column=8 then</SourceLine>
   <SourceLine>if Val(me.Cell(row1, column))=0 then</SourceLine>
   <SourceLine>return false</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>difference = Val(me.Cell(row1, column)) - Val(me.Cell(row2, column))</SourceLine>
   <SourceLine>result = difference/Abs(difference)</SourceLine>
   <SourceLine>Return true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Return false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif CompareType=5 then</SourceLine>
   <SourceLine>//sort by number, but keep the last row in place</SourceLine>
   <SourceLine>if me.Cell(row1, 0)="Team" then</SourceLine>
   <SourceLine>// Row 1 is our total list</SourceLine>
   <SourceLine>if me.ColumnSortDirection(column)=me.SortAscending then</SourceLine>
   <SourceLine>result=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>result=-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif me.Cell(row2, 0)="Team" then</SourceLine>
   <SourceLine>// Row 2 is our total ist</SourceLine>
   <SourceLine>if me.ColumnSortDirection(column)=me.SortAscending then</SourceLine>
   <SourceLine>result=-1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>result=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>// Neither row is total so sort by value unless a name</SourceLine>
   <SourceLine>if column=0 then</SourceLine>
   <SourceLine>dim ins1, ins2 as integer</SourceLine>
   <SourceLine>dim name1, name2 as string</SourceLine>
   <SourceLine>ins1=instr(me.cell(row1,column)," ")</SourceLine>
   <SourceLine>name1=mid(me.cell(row1,column), ins1)</SourceLine>
   <SourceLine>ins2=instr(me.cell(row2,column)," ")</SourceLine>
   <SourceLine>name2=mid(me.cell(row2,column), ins2)</SourceLine>
   <SourceLine>result=Strcomp(name1, name2,1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if val(me.Cell(row1,column)) &lt; val(me.Cell(row2,column)) then</SourceLine>
   <SourceLine>result=-1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>result=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>// We are doing the sorting...</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>#pragma BackgroundTasks true</SourceLine>
   <SourceLine>#pragma NilObjectChecking true</SourceLine>
   <SourceLine>#pragma BoundsChecking true</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
