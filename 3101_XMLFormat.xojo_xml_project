 <Method>
  <ItemName>ParseandLoadPlayerStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1989957631</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseandLoadPlayerStats()</SourceLine>
   <SourceLine>//when this method is called, we go through the category, build the sql query, and then return the info.</SourceLine>
   <SourceLine>//if mPlayerList has elements, we want to call the players in this order</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Dim rs As RecordSet</SourceLine>
   <SourceLine>dim clause,sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>popSeasonsSelected.Enabled=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, build the clauses to set whether we're pulling for one season or for the entire career</SourceLine>
   <SourceLine>clause="WHERE "</SourceLine>
   <SourceLine>if popSeasonsSelected.text="Career" then </SourceLine>
   <SourceLine>clause=clause+"Season LIKE '%'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>clause=clause+"Season='"+popSeasonsSelected.text+"'"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now set exhibition</SourceLine>
   <SourceLine>if chkExh.Value=false then</SourceLine>
   <SourceLine>clause=clause+" AND Game&lt;=24"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if mPlayerList has elements, we call in this order.  otherwise, we'll populate a new mplayerlist</SourceLine>
   <SourceLine>if mPlayerList.Ubound&gt;-1 then</SourceLine>
   <SourceLine>//have elements, so we can proceed</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="Select Distinct(Name) FROM STATS " + clause</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>mPlayerList.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have the order to call the players</SourceLine>
   <SourceLine>//are we calling for one player or for the entire team?</SourceLine>
   <SourceLine>for n as integer=0 to UBound(mPlayerList)</SourceLine>
   <SourceLine>methPullStats(mPlayerList(n),clause, popTypeofStats.text)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>methPullStats("Team",clause, popTypeofStats.text)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if UBound(mPlayerList)&gt;9 then //adjust scrollbar based on whether we have 10 or more players</SourceLine>
   <SourceLine>lbPlayerStats.ScrollBarVertical=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>lbPlayerStats.ScrollBarVertical=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
