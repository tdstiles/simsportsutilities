 <Method>
  <ItemName>LoadPlayerStatLB</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>300888063</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPlayerStatLB()</SourceLine>
   <SourceLine>#pragma NilObjectChecking false</SourceLine>
   <SourceLine>#pragma disablebackgroundtasks</SourceLine>
   <SourceLine>#pragma disableautowaitcursor</SourceLine>
   <SourceLine>#pragma disableboundschecking</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, if anything is  here, we load it up so we can pass the correct order</SourceLine>
   <SourceLine>//need to check to see if the season has changed, which changes mPlayerList</SourceLine>
   <SourceLine>if popSeasonsSelected.text&lt;&gt;mPreviousSeasonSelection then</SourceLine>
   <SourceLine>//new season selected, so get rid of all the previous text</SourceLine>
   <SourceLine>redim mPlayerList(-1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if lbPlayerStats.ListCount&lt;&gt;0 then</SourceLine>
   <SourceLine>//we add</SourceLine>
   <SourceLine>redim mPlayerList(-1)</SourceLine>
   <SourceLine>for n as integer=1 to lbPlayerStats.ListCount-1</SourceLine>
   <SourceLine>mPlayerList.Append lbPlayerStats.cell(n-1,0)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine> mPreviousSeasonSelection=popSeasonsSelected.text //reset this to what is selected now</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbPlayerStats.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Select Case popTypeofStats.text</SourceLine>
   <SourceLine>Case "Box Score"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,G,Min,FGM,FGA,FG%,3M,3A,3%,FTM,FTA,FT%,Reb,Ast,Blk,Stl,TOs,Fouls,Pts",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths = "85.78,0.7*,*,1.1*,*,1.1*,0.9*,*,*,*,*,1.1*,*,*,*,*,*,1.1*"</SourceLine>
   <SourceLine>Case "Shooting"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,shrtM,shrtA,shrt%,midM,midA,mid%,longM,longA,long%,TS%",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths = "85.78,*"</SourceLine>
   <SourceLine>Case "Defense"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,aFGM,aFGA,aFG%,aF3M,aF3A,aF3%,Blk,Stl,crTO,aPts",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths="85.78,*"</SourceLine>
   <SourceLine>Case "Ball Control"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,OReb,DReb,aOReb,aDReb,aTReb,Reb%,LostP,LostD,PUs,Touch",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths = "85.78,0.95*,0.95*,1.1*,1.1*,1.1*,1.1*,*,*,*,.85*,.*,*"</SourceLine>
   <SourceLine>Case "Efficiency"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,FD,t/FD,FT/FD,Ar,Ar/FGM,shBlkd,shBlk%,t/TO,Ast/TO,sht% ",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths = "85.78,*,*,*,.7*,1.1*,*"</SourceLine>
   <SourceLine>Case "Analysis"</SourceLine>
   <SourceLine>lbPlayerStats.LoadHeader(split("Name,Eff,aEff,+/-Eff,Tendex,SecTendex,+/-,SVx,Rating,NBS,WS,GS",","))</SourceLine>
   <SourceLine>lbPlayerStats.ColumnWidths="85.78,*"</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ParseandLoadPlayerStats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now actually clear out the pressed header</SourceLine>
   <SourceLine>lbPlayerStats.HasHeading=false</SourceLine>
   <SourceLine>lbPlayerStats.HasHeading=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>#Pragma BackgroundTasks True</SourceLine>
   <SourceLine>#pragma NilObjectChecking false</SourceLine>
   <SourceLine>#pragma boundschecking true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
