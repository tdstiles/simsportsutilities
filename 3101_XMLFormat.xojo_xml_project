 </Method>
 <Method>
  <ItemName>InitialChange</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>591822847</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub InitialChange(Choice as String)</SourceLine>
   <SourceLine>dim w,l,confw,confl,title,appearances,avgF as integer</SourceLine>
   <SourceLine>dim s16,f4,ch as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Select Case Choice</SourceLine>
   <SourceLine>case "Total"</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.LoadHeader(split("W,L,Pct,Conf.Title,ConfTourn Title,NTT App", ","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(WL='W'),Sum(WL='L')  FROM TeamHistory WHERE Game&lt;=24")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>w=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>w=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>l=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>l=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(ConfFinish='1'),Sum(ConfTournTitle='Y') FROM TotalTeam")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>ch=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ch=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>title=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>title =0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Distinct Season FROM TeamHistory WHERE TYPE LIKE 'NTT'")</SourceLine>
   <SourceLine>appearances=0</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>dim iCounter as integer=rs.RecordCount</SourceLine>
   <SourceLine>for x as integer=1 to iCounter</SourceLine>
   <SourceLine>appearances=appearances+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.DeleteAllRows</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.AddRow str(w),str(l),format(PctCheck(w,l),".000"),str(ch),str(title),str(appearances)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case "Regular Season"</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.LoadHeader(split("W,L,Pct,ConfW,ConfL,ConfPct", ","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(WL='W'),Sum(WL='L') From TeamHistory Where TYPE LIKE '%Conference' AND Game&lt;=24")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>w=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>w=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>l=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>l=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(WL='W'),SUm(WL='L') From TeamHistory WHERE TYPE LIKE 'Conference' AND Game&lt;=24")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>confw=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>confw=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>confl=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>confl=0</SourceLine>
