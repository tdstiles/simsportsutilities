   <SourceLine>lbTotalTeamStatHistory.DeleteAllRows</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.AddRow str(w),str(l),format(PctCheck(w,l),".000"),str(confw),str(confl),format(PctCheck(confw,confl),".000")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case "Conference"</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.LoadHeader(split("W,L,Pct,Conf. Title,Avg. Finish", ","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(WL='W'),Sum(WL='L') From TeamHistory WHERE TYPE LIKE 'Conference' AND Game&lt;=24")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>confw=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>confw=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>confl=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>confl=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(ConfFinish='1'), AVG(ConfFinish) FROM TotalTeam")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
