 <Method>
  <ItemName>SwitchtoViewPanel</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2008127487</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SwitchtoViewPanel()</SourceLine>
   <SourceLine>//when the wndStatViewer window opens, go through the NamesList and put players into their proper positions</SourceLine>
   <SourceLine>ppMain.Value=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim benchcount as integer</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>benchcount=6</SourceLine>
   <SourceLine>lbTeams(n).LoadHeader(split("Player,Pts,PF", ","))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for y as integer=0 to 12</SourceLine>
   <SourceLine>lbTeams(n).addrow "--", "0", "0"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbTeams(n).cell(5,0)="**BENCH**"</SourceLine>
   <SourceLine>lbTeams(n).cell(5,1)=""</SourceLine>
   <SourceLine>lbTeams(n).cell(5,2)=""</SourceLine>
   <SourceLine>lbTeams(n).cellbold(5,0)=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Name, Pos, rowID FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
   <SourceLine>if rs.IdxField(2).integervalue=0 then</SourceLine>
   <SourceLine>lbTeams(n).cell(benchcount, 0)=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>h="UPDATE SVTable SET Pos="+str(benchcount)+" WHERE rowID="+rs.IdxField(3).StringValue</SourceLine>
   <SourceLine>SVDB.SQLExecute(h)</SourceLine>
   <SourceLine>benchcount=benchcount+1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>lbTeams(n).cell(rs.idxfield(2).integervalue-1, 0)=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT TeamName FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>teamname(n).text=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.title="Game #"+str(GametoImport.Game)+":  "+trim(teamname(0).text)+" vs. "+trim(teamname(1).text)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's set the PBPLines</SourceLine>
   <SourceLine>dim textin as TextInputStream</SourceLine>
   <SourceLine>textin=TextInputStream.Open( GameToImport.f )</SourceLine>
   <SourceLine>PBPLines=split(TextIn.ReadAll,EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>k=gTeams.indexof(teamname(n).text)</SourceLine>
   <SourceLine>BoxScores.PlayingTeams(n)=k+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fWatchPBP=false then</SourceLine>
   <SourceLine>//need to automatically start the game</SourceLine>
   <SourceLine>slider1.Value=0</SourceLine>
   <SourceLine>TicksToWait=0</SourceLine>
   <SourceLine>UpdateTeamMethods("0")</SourceLine>
   <SourceLine>startorpause.push</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//we do want to watch </SourceLine>
   <SourceLine>UpdateTeamMethods("0")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and we need to figure out whether we want to see the box scores scrolling at the bottom, too</SourceLine>
   <SourceLine>if iBoxScore&gt;0 then</SourceLine>
   <SourceLine>thrdLoadBoxScore.Run</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
