  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AddinPlayerAtts()</SourceLine>
   <SourceLine>'sqlArray.append "CREATE TABLE PlayerAtts (rowID INTEGER PRIMARY KEY autoincrement, Name varchar, SHT varchar, HND varchar, DEF varchar, REB varchar, ATH varchar, HT varchar, INT varchar)"</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim ht as string</SourceLine>
   <SourceLine>dim name as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>ht=str(val(ht1(n).text)*12+val(ht2(n).text))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first initial last name</SourceLine>
   <SourceLine>name=name(n).text</SourceLine>
   <SourceLine>k=instr(name, " ")</SourceLine>
   <SourceLine>name=left(name,1)+" "+mid(name,k+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO PlayerAtts (FullName, Name, SHT, DEF, HND, REB, ATH, INT, HT) VALUES ('"+name(n).text+"', '"+name+"','"+sht(n).text+"','"+def(n).text+"','"+hnd(n).text+"','"+reb(n).text+"','"+ath(n).text+"','"+int(n).text+"','"+ht+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
