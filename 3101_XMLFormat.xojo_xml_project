  <Visible>1</Visible>
  <PartID>410275839</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdateScores()</SourceLine>
   <SourceLine>iBoxScoreCount=iBoxScoreCount+1</SourceLine>
   <SourceLine>if iBoxScoreCount=iBoxScoreMax then</SourceLine>
   <SourceLine>iBoxScoreCount=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if me.BackColor=&amp;c0000FF then</SourceLine>
   <SourceLine>me.TextColor=&amp;c0000FF</SourceLine>
   <SourceLine>me.BackColor=&amp;cFFFFFF</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>me.BackColor=&amp;c0000FF</SourceLine>
   <SourceLine>me.TextColor=&amp;cFFFFFF</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if me.CurrentScoreShown+1&gt;ubound(me.GameScores) then</SourceLine>
   <SourceLine>//at the top, so restart</SourceLine>
   <SourceLine>me.CurrentScoreShown=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>me.CurrentScoreShown=me.CurrentScoreShown+1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if me.GameScores(me.CurrentScoreShown-1).TeamID(0)=me.PlayingTeams(0) or me.GameScores(me.CurrentScoreShown-1).TeamID(1)=me.PlayingTeams(0) then</SourceLine>
   <SourceLine>me.CurrentScoreShown=me.CurrentScoreShown+1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.text=me.GameScores(me.CurrentScoreShown-1).ScoreString</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
