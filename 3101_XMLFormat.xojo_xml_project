 <Method>
  <ItemName>GetStarters</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>192524287</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetStarters() As string()</SourceLine>
   <SourceLine>//when called, this method downloads the box score of a game, then figures out which player is at which position</SourceLine>
   <SourceLine>//the return is a string(9) which has the starters for teamA (0-4) and teamB(5-9)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>sockHTTP = new cPostSocket</SourceLine>
   <SourceLine>dim TmpString as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>dim players(-1) as string</SourceLine>
   <SourceLine>dim sName as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//connect the socket</SourceLine>
   <SourceLine>dim Logged as Boolean</SourceLine>
   <SourceLine>Logged=sockHTTP.LogIn</SourceLine>
   <SourceLine>//logged in with username and password</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpLeague as string</SourceLine>
   <SourceLine>dim tmpGame as string</SourceLine>
   <SourceLine>dim tmpTeam1 as string</SourceLine>
   <SourceLine>dim tmpTeam2 as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tmpleague=EncodeURLComponent("000"+right("0"+prefleague,2))</SourceLine>
   <SourceLine>tmpGame=EncodeURLComponent(right("0"+str(Game),2))</SourceLine>
   <SourceLine>tmpTeam1=EncodeURLComponent(replaceall(iTeams(0).TeamName," ", ""))</SourceLine>
   <SourceLine>tmpTeam2=EncodeURLComponent(replaceall(iTeams(1).TeamName," ", ""))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/runtime/boxscore.asp?league="+tmpleague+"&amp;game="+tmpGame+"&amp;team1="+tmpTeam1+"&amp;team2="+tmpTeam2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpString=sockHTTP.Get(theurl, 45)</SourceLine>
   <SourceLine>if TmpString&lt;&gt;"" then</SourceLine>
   <SourceLine>TmpString=CleanHTML(TmpString)</SourceLine>
   <SourceLine>lines=split(TmpString,EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we first need to check to see if the starters are listed</SourceLine>
   <SourceLine>if UBound(lines)&gt;-1 then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//after splitting out the array, we start to parse through it, line by line</SourceLine>
   <SourceLine>dim j as integer=3</SourceLine>
   <SourceLine>dim iMax as integer=ubound(lines)</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>j=j+15</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get each player</SourceLine>
   <SourceLine>for t as integer=0 to 4</SourceLine>
   <SourceLine>if j+16&gt;iMax then exit //check in case we only have 9 players</SourceLine>
   <SourceLine>sName=trim(lines(j+1))</SourceLine>
   <SourceLine>l=instr(sName, " ")</SourceLine>
   <SourceLine>players.append left(sName,1)+" "+mid(sName, l+1)</SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for t as integer=0 to 4</SourceLine>
   <SourceLine>if j+16&gt;iMax then exit //check in case we only have 9 players</SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//no players, so this is a null set</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return Players</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
