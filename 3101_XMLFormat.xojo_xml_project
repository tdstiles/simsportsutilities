  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadlbAwardsBox()</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbAwards.LoadHeader(split("Season,Awards", ","))</SourceLine>
   <SourceLine>lbAwards.ColumnWidths=".3*,*"</SourceLine>
   <SourceLine>lbAwards.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for i as integer=0 to 3</SourceLine>
   <SourceLine>lbAwards.AddRow str((val(snn)+i))</SourceLine>
   <SourceLine>h=""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//pull base on last name</SourceLine>
   <SourceLine>dim tmpname as string=PlayersName</SourceLine>
   <SourceLine>dim k as integer=instr(tmpname, " ")</SourceLine>
   <SourceLine>tmpname=mid(tmpname, k+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Award FROM PlayerAwards WHERE Season='"+str(val(Snn)+i)+"' AND Name LIKE '%"+TmpName+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;NIL and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>dim iCount as integer=rs.RecordCount</SourceLine>
   <SourceLine>for x as integer=1 to iCount</SourceLine>
   <SourceLine>if x&lt;&gt;rs.RecordCount then</SourceLine>
   <SourceLine>h=h+ rs.IdxField(1).StringValue+", "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h=h+ rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lbAwards.cell(lbAwards.LastIndex,1)=h</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
