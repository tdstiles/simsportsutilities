   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>871024639</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Function ContextualMenuAction(hitItem as MenuItem) As Boolean</SourceLine>
    <SourceLine>dim PlayerName as string</SourceLine>
    <SourceLine>dim rs as recordset</SourceLine>
    <SourceLine>dim RPstoAdd as integer</SourceLine>
    <SourceLine>dim listfield as string</SourceLine>
    <SourceLine>dim fSkip as boolean=false</SourceLine>
    <SourceLine>dim fClear as Boolean=false</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if lbPlayerList.ListIndex &gt; -1 then</SourceLine>
    <SourceLine>// A Row Is Selected, Show the Player Info</SourceLine>
    <SourceLine>PlayerName = lbPlayerList.Cell(lbPlayerList.ListIndex, 0)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "Add 17 RPs"</SourceLine>
    <SourceLine>//17 rps on him</SourceLine>
    <SourceLine>RPstoAdd=17</SourceLine>
    <SourceLine>case "Add 1 RP"</SourceLine>
    <SourceLine>RPstoAdd=1</SourceLine>
    <SourceLine>case "Remove 1 RP"</SourceLine>
    <SourceLine>RPstoAdd=-1</SourceLine>
    <SourceLine>case "Clear RPs"</SourceLine>
    <SourceLine>RPstoAdd=0</SourceLine>
    <SourceLine>fClear=true</SourceLine>
    <SourceLine>case "Estimate Ties"</SourceLine>
    <SourceLine>fskip=true</SourceLine>
    <SourceLine>if lbPlayerList.ListIndex&gt;-1 then</SourceLine>
    <SourceLine>szPlayerName= PlayerName</SourceLine>
    <SourceLine>wndInitialTie.show</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>case "Messageboard Text"</SourceLine>
    <SourceLine>fskip=true</SourceLine>
    <SourceLine>//we want to generate a clipboard copy of the text for the mssage board</SourceLine>
    <SourceLine>dim c as new Clipboard</SourceLine>
    <SourceLine>c.text=mthWhoAreYouMaxing(PlayerName)</SourceLine>
    <SourceLine>msgbox "Copied to Clipboard"</SourceLine>
    <SourceLine>case "View Teammates"</SourceLine>
    <SourceLine>fskip=true</SourceLine>
    <SourceLine>//we want to pull up just the three of them</SourceLine>
    <SourceLine>dim sqlstring as string</SourceLine>
    <SourceLine>sqlstring="Select HSName FROM PLayerInfo WHERE Name='"+PlayerName+"'"</SourceLine>
    <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
    <SourceLine>sqlstring=BaseSQL+" WHERE HSName='"+rs.IdxField(1).StringValue+"'"</SourceLine>
    <SourceLine>PlayerListUpdate(sqlstring)</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if not fskip then</SourceLine>
    <SourceLine>rs=DB.SQLSelect("SELECT Name, RP FROM PlayerInfo WHERE Name LIKE '"+PlayerName+"'")</SourceLine>
    <SourceLine>if rs &lt;&gt; NIL and rs.recordCount&gt; 0 THEN</SourceLine>
    <SourceLine>dim iCurrentRps as integer=rs.IdxField(2).IntegerValue</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//update the saved recordset</SourceLine>
    <SourceLine>rs.Edit</SourceLine>
    <SourceLine>if not fClear then</SourceLine>
    <SourceLine>rs.field("RP").integerValue=RPstoAdd+iCurrentRps</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>rs.Field("RP").IntegerValue=0</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>rs.update</SourceLine>
    <SourceLine>db.commit</SourceLine>
    <SourceLine>spentrps.text="RPs Spent:  "+str(RPSum)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//determine if mylist or regular list to update RPs</SourceLine>
    <SourceLine>if not fClear then</SourceLine>
    <SourceLine>lbPlayerList.cell(lbPlayerList.ListIndex,14)=str(RPstoAdd+iCurrentRps)</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>lbPlayerList.cell(lbPlayerList.ListIndex,14)="0"</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>Msgbox "Record not found"</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>return true</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Function</SourceLine>
   </ItemSource>
  </HookInstance>
