 <ControlBehavior>
  <Superclass>PagePanel</Superclass>
  <HookInstance>
   <ItemName>Change</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>1824063487</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Change()</SourceLine>
    <SourceLine>if me.value=1 then</SourceLine>
    <SourceLine>LoadGameList</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//season view</SourceLine>
    <SourceLine>lbGameList.LoadHeader(split("G,Type,Opponent,Us,Them,Result", ","))</SourceLine>
    <SourceLine>lbGameList.ColumnWidths=".33*,*"</SourceLine>
    <SourceLine>lbGameList.ColumnAlignment(1)=listbox.AlignLeft</SourceLine>
    <SourceLine>lbgamelist.ColumnAlignment(2)=listbox.AlignLeft</SourceLine>
    <SourceLine>RefreshListBoxes</SourceLine>
    <SourceLine>elseif me.value=0 then</SourceLine>
    <SourceLine>//player stats</SourceLine>
    <SourceLine>LoadPlayerStatLB</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>elseif me.value=2 then</SourceLine>
    <SourceLine>//history view</SourceLine>
    <SourceLine>conHistory1.Loadhistory</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>elseif me.value=3 then</SourceLine>
    <SourceLine>//head to head records</SourceLine>
    <SourceLine>dim a as string</SourceLine>
    <SourceLine>dim w,l as integer</SourceLine>
    <SourceLine>dim rs, rec as RecordSet</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>lbhth.DeleteAllRows</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Distinct Opponent FROM TeamHistory WHERE Game&lt;=24")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>dim r as integer=rs.RecordCount</SourceLine>
    <SourceLine>for x as integer=1 to r</SourceLine>
    <SourceLine>a=rs.IdxField(1).StringValue</SourceLine>
    <SourceLine>rec=db.SQLSelect("SELECT Count(WL) as W from TeamHistory WHERE Opponent='"+a+"' AND WL='W' AND Game&lt;=24")</SourceLine>
    <SourceLine>if rec.RecordCount&lt;&gt;0 and rec&lt;&gt;nil then</SourceLine>
    <SourceLine>w=rec.field("W").value</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>w=0</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>rec=db.SQLSelect("SELECT Count(WL) as L from TeamHistory WHERE Opponent='"+a+"' AND WL='L' AND Game&lt;=24")</SourceLine>
    <SourceLine>if rec.RecordCount&lt;&gt;0 and rec&lt;&gt;nil then</SourceLine>
    <SourceLine>l=rec.field("L").IntegerValue</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>l=0</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>lbhth.addrow a,str(w),str(l), format(DivChk(w,(w+l)),"#.000")</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>elseif me.value=4 then</SourceLine>
    <SourceLine>//awards view</SourceLine>
    <SourceLine>dim x as integer</SourceLine>
    <SourceLine>dim rs, rec as recordset</SourceLine>
    <SourceLine>dim awards(4) as string</SourceLine>
    <SourceLine>dim sqlstring as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>lbAwardsoverall.LoadHeader(split("Sn,1st All-Conf,2nd All-Conf,Conf FOY,Conf POY,All-League", ","))</SourceLine>
    <SourceLine>lbawardsoverall.ColumnWidths=".4*,*"</SourceLine>
    <SourceLine>awards(0)="%1st All-Conf"</SourceLine>
    <SourceLine>awards(1)="%2nd All-Conf"</SourceLine>
    <SourceLine>awards(2)="%Conf FOY"</SourceLine>
    <SourceLine>awards(3)="%Conf POY"</SourceLine>
    <SourceLine>awards(4)="%All-League"</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>lbawardsoverall.DeleteAllRows</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Distinct Season FROM Stats ORDER BY Season DESC")</SourceLine>
    <SourceLine>while rs&lt;&gt;NIL and rs.eof=false</SourceLine>
    <SourceLine>x=rs.IdxField(1).Value</SourceLine>
    <SourceLine>lbawardsoverall.addrow str(x)</SourceLine>
    <SourceLine>for i as integer=0 to 4</SourceLine>
    <SourceLine>sqlstring="SELECT Count(Award) FROM PlayerAwards WHERE Season='"+str(x)+"' AND Award LIKE '%"+Awards(i)+"%'"</SourceLine>
    <SourceLine>rec=db.SQLSelect(sqlstring)</SourceLine>
    <SourceLine>lbawardsoverall.cell(lbawardsoverall.LastIndex,i+1)=str(rec.IdxField(1).Value)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>elseif me.value=5 then</SourceLine>
    <SourceLine>myselection=0</SourceLine>
    <SourceLine>SQLStatement(popStatchoice.text, popTimeSelection.ListIndex, myselection)</SourceLine>
    <SourceLine>elseif me.value=6 then</SourceLine>
    <SourceLine>CalculateHOFScore</SourceLine>
    <SourceLine>elseif me.value=7 then</SourceLine>
    <SourceLine>//featured games</SourceLine>
    <SourceLine>LoadFeaturedGames</SourceLine>
    <SourceLine>elseif me.value=8 then</SourceLine>
    <SourceLine>//recruiting history</SourceLine>
    <SourceLine>LoadRecruitingHistoryOverview</SourceLine>
    <SourceLine>elseif me.value=11 then</SourceLine>
    <SourceLine>//we have the adding awards list</SourceLine>
    <SourceLine>AddInAllAwards</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
 </ControlBehavior>
