 <Method>
  <ItemName>LoadTeamSchedule</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2036049919</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadTeamSchedule(TeamNum as integer) As cGame()</SourceLine>
   <SourceLine>dim sockHTTP as new HTTPSocket</SourceLine>
   <SourceLine>dim tmpString as string</SourceLine>
   <SourceLine>dim ScheduledGames(-1) as cGame</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tmpString=sockHTTP.Get("http://www.drivethelane.com/bask/runtime/sched.asp?league=league=lg000"+right("0"+prefleague,2)+"&amp;team="+str(TeamNum), 60)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if tmpString &lt;&gt; "" then</SourceLine>
   <SourceLine>tmpString=CleanHTML(tmpString)</SourceLine>
   <SourceLine>ScheduledGames=ParseScheduleFile(tmpString, TeamNum)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return ScheduledGames</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>TeamNum as integer</ItemParams>
  <ItemResult>cGame()</ItemResult>
 </Method>
 <Method>
  <ItemName>ParseScheduleFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1277091839</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ParseScheduleFile(tmpString as string, TeamNumber as integer) As cgame()</SourceLine>
   <SourceLine>Dim n As Integer</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>dim iGameNumber as integer=1</SourceLine>
   <SourceLine>dim szTeamString as string</SourceLine>
   <SourceLine>dim TmpScore as string</SourceLine>
   <SourceLine>dim rzLines(-1) as string</SourceLine>
   <SourceLine>dim rTmpGames(-1) as cGame</SourceLine>
   <SourceLine>dim tmpGame as cGame</SourceLine>
   <SourceLine>dim tmpTeam as cTeam</SourceLine>
   <SourceLine>dim Imax as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//put info in an array--pbparray(0)=game number, pbparray(1)=opponent</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rzLines=split(tmpString, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=15</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while i+8&lt;UBound(rzLines)</SourceLine>
   <SourceLine>if iGameNumber=4 then</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>elseif iGameNumber=19 then</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>elseif iGameNumber=22 then</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if trim(rzLines(i+5))&lt;&gt;"-" then</SourceLine>
   <SourceLine>tmpGame=new cGame</SourceLine>
   <SourceLine>for j as integer=0 to 1</SourceLine>
   <SourceLine>tmpTeam=new cTeam</SourceLine>
   <SourceLine>tmpGame.iTeams(j)=tmpTeam</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>rTmpGames.append tmpGame</SourceLine>
   <SourceLine>imax=UBound(rTmpGames)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rTmpGames(imax).iTeams(0).teamnumber=TeamNumber</SourceLine>
   <SourceLine>rTmpGames(imax).iTeams(1).teamnumber=val(left(rzLines(i+1),len(rzLines(i+1))-1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Pace/Defense of Team(0)</SourceLine>
   <SourceLine>rTmpGames(imax).Defense=trim(rzLines(i+8))</SourceLine>
   <SourceLine>rTmpGames(imax).Pace=trim(rzLines(i+7))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get the score</SourceLine>
   <SourceLine>TmpScore=trim(rzLines(i+6))</SourceLine>
   <SourceLine>n=InStr(TmpScore, "-")</SourceLine>
   <SourceLine>rTmpGames(imax).iTeams(0).Score=val(left(TmpScore, n-1))</SourceLine>
   <SourceLine>rTmpGames(imax).iTeams(1).Score=val(mid(TmpScore, n+1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if iGameNumber&lt;4 then</SourceLine>
   <SourceLine>rTmpGames(imax).Game=iGameNumber+24</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>rTmpGames(imax).Game=iGameNumber-3</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+9</SourceLine>
   <SourceLine>iGameNumber=iGameNumber+1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return rTmpGames</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
