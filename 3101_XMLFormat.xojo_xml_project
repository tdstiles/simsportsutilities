 <Method>
  <ItemName>mthWhoAreYouMaxing</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>823017471</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthWhoAreYouMaxing(PlayerName as string) As string</SourceLine>
   <SourceLine>//this method looks at which recruits have 17RPs and then generates a msgboard script that you can then paste to the msgboard</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT PlayerInfo.Height, PlayerInfo.Pos, PlayerInfo.Name, PlayerInfo.PlayerPlusMinus, HSInfo.Region, PlayerInfo.PPG, PlayerInfo.RPG, PlayerInfo.APG, PlayerInfo.SPG, PlayerInfo.BPG, PlayerInfo.TPG, PlayerInfo.SHT, PlayerInfo.DEF, PlayerInfo.HND, PlayerInfo.REB, PlayerInfo.ATH, PlayerInfo.Scout, PlayerInfo.t75rnk, PlayerInfo.GPA, PlayerInfo.Test FROM PlayerInfo, HSInfo WHERE PlayerInfo.HSName = HSInfo.HSName AND PlayerInfo.Name='"+PlayerName+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>if rs.IdxField(18).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>sbstring.append "[b]#"+rs.IdxField(18).StringValue+"[/b] "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append InchestoHT(rs.IdxField(1).IntegerValue)+" "</SourceLine>
   <SourceLine>sbstring.append rs.IdxField(2).StringValue+" "</SourceLine>
   <SourceLine>sbstring.Append "[b][color=green]"+rs.IdxField(3).StringValue+"[/color][/b] "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(4).DoubleValue, "+#0.0")+" "</SourceLine>
   <SourceLine>sbstring.append "(r"+rs.IdxField(5).StringValue+")"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now on to scouted attributes</SourceLine>
   <SourceLine>sbstring.Append numtoword(rs.IdxField(12).IntegerValue, true)+" "</SourceLine>
   <SourceLine>sbstring.Append numtoword(rs.IdxField(13).IntegerValue, true)+" "</SourceLine>
   <SourceLine>sbstring.Append numtoword(rs.IdxField(14).IntegerValue, true)+" "</SourceLine>
   <SourceLine>sbstring.Append numtoword(rs.IdxField(15).IntegerValue, true)+" "</SourceLine>
   <SourceLine>sbstring.Append numtoword(rs.IdxField(16).IntegerValue, true)+" "</SourceLine>
   <SourceLine>sbstring.append "(" +numtoword(rs.IdxField(17).IntegerValue, true)+" scout)  "</SourceLine>
   <SourceLine>sbstring.append rs.IdxField(19).StringValue+"/"+rs.IdxField(20).StringValue</SourceLine>
   <SourceLine>sbstring.append EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(6).DoubleValue, "#0.0")+"ppg"+" "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(7).DoubleValue, "#0.0")+"rpg"+" "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(8).DoubleValue, "#0.0")+"apg"+" "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(9).DoubleValue, "#0.0")+"spg"+" "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(10).DoubleValue, "#0.0")+"bpg"+" "</SourceLine>
   <SourceLine>sbstring.append format(rs.IdxField(11).DoubleValue, "#0.0")+"tpg"+EndOfLine</SourceLine>
   <SourceLine>sbstring.Append EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'4/4 on Carmine Macdonald (reg18)</SourceLine>
   <SourceLine>'6'8" F G-F-E-G+ (E scout), 2.9/56</SourceLine>
   <SourceLine>'C: 16.7ppg, 9.1rpg, 1.4apg, 0.3spg, 1.1TOpg, 1.6bpg</SourceLine>
   <SourceLine>'EXPECTED: 6'8" FGFEFG</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
