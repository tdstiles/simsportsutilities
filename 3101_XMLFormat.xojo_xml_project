 </Method>
 <Method>
  <ItemName>Foul</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1112373247</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Foul(offensive as boolean)</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim nFouls as integer</SourceLine>
   <SourceLine>dim TmpFouls as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//UpdateA player fouls drawn</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FD", 1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//UpdateA opp fouls</SourceLine>
   <SourceLine>TmpFouls=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "Fouls", 1)</SourceLine>
   <SourceLine>TmpFouls=replaceall(TmpFouls,"(","")</SourceLine>
   <SourceLine>TmpFouls=replaceall(TmpFouls,")","")</SourceLine>
   <SourceLine>nFouls=val(TmpFouls)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if offensive=false then</SourceLine>
   <SourceLine>//look at Previous action.  if missed FG, then subtract 1 FGA,, 1 aFGA</SourceLine>
   <SourceLine>n=AllActions(UBound(AllActions)-1).Action</SourceLine>
   <SourceLine>if n=28 or n=44 or n=19 or n=59 or n=17 or n=29 or n=41 or n=40 or n=43 or  n=34 or n=55 or n=56 or n=57 then</SourceLine>
   <SourceLine>//FGA</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FGA", -1)</SourceLine>
   <SourceLine>//opp aFGA</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFGA", -1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if n=43  or n=55 or n=44 then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "shrta", -1) //shrtFGA</SourceLine>
   <SourceLine>elseif n=28 or n=40 or n=41 or n=56 then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "meda", -1) //midFGA</SourceLine>
   <SourceLine>elseif n=17 or n=57 or n=34 then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "longa", -1)//longFGA</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//3pt</SourceLine>
   <SourceLine>if  n=29 or n=19 or n=59 then</SourceLine>
   <SourceLine>//3pt FG</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "FG3A", -1)//FG3A</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aFG3A", -1) //aFG3A</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if previous was block, subtract 1 block/1 shblkd</SourceLine>
   <SourceLine>if n=28 or n=29 or n=43 then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "Blk", -1) //opp Blks</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "shBlkd", -1) //shBlkd</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update player's stats</SourceLine>
   <SourceLine>sqlstring="SELECT Fouls, Pos FROM SVTable WHERE TeamNum='"+str(iAction.Player(1).Team)+"' AND PlayerNum='"+str(iAction.Player(1).Number)+"'"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>wndS.UpdateLbTeamsCell(iAction.Player(1).Team,rs.IdxField(2).IntegerValue-1,2,rs.IdxField(1).StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update team stats</SourceLine>
   <SourceLine>wndS.UpdateTeamMethods(iAction.Player(1).Team,3)</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if nFouls&lt;5 then</SourceLine>
   <SourceLine>ResultText.append rgStatPossibilities(10).Text(nFouls, iAction.Player(1).Name)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
