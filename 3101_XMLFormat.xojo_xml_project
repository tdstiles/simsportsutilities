 <Method>
  <ItemName>SQLStatement</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>653168639</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SQLStatement(Category as String, TPV as Integer, TI as Integer)</SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>dim sqlstatement as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>SELECT CASE TI</SourceLine>
   <SourceLine>Case 0 //individual stats</SourceLine>
   <SourceLine>Select Case TPV</SourceLine>
   <SourceLine>Case 0 //career stats</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT Distinct Name, Sum("+Category+") as Category from Stats WHERE Game&lt;='24' GROUP BY Name ORDER BY Category DESC")</SourceLine>
   <SourceLine>if rec&lt;&gt; nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadLeadersListbox(rec,0, category)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "No stats in database"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>Case 1//season stats</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT Distinct Season, Name, Sum("+Category+") as Category from Stats WHERE Game&lt;='24' GROUP BY Name, Season ORDER BY Category DESC")</SourceLine>
   <SourceLine>if rec&lt;&gt; nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadLeadersListbox(rec,1, category)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "No stats in database"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>Case 2//game stats</SourceLine>
   <SourceLine>sqlstatement="SELECT Game, name, "+Category+" as Category, season FROM stats WHERE Game&lt;='24' ORDER BY Category DESC"</SourceLine>
   <SourceLine>rec=db.SQLSelect(sqlstatement)</SourceLine>
   <SourceLine>if rec&lt;&gt; nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadLeadersListbox(rec,2, category)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "No stats in database"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Case 1 //team stats</SourceLine>
   <SourceLine>Select Case TPV</SourceLine>
   <SourceLine>case 0 //team career stats</SourceLine>
   <SourceLine>rec=db.SQLSelect("Select Sum("+Category+") as Category FROM Stats WHERE Game&lt;='24' ")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadTeamBox(rec,0,Category)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>case 1 //team season stats</SourceLine>
   <SourceLine>rec=db.SQLSelect("Select Season, Sum("+Category+") as Category FROM Stats WHERE Game&lt;='24' GROUP BY Season ORDER BY Category DESC")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadTeamBox(rec,1,Category)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>case 2 //team game stats</SourceLine>
   <SourceLine>sqlstatement="SELECT Season, Game, Sum("+Category+") as Category FROM Stats WHERE Game&lt;='24' GROUP BY Game, Season ORDER BY Category DESC"</SourceLine>
   <SourceLine>rec=db.SQLSelect(sqlstatement)</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>LoadTeamBox(rec,2,Category)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
