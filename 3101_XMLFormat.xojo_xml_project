   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Function ContextualMenuAction(hitItem as MenuItem) As Boolean</SourceLine>
    <SourceLine>dim PlayerName as string</SourceLine>
    <SourceLine>if me.ListIndex&gt;-1 then</SourceLine>
    <SourceLine>//row selected</SourceLine>
    <SourceLine>PlayerName=me.cell(me.ListIndex, 0)</SourceLine>
    <SourceLine>if PlayerName &lt;&gt;"Team" then</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "View Player"</SourceLine>
    <SourceLine>wndPlayerHistory.LoadPlayerHistory(PlayerName)</SourceLine>
    <SourceLine>case "Edit Atts"</SourceLine>
    <SourceLine>dim w as wndEditAtts</SourceLine>
    <SourceLine>w=new wndEditAtts(PlayerName)</SourceLine>
    <SourceLine>case "Get Overview Text for Message Board"</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Min(Season) as Season FROM Stats WHERE Name LIKE '"+PlayerName+"'")</SourceLine>
    <SourceLine>dim c as new Clipboard</SourceLine>
    <SourceLine>c.text=CreatePlayerExportText(PlayerName, rs.IdxField(1).StringValue)</SourceLine>
    <SourceLine>msgbox "Copied to Clipboard"</SourceLine>
    <SourceLine>end select </SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>return true</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Function</SourceLine>
   </ItemSource>
  </HookInstance>
