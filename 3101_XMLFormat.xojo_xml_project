  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function EfficiencyCalc(Pts as Integer, FGA as Integer, TOS as Integer) As Double</SourceLine>
   <SourceLine>if fga+tos&lt;&gt;0 then</SourceLine>
   <SourceLine>return Pts/(FGA+TOS)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
