   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun("   GHA%:  ", true)</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun(p.BTAltPct+"  (#"+p.BTAltPctRank+")"+endofline)</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun("PF%:  ", true)</SourceLine>
   <SourceLine>st.appendstylerun(texts)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>texts=NewStyleRun(p.PFPct+"  (#"+p.PFPctRank+")"+endofline)</SourceLine>
