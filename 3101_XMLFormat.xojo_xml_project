   <SourceLine>return right("0"+str(Game),2)+right("000"+str(iTeams(1).TeamNumber), 3)+right("000"+str(iTeams(0).TeamNumber), 3)+".zip"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return right("0"+str(Game),2)+right("000"+str(iTeams(0).TeamNumber), 3)+right("000"+str(iTeams(1).TeamNumber),3)+".zip"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if iTeams(0).TeamNumber&gt;iTeams(1).TeamNumber then</SourceLine>
   <SourceLine>return right("0"+str(Game),2)+right("000"+str(iTeams(1).TeamNumber), 3)+right("000"+str(iTeams(0).TeamNumber), 3)+".zip"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return right("0"+str(Game),2)+right("000"+str(iTeams(0).TeamNumber), 3)+right("000"+str(iTeams(1).TeamNumber),3)+".zip"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
