  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>PlayerName as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>PlayerListUpdate</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1219848191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PlayerListUpdate(sqlstring as string, MyList as boolean = false)</SourceLine>
   <SourceLine>dim iRecords as integer=0</SourceLine>
   <SourceLine>dim szMax as string</SourceLine>
   <SourceLine>Dim rs as recordset</SourceLine>
   <SourceLine>dim iTmpCounter as integer=0</SourceLine>
   <SourceLine>dim RPSpent as string //this tracks for each recruit whether we've spent any RPs </SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbPlayerList.DeleteAllRows</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbPlayerList.LoadHeader(split("Name,HT,Reg,Pos,Consensus,SSC,+/-,StDev,Bobby,GH,GHA,PF,Fit%,T75,RP", ","))</SourceLine>
   <SourceLine>lbPlayerList.ColumnWidths = "3*, 0.8*, *, *, 1.5*, *,*,*,*,*,*,*,1.5*, 0.8*,0.8*"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>//figure out if ever in the top 75, which we save as "SzMax"</SourceLine>
   <SourceLine>if rs.IdxField(14).IntegerValue&gt;0 OR rs.IdxField(15).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>szMax=rs.IdxField(14).StringValue+"/"+rs.IdxField(15).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>szMax="--"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(16).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>RPSpent=rs.IdxField(16).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>RPSpent="--"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbPlayerList.addrow rs.IdxField(1).StringValue, inchestoht(rs.IdxField(2).integerValue), rs.IdxField(3).StringValue, rs.IdxField(4).StringValue, rs.IdxField(5).stringvalue, rs.IdxField(6).stringValue,rs.IdxField(7).stringvalue, rs.IdxField(8).stringvalue, rs.idxfield(9).stringvalue, rs.IdxField(10).stringValue, rs.IdxField(11).stringValue, rs.idxfield(12).stringvalue, format(rs.IdxField(13).DoubleValue, "##0.0%"), szMax, RPSpent</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs&lt;&gt;nil then iRecords=rs.RecordCount</SourceLine>
   <SourceLine>lbPlayerList.ColumnAlignment(0)=lbPlayerList.AlignLeft</SourceLine>
   <SourceLine>for n as integer=1 to (lbPlayerList.ColumnCount-1)</SourceLine>
   <SourceLine>lbPlayerList.ColumnAlignment(n)=lbPlayerList.AlignCenter</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear out pressed header</SourceLine>
   <SourceLine>lbPlayerList.HasHeading=false</SourceLine>
   <SourceLine>lbPlayerList.HasHeading=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spentrps.text="RPs Spent:  "+str(RPSum)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>sqlstring as string, MyList as boolean = false</ItemParams>
  <ItemResult></ItemResult>
 </Method>
