  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub NTTPTT(GameType as String)</SourceLine>
   <SourceLine>dim sql as string</SourceLine>
   <SourceLine>dim n, appearances as integer</SourceLine>
   <SourceLine>dim w,l,s16,f4, ch as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lbTotalTeamStatHistory.LoadHeader(split("App,W,L,Pct,Sweet 16,Final 4,Champ", ","))</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.ColumnWidths=".5*,.5*,.5*,.5*.*"</SourceLine>
   <SourceLine>sql="Select Distinct Season FROM TeamHistory WHERE Type LIKE '"+Gametype+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sql)</SourceLine>
   <SourceLine>appearances=0</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>for x as integer=1 to rs.RecordCount</SourceLine>
   <SourceLine>appearances=appearances+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Count(WL) FROM TeamHistory WHERE TYPE LIKE '"+GameType+"' AND WL='W'")</SourceLine>
   <SourceLine>w=CheckNil(rs)</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Count(WL) FROM TeamHistory WHERE TYPE LIKE '"+GameType+"' AND WL='L'")</SourceLine>
   <SourceLine>l=CheckNil(rs)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sql="SELECT Count(*) FROM (Select Distinct teamhistory.season FROM teamhistory, totalteam WHERE teamhistory.season=totalteam.season AND totalteam.sweet16='Y' AND teamhistory.type='"+gametype+"')"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sql)</SourceLine>
   <SourceLine>s16=CheckNil(rs)</SourceLine>
   <SourceLine>sql="SELECT Count(*) FROM (Select Distinct teamhistory.season FROM teamhistory, totalteam WHERE teamhistory.season=totalteam.season AND totalteam.finalfour='Y' AND teamhistory.type='"+gametype+"')"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sql)</SourceLine>
   <SourceLine>f4=CheckNil(rs)</SourceLine>
   <SourceLine>sql="SELECT Count(*) FROM (Select Distinct teamhistory.season FROM teamhistory, totalteam WHERE teamhistory.season=totalteam.season AND totalteam.champ='Y' AND teamhistory.type='"+gametype+"')"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sql)</SourceLine>
   <SourceLine>ch=CheckNil(rs)</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.DeleteAllRows</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.addrow str(appearances), str(w), str(l), format(PctCheck(w,l),".000"), str(s16), str(f4), str(ch)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
