    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action(item As ToolItem)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>Select Case Item.Name</SourceLine>
    <SourceLine>Case "New Team"</SourceLine>
    <SourceLine>DBClose</SourceLine>
    <SourceLine>DBFileNewDB</SourceLine>
    <SourceLine>EnablePrintAll=True</SourceLine>
    <SourceLine>EnableButtons=TRUE</SourceLine>
    <SourceLine>case "Load Team"</SourceLine>
    <SourceLine>LoadDatabase</SourceLine>
    <SourceLine>case "Home"</SourceLine>
    <SourceLine>if DBLoaded then</SourceLine>
    <SourceLine>wndMain.mainpanel.value=0</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>msgbox "You must load a Stats Database before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>case "History"</SourceLine>
    <SourceLine>if DBLoaded then</SourceLine>
    <SourceLine>wndMain.mainpanel.value=2</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>msgbox "You must load a Stats Database before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>case "Current Season"</SourceLine>
    <SourceLine>if DBLoaded then</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>rs=db.SQLSelect("Select Max(Season) as Max from TeamHistory")</SourceLine>
    <SourceLine>prefSeason=str(rs.field("Max").IntegerValue)</SourceLine>
    <SourceLine>wndMain.mainpanel.value=1</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>msgbox "You must load a Stats Database before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>case "PBP Viewer"</SourceLine>
    <SourceLine>fWatchPBP=true</SourceLine>
    <SourceLine>PBPFileImport</SourceLine>
    <SourceLine>case "Recruiting"</SourceLine>
    <SourceLine>if DBLoaded then</SourceLine>
    <SourceLine>wndPrimary.show</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>msgbox "You must load a Stats Database before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>case "Homepage"</SourceLine>
    <SourceLine>showurl "http://sourceforge.net/projects/simsportsutils/"</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
