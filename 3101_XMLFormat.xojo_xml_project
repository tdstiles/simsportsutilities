  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function WinScoreCalc(pts as integer, steals as integer, orebs as integer, drebs as integer, assists as integer, blocks as integer, fga as integer, fta as integer, tos as integer, pfs as integer) As double</SourceLine>
   <SourceLine>'Points + Steals + Offensive Rebounds + ½*Defensive Rebounds + ½*Assists + ½*Blocked Shots – Field Goal Attempts – ½*Free Throw Attempts – Turnovers – ½*Personal Fouls</SourceLine>
   <SourceLine>return pts + steals + orebs + 0.5*drebs + 0.5*assists + 0.5*blocks-fga-0.5*fta-tos-0.5*pfs</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
