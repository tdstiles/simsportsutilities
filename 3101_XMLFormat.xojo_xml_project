  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Rebound()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if player is on same team as previousplayer then reb is O, otherwise D</SourceLine>
   <SourceLine>if AllActions(UBound(AllActions)-1).TeamWithBall=val(iAction.Player(0).Team) then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "oreb", 1) //offensive rebound</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "aoreb", 1) //allowed OReb</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT oreb,dreb FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(0).Number)+"'")</SourceLine>
   <SourceLine>StatReturn=" ("+format(rs.idxfield(1).IntegerValue+rs.idxfield(2).integervalue, "##0")+") "</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" pulls down an offensive rebound"+StatReturn</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "dreb", 1)//defensive rebound</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "adreb", 1)//allowed DReb</SourceLine>
   <SourceLine>rs=svdb.SQLSelect("SELECT oreb, dreb FROM SVTable WHERE TeamNum='"+str(iAction.Player(0).Team)+"' AND PlayerNum='"+str(iAction.Player(0).Number)+"'")</SourceLine>
   <SourceLine>StatReturn=" ("+format(rs.idxfield(1).IntegerValue+rs.idxfield(2).integervalue, "##0")+") "</SourceLine>
   <SourceLine>//Possession for B</SourceLine>
   <SourceLine>TP("B")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+" "+rgStatPossibilities(2).text+StatReturn</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update aTReb for all defenders on floor</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>sqlstring="SELECT aTReb, rowID FROM SVTable WHERE TeamNum="+str(iAction.Player(1).Team)+" AND (Pos=1 OR Pos=2 OR Pos=3 OR Pos=4 OR Pos=5)"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>svdb.SQLExecute("Update SVTable Set aTreb='"+str(rs.IdxField(1).IntegerValue+1)+"' WHERE rowID="+rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>End Sub</SourceLine>
