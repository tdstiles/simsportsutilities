  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function SetPageWidth(AvailableWidth As Integer, MyWidth As String) As Integer</SourceLine>
   <SourceLine>Dim p, aw As Integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>aw = AvailableWidth - 2</SourceLine>
   <SourceLine>MyWidth = Trim(MyWidth)</SourceLine>
   <SourceLine>If Right(MyWidth, 1) = "%" then</SourceLine>
   <SourceLine>p = Val(Left(MyWidth, Len(MyWidth) -1))</SourceLine>
   <SourceLine>Return p * aw / 100</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if Not isNumeric(MyWidth) then</SourceLine>
   <SourceLine>Return aw</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Return Val(MyWidth)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
