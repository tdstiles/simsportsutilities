 <Method>
  <ItemName>ExportAllPlayers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>385189887</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ExportAllPlayers()</SourceLine>
   <SourceLine>dim dlog as SaveAsDialog</SourceLine>
   <SourceLine>dim f as folderItem</SourceLine>
   <SourceLine>dim tout as TextOutputStream</SourceLine>
   <SourceLine>dim header,player as String</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Save Dialog</SourceLine>
   <SourceLine>dlog = New SaveAsDialog</SourceLine>
   <SourceLine>dlog.PromptText = "Export players to"</SourceLine>
   <SourceLine>dlog.SuggestedFileName = "Players.csv"</SourceLine>
   <SourceLine>dlog.Title="Export"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=dlog.ShowModal()</SourceLine>
   <SourceLine>If f&lt;&gt;NIL THEN</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Text File</SourceLine>
   <SourceLine>tout = TextOutputStream.Create( dlog.Result )</SourceLine>
   <SourceLine>if tout = nil then</SourceLine>
   <SourceLine>beep</SourceLine>
   <SourceLine>MsgBox "Export Error" + EndOfLine + EndOfLine + "Could not create the player file."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//info line</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Select All Players</SourceLine>
   <SourceLine>rs =DB.SQLSelect("SELECT * FROM PlayerInfo ORDER BY Region, MyRatingPct DESC")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//write header line</SourceLine>
   <SourceLine>header=writeplayerheader</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Write Players to File</SourceLine>
   <SourceLine>while rs &lt;&gt; nil and not rs.EOF</SourceLine>
   <SourceLine>// Create Player String</SourceLine>
   <SourceLine>Player = trimname(rs.Field("Name").StringValue)</SourceLine>
   <SourceLine>player = player+ chr(44) + rs.Field("Region").StringValue</SourceLine>
   <SourceLine>player=player+chr(44)+rs.field("HSName").StringValue</SourceLine>
   <SourceLine>player = player+ chr(44) + inchestoht(rs.Field("Height").integervalue)</SourceLine>
   <SourceLine>player = player+ chr(44) + rs.Field("Pos").StringValue</SourceLine>
   <SourceLine>player=player+chr(44)+rs.field("MyPosition").StringValue</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("GPA").DoubleValue, "#.0")</SourceLine>
   <SourceLine>player=player+chr(44)+rs.field("Test").StringValue</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("mratingpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(44) + format(rs.Field("myratingpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player=player+chr(44)+ format(rs.field("playerplusminus").DoubleValue, "+##.0")</SourceLine>
   <SourceLine>player=player+chr(44)+ rs.field("EstimatedAttributes").StringValue</SourceLine>
   <SourceLine>player = player+ chr(44) + format(rs.Field("oppratingpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(44) + format(rs.Field("plusminuspct").DoubleValue, "+#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(44) + format(rs.Field("fitpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("statpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("Attpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("PPG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("RPG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("APG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("SPG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("BPG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("TPG").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("Tendex").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("HSSOS").DoubleValue-1, "+#0.0%")</SourceLine>
   <SourceLine>player=player+chr(44)+format(rs.field("NormTendex").DoubleValue, "#0.0")</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("Scout").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("SHT").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("DEF").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("HND").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("REB").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("ATH").IntegerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("Local").integerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("Win").integerValue)</SourceLine>
   <SourceLine>player=player+chr(44)+numtoword(rs.field("Impact").integerValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Write Line</SourceLine>
   <SourceLine>tout.WriteLine player</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Next Player</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Close File</SourceLine>
   <SourceLine>tout.Close</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ExportAllPlayersOriginal</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1315471359</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ExportAllPlayersOriginal()</SourceLine>
   <SourceLine>dim dlog as SaveAsDialog</SourceLine>
   <SourceLine>dim f as folderItem</SourceLine>
   <SourceLine>dim tout as TextOutputStream</SourceLine>
   <SourceLine>dim header,player as String</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Save Dialog</SourceLine>
   <SourceLine>dlog = New SaveAsDialog</SourceLine>
   <SourceLine>dlog.PromptText = "Export players to"</SourceLine>
   <SourceLine>dlog.SuggestedFileName = "Players.txt"</SourceLine>
   <SourceLine>dlog.Title="Export"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=dlog.ShowModal()</SourceLine>
   <SourceLine>If f&lt;&gt;NIL THEN</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Text File</SourceLine>
   <SourceLine>tout = TextOutputStream.Create( dlog.Result )</SourceLine>
   <SourceLine>if tout = nil then</SourceLine>
   <SourceLine>beep</SourceLine>
   <SourceLine>MsgBox "Export Error" + EndOfLine + EndOfLine + "Could not create the player file."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//info line</SourceLine>
   <SourceLine>header="Player Evaluation for: "</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine>header=wndPrimary.txtTeamname.text + chr(44)+"L."+prefleague+chr(44)+chr(44)+"C."+prefconference + chr(44) +"Avg Power Ranking:  "+str(PowerRanking(preflastpr, prefpr2, prefpr3))</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine>header="Player Percentage (Atts vs HS):  " + str(prefplayerpct) + "%" +chr(44) +"Max Scout %:  " + str(15/(15+prefscoutstat)*100)+"%"</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine>tout.writeline</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Select All Players</SourceLine>
   <SourceLine>rs =DB.SQLSelect("SELECT * FROM PlayerInfo ORDER BY Region, MyRatingPct DESC")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//write header line</SourceLine>
   <SourceLine>header=writeplayerheader</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine>n=0</SourceLine>
   <SourceLine>// Write Players to File</SourceLine>
   <SourceLine>while rs &lt;&gt; nil and not rs.EOF</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>// Create Player String</SourceLine>
   <SourceLine>Player = trimname(rs.Field("Name").StringValue) +chr(32)</SourceLine>
   <SourceLine>player = player+ chr(9) + rs.Field("Height").StringValue</SourceLine>
   <SourceLine>player = player+ chr(9) + rs.Field("Pos").StringValue</SourceLine>
   <SourceLine>player = player+ chr(9) + rs.Field("Region").StringValue</SourceLine>
   <SourceLine>player = player+ chr(9) + format(rs.Field("myratingpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(9) + format(rs.Field("oppratingpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(9) + format(rs.Field("plusminuspct").DoubleValue, "+#00.0%")</SourceLine>
   <SourceLine>player = player+ chr(9) + format(rs.Field("fitpct").DoubleValue, "#00.0%")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Write Line</SourceLine>
   <SourceLine>tout.WriteLine player</SourceLine>
   <SourceLine>if n=24 then</SourceLine>
   <SourceLine>tout.writeline</SourceLine>
   <SourceLine>tout.writeline header</SourceLine>
   <SourceLine>n=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>// Next Player</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Close File</SourceLine>
   <SourceLine>tout.Close</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
