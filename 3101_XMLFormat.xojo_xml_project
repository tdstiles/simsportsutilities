   <SourceLine>else</SourceLine>
   <SourceLine>avgF=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.DeleteAllRows</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.AddRow str(confw),str(confl),format(PctCheck(confw,confl),".000"),str(title),format(avgF,"0.0")</SourceLine>
   <SourceLine>case "Conf. Tourney"</SourceLine>
   <SourceLine>lbTotalTeamStatHistory.LoadHeader(split("W,L,Pct,Conf. Tourn. Title", ","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Sum(WL='W'),Sum(WL='L') FROM TeamHistory WHERE TYPE LIKE 'Conf.%' AND Game&lt;=24")</SourceLine>
   <SourceLine>If rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
