   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function STDEVCalc(numbers() as double) As double</SourceLine>
   <SourceLine>dim mean, sum,a,b,c as double</SourceLine>
   <SourceLine>dim elements as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(numbers)</SourceLine>
   <SourceLine>for x as integer=0 to l</SourceLine>
   <SourceLine>elements=elements+1</SourceLine>
   <SourceLine>sum=sum+numbers(x)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mean=sum/elements</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=0 to l</SourceLine>
   <SourceLine>a=Numbers(x)-mean</SourceLine>
   <SourceLine>a=a*a</SourceLine>
   <SourceLine>b=b+a</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>c=b/elements</SourceLine>
   <SourceLine>return Sqrt(c)</SourceLine>
   <SourceLine>End Function</SourceLine>
