 <Method>
  <ItemName>LoadStatsBox</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1519958015</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadStatsBox(Team as integer, ListName as Integer)</SourceLine>
   <SourceLine>#Pragma DisableBackgroundTasks</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs,rec as RecordSet</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim clause as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>statbox.DeleteAllRows</SourceLine>
   <SourceLine>team=team+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Select Case Listname</SourceLine>
   <SourceLine>Case 0</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,Min,FGM,FGA,FG%,3M,3A,3%,FTM,FTA,FT%,Reb,Ast,Blk,Stl,TOs,Fouls,Pts",","))</SourceLine>
   <SourceLine>statbox.ColumnWidths = "85.78,*,1.1*,*,1.1*,1.3*,*,*,1.3*,*,*,1.3*,*,*,*,*,1.1*"</SourceLine>
   <SourceLine>Case 1</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,shrtM,shrtA,shrt%,midM,midA,mid%,longM,longA,long% ",","))</SourceLine>
   <SourceLine>statbox.ColumnWidths = "85.78,*"</SourceLine>
   <SourceLine>Case 2</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,aFGM,aFGA,aFG%,aF3M,aF3A,aPts,Blk,Stl,crTO,aPt/TP", ","))</SourceLine>
   <SourceLine>statbox.ColumnWidths="85.78,*"</SourceLine>
   <SourceLine>Case 3</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,OReb,DReb,aOReb,aDReb,aTReb,Reb%,LostP,LostD,crTO,PUs,Touch,t/TP,aPt/TP,Pt/TP", ","))</SourceLine>
   <SourceLine>statbox.ColumnWidths = "85.78,0.95*,0.95*,1.1*,1.1*,1.1*,1.1*,*,*,*,.85*,.*,*,1.1*,1.1*"</SourceLine>
   <SourceLine>Case 4</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,FD,t/FD,FT/FD,Ar,Ar/FGM,shBlkd,shBlk%,crTO/TP,t/TO, +/-,SVx", ","))</SourceLine>
   <SourceLine>statbox.ColumnWidths = "85.78,*,*,*,.7*,1.1*,*"</SourceLine>
   <SourceLine>Case 5</SourceLine>
   <SourceLine>statbox.LoadHeader(split("Name,Pos,Eff,aEff,+/-Eff,Ast/TO,Tendex,SecTendex,Shot%,Rating,NBS", ","))</SourceLine>
   <SourceLine>statbox.ColumnWidths="85.78,*"</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim list as listbox</SourceLine>
   <SourceLine>dim a,b,c,d as Double</SourceLine>
   <SourceLine>dim name as string</SourceLine>
   <SourceLine>dim reb as integer</SourceLine>
   <SourceLine>dim mins as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 12</SourceLine>
   <SourceLine>statbox.addrow ""</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>clause=" WHERE TeamNum='"+str(team)+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Select Name,SecondsPlayed,FGM,FGA,FG3M,FG3A, FTM,FTA,Blk,Stl,Ast,Fouls,Pts,TOs,shrtM,shrtA,medM,MedA,longM,LongA,aFGM,aFGA,aFG3M,aFG3A,aPts,FD,Touches,Ar,shblkd,PlusMinus,OReb,DReb,aOReb,aDReb,aTReb,LostD,LostP,crTO,PUs,TP,InitialPos FROM SVTable"+ clause+" AND SecondsPlayed&gt;0 ORDER BY Name ASC"</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
   <SourceLine>name=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>reb=rs.Field("OReb").IntegerValue+rs.Field("DReb").IntegerValue</SourceLine>
   <SourceLine>mins=format(rs.field("SecondsPlayed").IntegerValue/60,"##0")</SourceLine>
   <SourceLine>if name &lt;&gt;"" AND name&lt;&gt;"--" then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get a list of the values we want</SourceLine>
   <SourceLine>dim columnshere(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case listname</SourceLine>
   <SourceLine>case 0 //box score</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+mins+","+ format(rs.field("FGM").integerValue,"#0")+","+ format(rs.field("FGA").integerValue,"#0")+","+ format(DivChk(rs.field("FGM").IntegerValue,rs.field("FGA").Integervalue),"#0.0%")+","+ format(rs.field("FG3M").integerValue,"#0")+","+ format(rs.field("FG3A").integerValue,"#0")+","+ format(DivChk(rs.field("FG3M").IntegerValue,rs.field("FG3A").Integervalue),"#0.0%")+","+ format(rs.field("FTM").integervalue,"#0")+","+ format(rs.field("FTA").integervalue,"#0")+","+ format(DivChk(rs.field("FTM").IntegerValue,rs.field("FTA").Integervalue),"#0.0%")+","+ format(reb,"#0")+","+ format(rs.field("Ast").integervalue,"#0")+","+ format(rs.field("Blk").integervalue,"#0")+","+ format(rs.field("Stl").integervalue,"#0")+","+ format(rs.field("TOs").integervalue,"#0")+","+ format(rs.field("Fouls").integervalue,"#0")+","+ format(rs.field("Pts").IntegerValue,"#0"),",")</SourceLine>
   <SourceLine>case 1 //shooting</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+format(rs.field("shrtM").integervalue,"#0")+","+ format(rs.field("shrtA").integervalue,"#0")+","+ format(DivChk(rs.field("shrtM").IntegerValue,rs.field("shrtA").Integervalue),"#0.0%")+","+ format(rs.field("medM").integervalue,"#0")+","+ format(rs.field("medA").integervalue,"#0")+","+ format(DivChk(rs.field("medM").IntegerValue,rs.field("medA").Integervalue),"#0.0%")+","+ format(rs.field("longM").integervalue,"#0")+","+ format(rs.field("longA").integervalue,"#0")+","+ format(DivChk(rs.field("longM").IntegerValue,rs.field("longA").Integervalue),"#0.0%"),",")</SourceLine>
   <SourceLine>case 4 //defense</SourceLine>
   <SourceLine>a=(SVxCalc(rs.field("FGM").IntegerValue,rs.field("FG3M").IntegerValue,reb,rs.field("Ast").IntegerValue,rs.field("Blk").IntegerValue,rs.field("Stl").IntegerValue,rs.field("FTM").IntegerValue,rs.field("FTA").IntegerValue,rs.field("FGA").IntegerValue,rs.field("TOs").IntegerValue,rs.field("Fouls").IntegerValue,val(mins)))</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+format(rs.field("FD").integervalue,"#0")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("FD").IntegerValue),"#0.0")+","+ format(DivChk(rs.field("FTA").IntegerValue,rs.field("FD").IntegerValue),"#0.0")+","+ format(rs.field("Ar").integervalue,"#0")+","+ format(DivChk(rs.field("Ar").IntegerValue,rs.field("FGM").IntegerValue),"#0.0")+","+ format(rs.field("shblkd").integervalue,"#0")+","+ format(DivChk(rs.field("shblkd").IntegerValue,rs.field("FGA").IntegerValue),"#0.0%")+","+ format(DivChk(rs.field("crTO").IntegerValue,rs.field("TP").IntegerValue),"#0.00")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("TOs").IntegerValue),"#0.0")+","+ format(rs.field("PlusMinus").IntegerValue,"+###")+","+ format(a,"###0"),",")</SourceLine>
   <SourceLine>case 3 //rebounding</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+format(rs.field("OReb").integervalue,"#0")+","+ format(rs.field("DReb").integervalue,"#0")+","+ format(rs.field("aOReb").integervalue,"#0")+","+ format(rs.field("aDReb").integervalue,"#0")+","+ format(rs.field("aTReb").integervalue,"#0")+","+ format(DivChk(reb,rs.field("aTReb").IntegerValue),"#0.0%")+","+ format(rs.field("LostP").integervalue,"#0")+","+ format(rs.field("LostD").integervalue,"#0")+","+ format(rs.field("crTO").integervalue,"#0")+","+ format(rs.field("PUs").integervalue,"#0")+","+ format(rs.field("Touches").integervalue,"#0")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("TP").IntegerValue),"#0.0")+","+ format(DivChk(rs.field("aPts").IntegerValue,rs.field("TP").IntegerValue),"#0.00")+","+ format(DivChk(rs.field("Pts").IntegerValue,rs.field("TP").IntegerValue),"#0.00"),",")</SourceLine>
   <SourceLine>case 2</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+format(rs.field("aFGM").integervalue,"#0")+","+ format(rs.field("aFGA").integervalue,"#0")+","+ format(DivChk(rs.field("aFGM").IntegerValue,rs.field("aFGA").Integervalue),"#0.0%")+","+ format(rs.field("aFG3M").integervalue,"#0")+","+ format(rs.field("aFG3A").integervalue,"#0")+","+ format(rs.field("aPts").integervalue,"#0")+","+ format(rs.field("Blk").integervalue,"#0")+","+ format(rs.field("stl").integervalue,"#0")+","+ format(rs.field("crTO").integervalue,"#0")+","+ format(DivChk(rs.field("aPts").IntegerValue,rs.field("TP").IntegerValue),"#0.00"),",")</SourceLine>
   <SourceLine>case 5 //efficiency</SourceLine>
   <SourceLine>a=EfficiencyCalc(rs.field("Pts").IntegerValue,rs.field("FGA").IntegerValue,rs.field("TOS").IntegerValue)</SourceLine>
   <SourceLine>b=EfficiencyCalc(rs.field("aPts").IntegerValue,rs.field("aFGA").IntegerValue,rs.field("crTO").IntegerValue)</SourceLine>
   <SourceLine>c=EffectivenessCalc(rs.field("oreb").IntegerValue,rs.field("dreb").IntegerValue,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("pts").IntegerValue,rs.field("fga").IntegerValue,rs.field("fta").IntegerValue,rs.field("tos").IntegerValue,val(mins))</SourceLine>
   <SourceLine>d=ninjabovinescore(rs.field("FGM").IntegerValue,rs.field("ftm").IntegerValue,rs.field("fg3m").IntegerValue,reb,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("Pus").IntegerValue,rs.field("plusminus").IntegerValue,rs.field("fga").IntegerValue,rs.field("fta").IntegerValue,rs.field("tos").IntegerValue,rs.field("fouls").IntegerValue)</SourceLine>
   <SourceLine>columnshere=split(Name+","+ mthdplayerposition(rs.field("InitialPos").stringvalue)+","+format(a,"#0.00")+","+ format(b,"#0.00")+","+ format(a-b,"+#0.00")+","+ format(DivChk(rs.field("Ast").IntegerValue,rs.field("TOS").IntegerValue),"0.0")+","+format(NewTendexCalc(rs.field("pts").IntegerValue,rs.field("fgm").IntegerValue,rs.field("fga").IntegerValue,rs.field("FG3M").IntegerValue,rs.field("Stl").IntegerValue,rs.field("blk").IntegerValue,reb,rs.field("tos").IntegerValue,rs.field("fouls").IntegerValue,rs.field("fta").IntegerValue,rs.field("ftm").IntegerValue,val(mins),rs.field("ast").IntegerValue),"#0.0")+","+ format(SecondaryTendexCalc(reb,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("tos").IntegerValue,val(mins))*30,"#0.0")+","+ format(DivChk(rs.Field("fga").IntegerValue,rs.field("tp").IntegerValue),"#0.0%")+","+ format(c,"#.000")+","+ format(d,"+####.0"),",")</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rownum as integer</SourceLine>
   <SourceLine>rownum=BoxScoreModule.BoxPositions.IndexOf(mthdplayerposition(rs.field("InitialPos").StringValue))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to ubound(columnshere)</SourceLine>
   <SourceLine>statbox.cell(rownum,j)=columnshere(j)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load up starters, bench players, and team stats</SourceLine>
   <SourceLine>//clause=" WHERE TeamNum='"+str(team)+"'"</SourceLine>
   <SourceLine>//AND SecondsPlayed&gt;0 GROUP BY TeamNum"</SourceLine>
   <SourceLine>dim teamclause(2) as string</SourceLine>
   <SourceLine>dim listclause(2) as string=split("Starters,Bench,Team", ",")</SourceLine>
   <SourceLine>teamclause(0)=" AND initialpos NOT LIKE 'b%' AND SecondsPlayed&gt;0 GROUP BY TeamNum"</SourceLine>
   <SourceLine>teamclause(1)=" AND initialpos LIKE 'b%' AND SecondsPlayed&gt;0 GROUP BY TeamNum"</SourceLine>
   <SourceLine>teamclause(2)=" AND SecondsPlayed&gt;0 GROUP BY TeamNum"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>//now load up team stats at the bottom</SourceLine>
   <SourceLine>sqlstring="Select Sum(FGM) as FGM,Sum(FGA) as FGA,Sum(FG3M) as FG3M,Sum(FG3A) as FG3A,Sum(FTM) as FTM,Sum(FTA) as FTA,Sum(Blk) as Blk,Sum(Stl) as Stl,Sum(Ast) as Ast,Sum(Fouls) as Fouls,Sum(Pts) as Pts,Sum(TOs) as TOs,Sum(shrtM) as shrtM,Sum(shrtA) as shrtA,Sum(medM) as medM,Sum(MedA) as MedA,Sum(longM) as longM,Sum(LongA) as longA,Sum(aFGM) as aFGM,Sum(aFGA) as aFGA,Sum(aFG3M) as aFG3M,Sum(aFG3A) as aFG3A,Sum(aPts) as aPts,Sum(FD) as FD,Sum(Touches) as Touches,Sum(Ar) as AR,Sum(shblkd) as shblkd,Sum(PlusMinus) as PlusMinus,Sum(OReb) as OReb,Sum(DReb) as DReb,Sum(aOReb) as aOReb,Sum(aDReb) as aDReb,Sum(aTReb) as aTReb,Sum(LostD) as lostD,Sum(LostP) as lostP,Sum(crTO) as crTO,Sum(PUs) as PUs,Sum(TP) as TP FROM SVTable"+ clause+teamclause(n)</SourceLine>
   <SourceLine>rs=svdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>name=listclause(n)</SourceLine>
   <SourceLine>reb=rs.Field("OReb").IntegerValue+rs.Field("DReb").IntegerValue</SourceLine>
   <SourceLine>mins="--"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get a list of the values we want</SourceLine>
   <SourceLine>dim columnshere(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case listname</SourceLine>
   <SourceLine>case 0 //box score</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+mins+","+ format(rs.field("FGM").integerValue,"#0")+","+ format(rs.field("FGA").integerValue,"#0")+","+ format(DivChk(rs.field("FGM").IntegerValue,rs.field("FGA").Integervalue),"#0.0%")+","+ format(rs.field("FG3M").integerValue,"#0")+","+ format(rs.field("FG3A").integerValue,"#0")+","+ format(DivChk(rs.field("FG3M").IntegerValue,rs.field("FG3A").Integervalue),"#0.0%")+","+ format(rs.field("FTM").integervalue,"#0")+","+ format(rs.field("FTA").integervalue,"#0")+","+ format(DivChk(rs.field("FTM").IntegerValue,rs.field("FTA").Integervalue),"#0.0%")+","+ format(reb,"#0")+","+ format(rs.field("Ast").integervalue,"#0")+","+ format(rs.field("Blk").integervalue,"#0")+","+ format(rs.field("Stl").integervalue,"#0")+","+ format(rs.field("TOs").integervalue,"#0")+","+ format(rs.field("Fouls").integervalue,"#0")+","+ format(rs.field("Pts").IntegerValue,"#0"),",")</SourceLine>
   <SourceLine>case 1 //shooting</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+format(rs.field("shrtM").integervalue,"#0")+","+ format(rs.field("shrtA").integervalue,"#0")+","+ format(DivChk(rs.field("shrtM").IntegerValue,rs.field("shrtA").Integervalue),"#0.0%")+","+ format(rs.field("medM").integervalue,"#0")+","+ format(rs.field("medA").integervalue,"#0")+","+ format(DivChk(rs.field("medM").IntegerValue,rs.field("medA").Integervalue),"#0.0%")+","+ format(rs.field("longM").integervalue,"#0")+","+ format(rs.field("longA").integervalue,"#0")+","+ format(DivChk(rs.field("longM").IntegerValue,rs.field("longA").Integervalue),"#0.0%"),",")</SourceLine>
   <SourceLine>case 4 //defense</SourceLine>
   <SourceLine>a=(SVxCalc(rs.field("FGM").IntegerValue,rs.field("FG3M").IntegerValue,reb,rs.field("Ast").IntegerValue,rs.field("Blk").IntegerValue,rs.field("Stl").IntegerValue,rs.field("FTM").IntegerValue,rs.field("FTA").IntegerValue,rs.field("FGA").IntegerValue,rs.field("TOs").IntegerValue,rs.field("Fouls").IntegerValue,val(mins)))</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+format(rs.field("FD").integervalue,"#0")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("FD").IntegerValue),"#0.0")+","+ format(DivChk(rs.field("FTA").IntegerValue,rs.field("FD").IntegerValue),"#0.0")+","+ format(rs.field("Ar").integervalue,"#0")+","+ format(DivChk(rs.field("Ar").IntegerValue,rs.field("FGM").IntegerValue),"#0.0")+","+ format(rs.field("shblkd").integervalue,"#0")+","+ format(DivChk(rs.field("shblkd").IntegerValue,rs.field("FGA").IntegerValue),"#0.0%")+","+ format(DivChk(rs.field("crTO").IntegerValue,rs.field("TP").IntegerValue),"#0.00")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("TOs").IntegerValue),"#0.0")+","+ format(rs.field("PlusMinus").IntegerValue,"+###")+","+ format(a,"###0"),",")</SourceLine>
   <SourceLine>case 3 //rebounding</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+format(rs.field("OReb").integervalue,"#0")+","+ format(rs.field("DReb").integervalue,"#0")+","+ format(rs.field("aOReb").integervalue,"#0")+","+ format(rs.field("aDReb").integervalue,"#0")+","+ format(rs.field("aTReb").integervalue,"#0")+","+ format(DivChk(reb,rs.field("aTReb").IntegerValue),"#0.0%")+","+ format(rs.field("LostP").integervalue,"#0")+","+ format(rs.field("LostD").integervalue,"#0")+","+ format(rs.field("crTO").integervalue,"#0")+","+ format(rs.field("PUs").integervalue,"#0")+","+ format(rs.field("Touches").integervalue,"#0")+","+ format(DivChk(rs.field("Touches").IntegerValue,rs.field("TP").IntegerValue),"#0.0")+","+ format(DivChk(rs.field("aPts").IntegerValue,rs.field("TP").IntegerValue),"#0.00")+","+ format(DivChk(rs.field("Pts").IntegerValue,rs.field("TP").IntegerValue),"#0.00"),",")</SourceLine>
   <SourceLine>case 2</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+format(rs.field("aFGM").integervalue,"#0")+","+ format(rs.field("aFGA").integervalue,"#0")+","+ format(DivChk(rs.field("aFGM").IntegerValue,rs.field("aFGA").Integervalue),"#0.0%")+","+ format(rs.field("aFG3M").integervalue,"#0")+","+ format(rs.field("aFG3A").integervalue,"#0")+","+ format(rs.field("aPts").integervalue,"#0")+","+ format(rs.field("Blk").integervalue,"#0")+","+ format(rs.field("stl").integervalue,"#0")+","+ format(rs.field("crTO").integervalue,"#0")+","+ format(DivChk(rs.field("aPts").IntegerValue,rs.field("TP").IntegerValue),"#0.00"),",")</SourceLine>
   <SourceLine>case 5 //efficiency</SourceLine>
   <SourceLine>a=EfficiencyCalc(rs.field("Pts").IntegerValue,rs.field("FGA").IntegerValue,rs.field("TOS").IntegerValue)</SourceLine>
   <SourceLine>b=EfficiencyCalc(rs.field("aPts").IntegerValue,rs.field("aFGA").IntegerValue,rs.field("crTO").IntegerValue)</SourceLine>
   <SourceLine>c=EffectivenessCalc(rs.field("oreb").IntegerValue,rs.field("dreb").IntegerValue,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("pts").IntegerValue,rs.field("fga").IntegerValue,rs.field("fta").IntegerValue,rs.field("tos").IntegerValue,val(mins))</SourceLine>
   <SourceLine>d=ninjabovinescore(rs.field("FGM").IntegerValue,rs.field("ftm").IntegerValue,rs.field("fg3m").IntegerValue,reb,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("Pus").IntegerValue,rs.field("plusminus").IntegerValue,rs.field("fga").IntegerValue,rs.field("fta").IntegerValue,rs.field("tos").IntegerValue,rs.field("fouls").IntegerValue)</SourceLine>
   <SourceLine>columnshere=split(Name+",--,"+format(a,"#0.00")+","+ format(b,"#0.00")+","+ format(a-b,"+#0.00")+","+ format(DivChk(rs.field("Ast").IntegerValue,rs.field("TOS").IntegerValue),"0.0")+","+format(NewTendexCalc(rs.field("pts").IntegerValue,rs.field("fgm").IntegerValue,rs.field("fga").IntegerValue,rs.field("FG3M").IntegerValue,rs.field("Stl").IntegerValue,rs.field("blk").IntegerValue,reb,rs.field("tos").IntegerValue,rs.field("fouls").IntegerValue,rs.field("fta").IntegerValue,rs.field("ftm").IntegerValue,val(mins),rs.field("ast").IntegerValue),"#0.0")+","+ format(SecondaryTendexCalc(reb,rs.field("ast").IntegerValue,rs.field("stl").IntegerValue,rs.field("blk").IntegerValue,rs.field("tos").IntegerValue,val(mins))*30,"#0.0")+","+ format(DivChk(rs.Field("fga").IntegerValue,rs.field("tp").IntegerValue),"#0.0%")+","+ format(c,"#.000")+","+ format(d,"+####.0"),",")</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to ubound(columnshere)</SourceLine>
   <SourceLine>statbox.cell(10+n,j)=columnshere(j)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>#Pragma BackgroundTasks True</SourceLine>
   <SourceLine>End Sub</SourceLine>
