 <Method>
  <ItemName>PrintHeader</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1798125567</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PrintHeader(g As Graphics, ps As PrinterSetup, lb As Listbox) As Integer</SourceLine>
   <SourceLine>Dim startY, maxY, topY, xPos As Integer</SourceLine>
   <SourceLine>Dim Heading, HeaderContent As String</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>g.TextSize = g.TextSize + 2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Vpos = vPos</SourceLine>
   <SourceLine>topY = vPos - TextHeight</SourceLine>
   <SourceLine>xPos = 1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(headers)</SourceLine>
   <SourceLine>for i as integer= 0 to l</SourceLine>
   <SourceLine>if Wrap then</SourceLine>
   <SourceLine>if ColumnWidths(i) &gt; 0 then maxY = Max(maxY, g.StringHeight( Headers(i), ColumnWidths(i)) + 4 )</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>maxY = TextHeight</SourceLine>
   <SourceLine>Exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim r as integer=ubound(headers)</SourceLine>
   <SourceLine>for i as integer= 0 to r</SourceLine>
   <SourceLine>if ColumnWidths(i) &gt; 0 then</SourceLine>
   <SourceLine>// First, draw the cell background</SourceLine>
   <SourceLine>g.ForeColor = &amp;cE0E0E0</SourceLine>
   <SourceLine>g.FillRect(xPos, topY, ColumnWidths(i) + PixelScale(ps, 4), maxY)</SourceLine>
   <SourceLine>// Next, draw the cell border</SourceLine>
   <SourceLine>g.ForeColor = &amp;cC0C0C0</SourceLine>
   <SourceLine>g.DrawRect(xPos, topY, ColumnWidths(i) + PixelScale(ps, 4), maxY)</SourceLine>
   <SourceLine>// Next, draw the text</SourceLine>
   <SourceLine>g.ForeColor = &amp;c000000</SourceLine>
   <SourceLine>if Wrap then</SourceLine>
   <SourceLine>HeaderContent  = Headers(i)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>HeaderContent = TruncateString(g, Headers(i), ColumnWidths(i), true)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>g.DrawString( HeaderContent, xPos+PixelScale(ps, 2), vPos-PixelScale(ps, 2), ColumnWidths(i) )</SourceLine>
   <SourceLine>xPos = xPos + ColumnWidths(i) + PixelScale(ps, 4)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>g.TextSize = g.TextSize -2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return vPos + maxY</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>g As Graphics, ps As PrinterSetup, lb As Listbox</ItemParams>
  <ItemResult>Integer</ItemResult>
 </Method>
 <Method>
  <ItemName>PrintListBox</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>246409215</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PrintListBox(ByRef g As Graphics, ByRef ps As PrinterSetup, lb As Listbox, startPos As Integer = 0, Wrapped As Boolean = false, BoxWidth As String = "100%", StartRow As Integer = 0, EndRow As Integer = - 1)</SourceLine>
   <SourceLine>Dim rowEnd As Integer</SourceLine>
   <SourceLine>Redim ColumnWidths(-1)</SourceLine>
   <SourceLine>Redim Headers(-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>g.TextFont = lb.TextFont</SourceLine>
   <SourceLine>g.TextSize = TextScale(ps, lb.TextSize)</SourceLine>
   <SourceLine>g.Bold = false</SourceLine>
   <SourceLine>g.Underline = false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TextHeight = g.TextHeight() + PixelScale(ps, 2)</SourceLine>
   <SourceLine>PageHeight  = ps.Height</SourceLine>
   <SourceLine>PageWidth = SetPageWidth(ps.Width, BoxWidth)</SourceLine>
   <SourceLine>Wrap = Wrapped</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>CreateCheckBoxes(lb)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>vPos = startPos</SourceLine>
   <SourceLine>CurrentRow = 0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>GetHeaders(lb)</SourceLine>
   <SourceLine>SetColumnWidths(ps, lb)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>vPos = PrintHeader(g, ps, lb)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if EndRow &gt; -1 then</SourceLine>
   <SourceLine>rowEnd = EndRow</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>rowEnd = lb.ListCount-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For i as integer = StartRow to rowEnd</SourceLine>
   <SourceLine>vPos = printRow(g, ps, lb, i)</SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine></SourceLine>
