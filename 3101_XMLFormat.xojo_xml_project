 <Method>
  <ItemName>SaveAsString</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1606393855</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function SaveAsString() As string</SourceLine>
   <SourceLine>//This method goes through "choices" and the builds a string lie</SourceLine>
   <SourceLine>//5#hits,2#makes,2#sinks,1#nails,1#drains</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim ap(-1) as PossibleStrings</SourceLine>
   <SourceLine>dim posstring as PossibleStrings</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim tf as boolean</SourceLine>
   <SourceLine>dim iCount as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>posstring.text=Choices(0)</SourceLine>
   <SourceLine>posstring.frequency=1</SourceLine>
   <SourceLine>ap.append posstring</SourceLine>
   <SourceLine>dim iCounter as integer=ubound(Choices)</SourceLine>
   <SourceLine>for n as integer=1 to iCounter</SourceLine>
   <SourceLine>tf=true</SourceLine>
   <SourceLine>iCount=UBound(ap)</SourceLine>
   <SourceLine>for l as integer=0 to iCount</SourceLine>
   <SourceLine>If Choices(n)=ap(l).text then</SourceLine>
   <SourceLine>ap(l).frequency=ap(l).frequency+1</SourceLine>
   <SourceLine>tf=false</SourceLine>
   <SourceLine>exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if tf then</SourceLine>
   <SourceLine>//nowhere else in the string, so we need to add it</SourceLine>
   <SourceLine>posstring.text=Choices(n)</SourceLine>
   <SourceLine>posstring.frequency=1</SourceLine>
   <SourceLine>ap.append posstring</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iCount=UBound(ap)</SourceLine>
   <SourceLine>for n as integer=0 to iCount-1</SourceLine>
   <SourceLine>sbstring.append str(ap(n).frequency)+"#"+ap(n).text+","</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append  str(ap(iCount).frequency)+"#"+ap(iCount).text</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
