 <Method>
  <ItemName>UpdateInfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1999939583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdateInfo()</SourceLine>
   <SourceLine>dim rs, ars, brs as RecordSet</SourceLine>
   <SourceLine>dim k as string</SourceLine>
   <SourceLine>dim maxseason,maxgame as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefTeamNum=gTeams.indexof(efteamname.text)+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE TeamInfo SET TeamName='"+efteamname.text+"', League='"+efleague.Text+"', Region='"+efconference.text+"', lastpr='"+efpr.text+"', PR2='"+eflastpr.text+"',PR3='"+efpr2.text+"',TeamID='"+str(prefTeamNum)+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT max(season) FROM Stats")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>maxseason=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT max(game) FROM Stats WHERE Season='"+maxseason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>maxgame=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>if maxgame&lt;&gt;"24" then //not first game of season yet</SourceLine>
   <SourceLine>sqlstring="UPDATE TotalTeam SET PowerRanking='"+efpr.text+"' WHERE Season='"+maxseason+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ars=db.SQLSelect("SELECT * FROM TotalTeam WHERE Season='"+str(val(maxseason)-1)+"'")</SourceLine>
   <SourceLine>if ars&lt;&gt;nil and ars.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>sqlstring="UPDATE TotalTeam SET PowerRanking='"+eflastpr.text+"' WHERE Season='"+str(val(maxseason)-1)+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>brs=db.SQLSelect("SELECT * FROM TotalTeam WHERE Season='"+str(val(maxseason)-2)+"'")</SourceLine>
   <SourceLine>if brs&lt;&gt;nil and ars.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>sqlstring="UPDATE TotalTeam SET PowerRanking='"+efpr2.text+"' WHERE Season='"+str(val(maxseason)-2)+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="UPDATE TotalTeam SET PowerRanking='"+eflastpr.text+"' WHERE Season='"+maxseason+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ars=db.SQLSelect("SELECT * FROM TotalTeam WHERE Season='"+str(val(maxseason)-1)+"'")</SourceLine>
   <SourceLine>if ars&lt;&gt;nil and ars.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE TotalTeam SET PowerRanking='"+efPR2.text+"' WHERE Season='"+str(val(maxseason)-1)+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("Select TeamName, League, Region from teamInfo")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>wndMain.title="SimSportsConsole:  "+rs.idxfield(1).StringValue+ "   League: "+rs.idxField(2).stringValue+"  Conference: "+rs.idxfield(3).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's deal with the name and/or password issues here</SourceLine>
   <SourceLine>if efID.text&lt;&gt;"" and efPassword.text&lt;&gt;"" then</SourceLine>
   <SourceLine>prefUserName=efID.text</SourceLine>
   <SourceLine>prefPassword=efPassword.text</SourceLine>
   <SourceLine>sqlstring="Update MyKeys SET Value='"+prefUserName+"' WHERE Key='UserName'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Update MyKeys SET Value='"+prefPassword+"' WHERE Key='Password'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
