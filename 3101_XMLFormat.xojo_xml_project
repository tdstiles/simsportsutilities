 <ControlBehavior>
  <Superclass>PushButton</Superclass>
  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>374472703</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim tout as TextOutputStream</SourceLine>
    <SourceLine>dim k as FolderItem</SourceLine>
    <SourceLine>dim htmlstring as string</SourceLine>
    <SourceLine>dim mystring as string</SourceLine>
    <SourceLine>dim iColumns as integer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>k= SpecialFolder.Desktop.child("TeamHistory.txt")</SourceLine>
    <SourceLine>htmlstring="{{LeagueCompass|LID="+prefleague+"|minS="+lbAllSeasons.cell(0,0)+"}}"+EndOfLine</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if k.exists=false then</SourceLine>
    <SourceLine>// Create Text File</SourceLine>
    <SourceLine>tout = TextOutputStream.Create( k )</SourceLine>
    <SourceLine>if tout = nil then</SourceLine>
    <SourceLine>MsgBox "Export Error" + EndOfLine + EndOfLine + "Could not create the game file."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//tout.writeline</SourceLine>
    <SourceLine>dim mycolumns(-1) as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now loop through and set the rows</SourceLine>
    <SourceLine>iColumns=lbAllSeasons.ColumnCount-1</SourceLine>
    <SourceLine>redim mycolumns(-1)</SourceLine>
    <SourceLine>for n as integer=0 to iColumns</SourceLine>
    <SourceLine>//set the headings as all the current columns</SourceLine>
    <SourceLine>mycolumns.append lbAllSeasons.heading(n)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//add in custom columns</SourceLine>
    <SourceLine>mycolumns.append "PPG"</SourceLine>
    <SourceLine>mycolumns.append "aPPG"</SourceLine>
    <SourceLine>mycolumns.append "Reb"</SourceLine>
    <SourceLine>mycolumns.append "Ast"</SourceLine>
    <SourceLine>mycolumns.append "Stl"</SourceLine>
    <SourceLine>mycolumns.append "Blk"</SourceLine>
    <SourceLine>mycolumns.append "TOs"</SourceLine>
    <SourceLine>htmlstring=htmlstring+TableGeneratorTitle("Team History",mycolumns,0,1)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now add in the info from the table</SourceLine>
    <SourceLine>dim S as cTeamSeason</SourceLine>
    <SourceLine>for n as integer=0 to lbAllSeasons.ListCount-1</SourceLine>
    <SourceLine>S=new cTeamSeason(lbAllSeasons.cell(n,0))</SourceLine>
    <SourceLine>mystring=S.mSeason</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for r as integer=1 to iColumns</SourceLine>
    <SourceLine>mystring=mystring+"*"+lbAllSeasons.cell(n,r)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mystring=mystring+"*"+format(S.PPG,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.aPPG,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.REB,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.AST,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.STL,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.BLK,"##0.0")+"*"</SourceLine>
    <SourceLine>mystring=mystring+format(S.TOS,"##0.0")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mycolumns=split(mystring, "*")</SourceLine>
    <SourceLine>htmlstring=htmlstring+ColumnGenerator(n,mycolumns)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>htmlstring=htmlstring+CloseTable</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now we do one for each type of poptournlist as well</SourceLine>
    <SourceLine>for nn as integer=0 to 8</SourceLine>
    <SourceLine>//go through for each variation</SourceLine>
    <SourceLine>popTournList.ListIndex=nn</SourceLine>
    <SourceLine>iColumns=lbTotalTeamStatHistory.ColumnCount-1</SourceLine>
    <SourceLine>redim mycolumns(-1)</SourceLine>
    <SourceLine>for n as integer=0 to iColumns</SourceLine>
    <SourceLine>mycolumns.append lbTotalTeamStatHistory.heading(n)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>htmlstring=htmlstring+TableGeneratorTitle(popTournList.text,mycolumns)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//header is done.  now we move to the content</SourceLine>
    <SourceLine>for n as integer=0 to lbTotalTeamStatHistory.ListCount-1</SourceLine>
    <SourceLine>mystring=lbTotalTeamStatHistory.Cell(n,0)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for r as integer=1 to iColumns</SourceLine>
    <SourceLine>mystring=mystring+"*"+lbTotalTeamStatHistory.cell(n,r)</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mycolumns=split(mystring, "*")</SourceLine>
