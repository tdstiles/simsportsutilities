 <Method>
  <ItemName>Turnover</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1440555007</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Turnover(Type as String, Steal as Boolean)</SourceLine>
   <SourceLine>dim TmpTeamWithPtsOffTOOpp as integer //this is the team that has the opportunity to get pts off the turnover</SourceLine>
   <SourceLine>//Team iAction.Player(0).Team lost the ball</SourceLine>
   <SourceLine>//if a steal, iAction.Player(1).Team stole the ball</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "TOs", 1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If Type="P" then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "lostP", 1)//lost pass</SourceLine>
   <SourceLine>elseif Type="D" then</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "lostD", 1) //lost dribble</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if steal then</SourceLine>
   <SourceLine>StatReturn=UpdateField(iAction.Player(1).Team, iAction.Player(1).Number, "STL", 1) //stl</SourceLine>
   <SourceLine>TP("B")</SourceLine>
   <SourceLine>ResultText.append iAction.Player(0).Name+ " has pass stolen by "+iAction.Player(1).Name+StatReturn</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>igNewStatValue=UpdateField(iAction.Player(0).Team, iAction.Player(0).Number, "crTO", 1) //crTO</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Let's set the tracker for PtsoffTurnovers</SourceLine>
   <SourceLine>if iAction.Player(0).Team="1" then</SourceLine>
   <SourceLine>TmpTeamWithPtsOffTOOpp=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>TmpTeamWithPtsOffTOOpp=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>fOffTurnover(TmpTeamWithPtsOffTOOpp)=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>wndS.UpdateTeamMethods(iAction.Player(0).Team,4)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Type as String, Steal as Boolean</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>UpdateDB</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2059456511</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function UpdateDB(cDB as realsQLDatabase, MyTeam as integer) As realSQLDatabase</SourceLine>
   <SourceLine>dim r as DatabaseRecord</SourceLine>
   <SourceLine>dim positionplayed as string</SourceLine>
   <SourceLine>dim playerposition as string</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//which team do we want to import?</SourceLine>
   <SourceLine>if MyTeam=GameToImport.iTeams(0).TeamNumber then</SourceLine>
   <SourceLine>MyTeam=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>MyTeam=2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Name, initialpos, minutesplayed, FGM, fga, ftm, fta, fg3m, fg3a, ast, blk, stl, tos, fouls, pts, oreb, dreb, shrtm, shrta, medM, medA, longM, longA, aFGM, aFGA, aFG3M, aFG3A, aPts, crTO, TP, aOReb, aDReb, aTReb, lostP, lostD, PUs, touches, AR, shBlkd, plusminus, fd FROM SVTable WHERE TeamNum='"+str(MyTeam)+"' AND MinutesPlayed&gt;'0'"</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.eof=false and rs.RecordCount&lt;&gt;0</SourceLine>
   <SourceLine>if rs.IdxField(3).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>dim tablecolumns(-1), tablevalues(-1) as string</SourceLine>
   <SourceLine>//set player's position</SourceLine>
   <SourceLine>playerposition=mthdplayerposition(rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set table columns</SourceLine>
   <SourceLine>tablecolumns=split("Name, reb, APosition, season, game, mins, FGM, fga, ftm, fta, fg3m, fg3a, ast, blk, stl, tos, fouls, pts, oreb, dreb, shrtm, shrta, midM, midA, longM, longA, aFGM, aFGA, aF3M, aF3A, aPts, crTO, TP, aOReb, aDReb, aTReb, lostP, lostD, PUs, touch, AR, shBlkd, plusminus, fd", ", ")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's set up the tablecolumns</SourceLine>
   <SourceLine>tablevalues.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>tablevalues.append str(rs.field("oreb").integervalue+rs.field("dreb").integervalue)</SourceLine>
   <SourceLine>tablevalues.append playerposition</SourceLine>
   <SourceLine>tablevalues.append str(GametoImport.Season)</SourceLine>
   <SourceLine>tablevalues.append str(GametoImport.Game)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounter as integer=rs.FieldCount</SourceLine>
   <SourceLine>for n as integer=3 to iCounter</SourceLine>
   <SourceLine>tablevalues.append str(rs.IdxField(n).integerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring=mthBuildSQLString("Stats",tablecolumns, tablevalues)</SourceLine>
   <SourceLine>cdb.sqlexecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>cDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return cDB</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>cDB as realsQLDatabase, MyTeam as integer</ItemParams>
  <ItemResult>realSQLDatabase</ItemResult>
 </Method>
