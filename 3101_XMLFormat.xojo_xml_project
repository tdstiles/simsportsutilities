 <Method>
  <ItemName>UpdateTeamMethods</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>342687743</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdateTeamMethods(iTeam as string, nametype as integer = 0)</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim Scores(1) as string</SourceLine>
   <SourceLine>if MyAction=nil then</SourceLine>
   <SourceLine>Scores(0)="0"</SourceLine>
   <SourceLine>Scores(1)="0"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Scores(0)=format((MyAction.Scores(0)), "##0")</SourceLine>
   <SourceLine>Scores(1)=format((MyAction.Scores(1)), "##0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//iTeam=0--&gt;update for both teams</SourceLine>
   <SourceLine>//iTeam=1 or 2--&gt;just update for that team</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//nametype</SourceLine>
   <SourceLine>//FG=1, FT=2, Foul=3, TOs=4, PtsOffTO=5, everything=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim t,f as integer</SourceLine>
   <SourceLine>if iTeam="0" then</SourceLine>
   <SourceLine>t=0</SourceLine>
   <SourceLine>f=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if iteam="1" then</SourceLine>
   <SourceLine>t=0</SourceLine>
   <SourceLine>f=0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>t=1</SourceLine>
   <SourceLine>f=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if nametype=1 then</SourceLine>
   <SourceLine>for n as integer=t to f</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(FGM), Sum(FGA), Sum(FG3M), Sum(FG3A), Sum(Pts), Sum(shrtM) FROM SVTable WHERE TeamNum='"+str(n+1)+"'"</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>a=format(DivChk(rs.idxfield(1).doublevalue, rs.idxfield(2).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fg(n).text=a</SourceLine>
   <SourceLine>fg(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=format(DivChk(rs.idxfield(3).doublevalue,rs.idxfield(4).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fg3(n).text=a</SourceLine>
   <SourceLine>fg3(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lblPointsInPaint(n).text=format(2*rs.IdxField(6).IntegerValue, "##0")</SourceLine>
   <SourceLine>lblPointsInPaint(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set team scores</SourceLine>
   <SourceLine>score(n).text=format(rs.idxfield(5).integervalue, "##0")</SourceLine>
   <SourceLine>score(n).Refresh</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif nametype=2 then</SourceLine>
   <SourceLine>for n as integer=t to f</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Sum(FTM), Sum(FTA), Sum(Pts) FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>ft(n).text=format(DivChk(rs.idxfield(1).doublevalue,rs.idxfield(2).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>ft(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set team scores</SourceLine>
   <SourceLine>score(n).Text=format(rs.idxfield(3).integervalue, "##0")</SourceLine>
   <SourceLine>score(n).Refresh</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif nametype=3 then</SourceLine>
   <SourceLine>//foul</SourceLine>
   <SourceLine>for n as integer=t to f</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(FGM), Sum(FGA), Sum(FG3M), Sum(FG3A), Sum(Fouls) FROM SVTable WHERE TeamNum='"+str(n+1)+"'"</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>a=format(DivChk(rs.idxfield(1).doublevalue, rs.idxfield(2).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fg(n).text=a</SourceLine>
   <SourceLine>fg(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=format(DivChk(rs.idxfield(3).doublevalue,rs.idxfield(4).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fg3(n).text=a</SourceLine>
   <SourceLine>fg3(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>fouls(n).text=format(rs.IdxField(5).IntegerValue-foulminus(n), "#0")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If val(fouls(n).text)&gt;=7 and val(fouls(n).text)&lt;10 then</SourceLine>
   <SourceLine>fouls(n).text=fouls(n).text+"*"</SourceLine>
   <SourceLine>elseif val(fouls(n).text)&gt;=10 then</SourceLine>
   <SourceLine>fouls(n).text=fouls(n).text+"**"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>fouls(n).Refresh</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif nametype=4 then</SourceLine>
   <SourceLine>//just turnovers</SourceLine>
   <SourceLine>for n as integer=t to f</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Sum(TOs) FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>tos(n).text=format(rs.IdxField(1).IntegerValue, "#0")</SourceLine>
   <SourceLine>tos(n).Refresh</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//update everything</SourceLine>
   <SourceLine>for n as integer=t to f</SourceLine>
   <SourceLine>rs=SVDB.SQLSelect("SELECT Sum(FGM), Sum(FGA), Sum(FG3M), Sum(FG3A), Sum(FTM), Sum(FTA), Sum(Fouls), Sum(TOs), Sum(shrtM) FROM SVTable WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>fg(n).text=format(DivChk(rs.idxfield(1).doublevalue,rs.idxfield(2).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fg3(n).text=format(DivChk(rs.idxfield(3).doublevalue,rs.idxfield(4).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>ft(n).text=format(DivChk(rs.idxfield(5).doublevalue,rs.idxfield(6).doublevalue), "##0.0%")</SourceLine>
   <SourceLine>fouls(n).text=format(rs.IdxField(7).IntegerValue-FoulMinus(n), "#0")</SourceLine>
   <SourceLine>tos(n).text=format(rs.IdxField(8).IntegerValue, "#0")</SourceLine>
   <SourceLine>fg(n).Refresh</SourceLine>
   <SourceLine>fg3(n).Refresh</SourceLine>
   <SourceLine>ft(n).Refresh</SourceLine>
   <SourceLine>fouls(n).Refresh</SourceLine>
   <SourceLine>tos(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lblPointsInPaint(n).text=format(2*rs.IdxField(9).IntegerValue, "##0")</SourceLine>
   <SourceLine>lblPointsInPaint(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set team scores</SourceLine>
   <SourceLine>score(n).Text=Scores(n)</SourceLine>
   <SourceLine>score(n).Refresh</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If val(fouls(n).text)&gt;=7 and val(fouls(n).text)&lt;10 then</SourceLine>
   <SourceLine>fouls(n).text=fouls(n).text+"*"</SourceLine>
   <SourceLine>elseif val(fouls(n).text)&gt;=10 then</SourceLine>
   <SourceLine>fouls(n).text=fouls(n).text+"**"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>iTeam as string, nametype as integer = 0</ItemParams>
