 <Compatibility></Compatibility>
 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1646706687</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(tmpString as string)</SourceLine>
   <SourceLine>//this takes the string pulled from the preferences and turns it into "Choices"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim count as integer</SourceLine>
   <SourceLine>choices=split(tmpString, ",")</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>l=ubound(choices)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to l</SourceLine>
   <SourceLine>count=instr(choices(n), "#")</SourceLine>
   <SourceLine>if count&lt;&gt;0 then</SourceLine>
   <SourceLine>//we have a # in the array</SourceLine>
   <SourceLine>line=mid(choices(n), count+1)</SourceLine>
   <SourceLine>count=val(left(choices(n), count-1))-1</SourceLine>
   <SourceLine>choices(n)=line</SourceLine>
   <SourceLine>for j as integer=1 to count</SourceLine>
   <SourceLine>choices.append(line)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have choices fully loaded and ready to go</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>tmpString as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
