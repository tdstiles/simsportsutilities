 <Compatibility></Compatibility>
 <Method>
  <ItemName>TableGeneratorTitle</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>70971391</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TableGeneratorTitle(TableTitle as String, TableColumns() as String, NameColumn as Integer=0, HeadingLevel as integer=2) As string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim headercolor as string</SourceLine>
   <SourceLine>dim prefcolors(3) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefColors(0) = "FFFF99"</SourceLine>
   <SourceLine>prefColors(1) = "FFFFFF"</SourceLine>
   <SourceLine>prefColors(2) = "CCFF33"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>headercolor="#000000"  //this is the font color in the header</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;h"+str(HeadingLevel)+"&gt;"+tabletitle+"&lt;/h"+str(HeadingLevel)+"&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>//wiki format</SourceLine>
   <SourceLine>sbstring.append "{| class=""wikitable"" border=""1"""+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring.append "&lt;table border=""2"" cellspacing=""3"" cellpadding=""3""&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append "&lt;tr bgcolor="""+prefColors(0)+"""&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim r as integer=ubound(TableColumns)</SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>sbstring.append "|-"+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to r</SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>//doing wiki format</SourceLine>
   <SourceLine>sbstring.append "! "+trim(TableColumns(n))+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//doing html</SourceLine>
   <SourceLine>if NameColumn &lt;1 then</SourceLine>
   <SourceLine>sbstring.append "&lt;td&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>elseif NameColumn=1 then</SourceLine>
   <SourceLine>//we're dealing with all-american tables, so let's size them all out</SourceLine>
   <SourceLine>if n=1 then</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""120""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>elseif n=9 then</SourceLine>
   <SourceLine>//team names</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""90""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""25""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//high school all-america</SourceLine>
   <SourceLine>if n=1 then</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""120""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>elseif n=2 then</SourceLine>
   <SourceLine>//team names</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""90""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring.append "&lt;td width=""25""&gt;&lt;Font Color="""+headercolor+"""&gt;&lt;b&gt;"+trim(TableColumns(n))+"&lt;/b&gt;&lt;/Font&gt;&lt;/td&gt;"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>sbstring.append EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring.append "&lt;/tr&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>TableTitle as String, TableColumns() as String, NameColumn as Integer=0, HeadingLevel as integer=2</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>ColumnGenerator</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1020063743</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ColumnGenerator(Order as Integer, TableColumns() as String) As string</SourceLine>
   <SourceLine>dim mystring as string</SourceLine>
   <SourceLine>dim prefcolors(3) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>prefColors(0) = "FFFF99"</SourceLine>
   <SourceLine>prefColors(1) = "FFFFFF"</SourceLine>
   <SourceLine>prefColors(2) = "CCFF33"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If order Mod 2=0 then</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>prefcolors(3)="PaleGoldenrod"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>prefColors(3)=prefColors(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>prefcolors(3)="White"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>prefColors(3)=prefColors(1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>mystring=mystring+"|- style=""background:"+prefcolors(3)+chr(34)+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mystring=mystring+"&lt;tr bgcolor="""+prefColors(3)+""" onmouseover=""this.style.backgroundColor='"+prefColors(2)+"'"" onmouseout=""this.style.backgroundColor='"+prefColors(3)+"'""&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim r as integer=ubound(TableColumns)</SourceLine>
   <SourceLine>for j as integer=0 to r</SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>mystring=mystring+"| "+trim(TableColumns(j))+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mystring=mystring+"&lt;td&gt;"+trim(tablecolumns(j))+"&lt;/td&gt;"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>mystring=mystring+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mystring=mystring+"&lt;/tr&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return mystring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
