  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function EditHeight(HT as String) As Integer</SourceLine>
   <SourceLine>dim feet, inches as integer</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>k=instr(HT, "'")</SourceLine>
   <SourceLine>feet=val(left(HT,k-1))</SourceLine>
   <SourceLine>inches=val(mid(HT,k+1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return ((feet*12)+inches)</SourceLine>
