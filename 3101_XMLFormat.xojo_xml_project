 <Method>
  <ItemName>LoadlbRecruitingPlayerHistory</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1956022271</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadlbRecruitingPlayerHistory(sn as string)</SourceLine>
   <SourceLine>dim list as cShadedListbox</SourceLine>
   <SourceLine>list=lbRecruitingPlayerHistory</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>list.DeleteAllRows</SourceLine>
   <SourceLine>select case popRecruitingChoices.ListIndex</SourceLine>
   <SourceLine>case 0</SourceLine>
   <SourceLine>//HSOverview</SourceLine>
   <SourceLine>list.LoadHeader(split("Player,Consensus,SSC%,+/-,StdDev%",","))</SourceLine>
   <SourceLine>dim rating as string</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, mRatingpct,myRatingPct,PlayerPlusMinus,StdDevPct FROM Recruits WHERE Season='"+sn+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.eof=false</SourceLine>
   <SourceLine>list.addrow rs.IdxField(1).StringValue, format(rs.IdxField(2).DoubleValue, "##0.0%"), format(rs.IdxField(3).DoubleValue, "##0.0%"), format(rs.IdxField(4).DoubleValue, "+#0.0"), format(rs.IdxField(5).DoubleValue/10, "##0.0%")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 1</SourceLine>
   <SourceLine>//HS Stats</SourceLine>
   <SourceLine>list.LoadHeader(split("Player,PPG,RPG,APG,SPG,TPG,BPG",","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, PPG, RPG, APG, SPG, TPG, BPG FROM Recruits WHERE Season='"+sn+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>list.addrow rs.idxfield(1).StringValue, format(rs.idxfield(2).DoubleValue, "##.0"), format(rs.idxfield(3).DoubleValue, "##.0"), format(rs.idxfield(4).DoubleValue, "##.0"), format(rs.idxfield(5).DoubleValue, "##.0"), format(rs.idxfield(6).DoubleValue, "##.0"), format(rs.idxfield(7).DoubleValue, "##.0")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 2</SourceLine>
   <SourceLine>//HS atts</SourceLine>
   <SourceLine>list.LoadHeader(split("Player,SHT,DEF,HND,REB,ATH,Scout",","))</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, SHT, DEF, HND, REB, ATH, Scout FROM Recruits WHERE Season='"+sn+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>list.addrow rs.idxfield(1).StringValue, numtoword(rs.idxfield(2).IntegerValue), numtoword(rs.idxfield(3).IntegerValue), numtoword(rs.idxfield(4).IntegerValue), numtoword(rs.idxfield(5).IntegerValue), numtoword(rs.idxfield(6).IntegerValue),numtoword(rs.idxfield(7).IntegerValue)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 3</SourceLine>
   <SourceLine>//College Stats</SourceLine>
   <SourceLine>list.LoadHeader(split("Player,PPG,RPG,APG,SPG,TPG,BPG",","))</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>dim name, initial, lastname as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>list.DeleteAllRows</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name FROM Recruits WHERE Season='"+sn+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>name=rs.idxfield(1).StringValue</SourceLine>
   <SourceLine>x=InStr(name," ")</SourceLine>
   <SourceLine>initial=left(name, 1)</SourceLine>
   <SourceLine>lastname=mid(name,x)</SourceLine>
   <SourceLine>name=initial+lastname</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT AVG(pts), AVG(reb), AVG(ast), AVG(stl), AVG(tos), AVG(blk) FROM Stats WHERE Name LIKE '%"+name+"%'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>list.addrow rs.idxfield(1).StringValue, format(rec.idxfield(1).DoubleValue, "##.0"), format(rec.idxfield(2).DoubleValue,"##.0"), format(rec.idxfield(3).DoubleValue,"##.0"), format(rec.idxfield(4).DoubleValue,"##.0"), format(rec.idxfield(5).DoubleValue,"##.0"), format(rec.idxfield(6).DoubleValue,"##.0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 4</SourceLine>
   <SourceLine>//College Atts</SourceLine>
   <SourceLine>list.LoadHeader(split("Player,SHT,DEF,HND,REB,INT,ATH",","))</SourceLine>
   <SourceLine>dim x as integer</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>dim name, initial, lastname, sqlstring as string</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name FROM Recruits WHERE Season='"+sn+"'")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
   <SourceLine>name=rs.idxfield(1).StringValue</SourceLine>
   <SourceLine>x=InStr(name," ")</SourceLine>
   <SourceLine>initial=left(name, 1)</SourceLine>
   <SourceLine>lastname=mid(name,x)</SourceLine>
   <SourceLine>name=initial+lastname</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT SHT, DEF, HND, REB, INT, ATH FROM PlayerAtts WHERE Name LIKE '"+Name+"'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>list.addrow rs.idxfield(1).stringvalue, rec.IdxField(1).StringValue,rec.IdxField(2).StringValue, rec.IdxField(3).StringValue,rec.IdxField(4).StringValue,rec.IdxField(5).StringValue,rec.IdxField(6).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>list.addrow rs.idxfield(1).StringValue,"---","---","---","---","---","---"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>list.ColumnWidths="120,*"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>sn as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadLeadersListbox</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1370204159</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadLeadersListbox(rs as recordset, tabpanel as integer, cat as string)</SourceLine>
   <SourceLine>dim list as listbox</SourceLine>
   <SourceLine>dim a,b,j as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.RecordCount&gt;25 then</SourceLine>
   <SourceLine>j=25</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>j=rs.RecordCount</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Select Case tabpanel</SourceLine>
   <SourceLine>Case 0</SourceLine>
   <SourceLine>List=lbLeaders</SourceLine>
   <SourceLine>List.DeleteAllRows</SourceLine>
   <SourceLine>list.LoadHeader(split("#,Player,"+Cat, ","))</SourceLine>
   <SourceLine>List.ColumnWidths="0.3*, *"</SourceLine>
   <SourceLine>List.ColumnAlignment(0)=List.AlignLeft</SourceLine>
   <SourceLine>a=0</SourceLine>
   <SourceLine>b=0</SourceLine>
   <SourceLine>for x as integer=1 to j</SourceLine>
   <SourceLine>while rs.Field("Name").StringValue="--"</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>a=rs.field("Category").IntegerValue</SourceLine>
   <SourceLine>if a&lt;&gt;b then</SourceLine>
   <SourceLine>List.Addrow str(x)+".", rs.field("Name").StringValue, str(rs.field("Category").IntegerValue)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>List.addrow "--",rs.field("Name").StringValue, str(rs.field("Category").IntegerValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>b=a</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>Case 1</SourceLine>
   <SourceLine>List=lbLeaders</SourceLine>
   <SourceLine>list.DeleteAllRows</SourceLine>
