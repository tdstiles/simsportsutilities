   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(PBPLine as String)</SourceLine>
   <SourceLine>//this method creates the Action from the PBP Lines</SourceLine>
   <SourceLine>dim TmpPlayer as cPlayer</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>TmpPlayer=new cPlayer</SourceLine>
   <SourceLine>Player(n)=TmpPlayer</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.Action=val(PBPLine.NthField(",",1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//First, set Player A</SourceLine>
   <SourceLine>Player(0).Number=PBPLine.NthField(",",2)</SourceLine>
   <SourceLine>Player(0).Team=PBPLine.NthField(",",8)</SourceLine>
   <SourceLine>Player(0).SetName</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//------------</SourceLine>
   <SourceLine>//Player B</SourceLine>
   <SourceLine>//get team that has ball</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TeamWithBall=val(PBPLine.NthField(",",8))</SourceLine>
   <SourceLine>Player(2).Team=str(TeamWithBall)</SourceLine>
   <SourceLine>Player(2).Number=PBPLine.NthField(",",3)</SourceLine>
   <SourceLine>Player(2).SetName</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim Team as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//determine what sort of action</SourceLine>
   <SourceLine>//if players are on different teams</SourceLine>
   <SourceLine>If me.Action=6 OR me.Action=9 or me.Action=28 or me.Action=29 or me.Action=31 or me.Action=35 or me.Action=43 or me.Action=45 or me.Action=47 or me.Action= 61 or me.Action=69 or me.Action=72 THEN</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set opposing team</SourceLine>
   <SourceLine>if TeamWithBall=2 then</SourceLine>
   <SourceLine>team=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>team=2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Player(1).Team=str(Team)</SourceLine>
   <SourceLine>Player(1).Number=PBPLine.NthField(",",3)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//get opponent</SourceLine>
   <SourceLine>Player(1)=Player(0).GetOpponent</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Player(1).SetName</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Now set scores</SourceLine>
   <SourceLine>Scores(0)=val(PBPLine.NthField(",",6))</SourceLine>
   <SourceLine>Scores(1)=val(PBPLine.NthField(",",7))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Time=val(PBPLine.NthField(",",5))</SourceLine>
   <SourceLine>End Sub</SourceLine>
