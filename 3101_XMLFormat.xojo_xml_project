  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>981565439</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>progwheel.Visible=true</SourceLine>
    <SourceLine>dim rs as recordset</SourceLine>
    <SourceLine>dim max as string</SourceLine>
    <SourceLine>dim TmpDownloadTxt as string</SourceLine>
    <SourceLine>dim tout as TextOutputStream</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Season FROM TeamInfo")</SourceLine>
    <SourceLine>max=rs.IdxField(1).StringValue</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim sockHTTP as new HTTPSocket</SourceLine>
    <SourceLine>dim f as FolderItem</SourceLine>
    <SourceLine>dim k as FolderItem</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim j as integer</SourceLine>
    <SourceLine>j=listbox1.ListCount-1</SourceLine>
    <SourceLine>dim TmpName as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>f = getfolderitem("")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>f=f.child("PBP")</SourceLine>
    <SourceLine>if f.exists=false then</SourceLine>
    <SourceLine>f.CreateAsFolder</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>f=f.child("L"+prefleague+gTeams(prefTeamNum-1))</SourceLine>
    <SourceLine>if f.exists=false then</SourceLine>
    <SourceLine>f.CreateAsFolder</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>f=f.child("Sn"+max)</SourceLine>
    <SourceLine>if f.exists=false then</SourceLine>
    <SourceLine>f.CreateAsFolder</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for n as integer=0 to j</SourceLine>
    <SourceLine>//with folder created, now we see if this file is already downloaded</SourceLine>
    <SourceLine>if listbox1.cellcheck(n,2) then</SourceLine>
    <SourceLine>TmpName=iGames(j-n).PBPString</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if f.child(TmpName).exists=false then</SourceLine>
    <SourceLine>k=f.child(TmpName)</SourceLine>
    <SourceLine>TmpDownloadTxt=sockHTTP.Get("http://www.drivethelane.com/bask/weekly/lg000"+right("0"+prefleague,2)+"/"+TmpName, 30)</SourceLine>
    <SourceLine>tout=TextOutputStream.Create(k)</SourceLine>
    <SourceLine>tout.write TmpDownloadTxt</SourceLine>
    <SourceLine>tout.close</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>progwheel.Visible=false</SourceLine>
    <SourceLine>self.close</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
