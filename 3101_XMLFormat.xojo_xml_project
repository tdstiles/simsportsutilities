   <SourceLine></SourceLine>
   <SourceLine>dim scrimtenmin as double</SourceLine>
   <SourceLine>scrimtenmin= (((val(playerfield(11).text)+val(playerfield(5).text)+1.25*val(playerfield(6).text)+1.25*val(playerfield(8).text)+val(playerfield(7).text)-(val(playerfield(2).text)-val(playerfield(1).text))-((val(playerfield(4).text)-val(playerfield(3).text))/2)-(val(playerfield(10).text)/2)))/(val(playerfield(0).text)))</SourceLine>
   <SourceLine>sqlstatement=sqlstatement+"'"+str(scrimtenmin)+"', "</SourceLine>
   <SourceLine>sqlstatement=sqlstatement+"'"+rs.IdxField(1).StringValue+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstatement)</SourceLine>
   <SourceLine>end</SourceLine>
