   <SourceLine>Function CreateHeaderForCustomStats() As string</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>h="Name,"</SourceLine>
   <SourceLine>for n as integer=1 to prefNumCustomFunctions</SourceLine>
   <SourceLine>k=instr(prefCustomStatFunctions(n-1), ":")</SourceLine>
   <SourceLine>h=h+left(prefCustomStatFunctions(n-1),k-1)+","</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>h=left(h,len(h)-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return h</SourceLine>
   <SourceLine>End Function</SourceLine>
