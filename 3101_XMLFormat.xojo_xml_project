   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Sn"+str(SN))</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's figure out what the teams are</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim tmpstring as string=FireUp</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim TmpExtension as string</SourceLine>
   <SourceLine>if PBP then</SourceLine>
   <SourceLine>TmpExtension=".txt"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>TmpExtension=".html"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return f.child("S"+str(SN)+"G"+str(GN)+BoxScoreTeams(0)+"_v_"+BoxScoreTeams(1)+TmpExtension)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
