   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>//take players and load into new db</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>dim x as integer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>DBSQLExecute("DELETE FROM Recruits WHERE Season="+TextField1.text)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT * FROM PlayerInfo WHERE Name LIKE '%"+name(0).text+"%' or Name LIKE '%"+name(1).text+"%' OR Name LIKE '%"+name(2).text+"%'")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>Copyplayerover(rs)</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>db.Commit</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now change season number</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Season FROM TeamInfo")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>DBSQLExecute("UPDATE TeamInfo SET Season='"+str(rs.IdxField(1).IntegerValue+1)+"'")</SourceLine>
    <SourceLine>db.Commit</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now add in the info to their regular playerinfo</SourceLine>
    <SourceLine>AddinPlayerAtts</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>// chkParticipate  to see if we're going to participate</SourceLine>
    <SourceLine>if chkParticipate.Value=true then</SourceLine>
    <SourceLine>//yes, so let's create and save a DB file</SourceLine>
    <SourceLine>mthCreateDBFile</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT * FROM PlayerInfo WHERE Name LIKE '%"+name(0).text+"%' or Name LIKE '%"+name(1).text+"%' OR Name LIKE '%"+name(2).text+"%'")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>Copyplayerover(rs,true)</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>msgbox "Please e-mail the database file created on your desktop (AttributeStudy.ydb) to simsportsutilities@gmail.com.  Thanks!"</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now delete from playerinfo</SourceLine>
    <SourceLine>DBSQLExecute("DELETE FROM PlayerInfo")</SourceLine>
    <SourceLine>db.Commit</SourceLine>
    <SourceLine>wndRecruitSelect.Close</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
