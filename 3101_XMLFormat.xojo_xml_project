 <Method>
  <ItemName>PBPFileImport</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1603403775</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PBPFileImport()</SourceLine>
   <SourceLine>Dim dlg as OpenDialog</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as FolderItem</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f = getfolderitem("")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("PBP")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("L"+prefleague+gTeams(prefTeamNum-1))</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim max as string</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Season FROM TeamInfo")</SourceLine>
   <SourceLine>max=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=f.child("Sn"+max)</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dlg=New OpenDialog</SourceLine>
   <SourceLine>dlg.InitialDirectory = f</SourceLine>
   <SourceLine>dlg.Title = "Select a PBP file"</SourceLine>
   <SourceLine>dlg.Filter = "ZIP" // file type defined in File Types dialog</SourceLine>
   <SourceLine>f = dlg.ShowModal()</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If f &lt;&gt; Nil then</SourceLine>
   <SourceLine>GameToImport=new cGame</SourceLine>
   <SourceLine>GameToImport.f=f</SourceLine>
   <SourceLine>wndS = new wndStatViewer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//with the new window, let's clear out the constants in the StatViewerGlobals module that serve as the basis for the gametracker</SourceLine>
   <SourceLine>redim StatViewerGlobals.Team1Scores(-1)</SourceLine>
   <SourceLine>redim StatViewerGlobals.Team2Scores(-1)</SourceLine>
   <SourceLine>End</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>SeasonCheck</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>76333055</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SeasonCheck()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim oldpr as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>PRLoaded=new cLoadPR</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>CheckPR</SourceLine>
   <SourceLine>rPRTeams=PRLoaded.LoadPR</SourceLine>
   <SourceLine>GametoImport.iTeams(0).PR=rPRTeams.indexof(prefTeamNum)+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//put new PR in database</SourceLine>
   <SourceLine>if GameToImport.Game&gt;19 then //in tournament time, take the highest</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT PowerRanking FROM TotalTeam WHERE Season='"+str(GametoImport.Season)+"'")</SourceLine>
   <SourceLine>oldpr=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>if GametoImport.iTeams(0).PR&lt;oldpr then</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE TeamInfo SET lastPR='"+str(GametoImport.iTeams(0).PR)+"'")</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE TotalTeam SET PowerRanking='"+str(GametoImport.iTeams(0).PR)+"' WHERE Season='"+str(GametoImport.Season)+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE TeamInfo SET lastPR='"+str(GametoImport.iTeams(0).PR)+"'")</SourceLine>
   <SourceLine>sqlstring="UPDATE TotalTeam SET PowerRanking='"+str(GametoImport.iTeams(0).PR)+"' WHERE Season='"+str(GametoImport.Season)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>preflastpr=GametoImport.iTeams(0).PR</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GameToImport.Game=15 then</SourceLine>
   <SourceLine>//see seeding to determine conf finish</SourceLine>
   <SourceLine>wndRegularSeasonFinish.staMessage.text="Congratulations on finishing the season " + str(GametoImport.Season)+" regular season.  Please select your seed in the conference tournament."</SourceLine>
   <SourceLine>wndRegularSeasonFinish.Show</SourceLine>
   <SourceLine>elseif GameToImport.Game=18 then</SourceLine>
   <SourceLine>//method to check if conf tourney is won</SourceLine>
   <SourceLine>ConfTourneyWinCheck</SourceLine>
   <SourceLine>elseif GameToImport.Game=20 then</SourceLine>
   <SourceLine>//sweet 16</SourceLine>
   <SourceLine>Sweet16Check</SourceLine>
   <SourceLine>elseif GameToImport.Game=22 then</SourceLine>
   <SourceLine>//final 4</SourceLine>
   <SourceLine>Final4check</SourceLine>
   <SourceLine>elseif GameToImport.Game=24 then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//championship</SourceLine>
   <SourceLine>ChampCheck</SourceLine>
   <SourceLine>LoadFinalPR</SourceLine>
   <SourceLine>mthdLoadAllConf</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>wndMain.LoadPlayerStatLB</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
