   <PartID>1949114367</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>//this button, when pushed, takes the highlighted row and then prints a summary that you can then paste to the messageboard</SourceLine>
    <SourceLine>dim iSeason as string</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>dim tmpString as string</SourceLine>
    <SourceLine>dim w, l as integer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if lbRecruitOverview.ListIndex&gt;-1 then</SourceLine>
    <SourceLine>//something selected</SourceLine>
    <SourceLine>iSeason=lbRecruitOverview.cell(lbRecruitOverview.ListIndex,0) //we know which season</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now pull the players for that season</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT avg(hw), avg(sh), sum(atts) FROM Recruits WHERE Season='"+iSeason+"'")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>tmpString="[b]"+gTeams(prefTeamNum-1)+" Class of '"+str(val(iSeason)+4)+"[/b]"+EndOfLine</SourceLine>
    <SourceLine>tmpString=tmpString+format(rs.IdxField(1).integerValue, "###")+"/"+format(rs.IdxField(2).integerValue,"###")+"  ("+format(rs.IdxField(3).IntegerValue,"+##")+")"+EndOfLine</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>'now load each season</SourceLine>
    <SourceLine>dim S as cTeamSeason</SourceLine>
    <SourceLine>dim tmpI as integer=val(iSeason)+4</SourceLine>
    <SourceLine>dim TotalWins, TotalLosses, TotalConfWins, TotalConfLosses, TotalTournWins, TotalTournLosses, NTTApps as integer</SourceLine>
    <SourceLine>dim ConfTitles, ConfTourneyTitles as integer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//get all seasons in order</SourceLine>
    <SourceLine>for n as integer=0 to 3</SourceLine>
    <SourceLine>S=new cTeamSeason(str(tmpI-n))</SourceLine>
    <SourceLine>tmpString=tmpString+"S"+S.mSeason+" "</SourceLine>
    <SourceLine>tmpString=tmpString+str(S.w)+"-"+str(S.l)+" "</SourceLine>
    <SourceLine>tmpstring=tmpstring+ "("+str(S.confw)+"-"+str(S.confl)+")  "</SourceLine>
    <SourceLine>tmpString=tmpString+S.tourn+" "+ str(S.tournw)+"-"+str(S.tournl)+ " ([i]"+S.HowFar+"[/i]) "</SourceLine>
    <SourceLine>tmpstring=tmpstring+"PR #"+S.pr+EndOfLine</SourceLine>
    <SourceLine>TotalWins=TotalWins+s.w</SourceLine>
    <SourceLine>TotalLosses=TotalLosses+s.l</SourceLine>
    <SourceLine>TotalConfWins=TotalConfWins+s.confw</SourceLine>
    <SourceLine>TotalConfLosses=TotalConfLosses+s.confl</SourceLine>
    <SourceLine>TotalTournWins=TotalTournWins+s.tournw</SourceLine>
    <SourceLine>TotalTournLosses=TotalTournLosses+s.tournl</SourceLine>
    <SourceLine>ConfTitles=ConfTitles+s.ConfTitle</SourceLine>
    <SourceLine>ConfTourneyTitles=ConfTourneyTitles+s.ConfTourneyTitle</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if s.Tourn="NTT" then</SourceLine>
    <SourceLine>NTTApps=NTTApps+1</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>tmpString=tmpString+EndOfLine</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>tmpString=tmpString+"Total:  "+str(TotalWins)+"-"+str(TotalLosses)+" ("+str(TotalConfWins)+"-"+str(TotalConfLosses)+")"+EndOfLine</SourceLine>
    <SourceLine>tmpString=tmpString+str(ConfTitles)+" Conf Titles, "+str(ConfTourneyTitles)+" Conf Tournament Titles"+EndOfLine</SourceLine>
    <SourceLine>tmpString=tmpString+str(NTTApps)+" NTT Appearances, Total Tournament Record: "+str(TotalTournWins)+"-" +str(TotalTournLosses)</SourceLine>
    <SourceLine>tmpstring=tmpstring+EndOfLine+EndOfLine+EndOfLine</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now for the individual players</SourceLine>
    <SourceLine>rs=db.SQLSelect("SELECT Name FROM Recruits WHERE Season='"+iSeason+"'")</SourceLine>
    <SourceLine>while rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and rs.EOF=false</SourceLine>
    <SourceLine>//loop through for each player</SourceLine>
    <SourceLine>dim name, initial, lastname as string</SourceLine>
    <SourceLine>dim x as integer</SourceLine>
    <SourceLine>name=rs.idxfield(1).StringValue</SourceLine>
    <SourceLine>x=InStr(name," ")</SourceLine>
    <SourceLine>initial=left(name, 1)</SourceLine>
    <SourceLine>lastname=mid(name,x)</SourceLine>
    <SourceLine>name=initial+lastname</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>tmpString=tmpString+CreatePlayerExportText(Name, str(val(iSeason)+1))+EndOfLine+EndOfLine</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim c as new Clipboard</SourceLine>
    <SourceLine>c.text=tmpString</SourceLine>
    <SourceLine>MsgBox("Copied to Clipboard")</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
