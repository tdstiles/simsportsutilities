 <ObjName>cTeamSeason</ObjName>
 <ObjContainerID>867143679</ObjContainerID>
 <IsClass>1</IsClass>
 <ItemFlags>1</ItemFlags>
 <IsInterface>0</IsInterface>
 <Compatibility></Compatibility>
 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1633755135</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(tmpSeason as string)</SourceLine>
   <SourceLine>mSeason=tmpSeason</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load up this class with the relevant info</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT PowerRanking FROM TotalTeam WHERE Season='"+mSeason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>me.PR=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>me.pr="--"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get recordsets for current season and load variables</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as W FROM TeamHistory WHERE WL LIKE 'W' AND Season='"+mSeason+"' AND Game&lt;=24 ")</SourceLine>
   <SourceLine>w=checknil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as L FROM TeamHistory WHERE WL LIKE 'L' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>l=checknil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as W FROM TeamHistory WHERE WL LIKE 'W' AND Upper(Type) LIKE 'CONFERENCE' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>confw=checknil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as L FROM TeamHistory WHERE WL LIKE 'L' AND Upper(Type) LIKE 'CONFERENCE' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>confl=checknil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as W FROM TeamHistory WHERE WL LIKE 'W' AND Type LIKE '%TT' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>tournw=CheckNil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Count(WL) as W FROM TeamHistory WHERE WL LIKE 'L' AND Type LIKE '%TT' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>tournl=CheckNil(rs)</SourceLine>
   <SourceLine>rs=DB.SQLSelect("Select Type FROM TeamHistory WHERE Type NOT LIKE '%Conf%' AND Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>if rs&lt;&gt;NIL and rs.recordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>tourn=rs.field("Type").StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>tourn="---"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//determine how far into the tournament we made it</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select WL from TeamHistory WHERE Season='"+mSeason+"' AND Game&gt;='19' and Game&lt;='24' ORDER BY Game ASC")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>dim games(-1) as string</SourceLine>
   <SourceLine>for nnn as integer=0 to 5</SourceLine>
   <SourceLine>games.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we determine how far they've made it</SourceLine>
   <SourceLine>if games(0)="L" then</SourceLine>
   <SourceLine>HowFar="First Round"</SourceLine>
   <SourceLine>elseif games(0)="W" and games(1)="L" then</SourceLine>
   <SourceLine>HowFar="Round of 32"</SourceLine>
   <SourceLine>elseif games(0)="W" and games(1)="W" and games(2)="L" then</SourceLine>
   <SourceLine>HowFar="Sweet 16"</SourceLine>
   <SourceLine>elseif games(0)="W" and games(1)="W" and games(2)="W" and games(3)="L" then</SourceLine>
   <SourceLine>HowFar="Elite 8"</SourceLine>
   <SourceLine>elseif games(0)="W" and games(1)="W" and games(2)="W" and games(3)="W" and games(4)="L" then</SourceLine>
   <SourceLine>HowFar="Final Four"</SourceLine>
   <SourceLine>elseif games(0)="W" and games(1)="W" and games(2)="W" and games(3)="W" and games(4)="W" and games(5)="L" then</SourceLine>
   <SourceLine>HowFar="Runner-up"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>HowFar="Champ"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the recruiting for this year</SourceLine>
   <SourceLine>rs=db.SQLSelect("Select HW, SH From Recruits WHERE Season='"+mSeason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>Recruits=rs.IdxField(1).StringValue+"/"+rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>recruits=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TeamAverages</SourceLine>
   <SourceLine>DetermineConferenceChampionships</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>tmpSeason as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>TeamAverages</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1207109631</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub TeamAverages()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get averages for seasonstats box</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT AVG(TeamHistory.OurScore), AVG(TeamHistory.OppScore) FROM TeamHistory WHERE Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>me.ppg=rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>me.appg=rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim games as integer</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Distinct(Game) FROM Stats WHERE Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>games=rs.RecordCount</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT sum(Stats.Reb), sum(Stats.Ast), sum(Stats.Stl), sum(Stats.blk), sum(stats.tos) FROM Stats WHERE Stats.Season='"+mSeason+"' AND Game&lt;=24")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 and games&lt;&gt;0 then</SourceLine>
   <SourceLine>me.reb=rs.IdxField(1).IntegerValue/games</SourceLine>
   <SourceLine>me.ast=rs.IdxField(2).IntegerValue/games</SourceLine>
   <SourceLine>me.stl=rs.IdxField(3).IntegerValue/games</SourceLine>
   <SourceLine>me.blk=rs.IdxField(4).IntegerValue/games</SourceLine>
   <SourceLine>me.tos=rs.IdxField(5).IntegerValue/games</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>reb=0</SourceLine>
   <SourceLine>ast=0</SourceLine>
   <SourceLine>stl=0</SourceLine>
   <SourceLine>blk=0</SourceLine>
   <SourceLine>tos=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>DetermineConferenceChampionships</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1913477119</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub DetermineConferenceChampionships()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT ConfFinish, ConfTournTitle FROM TotalTeam WHERE Season='"+mSeason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue=1 then</SourceLine>
   <SourceLine>ConfTitle=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ConfTitle=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if rs.IdxField(2).StringValue="Y" then</SourceLine>
   <SourceLine>ConfTourneyTitle=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ConfTourneyTitle=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
