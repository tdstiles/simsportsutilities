  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdatePtsOffTO(Team as integer, Pts as integer)</SourceLine>
   <SourceLine>//this method looks at the team that just scored and figures out if they were doing it off a turnover, then updates the relevant info</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fOffTurnover(team) then</SourceLine>
   <SourceLine>//yes, scored off a turnover</SourceLine>
   <SourceLine>iPtsOffTurnover(team)=iPtsOffTurnover(team)+Pts</SourceLine>
   <SourceLine>wnds.lblPtsOffTOs(team).Text=format((iPtsOffTurnover(team)), "##0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
