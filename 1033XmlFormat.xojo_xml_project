 <Method>
  <ItemName>Pause</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1434673151</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Pause()</SourceLine>
   <SourceLine>If me.PauseFlag Is Nil then</SourceLine>
   <SourceLine>me.PauseFlag = new Semaphore</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>If NOT me.IsPaused then</SourceLine>
   <SourceLine>me.PauseFlag.Signal</SourceLine>
   <SourceLine>me.IsPaused = true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//IsPaused prevents a deadlock that would</SourceLine>
   <SourceLine>//otherwise occur if Pause is called twice without</SourceLine>
   <SourceLine>//calling Resume</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
