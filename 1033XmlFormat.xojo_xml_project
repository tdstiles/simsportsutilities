 <Method>
  <ItemName>CalcPreseasonRank</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1635497983</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CalcPreseasonRank(CN as integer) As string</SourceLine>
   <SourceLine>//this method is passed a conference number (as CN).  If it's 0, we find the preseason top 25.  Otherwise, we pull the conference preseason report.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim fChamp as string</SourceLine>
   <SourceLine>dim ars as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim teamvalue as double</SourceLine>
   <SourceLine>dim sbstring as string</SourceLine>
   <SourceLine>dim k(-1) as struConfRecords</SourceLine>
   <SourceLine>dim szConferenceClause as string</SourceLine>
   <SourceLine>dim PreviewTeam as cTeamInfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>IF CN&lt;&gt;0 then</SourceLine>
   <SourceLine>szConferenceClause=" AND PRI.Conference='"+str(CN)+"'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>szConferenceClause=""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("CREATE TABLE PreseasonTop25 (TeamNum integer, Rating double, PrevRec varchar, prevPR integer, Recruiting varchar, Coach varchar, AvgRecruiting double)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see if anything is entered for the season yet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GamesPlayed&lt;2 then</SourceLine>
   <SourceLine>'mthdAddKmoneyInfo</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see if we have previous seasons' data</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.TeamNum FROM PRI WHERE Season="+str(val(mCurrentSeason)-1)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if rs=nil or rs.RecordCount=0 or rs.EOF=true then</SourceLine>
   <SourceLine>mCurrentSeason=str(val(mCurrentSeason)+1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT PRI.TeamNum FROM PRI WHERE Season="+str(val(mCurrentSeason)-1)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if rs=nil or rs.RecordCount=0 or rs.EOF=true then</SourceLine>
   <SourceLine>msgbox "You must have data from a previous season in order to generate Preseason Top 25 rankings or Conference previews.  If you have just completed your season and are trying to generate previews for the next season, update your preferences to indicate the new season number."</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ReturningPlayers(CN)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get all of the information about each team to calculate the PreseasonTop25</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.TeamNum, PRI.RecruitSH, PRI.RecruitHW, PRI.KMoneyAve FROM PRI WHERE Season='"+mCurrentSeason+"'"+szConferenceClause</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=False</SourceLine>
   <SourceLine>//now that we have the current SimHoops and Hardwood ratings, let's get the info from last season</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.Last5WL, PRI.fPR, PRI.PR, PRI.WL, PRI.Coach FROM PRI WHERE PRI.Season='"+str(val(mCurrentSeason)-1)+"' AND PRI.TeamNum='"+rs.IdxField(1).StringValue+"'"+szConferenceClause</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(ars) then</SourceLine>
   <SourceLine>teamvalue=prefRecruiting*((rs.IdxField(2).IntegerValue+rs.IdxField(3).IntegerValue)/512)+prefHistory*(1-ars.IdxField(1).IntegerValue/120)+prefELO*(ars.IdxField(2).IntegerValue/256)+prefPR*3*(ars.IdxField(3).IntegerValue/256)*(1-mPctDouble(rs.IdxField(1).IntegerValue-1))+prefRecruiting*(rs.IdxField(4).DoubleValue/256)</SourceLine>
   <SourceLine>sqlstring="INSERT INTO PreseasonTop25 (TeamNum, Rating, PrevRec, PrevPR, Recruiting, Coach, AvgRecruiting) VALUES ('"+rs.IdxField(1).StringValue+"', '"+format(teamvalue, "######0.00")+"', '"+ars.IdxField(4).StringValue+"-"+str(24-ars.IdxField(4).IntegerValue)+"', '"+ars.IdxField(3).StringValue+"', '"+rs.IdxField(2).StringValue+"/"+rs.IdxField(3).StringValue+"', '"+ars.idxfield(5).stringvalue+"', '"+rs.IdxField(4).StringValue+"')"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now that we have a database full of stuff, we can create the PreseasonTop25</SourceLine>
   <SourceLine>dim columninfo(-1) as string</SourceLine>
   <SourceLine>columninfo=split("Rank,Team,PrevRec,PrevPR,Recruiting,Tournament,Ret. Starters,Ret. All-Conf,Player to Watch", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpTeamCount as integer</SourceLine>
   <SourceLine>if CN=0 then</SourceLine>
   <SourceLine>sbstring=sbstring+  TableGeneratorTitle("L"+League+" Preseason Top 25", columninfo)</SourceLine>
   <SourceLine>tmpTeamCount=25</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+TableGeneratorTitle("C"+str(CN)+" Preview", columninfo)</SourceLine>
   <SourceLine>tmpTeamCount=8</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, PrevRec, PrevPR, Recruiting, Coach, AvgRecruiting FROM Preseasontop25 ORDER BY Rating ASC"</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpURLString as string</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>for n as integer=1 to tmpTeamCount</SourceLine>
   <SourceLine>redim columninfo(-1)</SourceLine>
   <SourceLine>columninfo.append  str(n)+"."</SourceLine>
   <SourceLine>columninfo.append htmllink(rs.IdxField(1).IntegerValue,3)+" ("+rs.idxfield(5).stringvalue+")"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//include conference record</SourceLine>
   <SourceLine>if CN=0 then</SourceLine>
   <SourceLine>columninfo.append rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>k=mthdConferenceStandingsFromPreviousYear(str(CN))</SourceLine>
   <SourceLine>for nn as integer=0 to 7</SourceLine>
   <SourceLine>if k(nn).TeamNum=rs.IdxField(1).IntegerValue then</SourceLine>
   <SourceLine>//correct team</SourceLine>
   <SourceLine>fChamp=k(nn).wl</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tourneychamp as integer=mthdDetermineConfTourneyChamp(str(CN))</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue=tourneychamp then </SourceLine>
   <SourceLine>fchamp=fchamp+"*"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo.append rs.IdxField(2).StringValue+" "+fchamp</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo.append  rs.IdxField(3).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefWiki then</SourceLine>
   <SourceLine>tmpURLString="[http://kwallace.echoechoplus.com/simrec/leagueRecruiting.php?l="+league+"&amp;f=ave&amp;s=ave "+format(rs.idxfield(6).doublevalue, "##0.0")+"]"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>tmpURLString="&lt;a href=""http://kwallace.echoechoplus.com/simrec/leagueRecruiting.php?l="+league+"&amp;f=ave&amp;s=ave"" target=""_blank""&gt;"+format(rs.idxfield(6).doublevalue, "##0.0")+"&lt;/a&gt;"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'columninfo.append rs.IdxField(4).StringValue+"  ("+tmpURLString+")"  //until kmoney updates, let's not show this material</SourceLine>
   <SourceLine>columninfo.append rs.IdxField(4).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(rs.IdxField(1).IntegerValue, val(mCurrentSeason)-1)</SourceLine>
   <SourceLine>columninfo.append PreviewTeam.TournamentFinish(true)</SourceLine>
   <SourceLine>columninfo.append PreviewTeam.ReturningStarters</SourceLine>
   <SourceLine>columninfo.append PreviewTeam.ReturningAllConf</SourceLine>
   <SourceLine>columninfo.append PreviewTeam.GetMVP(true)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring=sbstring+  ColumnGenerator(n+1, columninfo)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring=sbstring+ CloseTable</SourceLine>
   <SourceLine>sbstring=sbstring+ "&lt;br&gt;"+ BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we add in the "on the outside looking in" teams</SourceLine>
   <SourceLine>if CN=0 then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+ "===Knockin' on the door==="+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ "&lt;h3&gt;Knockin' on the door&lt;/h3&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>dim additionalteams(-1) as integer</SourceLine>
   <SourceLine>for n as integer=1 to 10</SourceLine>
   <SourceLine>additionalteams.append rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>additionalteams.sort</SourceLine>
   <SourceLine>dim iCounter as integer=ubound(additionalteams)-1</SourceLine>
   <SourceLine>for n as integer=0 to iCounter</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+ htmllink(additionalteams(n), 8)+", "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ htmllink(additionalteams(n), 3)+", "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+ htmllink(additionalteams(9),8)+"&lt;br&gt;"+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ htmllink(additionalteams(9),3)+"&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>return sbstring</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
