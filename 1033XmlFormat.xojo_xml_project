  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GenerateStatString(rs as RecordSet) As string</SourceLine>
   <SourceLine>//this method creates the player's stat line</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>' PPG, RPG, APG, SPG, BPG, TPG,</SourceLine>
   <SourceLine>dim zstring as string</SourceLine>
   <SourceLine>zstring=format(rs.Field("PPG").DoubleValue, "##.0")+"ppg "</SourceLine>
   <SourceLine>zstring=zstring+format(rs.Field("RPG").DoubleValue, "##.0")+"rpg "</SourceLine>
   <SourceLine>zstring=zstring+format(rs.Field("APG").DoubleValue, "##.0")+"apg "</SourceLine>
   <SourceLine>zstring=zstring+format(rs.Field("SPG").DoubleValue, "##.0")+"spg "</SourceLine>
   <SourceLine>zstring=zstring+format(rs.Field("BPG").DoubleValue, "##.0")+"bpg "</SourceLine>
   <SourceLine>zstring=zstring+format(rs.Field("TPG").DoubleValue, "##.0")+"tpg "</SourceLine>
   <SourceLine>return zstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
