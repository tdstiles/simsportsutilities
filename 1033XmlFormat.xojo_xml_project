   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GenerateReport() As string</SourceLine>
   <SourceLine>//this method creates the text for the conference recap report</SourceLine>
   <SourceLine>//it includes the expanded conference standings, DTL all-conf, SSN all-conf, and the tournament bracket</SourceLine>
   <SourceLine>//note that this is ONLY in wiki format, not HTML</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>result= "{{LeagueCompass|LID="+League+"|minS="+mCurrentSeason+"}}"+EndOfLine</SourceLine>
   <SourceLine>result=result+"&lt;h1&gt;L"+league+" C"+str(CN)+" S"+mCurrentSeason+" Report&lt;/h1&gt;"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//conference standings</SourceLine>
   <SourceLine>result=result+ConferenceStandings</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//DTL all-conf</SourceLine>
   <SourceLine>result=result+AllConferencePlayers</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//SSN all-conf</SourceLine>
   <SourceLine>dim AllAm as new cAllAmericanCalc(CN, false)</SourceLine>
   <SourceLine>result=result+allam.CreateText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//conf tourney bracket</SourceLine>
   <SourceLine>result=result+ConfTourneyBracket</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>result=result+"{{ConferenceSeasonCompass|LID="+league+"|CID="+str(CN)+"|S="+mCurrentSeason+"}}"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return result</SourceLine>
   <SourceLine>End Function</SourceLine>
