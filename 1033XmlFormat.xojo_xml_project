  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>508397567</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseHSSOG(result as string)</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=instr(lines(0), "#")</SourceLine>
   <SourceLine>GN=mid(lines(0), i+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=9</SourceLine>
   <SourceLine>while i+8&lt;ubound(lines)</SourceLine>
   <SourceLine>mStarsOfGame.Append(trim(lines(i))+"#"+trim(lines(i+2)))</SourceLine>
   <SourceLine>i=i+8</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update HSStats to show game number</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Name, HSName FROM HSStats WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="UPDATE HSStats SET Game='"+GN+"' WHERE Name='"+rs.IdxField(1).StringValue+"' AND HSName='"+rs.IdxField(2).StringValue+"' AND Season='"+mCurrentSeason+"' AND Game&lt;1"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
