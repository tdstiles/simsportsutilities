  <PartID>1702266879</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthCreateInMemDB()</SourceLine>
   <SourceLine>sldb=new REALSQLDatabase</SourceLine>
