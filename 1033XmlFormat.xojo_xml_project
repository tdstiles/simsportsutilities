  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>204136447</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function t75overunder() As string</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim t75ranking as string</SourceLine>
   <SourceLine>dim Acolumns(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("CREATE table playerinfo (name varchar, mrank integer, t75rnk integer, region integer)")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=1</SourceLine>
   <SourceLine>sqlstring="SELECT Name, mratingpct, t75rnk, region FROM PlayerInfo WHERE Season='"+mCurrentSeason+"' ORDER BY mratingpct desc"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>if rs.IdxField(3).IntegerValue&lt;&gt;0 then</SourceLine>
   <SourceLine>sqlstring="INSERT INTO playerinfo (Name, mrank, t75rnk, region) VALUES ('"+rs.IdxField(1).StringValue+"', '"+str(n)+"', '"+rs.IdxField(3).StringValue+"', '"+rs.idxfield(4).stringvalue+"')"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="INSERT INTO playerinfo (Name, mrank, t75rnk, region) VALUES ('"+rs.IdxField(1).StringValue+"', '"+str(n)+"', '100', '"+rs.idxfield(4).stringvalue+"')"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Acolumns=split("Rank,Name,Region,Top 75 Rank,SSN Rank,+/- Rank", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//overrated players</SourceLine>
   <SourceLine>sbstring.append "&lt;h2&gt; Most Over/UnderRated Players&lt;/h2&gt;&lt;br&gt;&lt;br&gt;"</SourceLine>
   <SourceLine>sbstring.append BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle("25 Most OverRated Players",Acolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=1</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT Name, mrank, t75rnk, region, t75rnk-mrank as A FROM playerinfo WHERE t75rnk &lt;100 ORDER BY A ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while n&lt;26</SourceLine>
   <SourceLine>Acolumns=split(str(n)+","+rs.idxfield(1).stringvalue+","+rs.idxfield(4).stringvalue+","+rs.idxfield(3).stringvalue+","+rs.idxfield(2).stringvalue+","+format(rs.idxfield(5).integervalue, "+###"), ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n,acolumns)</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine> sbstring.append CloseTable</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;&lt;br&gt;"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now to underrated</SourceLine>
   <SourceLine>Acolumns=split("Rank,Name,Region,Top 75 Rank,SSN Rank,+/- Rank", ",")</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle("25 Most UnderRated Players",Acolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=1</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT Name, mrank, t75rnk, region, t75rnk-mrank as A FROM playerinfo ORDER BY A DESC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while n&lt;26</SourceLine>
   <SourceLine>if rs.IdxField(3).IntegerValue&lt;100 then</SourceLine>
   <SourceLine>t75ranking=rs.IdxField(3).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>t75ranking="NR"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>Acolumns=split(str(n)+","+rs.idxfield(1).stringvalue+","+rs.idxfield(4).stringvalue+","+t75ranking+","+rs.idxfield(2).stringvalue+","+format(rs.idxfield(5).integervalue, "+###"), ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n,acolumns)</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;&lt;br&gt;"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "Note:  Players who are not on the Top 75 Most Recruited list have been assumed to have a recruited value of 100."+EndOfLine</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
