 <Method>
  <ItemName>HSMainMethod</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1826502655</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub HSMainMethod()</SourceLine>
   <SourceLine>'GN="1"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, determine number of HS games by parsing HS Stars file</SourceLine>
   <SourceLine>GetHSSOG</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if first game, then insert general player info</SourceLine>
   <SourceLine>if GN="1" then</SourceLine>
   <SourceLine>GeneratePlayerInfo</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//next, generate high school info</SourceLine>
   <SourceLine>GenerateHSInfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//next, parse through the new HS files and determine insert string</SourceLine>
   <SourceLine>GenerateSingleGameStats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now add in stars of game</SourceLine>
   <SourceLine>AddSOG</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update playerplusminus</SourceLine>
   <SourceLine>UpdatePlayerPlusMinus</SourceLine>
   <SourceLine></SourceLine>
