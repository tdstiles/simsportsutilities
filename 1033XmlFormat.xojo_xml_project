 <Method>
  <ItemName>ParseBoxScore</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1336287231</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ParseBoxScore(a as string) As boolean</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>lines=split(a,EndOfLine)</SourceLine>
   <SourceLine>dim shortstring as string</SourceLine>
   <SourceLine>dim TmpPlayer as  new GOTWRecapPlayers</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//after splitting out the array, we start to parse through it, line by line</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if we have an asp error, we know that we should try b/c games, so return false</SourceLine>
   <SourceLine>if instr(lines(0), "Result")&lt;&gt;0 then</SourceLine>
   <SourceLine>//bad result</SourceLine>
   <SourceLine>return false</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim j as integer=3</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>RecapTeams(n).TeamNickName=trim(lines(j))</SourceLine>
   <SourceLine>j=j+15</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get each player</SourceLine>
   <SourceLine>for t as integer=0 to 9</SourceLine>
   <SourceLine>if (j+16)&lt;UBound(lines) then</SourceLine>
   <SourceLine>TmpPlayer=new GOTWRecapPlayers</SourceLine>
   <SourceLine>TmpPlayer.TeamNum=RecapTeams(n).teamNumber</SourceLine>
   <SourceLine>TmpPlayer.Name=lines(j+1)</SourceLine>
   <SourceLine>TmpPlayer.pos=lines(j+2)</SourceLine>
   <SourceLine>TmpPlayer.Minutes=val(lines(j+3))</SourceLine>
   <SourceLine>TmpPlayer.fgm=val(lines(j+4))</SourceLine>
   <SourceLine>TmpPlayer.fga=val(lines(j+5))</SourceLine>
   <SourceLine>TmpPlayer.FG3M=val(lines(j+6))</SourceLine>
   <SourceLine>TmpPlayer.fg3a=val(lines(j+7))</SourceLine>
   <SourceLine>TmpPlayer.ftm=val(lines(j+8))</SourceLine>
   <SourceLine>TmpPlayer.fta=val(lines(j+9))</SourceLine>
   <SourceLine>TmpPlayer.Reb=val(lines(j+10))</SourceLine>
   <SourceLine>TmpPlayer.ast=val(lines(j+11))</SourceLine>
   <SourceLine>TmpPlayer.blk=val(lines(j+12))</SourceLine>
   <SourceLine>TmpPlayer.stl=val(lines(j+13))</SourceLine>
   <SourceLine>TmpPlayer.TOs=val(lines(j+14))</SourceLine>
   <SourceLine>TmpPlayer.PFs=val(lines(j+15))</SourceLine>
   <SourceLine>TmpPlayer.points=val(lines(j+16))</SourceLine>
   <SourceLine>RecapTeams(n).Players.append TmpPlayer</SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=j+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now load up team stats</SourceLine>
   <SourceLine>RecapTeams(n).Minutes=val(lines(j+1))</SourceLine>
   <SourceLine>RecapTeams(n).fgm=val(lines(j+2))</SourceLine>
   <SourceLine>RecapTeams(n).fga=val(lines(j+3))</SourceLine>
   <SourceLine>RecapTeams(n).fg3m=val(lines(j+4))</SourceLine>
   <SourceLine>RecapTeams(n).fg3a=val(lines(j+5))</SourceLine>
   <SourceLine>RecapTeams(n).ftm=val(lines(j+6))</SourceLine>
   <SourceLine>RecapTeams(n).fta=val(lines(j+7))</SourceLine>
   <SourceLine>RecapTeams(n).reb=val(lines(j+8))</SourceLine>
   <SourceLine>RecapTeams(n).ast=val(lines(J+9))</SourceLine>
   <SourceLine>RecapTeams(n).Blk=val(lines(j+10))</SourceLine>
   <SourceLine>RecapTeams(n).stl=val(lines(j+11))</SourceLine>
   <SourceLine>RecapTeams(n).TOs=val(lines(j+12))</SourceLine>
   <SourceLine>RecapTeams(n).pfs=val(lines(J+13))</SourceLine>
   <SourceLine>RecapTeams(n).points=val(lines(J+14))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=j+15</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
