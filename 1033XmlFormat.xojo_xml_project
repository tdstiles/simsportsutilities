  <ItemName>mthdAddPlayers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1753915391</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthdAddPlayers()</SourceLine>
   <SourceLine>lbPlayers.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim season,game as string</SourceLine>
   <SourceLine>if popSeason.ListIndex=0 and popGame.ListIndex&lt;3 then</SourceLine>
   <SourceLine>//all games and season</SourceLine>
   <SourceLine>season=""</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if popSeason.ListIndex&lt;&gt;0 then</SourceLine>
   <SourceLine>season=" WHERE Season="+popSeason.text</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>season=" WHERE "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if popGame.ListIndex&gt;2 then</SourceLine>
   <SourceLine>game=" AND Game="+popGame.text</SourceLine>
   <SourceLine>end </SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//build SQL statement</SourceLine>
   <SourceLine>if popGame.ListIndex&gt;2 then</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Game, Name, HSName, Pts, Reb, Ast, Blk, Stl, TOs, SOG FROM HSStats "+season+game</SourceLine>
   <SourceLine>elseif popGame.ListIndex=0 then</SourceLine>
   <SourceLine>//all games</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Game, Name, HSName, Pts, Reb, Ast, Blk, Stl, TOs, SOG FROM HSStats "+season</SourceLine>
   <SourceLine>elseif popGame.ListIndex=1 then</SourceLine>
   <SourceLine>//totals</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Count(*), Name, HSName, Sum(Pts), Sum(Reb), Sum(Ast), Sum(Blk), Sum(Stl), Sum(TOs), Sum(SOG='Y') FROM HSStats "+season+" GROUP BY Name"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//averages</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Count(*), Name, HSName, Avg(Pts), Avg(Reb), Avg(Ast), Avg(Blk), Avg(Stl), Avg(TOs), Sum(SOG='Y') FROM HSStats "+season+" GROUP BY Name"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now loop through the recordset</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>//build out our row array</SourceLine>
   <SourceLine>lbPlayers.addrow rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>for n as integer=2 to 11</SourceLine>
   <SourceLine>lbPlayers.cell(lbPlayers.LastIndex, n-1)=rs.IdxField(n).StringValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
