  <PartID>880791551</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateInfo()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim editorspick as string</SourceLine>
   <SourceLine>dim gotw(1) as string</SourceLine>
   <SourceLine>dim thisgame as string</SourceLine>
   <SourceLine>dim lastgame as string</SourceLine>
   <SourceLine>dim rankings(3,2) as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim PreviewTeam as cTeamInfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rankings(0,0)="10"</SourceLine>
   <SourceLine>rankings(1,0)="25"</SourceLine>
   <SourceLine>rankings(2,0)="50"</SourceLine>
   <SourceLine>rankings(3,0)="100"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;p&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>gotw(n)=HTMLLink(mTeamNumbers(n), 4)+BloggerEndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Game #"</SourceLine>
   <SourceLine>sbstring.append str(mTeamNumbers(2))</SourceLine>
   <SourceLine>sbstring.append ":&lt;/b&gt;  "</SourceLine>
   <SourceLine>sbstring.append gotw(0)</SourceLine>
   <SourceLine>sbstring.append " vs. " </SourceLine>
   <SourceLine>sbstring.append gotw(1) </SourceLine>
   <SourceLine>sbstring.append "&lt;/p&gt;"</SourceLine>
   <SourceLine>sbstring.append BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(mTeamNumbers(n), val(mCurrentSeason))</SourceLine>
   <SourceLine>'sbstring.append PreviewTeam.ReturnString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//show matchups</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Player Matchups:&lt;/b&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append Matchups</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//find last meeting</SourceLine>
   <SourceLine>lastgame=FindLastGame</SourceLine>
   <SourceLine>if lastgame&lt;&gt;"" then</SourceLine>
   <SourceLine>sbstring.append lastgame</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;p&gt;"+PD(1)+BloggerEndofLine+"&lt;/p&gt;"</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PostResults(sbstring.ToString)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
