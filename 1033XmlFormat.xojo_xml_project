  <PartID>1351251967</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function RecordvsTourneyOpps(Tournament as string, mTourneyDB as REALSQLDatabase) As string</SourceLine>
   <SourceLine>//this method takes the teamnumber, goes through mTourneyDB, and gets the record against each team in the same tournament </SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim szTmp as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's load up an array with each team in the tournament</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim rTmpTeams(-1) as string</SourceLine>
   <SourceLine>rs=mTourneyDB.SQLSelect("SELECT Team FROM TdbTable")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>rTmpTeams.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we build a SQLString with the team numbers</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>sqlstring="SELECT SUM(WL='W'), Sum(WL='L') FROM Games WHERE Season='"+mSeason+"' AND TeamNum='"+str(TN)+"' AND ("</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now add in the team numbers</SourceLine>
   <SourceLine>for n as integer=0 to 62</SourceLine>
   <SourceLine>sqlstring=sqlstring+"OpponentNum='"+rTmpTeams(n)+"' OR "</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring=sqlstring+"OpponentNum='"+rTmpTeams(63)+"')"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the record, now</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>szTmp="&lt;b&gt;Record vs. "+Tournament+" teams:&lt;/b&gt;  "</SourceLine>
   <SourceLine>szTmp=szTmp+format(rs.IdxField(1).IntegerValue, "#0")+"-"+format(rs.IdxField(2).IntegerValue, "#0")+EndofLine+EndOfLine</SourceLine>
   <SourceLine>return szTmp</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return ""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Tournament as string, mTourneyDB as REALSQLDatabase</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
