  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>//this method constructs a table that ranks all of the conferences</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first we load up a REALSQLDatabase that has all the data, by conference</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>inmemdb=PrepareConferenceDB</SourceLine>
