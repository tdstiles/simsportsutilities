 <Method>
  <ItemName>POGString</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>376510463</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function POGString(POGHere as GoTWRecapPlayers) As string</SourceLine>
   <SourceLine>dim t as cGOTWRecapTeam</SourceLine>
   <SourceLine>t=RecapTeams(w)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim mystring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim POGString(-1) as string</SourceLine>
   <SourceLine>POGString.append "The "+t.TeamNickName+" were led by "+POGHere.pos+ " "+POGHere.name+", who scored  "</SourceLine>
   <SourceLine>POGString.append "The difference maker for the "+t.TeamNickName+" was "+POGHere.name+", who scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" starred for the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" had a big night for the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" was the player of the game for the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" led the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" showed up in a big way for the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine>POGString.append POGHere.name+" sealed the victory for the "+t.TeamNickName+".  He scored "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=new random</SourceLine>
   <SourceLine>mystring= pogstring(r.InRange(0,ubound(pogstring)))</SourceLine>
   <SourceLine>mystring= mystring+str(POGHere.points)+" points on "+str(POGHere.FGM)+"/"+str(POGHere.FGA)+" shooting"+CheckFor3PtPercentage(POGHere.FG3M, POGHere.FG3A, POGHere.FTM, POGHere.FTA)+", "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("CREATE TABLE Stats (StatType varchar, Score real)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>inmemdb.SQLExecute("INSERT INTO Stats (StatType, Score) VALUES ('Reb', '"+str(POGHere.reb)+"')")</SourceLine>
   <SourceLine>inmemdb.SQLExecute("INSERT INTO Stats (StatType, Score) VALUES ('Ast', '"+str(POGHere.ast)+"')")</SourceLine>
   <SourceLine>inmemdb.SQLExecute("INSERT INTO Stats (StatType, Score) VALUES ('Stl', '"+str(POGHere.stl)+"')")</SourceLine>
   <SourceLine>inmemdb.SQLExecute("INSERT INTO Stats (StatType, Score) VALUES ('Blk', '"+str(POGHere.blk)+"')")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim istring as string</SourceLine>
   <SourceLine>dim statscores(-1) as string</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT StatType, Score From Stats ORDER BY Score DESC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>istring=statgen(rs)</SourceLine>
   <SourceLine>if rs.IdxField(2).IntegerValue=1 then</SourceLine>
   <SourceLine>//remove last 's'</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>k=len(istring)</SourceLine>
   <SourceLine>istring=left(istring, k-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>statscores.append istring</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounter as integer=ubound(statscores)-1</SourceLine>
   <SourceLine>for j as integer=0 to iCounter</SourceLine>
   <SourceLine>mystring=mystring+statscores(j)+", "</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mystring=mystring+"and "+statscores(iCounter+1)+"."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if GamesPlayed&gt;2 then</SourceLine>
   <SourceLine>//now, let's give his season averages</SourceLine>
   <SourceLine>dim h(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's get just his last name</SourceLine>
   <SourceLine>dim lastname as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>k=instr(POGHere.Name, " ")</SourceLine>
   <SourceLine>lastname=mid(POGHere.Name, k+1)</SourceLine>
   <SourceLine>h.append "  On the season, "+lastname</SourceLine>
   <SourceLine>h.append "  For the season, "+lastname</SourceLine>
   <SourceLine>h.append "  So far this year, "+lastname</SourceLine>
   <SourceLine>h.append "  At this point, "+lastname</SourceLine>
   <SourceLine>mystring=mystring+h(r.InRange(0, ubound(h)))</SourceLine>
   <SourceLine>redim h(-1)</SourceLine>
   <SourceLine>h.append " averages "</SourceLine>
   <SourceLine>h.append " now averages "</SourceLine>
   <SourceLine>h.append " is averaging "</SourceLine>
   <SourceLine>h.append " is chipping in "</SourceLine>
   <SourceLine>h.append " is racking up "</SourceLine>
   <SourceLine>h.append " averages "</SourceLine>
   <SourceLine>h.append " now averages "</SourceLine>
   <SourceLine>h.append " is averaging "</SourceLine>
   <SourceLine>h.append " averages "</SourceLine>
   <SourceLine>h.append " now averages "</SourceLine>
   <SourceLine>h.append " is averaging "</SourceLine>
   <SourceLine>mystring=mystring+h(r.InRange(0, ubound(h)))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's add in his actual stats</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>sqlstring="SELECT Player, Pos, HT, YR, PPG, RPG, APG, STL, BLK, GM FROM Players WHERE TeamNum='"+str(t.teamnumber)+"' AND Season='"+mCurrentSeason+"' AND Player LIKE '"+POGHere.Name+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mJustPlayerStats=true</SourceLine>
   <SourceLine>mystring=mystring+PlayerString(rs)+"."</SourceLine>
   <SourceLine>mJustPlayerStats=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>return mystring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>POGHere as GoTWRecapPlayers</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
