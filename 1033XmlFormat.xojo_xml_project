  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function Matchups() As string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim mystring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim playerstrings(5,1,1), thisstring as string</SourceLine>
   <SourceLine>dim advantage as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim positionsstring as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;table border=""2"" cellspacing=""2"" cellpadding=""2""&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append "&lt;tr bgcolor="""+prefColors(0)+"""&gt;&lt;td&gt;&lt;b&gt;"+teams(mTeamNumbers(0)-1)+"&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Pos&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;"+teams(mTeamNumbers(1)-1)+"&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Advantage&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>for j as integer=0 to 1</SourceLine>
   <SourceLine>if n&lt;5 then</SourceLine>
   <SourceLine>sqlstring="SELECT Player, Pos, HT, YR, PPG, RPG, APG, STL, BLK, Tendex, GM FROM Players WHERE TeamNum='"+str(mTeamNumbers(j))+"' AND Season='"+mCurrentSeason+"' AND Pos='"+positions(n)+"'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="SELECT Player, Pos, HT, YR, PPG, RPG, APG, STL, BLK, Tendex, GM FROM Players WHERE TeamNum='"+str(mTeamNumbers(j))+"' AND Season='"+mCurrentSeason+"' AND Pos LIKE 'b%' ORDER BY Tendex DESC"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>playerstrings(n,j,0)=PlayerString(rs)</SourceLine>
   <SourceLine>playerstrings(n,j,1)=str(rs.IdxField(10).DoubleValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set player comparisons</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sbstring.append "&lt;tr&gt;&lt;td&gt;"+playerstrings(n,0,0)+"&lt;/td&gt;&lt;td&gt;"+positions(n)+"&lt;/td&gt;&lt;td&gt;"+playerstrings(n,1,0)+"&lt;/td&gt;"</SourceLine>
   <SourceLine>if val(playerstrings(n,0,1))&gt;val(playerstrings(n,1,1)) then</SourceLine>
   <SourceLine>advantage=teams(mTeamNumbers(0)-1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>advantage=teams(mTeamNumbers(1)-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append "&lt;td&gt;"+advantage+"&lt;/td&gt;&lt;/tr&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//6th man</SourceLine>
   <SourceLine>sbstring.append "&lt;tr&gt;&lt;td&gt;"+playerstrings(5,0,0)+"&lt;/td&gt;&lt;td&gt;6th Man&lt;/td&gt;&lt;td&gt;"+playerstrings(5,1,0)+"&lt;/td&gt;"</SourceLine>
   <SourceLine>if val(playerstrings(5,0,1))&gt;val(playerstrings(5,1,1)) then</SourceLine>
   <SourceLine>advantage=teams(mTeamNumbers(0)-1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>advantage=teams(mTeamNumbers(1)-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append "&lt;td&gt;"+advantage+"&lt;/td&gt;&lt;/tr&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;/table&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
