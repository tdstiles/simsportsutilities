 <Method>
  <ItemName>mthUpdateTeamList</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1845004287</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthUpdateTeamList(Player as cSignedPlayer)</SourceLine>
   <SourceLine>//This method takes the cSignedPlayer, then adds it to a new table in the SLDB.  We then pull from the SLDB to update the top teams list.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'sldb.SQLExecute("CREATE TABLE SLTeamsLoaded (TeamNumber integer, PlayerName varchar, Rating double)")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sldb.SQLExecute("INSERT INTO SLTeamsLoaded (TeamNumber, Rating) VALUES ('"+teams(player.mTeam-1)+"', '"+str(player.mRating)+"')")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now clean out lbTeams and add in the new top 25 list</SourceLine>
   <SourceLine>lbTeams.DeleteAllRows</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim i as integer=1</SourceLine>
   <SourceLine>rs=sldb.SQLSelect("SELECT TeamNumber, Avg(Rating) as A FROM SLTeamsLoaded GROUP BY TeamNumber ORDER BY A DESC")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.eof=false and i&lt;26</SourceLine>
   <SourceLine>lbTeams.addrow str(i)+". "+rs.IdxField(1).StringValue, format(rs.IdxField(2).DoubleValue, "##0.00")</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Player as cSignedPlayer</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>StartorPauseThread</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2068744191</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub StartorPauseThread()</SourceLine>
   <SourceLine>//let's set the highlighted team and conference first</SourceLine>
   <SourceLine>if cbTeams.text&lt;&gt;"" then</SourceLine>
   <SourceLine>iHighLightedTeam=TeamNumberFromName(cbTeams.Text)</SourceLine>
   <SourceLine>iHighlightedConference=ceil(iHighLightedTeam/8)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>iHighlightedConference=0</SourceLine>
   <SourceLine>iHighLightedTeam=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//when we press this button, we look to see how many players we're viewing.</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNumber, PlayerName, Rating, AA, AD, POY FROM SLTeams ORDER BY Rating ASC"</SourceLine>
   <SourceLine>recruitrs=sldb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's disable the team highlight</SourceLine>
   <SourceLine>cbTeams.Enabled=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>LoadPlayers</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>Sleep</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>852525055</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Sleep()</SourceLine>
   <SourceLine>dim starttime as integer=ticks</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while ticks &lt; startTime + (tickstowait)  // wait between running again</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>End Sub</SourceLine>
