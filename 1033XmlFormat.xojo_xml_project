 </Method>
 <Method>
  <ItemName>CalcSoS</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1956839423</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalcSoS()</SourceLine>
   <SourceLine>//Strength of Schedule Calculations</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this module calculates the SoS and then stores it in PRI.SoS</SourceLine>
   <SourceLine>dim rTeams(255) as integer</SourceLine>
   <SourceLine>dim rSoS(255) as double</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>rTeams(n)=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//select the teams and load up expected wins from a 1000 ELO team playing the same schedule</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.ELO FROM PRI, Games WHERE PRI.TeamNum=Games.OpponentNum AND Games.TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>rec=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>dim ew as double</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>while rec.eof=false</SourceLine>
   <SourceLine>ew=ew+1/(1+10^((rec.idxfield(1).integervalue-1000)/400))</SourceLine>
   <SourceLine>rec.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rSoS(n-1)=24-ew</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rSos.SortWith(rTeams)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now udpate the PRI table</SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE PRI SET SoS="+str(256-n)+" WHERE TeamNum="+str(rTeams(n))+" AND Season="+mCurrentSeason)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
