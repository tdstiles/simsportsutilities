  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPopups()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=0 to 3</SourceLine>
   <SourceLine>popup(x).DeleteAllRows</SourceLine>
   <SourceLine>popup(x).addrow "All"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//connect to db and add in season information for popup0</SourceLine>
   <SourceLine>sqlstring="SELECT TeamName FROM PRI ORDER BY TeamName ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>popup(0).addrow rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load popup1</SourceLine>
   <SourceLine>popup(1).addrow "Fast"</SourceLine>
   <SourceLine>popup(1).addrow "Norm"</SourceLine>
   <SourceLine>popup(1).addrow "Slow"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load popup2</SourceLine>
   <SourceLine>popup(2).addrow "Man"</SourceLine>
   <SourceLine>popup(2).addrow "Norm"</SourceLine>
   <SourceLine>popup(2).addrow "Zone"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load popup3</SourceLine>
   <SourceLine>popup(3).addrow "vs Top 10"</SourceLine>
   <SourceLine>popup(3).addrow "vs Top 25"</SourceLine>
   <SourceLine>popup(3).addrow "vs Top 50"</SourceLine>
   <SourceLine>popup(3).addrow "vs Top 100"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=0 to 3</SourceLine>
   <SourceLine>popup(x).ListIndex=0</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
