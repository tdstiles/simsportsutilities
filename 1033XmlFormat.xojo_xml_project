 </Method>
 <Method>
  <ItemName>VictoryEdge</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>270514175</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function VictoryEdge() As string</SourceLine>
   <SourceLine>dim k as string</SourceLine>
   <SourceLine>dim rgk(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim Winner as cGOTWRecapTeam</SourceLine>
   <SourceLine>dim Loser as cGOTWRecapTeam</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if MoV&gt;0 then</SourceLine>
   <SourceLine>Winner=RecapTeams(0)</SourceLine>
   <SourceLine>Loser=RecapTeams(1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Winner=RecapTeams(1)</SourceLine>
   <SourceLine>Loser=RecapTeams(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//rebounding, turnovers, shooting, three-pointers, free throws</SourceLine>
   <SourceLine>dim differences(-1) as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//rebounding margin</SourceLine>
   <SourceLine>differences.append Winner.Reb-Loser.Reb</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//turnover margin</SourceLine>
   <SourceLine>differences.append Loser.tos-Winner.tos</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//shooting percentage</SourceLine>
   <SourceLine>differences.append ((Winner.fgm/Winner.fga)-(Loser.fgm/Loser.fga))*80</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//three-pointers</SourceLine>
   <SourceLine>differences.append ((Winner.fg3m/Winner.fg3a)-(Loser.fg3m/Loser.fg3a))*10*Winner.fg3m</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//free throws</SourceLine>
   <SourceLine>differences.append ((Winner.ftm/Winner.fta)-(Loser.ftm/Loser.fta))*85</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//total free throws</SourceLine>
   <SourceLine>differences.append ((Winner.ftm*Winner.ftm/Winner.fta)-(Loser.ftm/Loser.fta*Winner.ftm))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we see where the biggest differential exists</SourceLine>
   <SourceLine>dim nHighestScore as double</SourceLine>
   <SourceLine>dim nHighestStat as integer</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>if differences(n)&gt;nHighestScore then</SourceLine>
   <SourceLine>nHighestScore=differences(n)</SourceLine>
   <SourceLine>nHighestStat=n</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this gives us the difference value that is the greatest</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim scoretext(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case nHighestStat</SourceLine>
   <SourceLine>case 0</SourceLine>
   <SourceLine>//rebounding</SourceLine>
   <SourceLine>h="won the battle of the boards,dominated the paint,controlled the inside,utilized their height"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>rgk=split(", outrebounding * and outrebounded ", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+Loser.TeamName+" by a "+format(differences(0), "+#0")+" margin"</SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(RPG*GM)/"+str(gamesplayed)+" FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>if Winner.reb&gt;rs.IdxField(1).DoubleValue then</SourceLine>
   <SourceLine>h=h+", which raises its season average to "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h=h+", which makes its season average "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>h=h+format(rs.IdxField(1).DoubleValue, "#0.0")+"."</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h=h+"."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>case 1</SourceLine>
   <SourceLine>//tos</SourceLine>
   <SourceLine>h="won the turnover battle,controlled the ball better,did a better job controlling the ball,generated a lot of turnovers,took good care of the ball"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>rgk=split(", producing a * and produced a *, which resulted in a *,resulting in a ", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+format(differences(1), "+#0")+" turnover margin"</SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(TOs*GM)/"+str(gamesplayed)+" FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>if Winner.tos&lt;rs.IdxField(1).DoubleValue then</SourceLine>
   <SourceLine>h=h+", which lowers its season average to "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h=h+", which moves the season average to "</SourceLine>
   <SourceLine>end </SourceLine>
   <SourceLine>h=h+format(rs.IdxField(1).DoubleValue, "#0.0")+"."</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h=h+"."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>case 2 </SourceLine>
   <SourceLine>//fgm</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's see if they were good enough to be "red hot"</SourceLine>
   <SourceLine>if Winner.fgm/Winner.fga&gt;0.52 then</SourceLine>
   <SourceLine>h="was red-hot from the field,outshot "+Loser.TeamName+",shot well,didn't miss many shots"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h="outshot "+Loser.TeamName+",did a better job of putting the ball in the basket,had a better time finding their range"</SourceLine>
   <SourceLine>end </SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>rgk=split(", making * and made * and hit * and sank * and made *, making * and hit*", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+format(Winner.fgm/Winner.fga, "#0.0%")+" of their shots, compared to "+Loser.TeamName+"'s "+format(Loser.fgm/Loser.fga, "#0.0%")+"."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(FGM)/Sum(FGA) FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>h=h+"  On the season, the "+Winner.TeamNickName+" are shooting "+format(rs.IdxField(1).DoubleValue, "##0.0%")+" from the field."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 3</SourceLine>
   <SourceLine>//fg3m</SourceLine>
   <SourceLine>//see if they were good enough to be "red hot"</SourceLine>
   <SourceLine>if Winner.fg3m/Winner.fg3a&gt;0.38 then</SourceLine>
   <SourceLine>h="was red-hot from the outside,outshot "+Loser.TeamName+" from behind the arc,did a nice job from behind the arc,was money from downtown"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h="outshot "+Loser.TeamName+" from behind the arc,shot better than "+Loser.TeamName+" from 3-pt range"</SourceLine>
   <SourceLine>end </SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>rgk=split(", making * and made * and hit * and sank * and made *, making * and hit *, going ", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+str(Winner.fg3m)+" of "+str(Winner.fg3a)+ " ("+format(Winner.fg3m/Winner.fg3a, "#0.0%")+") of their 3-pt shots, compared to "+Loser.TeamName+"'s "+str(Loser.fg3m)+" of "+str(Loser.fg3a)+ " ("+format(Loser.fg3m/Loser.fg3a, "#0.0%")+")."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(FG3M)/Sum(FG3A) FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>h=h+"  This season the "+Winner.TeamName+" is shooting "+format(rs.IdxField(1).DoubleValue, "##0.0%")+" from behind the arc."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 4</SourceLine>
   <SourceLine>//ftm</SourceLine>
   <SourceLine>h="shot better from the stripe, made a higher percentage of their free throws, earned it at the line,showed up at the charity stripe,shot better from the stripe,earned it at the line"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>rgk=split(", making * and went * and hit *, going ", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+str(Winner.ftm)+" for "+str(Winner.fta)+" from the free throw line.  "+Loser.teamname+" only managed to go "+str(Loser.ftm)+" for "+str(Loser.fta)+"."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(FTM)/Sum(FTA) FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>h=h+"  This season the "+Winner.TeamNickName+" has shot "+format(rs.IdxField(1).DoubleValue, "##0.0%")+" from the line."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case 5</SourceLine>
   <SourceLine>h="dominated from the stripe*made plenty of free throws*got to the line plenty*took advantage of their time at the line*played a more physical game, which resulted in more opportunities at the line*won the game at the stripe"</SourceLine>
   <SourceLine>scoretext=split(h,"*")</SourceLine>
   <SourceLine>rgk=split(", making * and went * and hit *, going ", "*")</SourceLine>
   <SourceLine>k=rgk(r.InRange(0,UBound(rgk)))</SourceLine>
   <SourceLine>h= scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>h=Winner.TeamName+" "+h+k+str(Winner.ftm)+" for "+str(Winner.fta)+" from the free throw line.  "+Loser.teamname+" only hit "+str(Loser.ftm)+" of "+str(Loser.fta)+"."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Sum(FTM)/Sum(FTA) FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(Winner.TeamNumber))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>h=h+"  Season to date, the "+Winner.TeamNickName+" has shot "+format(rs.IdxField(1).DoubleValue, "##0.0%")+" from the line."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return h+"  "+BloggerEndofLine</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
