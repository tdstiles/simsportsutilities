  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateOldPlayerDB()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim insertstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Name, HSName, Sum(Pts), Sum(Reb), Sum(Ast), Sum(Stl), Sum(TOs), Sum(Blk) FROM HSStats WHERE Season='"+mCurrentSeason+"' GROUP BY Name")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>insertstring=""</SourceLine>
   <SourceLine>for n as integer=1 to 7</SourceLine>
   <SourceLine>insertstring=insertstring+"'"+rs.IdxField(n).StringValue+"', "</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>insertstring=insertstring+"'"+rs.IdxField(8).StringValue+"'"</SourceLine>
   <SourceLine>sqlstring="INSERT INTO HSStats (Season, Name, HSName, Pts, Reb, Ast, Stl, Tos, Blk) VALUES ('"+mCurrentSeason+"', "+insertstring+")"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
