   <SourceLine>Sub Constructor(MyTeams() as integer, Gamenumber as integer, mBoxScore as boolean)</SourceLine>
   <SourceLine>//This method is passed the two team numbers and the game number.</SourceLine>
   <SourceLine>dim TmpTeams as cGOTWRecapTeam</SourceLine>
