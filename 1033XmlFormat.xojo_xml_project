  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>list as listbox, TitleB as String, Heading as Integer=2</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
