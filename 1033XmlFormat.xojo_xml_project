   <SourceLine>Function mthFinalFour(Rd4winners() as cTourneyTeam) As string</SourceLine>
   <SourceLine>//this method has an array with the four teams, then gives back the Final Four text</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim TourneyGame as cFinalFour</SourceLine>
   <SourceLine>dim winners(-1) as ctourneyteam</SourceLine>
