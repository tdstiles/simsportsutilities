  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1211154431</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function HSStatLeaders() As string</SourceLine>
   <SourceLine>//in this module, we get the top 10 in each HS stat category</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim statcategory(5,1) as string</SourceLine>
   <SourceLine>statcategory(0,0)="PPG"</SourceLine>
   <SourceLine>statcategory(0,1)="Points"</SourceLine>
   <SourceLine>statcategory(1,0)="RPG"</SourceLine>
   <SourceLine>statcategory(1,1)="Rebounds"</SourceLine>
   <SourceLine>statcategory(2,0)="APG"</SourceLine>
   <SourceLine>statcategory(2,1)="Assists"</SourceLine>
   <SourceLine>statcategory(3,0)="SPG"</SourceLine>
   <SourceLine>statcategory(3,1)="Steals"</SourceLine>
   <SourceLine>statcategory(4,0)="TPG"</SourceLine>
   <SourceLine>statcategory(4,1)="Turnovers"</SourceLine>
   <SourceLine>statcategory(5,0)="BPG"</SourceLine>
   <SourceLine>statcategory(5,1)="Blocks"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tablecolumns(-1) as string</SourceLine>
   <SourceLine>sbstring.append "&lt;h1&gt;L"+league+" Stats Leaders:  G"+str(gamesplayed+3)+"&lt;/h1&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>tablecolumns=split("Rnk, Name,Reg,Ht,Pos,"+statcategory(n,1), ",")</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle(statcategory(n,1)+" Leaders", tablecolumns)</SourceLine>
   <SourceLine>sqlstring="SELECT Name, Region, Height, Pos, "+statcategory(n,0)+" FROM PlayerInfo WHERE Season="+mCurrentSeason+" ORDER BY "+statcategory(n,0)+" DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) and rs.eof=false then</SourceLine>
   <SourceLine>for j as integer=1 to 10</SourceLine>
   <SourceLine>tablecolumns=split(str(j)+".,"+rs.IdxField(1).StringValue+","+rs.IdxField(2).StringValue+","+InchestoHT(rs.IdxField(3).IntegerValue)+","+rs.IdxField(4).StringValue+","+format(rs.IdxField(5).DoubleValue, "##0.0"), ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(j,tablecolumns)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append CloseTable+"&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
