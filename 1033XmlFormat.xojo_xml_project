 <Method>
  <ItemName>ImportRecruitCSV</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2028355583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ImportRecruitCSV()</SourceLine>
   <SourceLine>Dim TextIn As TextInputStream</SourceLine>
   <SourceLine>Dim n, d As Integer</SourceLine>
   <SourceLine>Dim line,c,s,addition, sqlstatement As String</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim f as FolderItem</SourceLine>
   <SourceLine>f=mCSVFile</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>addition=""</SourceLine>
   <SourceLine>If f.Exists Then // check to make sure the file exists</SourceLine>
   <SourceLine>TextIn = f.OpenAsTextFile</SourceLine>
   <SourceLine>If TextIn &lt;&gt; NIL Then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if DoGamebyGame then create temp database for comparison</SourceLine>
   <SourceLine>if DoGamebyGame then</SourceLine>
   <SourceLine>'CreateOldPlayerDB</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear old data from database</SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM PlayerInfo WHERE  Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// read the heading line</SourceLine>
   <SourceLine>line = TextIn.ReadLine</SourceLine>
   <SourceLine>Do</SourceLine>
   <SourceLine>// read a line</SourceLine>
   <SourceLine>line = TextIn.ReadLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For i as integer= 1 To 22</SourceLine>
   <SourceLine>// read the data</SourceLine>
   <SourceLine>c = NthField(line,",",i)</SourceLine>
   <SourceLine>if i=4 then</SourceLine>
   <SourceLine>c=str(FeettoInches(c))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if i = 8 or i=9 or i=10 or i=11 or i=12 or i=13 THEN</SourceLine>
   <SourceLine>c=str(wordtonum(c))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if i=1 then //player's name</SourceLine>
   <SourceLine>//remove apostrophes</SourceLine>
   <SourceLine>c=CheckNameforApos(c)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if i &lt;&gt; 22  THEN</SourceLine>
   <SourceLine>s = "'" + c + "',"</SourceLine>
   <SourceLine>elseif i=22 then</SourceLine>
   <SourceLine>s = "'" + c + "'"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>addition = addition+s</SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine>dbsqlexecute("INSERT INTO PlayerInfo (Season, Name, Region,HSName, Height, GPA, Test, Pos, Scout, SHT, DEF, HND, REB, ATH,Local, Win, Impact, PPG, RPG, APG, SPG, TPG, BPG) VALUES ('"+mCurrentSeason+"', " + addition + ")")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>addition=""</SourceLine>
   <SourceLine>Loop Until TextIn.EOF = True</SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>TextIn.Close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ParseFileB</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>817186815</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseFileB(result as string)</SourceLine>
   <SourceLine>dim teamarray(255,8) as string</SourceLine>
   <SourceLine>Dim n,i,r As Integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim short as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines = split(result,endOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=13</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=0</SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>for j as integer=0 to 24</SourceLine>
   <SourceLine>for k as integer=1 to 10</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//team name</SourceLine>
   <SourceLine>teamarray(n,0)=lines(r)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear team records and avg height</SourceLine>
   <SourceLine>short=lines(r+1)+"-"+lines(r+2)</SourceLine>
   <SourceLine>teamarray(n,6)=short  ///last WL</SourceLine>
   <SourceLine>short=lines(r+3)+"-"+lines(r+4)</SourceLine>
   <SourceLine>teamarray(n,7)=short  ///this WL</SourceLine>
   <SourceLine>teamarray(n,8)=lines(r+5)</SourceLine>
   <SourceLine>r=r+6</SourceLine>
   <SourceLine>for i=1 to 5</SourceLine>
   <SourceLine>teamarray(n,i)=lines(r)</SourceLine>
   <SourceLine>r=r+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>r=r+11</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//last 6 teams</SourceLine>
   <SourceLine>for k as integer=1 to 6</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//team name</SourceLine>
   <SourceLine>teamarray(n,0)=lines(r)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear team records and avg height</SourceLine>
   <SourceLine>short=lines(r+1)+"-"+lines(r+2)</SourceLine>
   <SourceLine>teamarray(n,6)=short  ///last WL</SourceLine>
   <SourceLine>short=lines(r+3)+"-"+lines(r+4)</SourceLine>
   <SourceLine>teamarray(n,7)=short  ///this WL</SourceLine>
   <SourceLine>teamarray(n,8)=lines(r+5)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r=r+6</SourceLine>
   <SourceLine>for i=1 to 5</SourceLine>
   <SourceLine>teamarray(n,i)=lines(r)</SourceLine>
   <SourceLine>r=r+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ImportHSCSV(teamarray)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>result as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
