 <Method>
  <ItemName>ConvertToMediaWiki</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1715914751</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ConvertToMediaWiki() As string</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim type(-1) as creplacement</SourceLine>
   <SourceLine>dim t as creplacement</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine>dim mymatch as new RegExMatch</SourceLine>
   <SourceLine>dim CN as integer</SourceLine>
   <SourceLine>dim replace as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'&lt;a href="http://drivethelane.com/bask/runtime/whoibbjv.asp?lg=00005&amp;idno=66" target="_blank"&gt;Jacksonville&lt;/a&gt;</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=FormattedText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.SearchPattern="&lt;a href=""http://drivethelane.com/bask/runtime/whoibbjv.asp.lg=(.*)&amp;idno=(.*)"" target.*&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>mymatch=r.Search(a)</SourceLine>
   <SourceLine>while mymatch&lt;&gt;nil</SourceLine>
   <SourceLine>replace="[http://simsports.sainio.org/wiki/index.php?title=L"+league+"_C"</SourceLine>
   <SourceLine>replace=replace+str(ceil(val(mymatch.subexpressionstring(2))/8))+" "+mymatch.SubExpressionstring(3)+"]"</SourceLine>
   <SourceLine>r.ReplacementPattern=replace</SourceLine>
   <SourceLine>a=r.Replace(a)</SourceLine>
   <SourceLine>mymatch=r.Search(a)</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;a href=""(.*)"".*&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>t.replacement="[\1 \2]"</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;tr.*&gt;(.*)&lt;/tr&gt;"</SourceLine>
   <SourceLine>t.replacement="|-"+EndOfLine+"\1"</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;td.*&gt;(.*)&lt;/td&gt;"</SourceLine>
   <SourceLine>t.replacement=EndOfLine+"| \1"</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;table.*&gt;(.*)&lt;/table&gt;"</SourceLine>
   <SourceLine>t.replacement="{| class=""wikitable"" border=""1"""+EndOfLine+"\1"+EndOfLine+"|}"</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;Font.*&gt;(.*)&lt;/Font&gt;"</SourceLine>
   <SourceLine>t.replacement="\1"</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;h1&gt;(.*)&lt;/h1&gt;"</SourceLine>
   <SourceLine>t.replacement="= \1 ="+EndOfLine</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;h2&gt;(.*)&lt;/h2&gt;"</SourceLine>
   <SourceLine>t.replacement="== \1 =="+EndOfLine</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;h3&gt;(.*)&lt;/h3&gt;"</SourceLine>
   <SourceLine>t.replacement="=== \1 ==="+EndOfLine</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;h4&gt;(.*)&lt;/h4&gt;"</SourceLine>
   <SourceLine>t.replacement="===== \1 ===="+EndOfLine</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>t=new cReplacement</SourceLine>
   <SourceLine>t.original="&lt;br&gt;"</SourceLine>
   <SourceLine>t.replacement=EndOfLine+EndOfLine</SourceLine>
   <SourceLine>type.append t</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to UBound(type)</SourceLine>
   <SourceLine>r.SearchPattern = type(n).original</SourceLine>
   <SourceLine>r.ReplacementPattern = type(n).replacement</SourceLine>
   <SourceLine>a=Trim(r.Replace(a))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>exception err as RegExException</SourceLine>
   <SourceLine>MsgBox err.message</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
