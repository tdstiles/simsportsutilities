 <Compatibility></Compatibility>
 <Method>
  <ItemName>MainTourneyPreviewMethod</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>87707647</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function MainTourneyPreviewMethod(Tournament as String) As string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim PreviewTeam as cTeamInfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, we create an in-memory database to store all the info for regions</SourceLine>
   <SourceLine>mTourneyDB=new REALSQLDatabase</SourceLine>
   <SourceLine>if mTourneyDB.Connect then</SourceLine>
   <SourceLine>mTourneyDB.SQLExecute("CREATE TABLE tdbTable (Team integer, Region integer, seed integer, ELO double, opp double, rnk integer)")</SourceLine>
   <SourceLine>mTourneyDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//second, we download the correct tournament file</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim szTournamentName as string</SourceLine>
   <SourceLine>if Tournament="NTT" then</SourceLine>
   <SourceLine>szTournamentName="nt1a.html"</SourceLine>
   <SourceLine>elseif Tournament="PTT" then</SourceLine>
   <SourceLine>szTournamentName="nt2a.html"</SourceLine>
   <SourceLine>elseif Tournament="RTT" then</SourceLine>
   <SourceLine>szTournamentName="nt3a.html"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>szTournamentName="nt4a.html"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>mResult=thissocket.Get("http://drivethelane.com/bask/weekly/lg000"+right("0"+league,2)+"/"+szTournamentName, 30)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//third, we parse the file and clean it up</SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//fourth, we go through and add in the proper teams for the bracket</SourceLine>
   <SourceLine>ParseDownloadedString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//fifth, we generate how we think the teams will finish, and give a quick bio on each team</SourceLine>
   <SourceLine>//here, input the eloRnk for each team</SourceLine>
   <SourceLine>AddELORnk</SourceLine>
   <SourceLine>GenerateRankedStats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring.append "{{LeagueCompass|LID="+League+"|minS="+mCurrentSeason+"}}"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;h1&gt;L"+league+" S"+mcurrentseason+" "+Tournament+" Preview&lt;/h1&gt;&lt;br&gt;"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for regionnumber as integer=0 to 3</SourceLine>
   <SourceLine>sbstring.append  "&lt;h2&gt;"+Tournament+" Region "+str(regionnumber+1)+" analysis&lt;/h2&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>rs=mTourneyDB.SQLSelect("SELECT Team, Region, Seed FROM TdbTable WHERE Region='"+str(regionnumber)+"' ORDER BY SEED ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>sbstring.append  "&lt;i&gt;The Favorite&lt;/i&gt;"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(rs.IdxField(1).IntegerValue, val(mCurrentSeason))</SourceLine>
   <SourceLine>PreviewTeam.Region=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.Tournament=Tournament</SourceLine>
   <SourceLine>PreviewTeam.Seed=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.mTourneyDB=mTourneyDB</SourceLine>
   <SourceLine>PreviewTeam.mStatDB=mStatDB</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append  PreviewTeam.ReturnString</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>sbstring.append EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;The Contenders&lt;/i&gt;"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(rs.IdxField(1).IntegerValue, val(mCurrentSeason))</SourceLine>
   <SourceLine>PreviewTeam.Region=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.Tournament=Tournament</SourceLine>
   <SourceLine>PreviewTeam.Seed=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.mTourneyDB=mTourneyDB</SourceLine>
   <SourceLine>PreviewTeam.mStatDB=mStatDB</SourceLine>
   <SourceLine>sbstring.append  PreviewTeam.ReturnString</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;The Dark Horses&lt;/i&gt;"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(rs.IdxField(1).IntegerValue, val(mCurrentSeason))</SourceLine>
   <SourceLine>PreviewTeam.Region=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.Tournament=Tournament</SourceLine>
   <SourceLine>PreviewTeam.Seed=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.mTourneyDB=mTourneyDB</SourceLine>
   <SourceLine>PreviewTeam.mStatDB=mStatDB</SourceLine>
   <SourceLine>sbstring.append  PreviewTeam.ReturnString</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;The Rest&lt;/i&gt;"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>PreviewTeam=new cTeamInfo(rs.IdxField(1).IntegerValue, val(mCurrentSeason))</SourceLine>
   <SourceLine>PreviewTeam.Region=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.Tournament=Tournament</SourceLine>
   <SourceLine>PreviewTeam.Seed=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>PreviewTeam.mTourneyDB=mTourneyDB</SourceLine>
   <SourceLine>PreviewTeam.mStatDB=mStatDB</SourceLine>
   <SourceLine>sbstring.append  PreviewTeam.ReturnString</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>rec=mTourneyDB.SQLSelect("SELECT Team FROM TdbTable WHERE Region='"+str(regionnumber)+"' ORDER BY ELO DESC")</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;b&gt;SimSportsNews's Pick for Region "+str(regionnumber+1)+"&lt;/b&gt;:  "+HTMLLink(rec.IdxField(1).integerValue, 2)</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "Downloading error.  Check your internet connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "Could not create temporary database.  Please e-mail webmaster@commonsenseonline.net and let him know that you are having problems."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
