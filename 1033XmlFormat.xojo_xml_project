  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function WinningStreak() As string</SourceLine>
   <SourceLine>dim TmpReturn as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpTeam as new cTeamInfo(RecapTeams(w).TeamNumber, val(mCurrentSeason))</SourceLine>
   <SourceLine>dim tmpString as string=tmpTeam.Streak</SourceLine>
   <SourceLine>if left(tmpString,1)="W" then</SourceLine>
   <SourceLine>tmpString=mid(tmpString,2)</SourceLine>
   <SourceLine>//we are on a winning streak</SourceLine>
   <SourceLine>if val(tmpString)&gt;3 then</SourceLine>
   <SourceLine>dim h(-1) as string</SourceLine>
   <SourceLine>h.append " is on a "+tmpString+" game winning streak."</SourceLine>
   <SourceLine>h.append " has now won "+tmpString+" games in a row."</SourceLine>
   <SourceLine>h.append "'s winning streak has stretched to "+tmpString+" games."</SourceLine>
   <SourceLine>TmpReturn= "  "+RecapTeams(w).TeamName+h(r.InRange(0,ubound(h)))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return TmpReturn</SourceLine>
   <SourceLine>End Function</SourceLine>
