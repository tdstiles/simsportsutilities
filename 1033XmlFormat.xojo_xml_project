 <Method>
  <ItemName>mthConfTourneyBracket</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>38135807</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthConfTourneyBracket(lines() as string) As string</SourceLine>
   <SourceLine>//this method creates data for the wiki that includes the breakdown of teams and how far they made it.</SourceLine>
   <SourceLine>dim sbstring as StringBuilder</SourceLine>
   <SourceLine>sbstring=new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim TourneyGame as  cConfTourneyGame</SourceLine>
   <SourceLine>dim TmpSeeds(1) as integer</SourceLine>
   <SourceLine>dim TeamNumbers(1) as integer</SourceLine>
   <SourceLine>dim winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine>dim Rd2winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;h2&gt;L"+league+" C"+str(CN)+" S"+mCurrentSeason+" Tournament Bracket&lt;/h2&gt;"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "{{8TeamBracket | RD1=Quarterfinals"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| RD2=Semifinals"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| RD3=Championship"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| group1="+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| group2="+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| seed-width=25"+EndOfLine</SourceLine>
   <SourceLine>sbstring.Append "| score-width=50"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "| team-width=175"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=1</SourceLine>
   <SourceLine>TmpSeeds(1)=8</SourceLine>
   <SourceLine>TeamNumbers(0)=TeamNumberFromName(lines(0))</SourceLine>
   <SourceLine>TeamNumbers(1)=TeamNumberFromName(lines(7))</SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(1,TmpSeeds,1,TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=4</SourceLine>
   <SourceLine>TmpSeeds(1)=5</SourceLine>
   <SourceLine>TeamNumbers(0)=TeamNumberFromName(lines(9))</SourceLine>
   <SourceLine>TeamNumbers(1)=TeamNumberFromName(lines(13))</SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(1,TmpSeeds,3,TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=2</SourceLine>
   <SourceLine>TmpSeeds(1)=7</SourceLine>
   <SourceLine>TeamNumbers(0)=TeamNumberFromName(lines(6))</SourceLine>
   <SourceLine>TeamNumbers(1)=TeamNumberFromName(lines(8))</SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(1,TmpSeeds,5,TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=3</SourceLine>
   <SourceLine>TmpSeeds(1)=6</SourceLine>
   <SourceLine>TeamNumbers(0)=TeamNumberFromName(lines(12))</SourceLine>
   <SourceLine>TeamNumbers(1)=TeamNumberFromName(lines(14))</SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(1,TmpSeeds,7,TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now round 2</SourceLine>
   <SourceLine>for nn as integer=0 to 1</SourceLine>
   <SourceLine>TmpSeeds(nn)=winners(nn).mSeed</SourceLine>
   <SourceLine>TeamNumbers(nn)=winners(nn).mteamnumber</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(2,TmpSeeds,1, TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>Rd2winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=winners(2).mSeed</SourceLine>
   <SourceLine>TmpSeeds(1)=winners(3).mSeed</SourceLine>
   <SourceLine>TeamNumbers(0)=winners(2).mteamnumber</SourceLine>
   <SourceLine>TeamNumbers(1)=winners(3).mteamnumber</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(2,TmpSeeds,3, TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>Rd2winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and round 3</SourceLine>
   <SourceLine>for nn as integer=0 to 1</SourceLine>
   <SourceLine>TmpSeeds(nn)=rd2winners(nn).mSeed</SourceLine>
   <SourceLine>TeamNumbers(nn)=rd2winners(nn).mteamnumber</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TourneyGame=new cConfTourneyGame(3,TmpSeeds,1, TeamNumbers)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>sbstring.append "}}"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
