  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub smm(scouter as integer, shot as integer, defense as integer, hands as integer, rebounding as integer, athleticism as integer)</SourceLine>
   <SourceLine>dim variance as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if scouter=14 then //exc</SourceLine>
   <SourceLine>variance=0.33</SourceLine>
   <SourceLine>elseif scouter=11 then //good</SourceLine>
   <SourceLine>variance=0.67</SourceLine>
   <SourceLine>elseif scouter=9 then //f+</SourceLine>
   <SourceLine>variance=1</SourceLine>
   <SourceLine>elseif scouter=7 then //f-</SourceLine>
   <SourceLine>variance=1.33</SourceLine>
   <SourceLine>else //poor</SourceLine>
   <SourceLine>variance=1.67</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>attrs(0,0)=((shot-8)/3)-variance</SourceLine>
   <SourceLine>attrs(0,1)=((shot-8)/3)+variance</SourceLine>
   <SourceLine>attrs(1,0)=((defense-8)/3)-Variance</SourceLine>
   <SourceLine>attrs(1,1)=((defense-8)/3)+variance</SourceLine>
   <SourceLine>attrs(2,0)=((hands-8)/3)-variance</SourceLine>
   <SourceLine>attrs(2,1)=((hands-8)/3)+Variance</SourceLine>
   <SourceLine>attrs(3,0)=((rebounding-8)/3)-Variance</SourceLine>
   <SourceLine>attrs(3,1)=((rebounding-8)/3)+variance</SourceLine>
   <SourceLine>attrs(4,0)=((athleticism-8)/3)-variance</SourceLine>
   <SourceLine>attrs(4,1)=((athleticism-8)/3)+variance</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>if attrs(n,0)&lt;-2.33 then</SourceLine>
   <SourceLine>attrs(n,0)=-2.33</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if attrs(n,1)&gt;2.33 then</SourceLine>
   <SourceLine>attrs(n,1)=2.33</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
