 <Method>
  <ItemName>ListboxToHTML</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>474789887</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ListboxToHTML(list as listbox, TitleB as String, Heading as Integer=2) As string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim s as integer</SourceLine>
   <SourceLine>dim columninfo(-1) as string</SourceLine>
   <SourceLine>dim columnnames(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounter as integer=list.ColumnCount-1</SourceLine>
   <SourceLine>for n as integer=0 to iCounter</SourceLine>
   <SourceLine>columnnames.append list.heading(n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle(titleB, columnnames,0, heading)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCount as Integer=list.ListCount-1</SourceLine>
   <SourceLine>for n as integer=0 to iCount</SourceLine>
   <SourceLine>redim columninfo(-1)</SourceLine>
   <SourceLine>for i as integer=0 to iCounter</SourceLine>
   <SourceLine>if i=0 then</SourceLine>
   <SourceLine>s=teams.IndexOf(list.cell(n,i))+1</SourceLine>
   <SourceLine>if s&lt;&gt;0 then</SourceLine>
   <SourceLine>columninfo.append "&lt;a href="""+mLocationString+str(s)+""" target=""_blank""&gt;"+teams(s-1)+"&lt;/a&gt;"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>columninfo.append list.cell(n,i)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif i=1 then</SourceLine>
   <SourceLine>s=teams.IndexOf(list.cell(n,i))+1</SourceLine>
   <SourceLine>if s&lt;&gt;0 then</SourceLine>
   <SourceLine>columninfo.append "&lt;a href="""+mLocationString+str(s)+""" target=""_blank""&gt;"+teams(s-1)+"&lt;/a&gt;"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>columninfo.append list.cell(n,i)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>columninfo.append list.cell(n,i)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n, columninfo)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>FormattedText=sbstring.ToString</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
