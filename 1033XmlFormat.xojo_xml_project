 <Method>
  <ItemName>mthCalcConfTriMean</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1758478335</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthCalcConfTriMean(ConfNum as integer, NumTeams as integer) As string()</SourceLine>
   <SourceLine>//this method calculates the trimean for the RPI and Ratings</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>dim maxEloMultiplier as integer</SourceLine>
   <SourceLine>dim fonlyone as boolean=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//maxEloMultiplier is the highest number we give for the number of teams for the trimean</SourceLine>
   <SourceLine>maxEloMultiplier=floor(NumTeams/2)</SourceLine>
   <SourceLine>if NumTeams mod maxEloMultiplier=0 then</SourceLine>
   <SourceLine>//no leftover teams</SourceLine>
   <SourceLine>fonlyone=false</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>maxEloMultiplier=maxEloMultiplier+1</SourceLine>
   <SourceLine>fonlyone=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now pull the teams from the conference</SourceLine>
   <SourceLine>dim conftrimeanRPI as double</SourceLine>
   <SourceLine>dim conftrimeanRatings as double</SourceLine>
   <SourceLine>dim currentmodifier as integer</SourceLine>
   <SourceLine>dim iterations as integer</SourceLine>
   <SourceLine>dim currentiteration as integer=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if db.connect then</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT RPI, AdjustedELO FROM PRI WHERE Season='"+mcurrentseason+"' AND Conference='"+str(ConfNum)+"' ORDER BY AdjustedELO DESC")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>currentmodifier=1</SourceLine>
   <SourceLine>while rec.EOF=false</SourceLine>
   <SourceLine>conftrimeanRPI=conftrimeanRPI+rec.IdxField(1).DoubleValue*currentmodifier</SourceLine>
   <SourceLine>conftrimeanRatings=conftrimeanRatings+rec.IdxField(2).DoubleValue*currentmodifier</SourceLine>
   <SourceLine>iterations=iterations+currentmodifier</SourceLine>
   <SourceLine>if currentiteration&lt;maxEloMultiplier then</SourceLine>
   <SourceLine>currentmodifier=currentmodifier+1</SourceLine>
   <SourceLine>elseif currentiteration=maxEloMultiplier then</SourceLine>
   <SourceLine>if fonlyone then</SourceLine>
   <SourceLine>//leftover teams, so immediately decrease</SourceLine>
   <SourceLine>fonlyone=false</SourceLine>
   <SourceLine>currentmodifier=currentmodifier-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//we're over the hill</SourceLine>
   <SourceLine>currentmodifier=currentmodifier-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>currentiteration=currentiteration+1</SourceLine>
   <SourceLine>rec.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update the conference strength</SourceLine>
   <SourceLine>conftrimeanRPI=conftrimeanRPI/iterations</SourceLine>
   <SourceLine>conftrimeanRatings=conftrimeanRatings/iterations</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim j(-1) as string</SourceLine>
   <SourceLine>j.Append str(conftrimeanRatings)</SourceLine>
   <SourceLine>j.Append str(conftrimeanRPI)</SourceLine>
   <SourceLine>return j</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>ConfNum as integer, NumTeams as integer</ItemParams>
  <ItemResult>string()</ItemResult>
 </Method>
 <Method>
  <ItemName>PrepareConferenceDB</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1791256575</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PrepareConferenceDB() As realSQLDatabase</SourceLine>
   <SourceLine>//This method adds another sheet to the Excel export</SourceLine>
   <SourceLine>//It has a list of confererences in order of weighted Rating.</SourceLine>
   <SourceLine>//Conference (linked), Teams, OOC Record, Pct, RPI (weighted/simple), Rating (Weighted, Simple)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we're going to build this all in a temp database, and then give that back to the export thread to generate the necessary info</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim numteams as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>sqlstring="CREATE TABLE Conferences (ConfNumber integer, OOCWins integer, OOCLosses integer, RPITri double, RPISimple double, RatingTri double, RatingSimple double, Strength double, NTTbids integer, NTTS16 integer)"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>end if</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's loop through all the conferences</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//median conference strength</SourceLine>
   <SourceLine>if db.connect then</SourceLine>
   <SourceLine>dim medELO as double</SourceLine>
   <SourceLine>sqlstring="SELECT a.ELO as Median FROM PRI as A, PRI  as B WHERE A.Season='"+mCurrentSeason+"' AND B.Season='"+mCurrentSeason+"' GROUP BY A.ELO HAVING SUM(CASE WHEN B.ELO &lt;= A.ELO THEN 1 ELSE 0 END)&gt;=(COUNT(*)+1)/2 AND SUM(CASE WHEN B.ELO &gt;= A.ELO THEN 1 ELSE 0 END)&gt;=(COUNT(*)/2)+1"</SourceLine>
   <SourceLine>rec=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>medELO=rec.idxfield(1).doublevalue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Distinct(Conference) FROM PRI WHERE Season='"+mcurrentseason+"'")</SourceLine>
   <SourceLine>dim tmpstring as string</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>//add in the name and the number</SourceLine>
   <SourceLine>sqlstring="INSERT INTO Conferences (ConfNumber) VALUES ('"+rs.IdxField(1).StringValue+"')"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>numteams=8</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now the non conference wins and losses</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT Sum(A.WL='W'), Sum(A.WL='L') FROM Games as A, PRI as B, PRI as C WHERE A.Season='"+mCurrentSeason+"' AND B.Season='"+mCurrentSeason+"' AND C.Season='"+mCurrentSeason+"' AND A.TeamNum=B.TeamNum AND B.Conference='"+rs.idxfield(1).stringvalue+"' AND A.OpponentNum=C.TeamNum AND C.Conference&lt;&gt;'"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>tmpstring="UPDATE Conferences SET OOCWins='"+rec.IdxField(1).StringValue+"', OOCLosses='"+rec.IdxField(2).StringValue+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(tmpstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we've gotta do the RPI/Rating Simple</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT AVG(RPI), AVG(AdjustedELO) FROM PRI WHERE PRI.Season='"+mcurrentseason+"' AND PRI.Conference='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>tmpstring="UPDATE Conferences SET RPISimple='"+rec.IdxField(1).StringValue+"', RatingSimple='"+rec.IdxField(2).StringValue+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(tmpstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now the more difficult--RPI and Rating TriMean</SourceLine>
   <SourceLine>dim j(-1) as string</SourceLine>
   <SourceLine>j=mthCalcConfTriMean(rs.IdxField(1).IntegerValue, numteams)</SourceLine>
   <SourceLine>tmpstring="UPDATE Conferences SET RPITri='"+j(1)+"', RatingTri='"+j(0)+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(tmpstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now the conference strength</SourceLine>
   <SourceLine>dim ew as double</SourceLine>
   <SourceLine>//now, for each conference, let's select all the teams and then loop through like we would for SoS</SourceLine>
   <SourceLine>rec=db.SQLSelect("SELECT ELO FROM PRI WHERE PRI.Season='"+mcurrentseason+"' AND PRI.Conference='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>do until rec.eof</SourceLine>
   <SourceLine>ew=ew+CalcExpectedWins(rec.idxfield(1).integervalue)</SourceLine>
   <SourceLine>rec.MoveNext</SourceLine>
   <SourceLine>loop</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have the expected wins</SourceLine>
   <SourceLine>//divide by the number of teams to get the ConfStrength</SourceLine>
   <SourceLine>ew=ew/rec.RecordCount</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now update the Conferences table</SourceLine>
   <SourceLine>inmemDB.SQLExecute("UPDATE Conferences SET Strength='"+str(1-ew)+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//count the number of NTT bids</SourceLine>
   <SourceLine>'rs=dbsqlselect("SELECT Tournament, Round FROM PostSeasonResults WHERE TeamNum="+str(TN)+" AND Season="+str(val(mCurrentSeason)-1))</SourceLine>
   <SourceLine>rec=db.SQLSelect("select count(*) from postseasonresults as A, PRI where pri.teamnum=A.teamnum AND A.Season='"+mcurrentseason+"' AND PRI.Season='"+mcurrentseason+"' AND A.Tournament='NTT' AND PRI.Conference='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("UPDATE Conferences SET NTTBids='"+rec.idxfield(1).stringvalue+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//NTT Sweet 16 bids</SourceLine>
   <SourceLine>sqlstring="select count(*) from postseasonresults as A, PRI where pri.teamnum=A.teamnum AND A.Season='"+mcurrentseason+"' AND PRI.Season='"+mcurrentseason+"' AND A.Tournament='NTT' AND PRI.Conference='"+rs.IdxField(1).StringValue+"' AND (round like '4' or round like '8' or round like '16' or round like '32' or round like '48')"</SourceLine>
   <SourceLine>rec=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rec&lt;&gt;nil and rec.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("UPDATE Conferences SET NTTS16='"+rec.idxfield(1).stringvalue+"' WHERE ConfNumber='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//finished for this one and on to the next!</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>inmemdb.Commit</SourceLine>
   <SourceLine>//inmemdb is laoded with all the conference information</SourceLine>
   <SourceLine>return inmemdb</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>realSQLDatabase</ItemResult>
 </Method>
