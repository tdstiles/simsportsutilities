  <PartID>1226186751</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>//step one is to multiply the values for each player</SourceLine>
   <SourceLine>//we run this afte rall stats have been loaded</SourceLine>
   <SourceLine>'Players (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Pos varchar, Player varchar,  GM integer, MPG integer, PPG double, RPG double, APG double, FGM double, FGA double, FG3M double, FG3A double, FTM double, FTA double, STL double, TOS double, BLK double, tendex double, WinsProduced double)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim P40 as double</SourceLine>
   <SourceLine>dim PROD as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'PROD =     3FGM*0.064 + 2FGM*0.032 + FTM*0.017 + FGMS*-0.034 + FTMS*-0.015 + REBO*0.034 + REBD*0.034 + TO*-0.034 + STL*0.033 + FTM(opp.)*-0.017 + BLK*0.020</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="Select FG3M, FGM, FTM, FGA, FTA, RPG, TOS, STL, BLK, GM, MPG, APG, rowID FROM Players WHERE Players.Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>Prod=0.064*(rs.field("FG3M").IntegerValue)</SourceLine>
   <SourceLine>Prod=Prod+(rs.field("FGM").IntegerValue-rs.Field("FG3M").IntegerValue)*0.032</SourceLine>
   <SourceLine>Prod=Prod+rs.Field("FTM").IntegerValue*0.017</SourceLine>
   <SourceLine>Prod=PROD - (rs.Field("FGA").IntegerValue-rs.Field("FGM").IntegerValue)*0.034</SourceLine>
   <SourceLine>PROD=Prod - (rs.Field("FTA").IntegerValue-rs.Field("FTM").IntegerValue)*0.015</SourceLine>
   <SourceLine>PROD=PROD + rs.Field("RPG").DoubleValue*rs.field("GM").integervalue*0.034</SourceLine>
   <SourceLine>PROD=PROD - rs.Field("TOS").DoubleValue*rs.field("GM").IntegerValue*0.034</SourceLine>
   <SourceLine>PROD=PROD + rs.Field("STL").DoubleValue*rs.Field("GM").IntegerValue*0.033</SourceLine>
   <SourceLine>PROD=PROD + rs.field("APG").DoubleValue*rs.Field("GM").IntegerValue*0.022</SourceLine>
   <SourceLine>PROD=PROD + rs.Field("Blk").IntegerValue*0.020</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>P40=PROD/(rs.Field("GM").IntegerValue*rs.Field("MPG").DoubleValue)*40</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//P40 is the production per 40 minutes, or one game</SourceLine>
   <SourceLine>sqlstring="UPDATE Players SET WinsProduced='"+format(P40, "###.00000")+"' WHERE rowID='"+rs.Field("rowID").StringValue+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//everyone now has their base</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we adjust for assists</SourceLine>
   <SourceLine>'AddAssists</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and adjust for position</SourceLine>
   <SourceLine>AdjForPosition</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and sum it all up</SourceLine>
   <SourceLine>FinalWPTally</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
