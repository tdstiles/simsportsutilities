  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>mthSetAAStatus</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1196886015</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthSetAAStatus()</SourceLine>
   <SourceLine>//this method sets the AA status in SLTeams DB</SourceLine>
   <SourceLine>dim mplayers(25,10) as string</SourceLine>
   <SourceLine>mplayers=mthHSAAAwardList</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we have a list of players.</SourceLine>
   <SourceLine>//0-4--&gt;1st team</SourceLine>
   <SourceLine>//5-9--&gt;2nd team</SourceLine>
   <SourceLine>//10-14--&gt;3rd team</SourceLine>
   <SourceLine>//15-19--&gt;4th team</SourceLine>
   <SourceLine>//20-24--&gt;all-defense</SourceLine>
   <SourceLine>//25--&gt;POY</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, add in ***1st Team AA for 1-4 teams</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>for j as integer=0 to 4</SourceLine>
   <SourceLine>sldb.SQLExecute("UPDATE SLTeams SET AA='"+str(n+1)+"' WHERE PlayerName='"+mplayers(n*5+j,0)+"'")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now all-defense team</SourceLine>
   <SourceLine>for j as integer=0 to 4</SourceLine>
   <SourceLine>sldb.SQLExecute("UPDATE SLTeams SET AD='1' WHERE PlayerName='"+mplayers(20+j,0)+"'")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now POY</SourceLine>
   <SourceLine>sldb.SQLExecute("UPDATE SLTeams SET POY='1' WHERE PlayerName='"+mplayers(25,0)+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sldb.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadPlayers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>299845631</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPlayers()</SourceLine>
   <SourceLine>//Okay.  We start at the end of the recordset and move forward through each one, adding it in.</SourceLine>
   <SourceLine>//We get the recruit, then create a cSignedPlayer.  We display the cSignedPlayer info on the left list, then update it on the right list.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim Player as cSignedPlayer</SourceLine>
   <SourceLine>dim starttime as integer</SourceLine>
   <SourceLine>dim s as string</SourceLine>
   <SourceLine>dim iCountDown as integer=recruitrs.RecordCount</SourceLine>
   <SourceLine>'</SourceLine>
   <SourceLine>while iCountDown&gt;0</SourceLine>
   <SourceLine>'starttime=ticks</SourceLine>
   <SourceLine>Player=new cSignedPlayer(recruitrs.IdxField(2).StringValue, recruitrs.IdxField(1).StringValue, recruitrs.IdxField(4).IntegerValue, recruitrs.IdxField(5).IntegerValue, recruitrs.IdxField(6).IntegerValue)</SourceLine>
   <SourceLine>s="#"+str(iCountDown)+ "  "+player.szReturn</SourceLine>
   <SourceLine>lbPlayers.InsertRow(0,s)</SourceLine>
   <SourceLine>lbPlayers.CellBold(0,0)=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//italicize if in our conference</SourceLine>
   <SourceLine>if ceil(player.mTeam/8)=iHighlightedConference then</SourceLine>
   <SourceLine>lbPlayers.CellItalic(0,0)=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if my player, different color</SourceLine>
   <SourceLine>'if player.mTeam=iHighLightedTeam then</SourceLine>
   <SourceLine>'lbPlayers.</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if lbPlayers.ListCount&gt;1 then</SourceLine>
   <SourceLine>lbPlayers.CellBold(1,0)=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we need to update the team list</SourceLine>
   <SourceLine>mthUpdateTeamList(Player)</SourceLine>
   <SourceLine>recruitrs.MoveNext</SourceLine>
   <SourceLine>iCountDown=iCountDown-1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//after we've finished, let's enable the export buttons</SourceLine>
   <SourceLine>butTeams.Enabled=true</SourceLine>
   <SourceLine>butPlayers.Enabled=true</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
