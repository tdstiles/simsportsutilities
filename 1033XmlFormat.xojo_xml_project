  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function VsTopOpponents() As string()</SourceLine>
   <SourceLine>//this method returns the recors vs top 10, 25, 50, and 100</SourceLine>
   <SourceLine>//in a string array</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim returnstring(3) as string</SourceLine>
   <SourceLine>dim rankings(3) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rankings(0)="10"</SourceLine>
   <SourceLine>rankings(1)="25"</SourceLine>
   <SourceLine>rankings(2)="50"</SourceLine>
   <SourceLine>rankings(3)="100"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 3</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Games.WL='W'), Sum(Games.WL='L') FROM Games, PRI WHERE Games.Season='"+mSeason+"' AND PRI.Season='"+mSeason+"' AND Games.TeamNum='"+str(TN)+"'  AND Games.OpponentNum=PRI.TeamNum and PRI.PR&lt;='"+rankings(j)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>returnstring(j)=format(rs.IdxField(1).IntegerValue, "#0")+"-"+format(rs.IdxField(2).IntegerValue, "#0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return returnstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
