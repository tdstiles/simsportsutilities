  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function HTMLLink(TN as integer, Optional PRIncluded as Integer) As string</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine>dim b as string</SourceLine>
   <SourceLine>dim c as string</SourceLine>
   <SourceLine>dim d as string</SourceLine>
   <SourceLine>dim f as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//No PR then Hartford (Team #12 Conf 11)</SourceLine>
   <SourceLine>//PRIncluded=1 then No. 6 Hartford (8-4) (Conf 12)</SourceLine>
   <SourceLine>//PR=2 then Hartford (8-4)</SourceLine>
   <SourceLine>//pr=3 then Hartford</SourceLine>
   <SourceLine>//pr=4 then No. 7 Hartford</SourceLine>
   <SourceLine>//pr=5 then no. 7 Hartford (8-4)</SourceLine>
   <SourceLine>//pr=6 then no. 8 Hartfold (8-4) (Conf 12)</SourceLine>
   <SourceLine>//pr=7 then  Hartford (8-4) (Conf 12)</SourceLine>
   <SourceLine>//pr=8 then wikilink directly (points to the conference page)</SourceLine>
   <SourceLine>//pr=9 Hartford (Conf 12)</SourceLine>
   <SourceLine>//pr=10 Hartford (C12) (team points to real, C12 points to conference)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a="&lt;a href="""+mLocationString+str(TN)+""" target=""_blank""&gt;"</SourceLine>
   <SourceLine>b=""</SourceLine>
