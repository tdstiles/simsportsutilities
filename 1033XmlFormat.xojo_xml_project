  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthDTLAllLeague() As string</SourceLine>
   <SourceLine>//gets the DTL All-League page and sends it back as the first string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim teaminfo as string</SourceLine>
   <SourceLine>dim columnstring(-1) as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim playername as string</SourceLine>
   <SourceLine>dim headingheight as integer=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/allstars.asp?league="+league+"&amp;conference=33"</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine>result=CleanHTML(result)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim lines(-1) as string=split(result, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we need to parse this string and build an actual table that's HTML formatted and clean because the DTL table is ugly</SourceLine>
   <SourceLine>//first line to pull from</SourceLine>
   <SourceLine>dim i as integer=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim playerstring(-1) as string</SourceLine>
   <SourceLine>playerstring=split("Pos,Name,Yr,Ht,PPG,RPG,APG,SPG,Blk,Team", ",")</SourceLine>
   <SourceLine>dim mainstring as string</SourceLine>
   <SourceLine>mainstring="SELECT Players.Player, Players.Pos, PRI.TeamNum, Players.YR, Players.HT, Players.PPG, Players.RPG, Players.APG, Players.STL, Players.BLK FROM Players, PRI WHERE  Players.season='"+mcurrentseason+"' AND PRI.Season='"+mcurrentseason+"' AND Players.TeamNum=PRI.TeamNum"</SourceLine>
   <SourceLine>dim estring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>estring.append "&lt;h"+str(HeadingHeight)+"&gt;DTL L"+league+" All-America&lt;/h"+str(HeadingHeight)+"&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//LPOY</SourceLine>
   <SourceLine>estring.append TableGeneratorTitle("Player of the Year",playerstring,1,HeadingHeight+1)</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>sqlstring=mainstring+" AND Players.Player='"+playername+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>teaminfo=HTMLLink(rs.IdxField(3).IntegerValue,3)</SourceLine>
   <SourceLine>columnstring=split(rs.idxfield(2).stringvalue+","+ rs.IdxField(1).stringValue+","+ rs.IdxField(4).stringValue+","+ changeheight(rs.IdxField(5).StringValue)+","+format(rs.IdxField(6).doubleValue, "##.0")+","+format(rs.IdxField(7).doubleValue, "##.0")+","+format(rs.IdxField(8).doubleValue, "##.0")+","+format(rs.IdxField(9).doubleValue, "##.0")+","+format(rs.IdxField(10).doubleValue, "##")+","+teaminfo, ",")</SourceLine>
   <SourceLine>estring.append ColumnGenerator(1, columnstring)</SourceLine>
   <SourceLine>estring.append CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//LFOY</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>estring.append TableGeneratorTitle("Freshman of the Year",playerstring,1,HeadingHeight+1)</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>sqlstring=mainstring+" AND Players.Player='"+playername+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>teaminfo=HTMLLink(rs.IdxField(3).IntegerValue,3)</SourceLine>
   <SourceLine>columnstring=split(rs.idxfield(2).stringvalue+","+ rs.IdxField(1).stringValue+","+ rs.IdxField(4).stringValue+","+ changeheight(rs.IdxField(5).StringValue)+","+format(rs.IdxField(6).doubleValue, "##.0")+","+format(rs.IdxField(7).doubleValue, "##.0")+","+format(rs.IdxField(8).doubleValue, "##.0")+","+format(rs.IdxField(9).doubleValue, "##.0")+","+format(rs.IdxField(10).doubleValue, "##")+","+teaminfo, ",")</SourceLine>
   <SourceLine>estring.append ColumnGenerator(1, columnstring)</SourceLine>
   <SourceLine>estring.append CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>//All-League Teams</SourceLine>
   <SourceLine>dim titles(-1) as string=split("1st,2nd,3rd,4th", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For nn as integer=1 to 4</SourceLine>
   <SourceLine>estring.append TableGeneratorTitle(titles(nn-1)+" Team All-League",playerstring,1,HeadingHeight+1)</SourceLine>
   <SourceLine>for nnn as integer=1 to 5</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>sqlstring=mainstring+" AND Players.Player='"+playername+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>teaminfo=HTMLLink(rs.IdxField(3).IntegerValue,3)</SourceLine>
   <SourceLine>columnstring=split(rs.idxfield(2).stringvalue+","+ rs.IdxField(1).stringValue+","+ rs.IdxField(4).stringValue+","+ changeheight(rs.IdxField(5).StringValue)+","+format(rs.IdxField(6).doubleValue, "##.0")+","+format(rs.IdxField(7).doubleValue, "##.0")+","+format(rs.IdxField(8).doubleValue, "##.0")+","+format(rs.IdxField(9).doubleValue, "##.0")+","+format(rs.IdxField(10).doubleValue, "##")+","+teaminfo, ",")</SourceLine>
   <SourceLine>estring.append ColumnGenerator(nnn, columnstring)</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>estring.append CloseTable</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return estring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Exception </SourceLine>
   <SourceLine>msgbox  "Error occurred in mthDTLAllLeague"</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
