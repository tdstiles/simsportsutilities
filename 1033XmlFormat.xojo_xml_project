   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GameUpdatingMethod()</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>'staUpdating.text="Parsing Recruit CSV file"</SourceLine>
   <SourceLine>ImportRecruitCSV</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'staUpdating.text="Downloading HS Info"</SourceLine>
   <SourceLine>result=thissocket.Get("http://drivethelane.com/bask/weekly/lg000"+right("0"+league,2)+"/hsinfo.html", 30)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if result &lt;&gt; "" then</SourceLine>
   <SourceLine>result=CleanHTML(result)</SourceLine>
   <SourceLine>ParseFileB(result)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>MsgBox "Error downloading.  Please check your internet connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'//now we'll add in the info from all the HS Teams</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'staUpdating.text="Updating HS SoS"</SourceLine>
   <SourceLine>dim updateHS as new cHSInfo</SourceLine>
   <SourceLine>//updateHS should, in its constructor, fire all the things we need fired.  The HSInfo table in the main database should now be up to date.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'staUpdating.text="Updating Recruit Stats"</SourceLine>
   <SourceLine>dim updateRecruit as new cRecruitMethod</SourceLine>
   <SourceLine>//similarly, in its updater, this should parse all the recruit information we need</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's go ahead and update all the recruits iwth the new season</SourceLine>
   <SourceLine>mthUpdateRecruitSeason</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if we want game by game hs stats, generate them now</SourceLine>
   <SourceLine>if DoGamebyGame then</SourceLine>
   <SourceLine>'staUpdating.text="Preparing game-by-game info"</SourceLine>
   <SourceLine>HSMainMethod</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>dbsqlexecute("VACUUM")</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>self.close</SourceLine>
   <SourceLine>End Sub</SourceLine>
