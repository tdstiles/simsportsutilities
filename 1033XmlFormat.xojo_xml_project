   <SourceLine>dim tsp as string //true shooting percentage</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>titles=split("Player of the Year,1st Team,2nd Team,3rd Team,4th Team,All-Senior Team,Freshman of the Year,All-Freshman Team,All-Defense Team,6th Man of the Year,Long Distance Specialist,Wins Produced Leaders,Coach of the Year", ",")</SourceLine>
