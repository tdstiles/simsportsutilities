 <ControlBehavior>
  <Superclass>PushButton</Superclass>
  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>915816447</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim rs as RecordSet</SourceLine>
    <SourceLine>dim sbstring as new StringBuilder</SourceLine>
    <SourceLine>dim i as integer=1</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim columns(-1) as string</SourceLine>
    <SourceLine>columns=split("Rank,Team,Rating", ",")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>sbstring.append TableGeneratorTitle("L"+League+" Team Recruiting Rankings", columns, 0,1)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=sldb.SQLSelect("SELECT TeamNumber, Sum(Rating) as A FROM SLTeamsLoaded GROUP BY TeamNumber ORDER BY A DESC")</SourceLine>
    <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>while rs.eof=false</SourceLine>
    <SourceLine>redim columns(-1)</SourceLine>
    <SourceLine>columns.append str(i)+"."</SourceLine>
    <SourceLine>columns.append rs.IdxField(1).StringValue</SourceLine>
    <SourceLine>columns.append format(rs.IdxField(2).DoubleValue, "+#0.0")</SourceLine>
    <SourceLine>sbstring.append ColumnGenerator(i,columns)</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>i=i+1</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>sbstring.append CloseTable</SourceLine>
    <SourceLine>//now generate</SourceLine>
    <SourceLine>sbstring.append AddFooter</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>PostResults(sbstring.ToString)</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
 </ControlBehavior>
 <ControlBehavior>
  <Superclass>PushButton</Superclass>
  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>830853119</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim sbstring as new StringBuilder</SourceLine>
    <SourceLine>dim i as integer=1</SourceLine>
    <SourceLine>dim Player as cSignedPlayer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>dim columns(-1) as string</SourceLine>
    <SourceLine>columns=split("Rank Player School Awards")</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>sbstring.append TableGeneratorTitle("L"+League+" S"+mCurrentSeason+" Recruit Rankings", columns, 0,1)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>recruitrs=sldb.SQLSelect("SELECT TeamNumber, PlayerName, Rating, AA, AD, POY FROM SLTeams ORDER BY Rating DESC")</SourceLine>
    <SourceLine>if recruitrs&lt;&gt;nil and recruitrs.RecordCount&lt;&gt;0 then</SourceLine>
    <SourceLine>for n as integer=1 to 150</SourceLine>
    <SourceLine>Player=new cSignedPlayer(recruitrs.IdxField(2).StringValue, recruitrs.IdxField(1).StringValue, recruitrs.IdxField(4).IntegerValue, recruitrs.IdxField(5).IntegerValue, recruitrs.IdxField(6).IntegerValue)</SourceLine>
    <SourceLine>redim columns(-1)</SourceLine>
    <SourceLine>columns.append str(n)</SourceLine>
    <SourceLine>columns.append player.NameString</SourceLine>
    <SourceLine>columns.append RecruitRS.IdxField(1).StringValue</SourceLine>
    <SourceLine>columns.append player.AwardString</SourceLine>
    <SourceLine>sbstring.append ColumnGenerator(n, columns)</SourceLine>
    <SourceLine>recruitrs.MoveNext</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>//now generate</SourceLine>
    <SourceLine>sbstring.append CloseTable</SourceLine>
