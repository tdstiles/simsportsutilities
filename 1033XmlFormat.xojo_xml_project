   <SourceLine>sqlstring="SELECT Sum(Games.WL='W'), Sum(Games.WL='L') FROM Games, PRI WHERE Games.TeamNum='"+TN+"' AND Games.Season='"+mCurrentSeason+"' AND Games.OpponentNum=PRI.TeamNum AND PRI.Season='"+mCurrentSeason+"' AND PRI.Conference='"+rs.IdxField(3).StringValue+"' AND Games.GameNum&gt;3 AND Games.GameNum&lt;'16'"</SourceLine>
