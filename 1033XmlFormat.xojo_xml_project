 <Method>
  <ItemName>LoadStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1841221631</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadStats()</SourceLine>
   <SourceLine>dim a,b as string</SourceLine>
   <SourceLine>dim rs,ars, brs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim games as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=popup(0).text</SourceLine>
   <SourceLine>b=popup(1).text</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lb.DeleteAllRows</SourceLine>
   <SourceLine>if b="Overall" then //compiled stats overall</SourceLine>
   <SourceLine>if a="Team" then //for team</SourceLine>
   <SourceLine>LoadupHeaders(true)</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Distinct PreNTT.TeamNum FROM PreNTT")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT Count(Distinct Season) FROM PreNTT WHERE TeamNum='"+rs.idxfield(1).stringvalue+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>games=str(ars.IdxField(1).IntegerValue*3)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT PRI.TeamName, Avg(PreNTT.OurScore), Avg(PreNTT.OppScore), (SELECT Count(*) FROM PreNTT WHERE PreNTT.WL='W' AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"'), (SELECT Count(*) FROM PreNTT WHERE PreNTT.WL='L' AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"') FROM PreNTT, PRI WHERE  PreNTT.TeamNum=PRI.TeamNum AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Stats.Reb)/'"+games+"', Sum(Stats.Ast)/'"+games+"', Sum(Stats.FGM), Sum(Stats.FGA), Sum(Stats.FG3M), Sum(Stats.FG3A), Sum(Stats.FTM), Sum(Stats.FTA), Sum(Stats.TOs)/'"+games+"', sum(Stats.Stl)/'"+games+"', sum(Stats.Blk)/'"+games+"' FROM Stats WHERE Stats.TeamNum='"+rs.IdxField(1).StringValue+"' GROUP BY Stats.TeamNum"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>lb.addrow ars.IdxField(1).StringValue, ars.IdxField(4).StringValue, ars.IdxField(5).StringValue, format(ars.IdxField(2).DoubleValue, "###.0"), format(ars.IdxField(3).DoubleValue, "###.0"), format(brs.IdxField(1).DoubleValue, "##.0"), format(brs.IdxField(2).DoubleValue, "##.0"), format(brs.IdxField(10).DoubleValue, "##.0"), format(brs.IdxField(11).DoubleValue, "##.0"), format(brs.IdxField(3).doubleValue/brs.idxfield(4).doublevalue, "###.0%"), format(brs.IdxField(5).doubleValue/brs.idxfield(6).doublevalue, "###.0%"), format(brs.IdxField(7).doubleValue/brs.idxfield(8).doublevalue, "###.0%"), format(brs.IdxField(9).DoubleValue, "##.0"), format((ars.IdxField(2).DoubleValue-ars.IdxField(3).DoubleValue)*val(games), "+###")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else //for individuals</SourceLine>
   <SourceLine>LoadupHeaders(false)</SourceLine>
   <SourceLine>sqlstring="SELECT Distinct(Name), TeamNum FROM Stats"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT (SELECT PRI.TeamName FROM PRI WHERE PRI.TeamNum='"+rs.IdxField(2).StringValue+"'), (SELECT Count(*) FROM Stats WHERE Stats.Name='"+rs.IdxField(1).StringValue+"' AND Stats.TeamNum='"+rs.idxfield(2).stringvalue+"'), Sum(Stats.Mins), Sum(Stats.FGM), Sum(Stats.FGA), Sum(Stats.FG3M), Sum(Stats.FG3A), Sum(Stats.FTM), Sum(Stats.FTA), Sum(Stats.Reb), Sum(Stats.Ast), Sum(Stats.Blk), Sum(Stats.Stl), Sum(stats.TOs), Sum(Stats.Fouls), Sum(Stats.Pts) FROM Stats WHERE Stats.TeamNum='"+rs.idxfield(2).stringvalue+"' AND Name LIKE '%"+rs.IdxField(1).StringValue+"%' GROUP BY Stats.Name"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>lb.AddRow rs.IdxField(1).StringValue, ars.IdxField(1).StringValue, ars.IdxField(2).StringValue, ars.IdxField(3).StringValue, ars.IdxField(4).StringValue, ars.IdxField(5).StringValue, divchk(ars.idxfield(4).doublevalue,ars.idxfield(5).doublevalue), ars.IdxField(6).StringValue, ars.IdxField(7).StringValue, divchk(ars.idxfield(6).doublevalue,ars.idxfield(7).doublevalue),ars.IdxField(8).StringValue, ars.IdxField(9).StringValue, divchk(ars.idxfield(8).doublevalue,ars.idxfield(9).doublevalue),ars.IdxField(10).StringValue, ars.IdxField(11).StringValue, ars.IdxField(12).StringValue, ars.IdxField(13).StringValue, ars.IdxField(14).StringValue, ars.IdxField(15).StringValue, ars.IdxField(16).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //for individual seasons</SourceLine>
   <SourceLine>if a="Team" then //for team</SourceLine>
   <SourceLine>LoadupHeaders(true)</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Distinct PreNTT.TeamNum FROM PreNTT WHERE Season='"+b+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>games="3"</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.TeamName, Avg(PreNTT.OurScore), Avg(PreNTT.OppScore), (SELECT Count(*) FROM PreNTT WHERE PreNTT.WL='W' AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"' AND PreNTT.Season='"+b+"'), (SELECT Count(*) FROM PreNTT WHERE PreNTT.WL='L' AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"' AND PreNTT.Season='"+b+"') FROM PreNTT, PRI WHERE  PreNTT.TeamNum=PRI.TeamNum AND PreNTT.TeamNum='"+rs.IdxField(1).StringValue+"' AND PreNTT.Season='"+b+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Stats.Reb)/'"+games+"', Sum(Stats.Ast)/'"+games+"', Sum(Stats.FGM), Sum(Stats.FGA), Sum(Stats.FG3M), Sum(Stats.FG3A), Sum(Stats.FTM), Sum(Stats.FTA), Sum(Stats.TOs)/'"+games+"', sum(Stats.Stl)/'"+games+"', sum(Stats.Blk)/'"+games+"' FROM Stats WHERE Stats.TeamNum='"+rs.IdxField(1).StringValue+"' AND Stats.Season='"+b+"' GROUP BY Stats.TeamNum"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>lb.addrow ars.IdxField(1).StringValue, ars.IdxField(4).StringValue, ars.IdxField(5).StringValue, format(ars.IdxField(2).DoubleValue, "###.0"), format(ars.IdxField(3).DoubleValue, "###.0"), format(brs.IdxField(1).DoubleValue, "##.0"), format(brs.IdxField(2).DoubleValue, "##.0"), format(brs.IdxField(10).DoubleValue, "##.0"), format(brs.IdxField(11).DoubleValue, "##.0"), format(brs.IdxField(3).doubleValue/brs.idxfield(4).doublevalue, "###.0%"), format(brs.IdxField(5).doubleValue/brs.idxfield(6).doublevalue, "###.0%"), format(brs.IdxField(7).doubleValue/brs.idxfield(8).doublevalue, "###.0%"), format(brs.IdxField(9).DoubleValue, "##.0"), format((ars.IdxField(2).DoubleValue-ars.IdxField(3).DoubleValue)*val(games), "+###")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else //for individuals</SourceLine>
   <SourceLine>LoadupHeaders(false)</SourceLine>
   <SourceLine>sqlstring="SELECT Distinct(Stats.Name), Stats.TeamNum FROM Stats WHERE Stats.Season='"+b+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT (SELECT PRI.TeamName FROM PRI WHERE PRI.TeamNum='"+rs.IdxField(2).StringValue+"'), (SELECT Count(*) FROM Stats WHERE Stats.Name='"+rs.IdxField(1).StringValue+"' AND Stats.TeamNum='"+rs.idxfield(2).stringvalue+"' AND Stats.Season='"+b+"'), Sum(Stats.Mins), Sum(Stats.FGM), Sum(Stats.FGA), Sum(Stats.FG3M), Sum(Stats.FG3A), Sum(Stats.FTM), Sum(Stats.FTA), Sum(Stats.Reb), Sum(Stats.Ast), Sum(Stats.Blk), Sum(Stats.Stl), Sum(stats.TOs), Sum(Stats.Fouls), Sum(Stats.Pts) FROM Stats WHERE Stats.TeamNum='"+rs.idxfield(2).stringvalue+"' AND Name LIKE '%"+rs.IdxField(1).StringValue+"%' AND Stats.Season='"+b+"' GROUP BY Stats.Name"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>lb.AddRow rs.IdxField(1).StringValue, ars.IdxField(1).StringValue, ars.IdxField(2).StringValue, ars.IdxField(3).StringValue, ars.IdxField(4).StringValue, ars.IdxField(5).StringValue, divchk(ars.idxfield(4).doublevalue,ars.idxfield(5).doublevalue), ars.IdxField(6).StringValue, ars.IdxField(7).StringValue, divchk(ars.idxfield(6).doublevalue,ars.idxfield(7).doublevalue),ars.IdxField(8).StringValue, ars.IdxField(9).StringValue, divchk(ars.idxfield(8).doublevalue,ars.idxfield(9).doublevalue),ars.IdxField(10).StringValue, ars.IdxField(11).StringValue, ars.IdxField(12).StringValue, ars.IdxField(13).StringValue, ars.IdxField(14).StringValue, ars.IdxField(15).StringValue, ars.IdxField(16).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
