   <SourceLine>if sldb.Connect then</SourceLine>
   <SourceLine>sldb.SQLExecute("CREATE TABLE SLTeams (TeamNumber integer, PlayerName varchar, Rating double, AA integer, AD integer, POY integer)")</SourceLine>
   <SourceLine>sldb.SQLExecute("CREATE TABLE SLTeamsLoaded (TeamNumber integer, Rating double)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
