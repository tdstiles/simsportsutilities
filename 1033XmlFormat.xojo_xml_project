   <SourceLine>pergame=rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>sqlstring="SELECT (0.9*Sum(RPG)+1.5*Sum(APG)+3*Sum(Stl)-1.5*Sum(TOS)), Sum(PPG) FROM Players WHERE Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>mLeagueModifier=(pergame+rs.IdxField(1).DoubleValue)/rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>End Sub</SourceLine>
