  <HookInstance>
   <ItemName>DropDownMenuAction</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>614348799</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub DropDownMenuAction(item As ToolItem, hitItem As MenuItem)</SourceLine>
    <SourceLine>dim a as cAllAmericanCalc</SourceLine>
    <SourceLine>dim myConference as integer</SourceLine>
    <SourceLine>dim result as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if XDBLoaded then</SourceLine>
    <SourceLine>select case item.Name</SourceLine>
    <SourceLine>case "HS Recruiting"</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "Prospect Ranking"</SourceLine>
    <SourceLine>wndHSTopRecruits.ShowModal</SourceLine>
    <SourceLine>case "Top Over/UnderRated Prospects"</SourceLine>
    <SourceLine>result=t75overunder</SourceLine>
    <SourceLine>case "High School Stat Leaders"</SourceLine>
    <SourceLine>result=HSStatLeaders</SourceLine>
    <SourceLine>case "Top 75 List"</SourceLine>
    <SourceLine>result=mthdTop75List</SourceLine>
    <SourceLine>case "High School Game by Game"</SourceLine>
    <SourceLine>wndHSStats.ShowModal</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine>case "GOTW"</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "Computer-generated GOTW"</SourceLine>
    <SourceLine>dim GOTW as cGOTW</SourceLine>
    <SourceLine>GOTW=new cGOTW</SourceLine>
    <SourceLine>case "User-Selected GOTW"</SourceLine>
    <SourceLine>wndPickGOTW.ShowModal</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine>case "Top 25"</SourceLine>
    <SourceLine>//top 25 lists</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "College Top 25 Poll"</SourceLine>
    <SourceLine>Top25Display.ShowModal</SourceLine>
    <SourceLine>case "College Top 25 Power Ranking"</SourceLine>
    <SourceLine>result=COLLT25</SourceLine>
    <SourceLine>case "High School Top 25 Power Ranking"</SourceLine>
    <SourceLine>result=hst25</SourceLine>
    <SourceLine>case "Generate Linked Tournament Brackets"</SourceLine>
    <SourceLine>GenerateLinkedBrackets</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine>case "All-America"</SourceLine>
    <SourceLine>//all-america lists</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "College All-America"</SourceLine>
    <SourceLine>a=new cAllAmericanCalc(0)</SourceLine>
    <SourceLine>result=a.CreateText</SourceLine>
    <SourceLine>case "High School All-America"</SourceLine>
    <SourceLine>result=HSAACalc</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine>case "Preview &amp; Recap"</SourceLine>
    <SourceLine>select case hitItem.text</SourceLine>
    <SourceLine>case "NTT Recap"</SourceLine>
    <SourceLine>Result=mthGenerateNTTRecapText("NTT")</SourceLine>
    <SourceLine>case "PTT Recap"</SourceLine>
    <SourceLine>Result=mthGenerateNTTRecapText("PTT")</SourceLine>
    <SourceLine>case "RTT Recap"</SourceLine>
    <SourceLine>Result=mthGenerateNTTRecapText("RTT")</SourceLine>
    <SourceLine>case "DTT Recap"</SourceLine>
    <SourceLine>Result=mthGenerateNTTRecapText("DTT")</SourceLine>
    <SourceLine>case "Preseason Preview"</SourceLine>
    <SourceLine>result=mthPreseasonCalc</SourceLine>
    <SourceLine>case "NTT Preview"</SourceLine>
    <SourceLine>result=MainTourneyPreviewMethod("NTT")</SourceLine>
    <SourceLine>case "PTT Preview"</SourceLine>
    <SourceLine>result=MainTourneyPreviewMethod("PTT")</SourceLine>
    <SourceLine>case "RTT Preview"</SourceLine>
    <SourceLine>result=MainTourneyPreviewMethod("RTT")</SourceLine>
    <SourceLine>case "DTT Preview"</SourceLine>
    <SourceLine>result=MainTourneyPreviewMethod("DTT")</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>//we're dealing with conference previews</SourceLine>
    <SourceLine>myConference=val(trim(mid(hitItem.text,2,2)))</SourceLine>
    <SourceLine>if myconference&lt;&gt;0 then</SourceLine>
    <SourceLine>dim testreport as new cConferenceSeasonReport(myConference)</SourceLine>
    <SourceLine>result=testreport.GenerateReport</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>end select</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if result&lt;&gt;"" then </SourceLine>
    <SourceLine>PostResults(result)</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>mthdXDBLoaded</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
