 <ControlBehavior>
  <Superclass>PushButton</Superclass>
  <HookInstance>
   <ItemName>Action</ItemName>
   <Compatibility></Compatibility>
   <Visible>1</Visible>
   <PartID>847681535</PartID>
   <ItemSource>
    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim showstring as string</SourceLine>
    <SourceLine>dim rs as recordset</SourceLine>
    <SourceLine>dim sqlstring as string</SourceLine>
    <SourceLine>dim i as integer</SourceLine>
    <SourceLine>dim season, pollnum as string</SourceLine>
    <SourceLine>dim previousrnk as string</SourceLine>
    <SourceLine>dim haspreviousrnk as boolean</SourceLine>
    <SourceLine>dim ars as RecordSet</SourceLine>
    <SourceLine>dim teamstring as string</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=dbsqlselect("SELECT Max(Season) FROM VoteResults")</SourceLine>
    <SourceLine>ars=dbsqlselect("SELECT Pollnum FROM VoteResults WHERE Season='"+rs.IdxField(1).StringValue+"' ORDER BY PollNum DESC")</SourceLine>
    <SourceLine>if ars.RecordCount&lt;2 then</SourceLine>
    <SourceLine>haspreviousrnk=false</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>haspreviousrnk=true</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>season=rs.IdxField(1).StringValue</SourceLine>
    <SourceLine>pollnum=ars.IdxField(1).StringValue</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>showstring="&lt;table border=""2"" bordercolor=""#000000"" cellspacing=""2"" cellpadding=""4""&gt;"+EndOfLine</SourceLine>
    <SourceLine>showstring=showstring+"&lt;tr&gt;&lt;td&gt;Rank&lt;/td&gt;&lt;td&gt;Team&lt;/td&gt;&lt;td&gt;Points (1st)&lt;/td&gt;&lt;td&gt;Prev&lt;/td&gt;&lt;/tr&gt;"+EndOfLine</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>sqlstring="SELECT TeamNum, Points, Firstplace FROM VoteResults WHERE Season='"+season+"' AND pollnum='"+pollnum+"' ORDER BY Points DESC"</SourceLine>
    <SourceLine>i=1</SourceLine>
    <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
    <SourceLine>if IfRSGood(rs) then</SourceLine>
    <SourceLine>while rs.eof=false</SourceLine>
    <SourceLine>if haspreviousrnk then</SourceLine>
    <SourceLine>previousrnk=FindingPreviousRank(rs.IdxField(1).integerValue, season, str(val(pollnum)-1))</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>previousrnk="-"</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if i&lt;26 then</SourceLine>
    <SourceLine>teamstring=GenerateTeamString(rs.IdxField(1).StringValue)</SourceLine>
    <SourceLine>showstring=showstring+"&lt;tr&gt;&lt;td&gt;"+str(i)+"&lt;/td&gt;&lt;td&gt;"+teamstring+"&lt;/td&gt;&lt;td&gt;"+rs.idxfield(2).stringvalue+" ("+rs.idxfield(3).stringvalue+")&lt;/td&gt;&lt;td&gt;"+previousrnk+"&lt;/td&gt;&lt;/tr&gt;"+EndOfLine</SourceLine>
    <SourceLine>elseif i=26 then</SourceLine>
    <SourceLine>showstring=showstring+"&lt;/table&gt;&lt;br&gt;&lt;br&gt;br&gt;"+EndOfLine</SourceLine>
    <SourceLine>showstring=showstring+"&lt;i&gt;Also receiving votes:  &lt;/i&gt;&lt;br&gt;"+EndOfLine</SourceLine>
    <SourceLine>showstring=showstring+teams(rs.IdxField(1).IntegerValue-1)+" ("+rs.IdxField(2).StringValue+") &lt;br&gt;"+EndOfLine</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>showstring=showstring+teams(rs.IdxField(1).IntegerValue-1)+" ("+rs.IdxField(2).StringValue+") &lt;br&gt;"+EndOfLine</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>i=i+1</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>showstring=showstring+"&lt;/table&gt;&lt;br&gt;&lt;br&gt;&lt;i&gt;Coaches voting:  &lt;/i&gt;"+EndOfLine</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>rs=dbsqlselect("SELECT Distinct(coachname) from TempVoteResults ORDER BY coachname ASC")</SourceLine>
    <SourceLine>if IfRSGood(rs) then</SourceLine>
    <SourceLine>while rs.eof=false</SourceLine>
    <SourceLine>showstring=showstring+rs.IdxField(1).StringValue+"&lt;br&gt;"+EndOfLine</SourceLine>
    <SourceLine>rs.MoveNext</SourceLine>
    <SourceLine>wend</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>wndMain.showfield.text=showstring</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>db.Commit</SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
 </ControlBehavior>
