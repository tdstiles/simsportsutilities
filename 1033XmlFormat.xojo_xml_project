 <Method>
  <ItemName>mthPreseasonCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1565454335</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthPreseasonCalc() As string</SourceLine>
   <SourceLine>//this method calcuates the (1) preseason top 25, (2) preseason all-america, and (3) pre-season conference previews</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sbstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+"{{LeagueCompass|LID="+league+"|minS="+mCurrentSeason+"}}"+EndOfLine</SourceLine>
   <SourceLine>sbstring=sbstring+"= L"+league+" S"+mCurrentSeason+" Preview ="+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+"&lt;h1&gt;L-"+league+" S"+mCurrentSeason+" Preview&lt;/h1&gt;"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//top 25/all-league</SourceLine>
   <SourceLine>//first, the preseason top 25</SourceLine>
   <SourceLine>sbstring=sbstring+CalcPreseasonRank(0)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then, the preseason all-america</SourceLine>
   <SourceLine>dim a as cAllAmericanCalc</SourceLine>
   <SourceLine>a =new cAllAmericanCalc(0,true)</SourceLine>
   <SourceLine>sbstring=sbstring+a.CreateText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//and leaders</SourceLine>
   <SourceLine>sbstring=sbstring+ mthdReturningLeaders("0")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//////////////now conference stats</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then, for each conference</SourceLine>
   <SourceLine>for n as integer=1 to 32</SourceLine>
   <SourceLine>sbstring=sbstring+CalcPreseasonRank(n)</SourceLine>
