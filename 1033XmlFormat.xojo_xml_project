 <Method>
  <ItemName>BiggestWin</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>698253311</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function BiggestWin() As string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim returnstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now load up biggest win over opponent</SourceLine>
   <SourceLine>sqlstring="SELECT PRI.PR, PRI.TeamNum, Games.OurScore, Games.OppScore, Games.GameNum, (257-PRI.PR)*(257-PRI.PR)*(257-PRI.PR)*(257-PRI.PR)*(Games.OurScore-Games.OppScore+20)*(Games.OurScore-Games.OppScore+20) as A FROM PRI, Games WHERE Games.Season='"+mSeason+"' AND Games.TeamNum='"+Str(TN)+"' AND Games.OpponentNum=PRI.TeamNum AND PRI.Season='"+mSeason+"' AND Games.WL='W' ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>returnstring="Game #"+rs.IdxField(5).StringValue+" over "+HTMLLink(rs.IdxField(2).IntegerValue, 6)+", "+rs.IdxField(3).StringValue+"-"+rs.IdxField(4).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return returnstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
