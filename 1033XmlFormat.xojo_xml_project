 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>170448895</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>//when this loads, we want to get a list of the players and their stats</SourceLine>
   <SourceLine>// Calling the overridden superclass constructor.</SourceLine>
   <SourceLine>Super.Window</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mthCreateInMemDB</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's download the page that has the listed recruits and where they've signed</SourceLine>
   <SourceLine>dim mResult as string</SourceLine>
   <SourceLine>dim mySock as new HTTPSocket</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while mResult=""</SourceLine>
   <SourceLine>mResult=mySock.Get( "http://drivethelane.com/bask/weekly/lg000"+right("00"+League,2)+"/signlist.html",45)</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//at this point, mResult should have the list of players.  we want to stick them with their correct team.</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>lines=split(mResult,EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now loop through</SourceLine>
   <SourceLine>//as we loop through, add the player to his team</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim iCount as integer=8</SourceLine>
   <SourceLine>dim PlayerName as string</SourceLine>
   <SourceLine>dim HomeTown as String</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//sldb.SQLExecute("CREATE TABLE SLTeams (TeamNumber integer, PlayerName varchar, Rating double)")</SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>//go through for each town and add the three players</SourceLine>
   <SourceLine>HomeTown=lines(iCount)</SourceLine>
   <SourceLine>iCount=iCount+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 2</SourceLine>
   <SourceLine>PlayerName=lines(iCount)</SourceLine>
   <SourceLine>//add the new player</SourceLine>
   <SourceLine>sqlstring="SELECT mRatingPct FROM PlayerInfo WHERE Season='"+mCurrentSeason+"' AND Name='"+PlayerName+"' AND HSName='"+HomeTown+"'"</SourceLine>
   <SourceLine>rs=db.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>sqlstring="INSERT INTO SLTeams (TeamNumber, PlayerName, Rating) VALUES ('"+lines(iCount+1)+"', '"+PlayerName+"', '"+format(100*rs.IdxField(1).DoubleValue, "+0000.000")+"')"</SourceLine>
   <SourceLine>sldb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>iCount=iCount+2</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//players are loaded, but their all-america status is not set yet.  we need to set that</SourceLine>
   <SourceLine>mthSetAAStatus</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//at this point, all players are included in the database, so we can enable the start button</SourceLine>
   <SourceLine>butStart.Enabled=true</SourceLine>
   <SourceLine>sldb.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim myteams(255) as string</SourceLine>
   <SourceLine>for x as integer=0 to 255</SourceLine>
   <SourceLine>myteams(x)=teams(x)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>myteams.sort</SourceLine>
   <SourceLine>cbTeams.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>For x as integer =1 to 256</SourceLine>
   <SourceLine>cbteams.AddRow myteams(x-1)</SourceLine>
   <SourceLine>next x</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>self.SetFocus</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
