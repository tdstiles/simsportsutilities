 <Method>
  <ItemName>ReturnString</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1643980799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ReturnString() As String</SourceLine>
   <SourceLine>//this method generates the result text</SourceLine>
   <SourceLine>dim ResultString as string</SourceLine>
   <SourceLine>dim winner(1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rgTeams(0).mScore&gt;rgTeams(1).mScore then</SourceLine>
   <SourceLine>winner(0)="'''"</SourceLine>
   <SourceLine>winner(1)=""</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>winner(0)=""</SourceLine>
   <SourceLine>winner(1)="'''"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>ResultString=ResultString+"|RD"+mRound+"-seed"+mteam(n)+"="+str(rgTeams(n).mSeed)+EndOfLine</SourceLine>
   <SourceLine>ResultString=ResultString+"|RD"+mRound+"-team"+mTeam(n)+"="+winner(n)+HTMLLink(rgTeams(n).mTeamNumber,8)+winner(n)+EndOfLine</SourceLine>
   <SourceLine>ResultString=ResultString+"|RD"+mRound+"-score"+mTeam(n)+"="+str(rgTeams(n).mScore)+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return ResultString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
