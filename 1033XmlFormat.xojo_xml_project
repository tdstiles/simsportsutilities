  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetStarString(Name as string, StarArray() as string) As string</SourceLine>
   <SourceLine>//top 20--5*</SourceLine>
   <SourceLine>//next 20--4.5*</SourceLine>
   <SourceLine>//next 60 -- 4*</SourceLine>
   <SourceLine>//next 80 -- 3.5*</SourceLine>
   <SourceLine>//next 80 -- 3*</SourceLine>
   <SourceLine>//next 100 -- 2.5*</SourceLine>
   <SourceLine>//next 100 -- 2*</SourceLine>
   <SourceLine>//the rest -- 1*</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpCount as integer</SourceLine>
   <SourceLine>dim STarString as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tmpCount=StarArray.IndexOf(Name)+1</SourceLine>
   <SourceLine>if tmpCount&lt;=20 then</SourceLine>
   <SourceLine>return "5*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=40 then</SourceLine>
   <SourceLine>return "4.5*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=100 then</SourceLine>
   <SourceLine>return "4*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=180 then</SourceLine>
   <SourceLine>return "3.5*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=260 then</SourceLine>
   <SourceLine>return "3*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=360 then</SourceLine>
   <SourceLine>return "2.5*"</SourceLine>
   <SourceLine>elseif tmpCount&lt;=460 then</SourceLine>
   <SourceLine>return "2*"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return "1*"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
