 <Method>
  <ItemName>EstimatedRatings</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>851197951</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function EstimatedRatings(gpa as double, test as double) As string</SourceLine>
   <SourceLine>dim a,b as string</SourceLine>
   <SourceLine>dim intscore as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>if attrs(n,2)&gt;=1.5 then //exc</SourceLine>
   <SourceLine>b="E"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(n,2)&gt;=0.5 then //good</SourceLine>
   <SourceLine>b="G"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(n,2) &gt;=-0.5 then //fair</SourceLine>
   <SourceLine>b="F"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(n,2)&gt;= -1.5 then //poor</SourceLine>
   <SourceLine>b="P"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //none</SourceLine>
   <SourceLine>b="N"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>a=a+b</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'</SourceLine>
   <SourceLine>'intscore=-3.8154+.7677*GPA+.0328*test</SourceLine>
   <SourceLine>'if intscore&gt;=1.5 then</SourceLine>
   <SourceLine>'a=a+"E"</SourceLine>
   <SourceLine>'elseif intscore&gt;=0.5 then</SourceLine>
   <SourceLine>'a=a+"G"</SourceLine>
   <SourceLine>'elseif intscore&gt;=-0.5 then</SourceLine>
   <SourceLine>'a=a+"F"</SourceLine>
   <SourceLine>'elseif intscore&gt;=-1.5 then</SourceLine>
   <SourceLine>'a=a+"P"</SourceLine>
   <SourceLine>'else</SourceLine>
   <SourceLine>'a=a+"N"</SourceLine>
   <SourceLine>'end</SourceLine>
   <SourceLine>'</SourceLine>
   <SourceLine>attrs(5,2)=0.7*intscore</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>intscore = -0.884 + 0.741 * GPA + 0.0355 *test</SourceLine>
   <SourceLine>attrs(5,2)=0.8*intscore</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if intscore&gt;=3.99 then</SourceLine>
   <SourceLine>a=a+"E"</SourceLine>
   <SourceLine>elseif intscore&gt;=3.63 then</SourceLine>
   <SourceLine>a=a+"G"</SourceLine>
   <SourceLine>elseif intscore&gt;=3.28 then</SourceLine>
   <SourceLine>a=a+"F"</SourceLine>
   <SourceLine>elseif intscore&gt;=2.92 then</SourceLine>
   <SourceLine>a=a+"P"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>a=a+"N"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if attrs(4,2)&gt;=1.5 then //exc</SourceLine>
   <SourceLine>b="E"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(4,2)&gt;=0.5 then //good</SourceLine>
   <SourceLine>b="G"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(4,2) &gt;=-0.5 then //fair</SourceLine>
   <SourceLine>b="F"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif attrs(4,2)&gt;= -1.5 then //poor</SourceLine>
   <SourceLine>b="P"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //none</SourceLine>
   <SourceLine>b="N"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>a=a+b</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>gpa as double, test as double</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mRateCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1061036031</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mRateCalc()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim estrate as string</SourceLine>
   <SourceLine>dim playerplusminus as double</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim avgheight as double</SourceLine>
   <SourceLine>dim squared as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the average height for the players</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT avg(Height) FROM PlayerInfo")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>avgheight=rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>avgheight=77.34</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//calculated the estimated ratings for each player</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Name, Scout, Pos, SHT, DEF, HND, REB, ATH, PPG, RPG, APG, SPG, BPG, TPG, GPA, Test, Height, rowID FROM PlayerInfo")</SourceLine>
   <SourceLine>while rs&lt;&gt;nil and rs.eof=false and rs.RecordCount&lt;&gt;0</SourceLine>
   <SourceLine>estrate=""</SourceLine>
   <SourceLine>//for each player, determine min/max values according to scout</SourceLine>
   <SourceLine>smm(rs.IdxField(2).IntegerValue, rs.IdxField(4).IntegerValue, rs.IdxField(5).IntegerValue, rs.IdxField(6).IntegerValue, rs.IdxField(7).IntegerValue, rs.IdxField(8).IntegerValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>if attrs(n,0)&lt;-2.33 then</SourceLine>
   <SourceLine>attrs(n,0)=-2.33</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if attrs(n,1)&gt;2.33 then</SourceLine>
   <SourceLine>attrs(n,1)=2.33</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//for each player, determine attributes based on average stats</SourceLine>
   <SourceLine>DetermineRatingsFromStats(rs.IdxField(3).StringValue, rs.IdxField(9).DoubleValue, rs.IdxField(10).DoubleValue, rs.IdxField(11).DoubleValue, rs.IdxField(12).DoubleValue, rs.IdxField(13).DoubleValue, rs.IdxField(14).DoubleValue)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//generate estimatedratings and save to DB</SourceLine>
   <SourceLine>estrate=EstimatedRatings(rs.IdxField(15).DoubleValue, rs.IdxField(16).DoubleValue)</SourceLine>
   <SourceLine>sqlstring="UPDATE PlayerInfo SET estimatedattributes='"+estrate+"' WHERE rowID="+rs.IdxField(18).StringValue</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//generate playerplusminus and save to DB (include height modifier)</SourceLine>
   <SourceLine>playerplusminus=PlayerPMCalc(rs.IdxField(17).IntegerValue, avgheight)</SourceLine>
   <SourceLine>sqlstring="UPDATE PlayerInfo SET playerplusminus='"+str(playerplusminus)+"' WHERE rowID="+rs.IdxField(18).StringValue</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>CalcSSCPct(avgheight)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
