  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub TeamsUpdateOverview()</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim missedteams(-1) as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM Players WHERE Season='"+trim(mCurrentSeason)+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+league,2)+"&amp;idno="+str(n)</SourceLine>
   <SourceLine>mResult=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine>ParsePlayerfile(n)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>missedteams.append(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while ubound(missedteams)&gt;-1</SourceLine>
   <SourceLine>mResult=""</SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+league,2)+"&amp;idno="+str(missedteams(0))</SourceLine>
   <SourceLine>mResult=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine>ParsePlayerfile(missedteams(0))</SourceLine>
   <SourceLine>missedteams.Remove(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
