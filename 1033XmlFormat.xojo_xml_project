  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LogIn() As boolean</SourceLine>
   <SourceLine>//first we need to fake log in to the site</SourceLine>
   <SourceLine>Dim formDict As New Dictionary</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>formDict.value("01)required-name")=mUsername // Name</SourceLine>
   <SourceLine>formDict.value("11)passcard")=mpassword //password</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.SetFormData formDict // Get the POST data ready</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim page as string</SourceLine>
   <SourceLine>page=me.Post ("http://drivethelane.com/bask/runtime/login.asp", 5)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim cookie as string</SourceLine>
   <SourceLine>for i as integer = 0 to me.pageHeaders.nameCount("set-cookie") - 1//</SourceLine>
   <SourceLine>cookie = me.pageHeaders.value("set-cookie",i)</SourceLine>
   <SourceLine>me.requestHeaders.AppendHeader "cookie",cookie</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>page=me.get ("http://drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+league,2)+"&amp;idno=120",30)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return true</SourceLine>
   <SourceLine>End Function</SourceLine>
