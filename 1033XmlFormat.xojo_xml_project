  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GenerateAttributeString(rs as RecordSet) As string</SourceLine>
   <SourceLine>//this method takes the recordset that's passed and sends back the recruit's attributes</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim zstring as string</SourceLine>
   <SourceLine>zstring=numtoword(rs.field("SHT").integerValue)+" "+numtoword(rs.Field("DEF").integerValue)+" "+numtoword(rs.Field("HND").integerValue)+" "+numtoword(rs.Field("REB").integerValue)+" "+numtoword(rs.Field("ATH").integerValue)+" ("</SourceLine>
   <SourceLine>zstring=zstring+numtoword(rs.Field("Scout").IntegerValue)</SourceLine>
   <SourceLine>zstring=zstring+" scout)"</SourceLine>
   <SourceLine>return zstring</SourceLine>
   <SourceLine>End Function</SourceLine>
