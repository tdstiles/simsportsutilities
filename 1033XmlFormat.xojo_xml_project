 <Method>
  <ItemName>CreateText</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2041292799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CreateText() As string</SourceLine>
   <SourceLine>//This method returns a string in HTML format.</SourceLine>
   <SourceLine>//The string is composed of two parts:  the zHeader, which goes at the beginning and has hyperlinked team pages,</SourceLine>
   <SourceLine>//and the zReturn, which is the bottom part, composed of returns from the GOTWRecap methods</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim jstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim POG as GOTWRecapPlayers</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Games.WL='W'), Sum(Games.WL='L') FROM Games, PRI WHERE Games.TeamNum=PRI.TeamNum AND PRI.Conference="+str(ConfRecapCN)+" AND Games.GameNum="+str(ConfRecapGN)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>jstring=" ("+rs.IdxField(1).StringValue+"-"+rs.IdxField(2).StringValue+")"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if ConfRecapCN&lt;33 then</SourceLine>
   <SourceLine>zHeader.append "&lt;h2&gt;Conference "+str(ConfRecapCN)+" Report for Game "+str(ConfRecapGN)+jstring+"&lt;/h2&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>zHeader.append "&lt;h2&gt;Super Conference Report for Game "+str(ConfRecapGN)+jstring+"&lt;/h2&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim Recap as cGOTWRecap</SourceLine>
   <SourceLine>dim tn(1) as integer</SourceLine>
   <SourceLine>for n as integer=0 to 7</SourceLine>
   <SourceLine>//for each team in the conference, let's create a new cGOTWRecap and load up the results</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, let's make sure we're not repeating games</SourceLine>
   <SourceLine>dim fGood as Boolean=true</SourceLine>
   <SourceLine>for j as integer=0 to n-1</SourceLine>
   <SourceLine>if rTeams(j,1)=rTeams(n,0) then fGood=false</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fGood then</SourceLine>
   <SourceLine>tn(0)=rTeams(n,0)</SourceLine>
   <SourceLine>tn(1)=rTeams(n,1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Recap=new cGOTWRecap(tn, ConfRecapGN,fBoxScore)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//build anchored links</SourceLine>
   <SourceLine>zReturn.append recap.AnchoredLink</SourceLine>
   <SourceLine>zReturn.append Recap.CreateText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//add on to the header</SourceLine>
   <SourceLine>zHeader.append Recap.ConferenceString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Add in the POTW from this game</SourceLine>
   <SourceLine>POG=Recap.GetPOG</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//is he in our conference?</SourceLine>
   <SourceLine>if GetConference(pog.TeamNum)=ConfRecapCN then</SourceLine>
   <SourceLine>Potw.append POG</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's stick a divider between the two</SourceLine>
   <SourceLine>zReturn.append "----------------------------&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//at this point, we have all the games loaded, as well as a list of POTW</SourceLine>
   <SourceLine>//Let's figure out who the ConfPOTW is</SourceLine>
   <SourceLine>POG=GetConfPOTW</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Add in ConfPOTW</SourceLine>
   <SourceLine>zHeader.append "&lt;H3&gt;Conference Player of the Week&lt;/h3&gt;:  "+POG.Name+" of "+Teams(POG.TeamNum-1)+"&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>zHeader.append "&lt;br&gt;"</SourceLine>
   <SourceLine>dim a as string=zHeader.ToString+zReturn.ToString</SourceLine>
   <SourceLine>a=a+AddFooter</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>SetTeams</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1010886655</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SetTeams()</SourceLine>
   <SourceLine>//first, we get a list of all the teams from this conference</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//teamsandopps(n,0)=teamnumber  teamsandopps(n,1)=opponentnumber  teamsandopps(n,2)=teamfPR teamsandopps(n,3)=oppfPR</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim i as integer=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, fPR FROM PRI WHERE Conference='"+str(ConfRecapCN)+"' ORDER BY TeamNum ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>rTeams(i,0)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>rTeams(i,2)=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i-1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to i</SourceLine>
   <SourceLine>//now, who they played in game GameNumber as an array</SourceLine>
   <SourceLine>sqlstring="SELECT OpponentNum FROM Games WHERE TeamNum='"+str(rTeams(n,0))+"' AND Season='"+mCurrentSeason+"' AND GameNum='"+str(ConfRecapGN)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>rTeams(n,1)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT fPR FROM PRI WHERE TeamNum="+rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>rTeams(n,3)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//at this point, the rTeams array is set with all the teams and who they played</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
