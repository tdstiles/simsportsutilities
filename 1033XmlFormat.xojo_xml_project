  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(Region as String, Round as integer, Seed() as integer, FirstTeamListing as Integer)</SourceLine>
   <SourceLine>//this method, we pass the region, game, and the seed, and we get back the team number and score</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim RegionClause as string</SourceLine>
   <SourceLine>if region&lt;&gt;"--" then</SourceLine>
   <SourceLine>mRegion=Region</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mRound=str(Round)</SourceLine>
   <SourceLine>mGN=val(mRound)+18</SourceLine>
   <SourceLine>mTeam(0)=right("0"+str(FirstTeamListing),2)</SourceLine>
   <SourceLine>mTeam(1)=right("0"+str(FirstTeamListing+1),2)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim iTeam as cTourneyTeam</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=DBSQLSELECT("Select TeamNum FROM PostSeasonResults WHERE Tournament='"+iTT+"' and Season='"+mcurrentseason+"' AND Region='"+mRegion+"' AND Seed='"+str(Seed(n))+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>iTeam=new cTourneyTeam</SourceLine>
   <SourceLine>iTeam.mTeamNumber=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>iTeam.mSeed=seed(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("Select OurScore FROM Games WHERE GameNum='"+str(mGN)+"' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(iTeam.mTeamNumber)+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>iTeam.mScore=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rgTeams(n)=iTeam</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have two teams set</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
