 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1335027711</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(Round as Integer, FirstTeam as cTourneyTeam, SecondTeam as cTourneyTeam, FirstTeamListing as Integer)</SourceLine>
   <SourceLine>//this method, we pass the region, game, and the seed, and we get back the team number and score</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mRound=str(Round)</SourceLine>
   <SourceLine>mGN=val(mRound)+22</SourceLine>
   <SourceLine>mTeam(0)=right("0"+str(FirstTeamListing),2)</SourceLine>
   <SourceLine>mTeam(1)=right("0"+str(FirstTeamListing+1),2)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rgTeams(0)=FirstTeam</SourceLine>
   <SourceLine>rgTeams(1)=SecondTeam</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=DBSQLSELECT("Select OurScore FROM Games WHERE GameNum='"+str(mGN)+"' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(rgTeams(n).mTeamNumber)+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>rgteams(n).mScore=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have two teams set</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
