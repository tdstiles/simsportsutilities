  <PartID>1412943871</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function Streak() As string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim streak as integer</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim stillgoing as Boolean</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT GameNum, WL FROM Games WHERE Season='"+mSeason+"' AND TeamNum='"+str(TN)+"' ORDER BY GameNum DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt; nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>result=rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>streak=1</SourceLine>
   <SourceLine>stillgoing=true</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false and stillgoing=true</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>if rs.IdxField(2).StringValue=result then</SourceLine>
   <SourceLine>streak=streak+1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>stillgoing=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if result="W" then</SourceLine>
   <SourceLine>return "W"+str(streak)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return "L"+str(streak)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
