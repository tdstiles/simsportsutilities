 <Method>
  <ItemName>GenerateRankedStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1389737983</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GenerateRankedStats()</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mStatDB=new REALSQLDatabase</SourceLine>
   <SourceLine>if mStatDB.Connect then</SourceLine>
   <SourceLine>mStatDB.SQLExecute("CREATE TABLE stattable (TeamNum integer, ppg double, appg double, rpg double, tos double, experience integer, depth integer, height integer)")</SourceLine>
   <SourceLine>mStatDB.Commit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Sum(RPG*GM), Sum((STL-TOS)*GM) FROM Players WHERE Season='"+mCurrentSeason+"' GROUP BY TeamNum ORDER BY TeamNum ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>mStatDB.SQLExecute("INSERT INTO StatTable (TeamNum, RPG, TOS) VALUES ('"+rs.IdxField(1).StringValue+"', '"+rs.IdxField(2).StringValue+"', '"+rs.IdxField(3).StringValue+"')")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>mStatDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, AVG(OurScore), 200-AVG(OppScore) FROM Games WHERE Season='"+mCurrentSeason+"' GROUP BY TeamNum ORDER BY TeamNum ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>mStatDB.SQLExecute("UPDATE STatTable SET PPG='"+rs.IdxField(2).StringValue+"', aPPG='"+rs.IdxField(3).StringValue+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set experience and depth</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>dim iCounter as double</SourceLine>
   <SourceLine>dim ClassTmp as integer</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, YR, GM, MPG FROM Players WHERE MPG&gt;='20' AND GM&gt;='"+str(gamesplayed-3)+"' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>if rs.IdxField(2).StringValue="Sr" then</SourceLine>
   <SourceLine>ClassTmp=6</SourceLine>
   <SourceLine>elseif rs.IdxField(2).StringValue="Jr" then</SourceLine>
   <SourceLine>ClassTmp=4</SourceLine>
   <SourceLine>elseif rs.IdxField(2).StringValue="So" then</SourceLine>
   <SourceLine>ClassTmp=2</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>ClassTmp=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>iCounter=iCounter+ClassTmp</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounterForDepth as integer</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(MPG&gt;='17') FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"' AND GM&gt;='"+str(GamesPlayed-3)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>iCounterForDepth=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iCounterForHeight as integer</SourceLine>
   <SourceLine>sqlstring="SELECT HT FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"' AND GM&gt;='"+str(GamesPlayed-3)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>dim HTInches as integer</SourceLine>
   <SourceLine>HTInches=FeettoInches(rs.IdxField(1).StringValue)</SourceLine>
   <SourceLine>if HTInches&gt;=81 then</SourceLine>
   <SourceLine>iCounterForHeight=iCounterForHeight+1</SourceLine>
   <SourceLine>elseif HTInches&lt;=74 then</SourceLine>
   <SourceLine>iCounterForHeight=iCounterForHeight-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE StatTable SET Experience='"+str(iCounter)+"', Depth='"+str(iCounterforDepth)+"', Height='"+str(iCounterForHeight)+"' WHERE TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>mStatDB.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mStatDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim statlist(6) as string</SourceLine>
   <SourceLine>statlist(0)="PPG"</SourceLine>
   <SourceLine>statlist(1)="aPPG"</SourceLine>
   <SourceLine>statlist(2)="RPG"</SourceLine>
   <SourceLine>statlist(3)="TOS"</SourceLine>
   <SourceLine>statlist(4)="Experience"</SourceLine>
   <SourceLine>statlist(5)="Depth"</SourceLine>
   <SourceLine>statlist(6)="Height"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 6</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum FROM StatTable ORDER BY "+statlist(n)+" DESC"</SourceLine>
   <SourceLine>rs=mStatDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>j=j+1</SourceLine>
   <SourceLine>sqlstring="UPDATE StatTable SET "+statlist(n)+"='"+str(j)+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>mStatDB.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mStatDB.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ConfFinish</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1447356415</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ConfFinish(TeamNum as integer, Tournament as String) As string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine>dim b(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT ConfFinish, Conference FROM PRI WHERE TeamNum="+str(TeamNum)+" AND Season="+mCurrentSeason)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>a= "C-"+rs.IdxField(2).StringValue+"  "+RankedValue(rs.IdxField(1).IntegerValue)+" place"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if Tournament="NTT" then</SourceLine>
   <SourceLine>//in the NTT, show how they got their bid</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>rec=DBSQLSELECT("SELECT Sum(WL='W') FROM Games WHERE TeamNum="+str(TeamNum)+" AND Season="+mCurrentSeason+" AND GameNum&gt;15 AND GameNum&lt;19")</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>if rec.IdxField(1).IntegerValue=3 then</SourceLine>
   <SourceLine>//conference champion</SourceLine>
   <SourceLine>b.append "Conf. Tourney Champ"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if UBound(b)=0 then</SourceLine>
   <SourceLine>//conference and regular season champ</SourceLine>
   <SourceLine>a=a+", "+b(0)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue&lt;&gt;1 then</SourceLine>
   <SourceLine>a=a+", at-large bid"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
