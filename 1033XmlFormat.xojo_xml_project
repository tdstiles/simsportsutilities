 <Method>
  <ItemName>GenerateSingleGameStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2122031103</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GenerateSingleGameStats()</SourceLine>
   <SourceLine>dim rs, brs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim insertstring as string</SourceLine>
   <SourceLine>dim playerstats(5) as double</SourceLine>
   <SourceLine>dim j(1) as double</SourceLine>
   <SourceLine>dim y as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="DELETE FROM HSStats WHERE Season='"+mCurrentSeason+"' AND Game='"+GN+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Name, HSName, PPG, RPG, APG, SPG, TPG, BPG FROM PlayerInfo WHERE Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>mMainSQLString=mMainSQLString+"DELETE FROM HSPlayers WHERE Season='"+mCurrentSeason+"' AND GameNum='"+GN+"';"+EndOfLine</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>sqlstring="SELECT Season, Name, HSName, Sum(Pts), Sum(Reb), Sum(Ast), Sum(Stl), Sum(Tos), Sum(Blk) FROM HSStats WHERE Name='"+rs.IdxField(2).StringValue+"' AND Season='"+mCurrentSeason+"' AND HSName='"+rs.IdxField(3).StringValue+"' GROUP BY Name"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(brs) then</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>y=(round(rs.IdxField(n+4).DoubleValue*val(GN)))-brs.IdxField(n+4).IntegerValue</SourceLine>
   <SourceLine>if y&lt;1 then</SourceLine>
   <SourceLine>playerstats(n)=0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>playerstats(n)=y</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>insertstring=insertstring+", '"+str(playerstats(n))+"'"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//if first game and player is not in HSStats yet</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>playerstats(n)=rs.IdxField(n+4).IntegerValue</SourceLine>
   <SourceLine>insertstring=insertstring+", '"+str(playerstats(n))+"'"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO HSPlayers (Season, Player, HSName, GameNum, Pts, Reb, Ast, Stl, TOs, Blk) VALUES ('"+mCurrentSeason+"', '"+ rs.IdxField(2).StringValue+"', '"+rs.IdxField(3).StringValue+"', '"+GN+"'"+insertstring+");"+EndOfLine</SourceLine>
   <SourceLine>mMainSQLString=mMainSQLString+sqlstring</SourceLine>
   <SourceLine>sqlstring="INSERT INTO HSStats (Season, Name, HSName, Game, Pts, Reb, Ast, Stl, TOs, Blk) VALUES ('"+mCurrentSeason+"', '"+ rs.IdxField(2).StringValue+"', '"+rs.IdxField(3).StringValue+"', '"+GN+"'"+insertstring+")"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>insertstring=""</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
