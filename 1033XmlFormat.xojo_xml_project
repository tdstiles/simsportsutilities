   <SourceLine>previousrnk=FindingPreviousRank(rs.IdxField(1).integerValue, mCurrentSeason, str(val(pollnum)-1))</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>previousrnk="-"</SourceLine>
   <SourceLine>end</SourceLine>
