   <SourceLine>tout.WriteLine line</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 14</SourceLine>
   <SourceLine>line=lb1.cell(n,0)+chr(44)+lb1.cell(n,1)+chr(44)+lb1.cell(n,2)+chr(44)+lb1.cell(n,3)+chr(44)+lb1.cell(n,4)+chr(44)+lb1.cell(n,5)+chr(44)+lb1.cell(n,6)+chr(44)+lb1.cell(n,7)</SourceLine>
   <SourceLine>tout.WriteLine line</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tout.close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
