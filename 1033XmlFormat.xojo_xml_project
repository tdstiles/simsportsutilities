   <SourceLine>playerstring=split("Pos,Name,Yr,Ht,PPG,RPG,APG,SPG,Blk,TS%,Team", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mConferenceChoice=0 then</SourceLine>
