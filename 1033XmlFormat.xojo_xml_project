  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CalcPreseasonAllConf(ConferenceNum as String) As string</SourceLine>
   <SourceLine>//now we load up the preseason all-conference team</SourceLine>
   <SourceLine>//we're pulling for the preseason</SourceLine>
   <SourceLine>dim playerstring(-1) as string</SourceLine>
   <SourceLine>dim columnstring(-1) as string</SourceLine>
   <SourceLine>dim mainstring as string</SourceLine>
   <SourceLine>dim estring as string</SourceLine>
   <SourceLine>dim sbstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>playerstring=split("Pos, Name, Yr, Ht, PPG, RPG, APG, SPG, Blk, Team", ",")</SourceLine>
   <SourceLine>sbstring=sbstring+TableGeneratorTitle("Preseason All-C"+ConferenceNum+" Team",playerstring,0,3)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mainstring="SELECT Players.Player, Players.Pos, PRI.TeamNum, Players.YR, Players.HT, Players.PPG, Players.RPG, Players.APG, Players.STL, Players.BLK FROM Players, PRI WHERE  Players.season='"+str(val(mCurrentSeason)-1)+"' AND PRI.Season='"+str(val(mCurrentSeason)-1)+"' AND Players.TeamNum=PRI.TeamNum AND PRI.Conference='"+ConferenceNum+"' AND Players.YR&lt;&gt;'Sr'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first team</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring=mainstring+"  AND Players.Pos LIKE '%"+positions(n)+"' ORDER BY Players.Tendex DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>columnstring=split(positions(n)+","+ rs.IdxField(1).stringValue+","+ modAddaYear(rs.IdxField(4).stringValue)+","+ changeheight(rs.IdxField(5).StringValue)+","+format(rs.IdxField(6).doubleValue, "##.0")+","+format(rs.IdxField(7).doubleValue, "##.0")+","+format(rs.IdxField(8).doubleValue, "##.0")+","+format(rs.IdxField(9).doubleValue, "##.0")+","+format(rs.IdxField(10).doubleValue, "##")+","+HTMLLink(rs.IdxField(3).IntegerValue, 3), ",")</SourceLine>
   <SourceLine>sbstring=sbstring+ColumnGenerator(1, columnstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring=sbstring+CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
