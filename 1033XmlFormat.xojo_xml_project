 <Method>
  <ItemName>ChangeCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2005004287</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ChangeCalc(PD as Integer, Ra as Double, Rb as Double) As double</SourceLine>
   <SourceLine>dim gp as double</SourceLine>
   <SourceLine>dim we as double</SourceLine>
   <SourceLine>dim rn as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if pd&gt;0 then</SourceLine>
   <SourceLine>gp=1-0.4^(1+PD/11)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>gp=0.4^(1+abs(PD)/11)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>we=1/(1+10^((Rb-Ra)/200))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rn=ra+125/divisor*(gp-we)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rn&lt;0 then rn=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return rn</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>PD as Integer, Ra as Double, Rb as Double</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>MainELOMethod</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>406802431</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub MainELOMethod()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim fHome, fAway as double</SourceLine>
   <SourceLine>dim tmpELO(255) as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>divisor=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>tmpELO(n)=1000</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 25</SourceLine>
   <SourceLine>if n mod 5=0 then</SourceLine>
   <SourceLine>divisor=(divisor+1)*2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Games.TeamNum, Games.OpponentNum, Games.OurScore, Games.OppScore FROM Games WHERE Games.Season='"+mCurrentSeason+"' ORDER BY Random()"</SourceLine>
   <SourceLine>//Random ()</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>//loop through each game</SourceLine>
   <SourceLine>fHome=ChangeCalc(rs.IdxField(3).IntegerValue-rs.IdxField(4).IntegerValue, tmpELO(rs.IdxField(1).IntegerValue-1), tmpELO(rs.IdxField(2).IntegerValue-1))</SourceLine>
   <SourceLine>fAway=ChangeCalc(rs.IdxField(4).IntegerValue-rs.IdxField(3).IntegerValue, tmpELO(rs.IdxField(2).IntegerValue-1), tmpELO(rs.IdxField(1).IntegerValue-1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tmpELO(rs.IdxField(1).IntegerValue-1)=fHome</SourceLine>
   <SourceLine>tmpELO(rs.IdxField(2).IntegerValue-1)=fAway</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 255</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE PRI SET ELO='"+str(tmpELO(n))+"' WHERE TeamNum='"+str(n+1)+"'")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, rowID FROM PRI WHERE Season='"+mCurrentSeason+"' ORDER BY ELO DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine>n=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE PRI SET fPR='"+str(n)+"' WHERE rowID='"+rs.IdxField(2).StringValue+"'")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>CalcSoS</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>AdjustELO</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
