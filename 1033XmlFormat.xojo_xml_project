 <Method>
  <ItemName>CreateText</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>940253183</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CreateText() As string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>r=new Random</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>MoV= RecapTeams(0).points-RecapTeams(1).points</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;p&gt;&lt;b&gt;Recap:  "+HTMLLink(RecapTeams(w).TeamNumber,4)+" "+str(RecapTeams(w).Points)+"  "+HTMLLink(RecapTeams(l).TeamNumber,4)+" "+str(RecapTeams(l).Points)+GetTournament(recapteams(w).teamnumber)+"&lt;/b&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append "The "+RecapTeams(w).TeamName+" "+RecapTeams(w).TeamNickName+" "</SourceLine>
   <SourceLine>sbstring.append ScoreDifferential(abs(MoV))+" the "+RecapTeams(l).TeamName+" "+RecapTeams(l).TeamNickName+" in game "+str(GOTWRecapGN)+" by a score of "+str(RecapTeams(w).Points)+"-"+str(RecapTeams(l).Points)+".  "+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append VictoryEdge</SourceLine>
   <SourceLine>sbstring.append POGString(GetPOG)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get if the team is on a streak</SourceLine>
   <SourceLine>sbstring.append WinningStreak+"&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim columns(-1) as string</SourceLine>
   <SourceLine>//now let's throw out the box score</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we may not want it; we have to check first to see if fBoxScore is true</SourceLine>
   <SourceLine>if fBoxScore then</SourceLine>
   <SourceLine>for j as integer=0 to 1</SourceLine>
   <SourceLine>//first the table and its heading</SourceLine>
   <SourceLine>columns=split("Name, Pos,MIN,FGM,FGA,3PM,3PA,FTM,FTA,REB,AST,BLK,STL,TOs,PFs,PTS ", ",")</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle(RecapTeams(j).TeamName, columns)</SourceLine>
   <SourceLine>for n as integer=0 to UBound(RecapTeams(j).Players)</SourceLine>
   <SourceLine>redim columns(-1)</SourceLine>
   <SourceLine>columns.append RecapTeams(j).Players(n).name</SourceLine>
   <SourceLine>columns.append RecapTeams(j).Players(n).pos</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).minutes)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).fgm)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).fga)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).fg3m)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).fg3a)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).ftm)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).fta)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).reb)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).ast)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).blk)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).stl)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).tos)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).pfs)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).Players(n).points)</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n+1, columns)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>redim columns(-1)</SourceLine>
   <SourceLine>columns.append RecapTeams(j).TeamNickname</SourceLine>
   <SourceLine>columns.append "--"</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).minutes)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).fgm)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).fga)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).fg3m)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).fg3a)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).ftm)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).fta)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).reb)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).ast)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).blk)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).stl)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).tos)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).pfs)</SourceLine>
   <SourceLine>columns.append str(RecapTeams(j).points)</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(11, columns)</SourceLine>
   <SourceLine>sbstring.append CloseTable+"&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>Return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>CheckFor3PtPercentage</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>169689087</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CheckFor3PtPercentage(fg3m as integer, fg3a as integer, ftm as integer, fta as integer) As string</SourceLine>
   <SourceLine>//first, determine whether threes or free throws were more important</SourceLine>
   <SourceLine>if fg3m*fg3m*3/fg3a&gt;ftm*ftm/fta then</SourceLine>
   <SourceLine>//threes more important</SourceLine>
   <SourceLine>if fg3m&gt;1 then</SourceLine>
   <SourceLine>//if he made more than 1 three and his pct is greater than 50%, return it</SourceLine>
   <SourceLine>if fg3m/fg3a&gt;0.4 then</SourceLine>
   <SourceLine>return " ("+str(fg3m)+"/"+str(fg3a)+" from behind the arc)"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return ""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return ""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//free throws more important</SourceLine>
   <SourceLine>if ftm&gt;4 then</SourceLine>
   <SourceLine>//if he made more than 1 three and his pct is greater than 50%, return it</SourceLine>
   <SourceLine>if ftm/fta=1 then</SourceLine>
   <SourceLine>return " (including a perfect "+str(ftm)+"/"+str(fta)+" from the stripe)"</SourceLine>
   <SourceLine>elseif ftm/fta&gt;0.7 then</SourceLine>
   <SourceLine>return " ("+str(ftm)+"/"+str(fta)+" from the stripe)"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return ""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return ""</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>fg3m as integer, fg3a as integer, ftm as integer, fta as integer</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>GetPOG</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1221226495</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetPOG() As GOTWRecapPlayers</SourceLine>
   <SourceLine>dim t as cGOTWRecapTeam</SourceLine>
   <SourceLine>dim POGHere as new GOTWRecapPlayers</SourceLine>
   <SourceLine>dim tempplayer as new GOTWRecapPlayers</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim a as integer</SourceLine>
   <SourceLine>dim iMaxPlayers as integer</SourceLine>
   <SourceLine>for j as integer=0 to 1</SourceLine>
   <SourceLine>t=RecapTeams(j)</SourceLine>
   <SourceLine>iMaxPlayers=UBound(t.Players)</SourceLine>
   <SourceLine>for n as integer=0 to iMaxPlayers</SourceLine>
   <SourceLine>a=ninjabovinescore(t.Players(n).FGM, t.Players(n).FTM, t.Players(n).FG3M, t.Players(n).Reb, t.Players(n).Ast, t.Players(n).Stl, t.Players(n).Blk, t.Players(n).FGA, t.Players(n).FTA, t.Players(n).TOS, t.Players(n).PFs, t.Players(n).points)</SourceLine>
   <SourceLine>t.Players(n).nbs=a</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's get the best player of this current game</SourceLine>
   <SourceLine>POGHere=new GOTWRecapPlayers</SourceLine>
   <SourceLine>t=RecapTeams(w)</SourceLine>
   <SourceLine>iMaxPlayers=UBound(t.Players)</SourceLine>
   <SourceLine>for n as integer=0 to iMaxPlayers</SourceLine>
   <SourceLine>if t.Players(n).nbs&gt;POGHere.nbs then</SourceLine>
   <SourceLine>POGHere=t.players(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return POGHere</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
