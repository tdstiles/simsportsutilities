 <Method>
  <ItemName>ParseSchedule</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>586735615</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseSchedule(teamnum as integer)</SourceLine>
   <SourceLine>dim j as Boolean</SourceLine>
   <SourceLine>dim teamarray(6) as string</SourceLine>
   <SourceLine>Dim n,k As Integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim short, gamenumber as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>dim type,sqlstring as string</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>teamarray(0)=str(TeamNum)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mHighestGame&lt;16 then</SourceLine>
   <SourceLine>i=(mHighestGame+1)*9+34</SourceLine>
   <SourceLine>elseif mHighestGame&lt;19 then</SourceLine>
   <SourceLine>i=(mHighestGame+1)*9+35</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>i=(mHighestGame+1)*9+36</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>dim iCounter as integer=mHighestGame+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for y as integer=iCounter to GamesPlayed</SourceLine>
   <SourceLine>if i+8&lt;ubound(lines) then</SourceLine>
   <SourceLine>//check to see if this is an extra line from conference tournament or national tournament</SourceLine>
   <SourceLine>k=instr(lines(i), "Tournament")</SourceLine>
   <SourceLine>if k&lt;&gt;0 then</SourceLine>
   <SourceLine>//if so, let's add another to i and get moving</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>gamenumber=trim(lines(i))</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>short=trim(lines(i))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//try to remove team name, just get city name</SourceLine>
   <SourceLine>n=TeamNumberFromName(short)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>teamarray(1)=str(n)</SourceLine>
   <SourceLine>i=i+4</SourceLine>
   <SourceLine>teamarray(4)=lines(i)</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>line=lines(i)</SourceLine>
