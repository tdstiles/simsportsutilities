   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim columnshere(-1) as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>columnshere=split("Rank*Name*Region", "*")</SourceLine>
   <SourceLine>dim i as integer=1</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle("Top 75 Most Recruited",columnshere)</SourceLine>
   <SourceLine>sqlstring="SELECT t75rnk, Name, Region FROM PlayerInfo WHERE Season="+mCurrentSeason+" AND t75rnk&gt;0 ORDER BY t75rnk ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false </SourceLine>
   <SourceLine>columnshere=split(rs.IdxField(1).StringValue+".*"+rs.IdxField(2).StringValue+"*"+rs.IdxField(3).StringValue, "*")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(i,columnshere)</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
