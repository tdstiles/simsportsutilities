    <TextEncoding>134217984</TextEncoding>
    <SourceLine>Sub Action()</SourceLine>
    <SourceLine>dim sqlstring as string</SourceLine>
    <SourceLine>dim duplicate as boolean</SourceLine>
    <SourceLine>dim k as integer</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>mCurrentSeason=season.text</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>for n as integer=0 to 24</SourceLine>
    <SourceLine>for j as integer=0 to 24</SourceLine>
    <SourceLine>if j&lt;&gt;n then</SourceLine>
    <SourceLine>if pu(n).text=pu(j).text then</SourceLine>
    <SourceLine>duplicate=true</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if coachname.text="" or duplicate  then</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if coachname.text="" then</SourceLine>
    <SourceLine>msgbox "Please fill in the coach name before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>If duplicate then</SourceLine>
    <SourceLine>msgbox "You have duplicative entries; please correct them before continuing."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>for n as integer=0 to 24</SourceLine>
    <SourceLine>sqlstring="INSERT INTO TempVoteResults (coachname, teamnum, points, season) VALUES ('"+coachname.text+"', '"+str(teams.indexof(pu(n).text)+1)+"', '"+str(25-n)+"', '"+mCurrentSeason+"')"</SourceLine>
    <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>next</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>db.Commit</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>self.close</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine>End Sub</SourceLine>
