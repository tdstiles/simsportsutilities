 <Method>
  <ItemName>StatsByTeam</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>375111679</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function StatsByTeam(LoadArray() as String) As integer</SourceLine>
   <SourceLine>dim sqlstring, recstring, recbstring,w,l as string</SourceLine>
   <SourceLine>dim avgpr as Double</SourceLine>
   <SourceLine>dim rs,rec,recb as RecordSet</SourceLine>
   <SourceLine>dim k as integer=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mainbox.loadheader(split("Team,W,L,Pct,PF,PA,PR", ","))</SourceLine>
   <SourceLine>sqlstring="SELECT Games.TeamNum, avg(games.ourscore), avg(games.oppscore)  FROM Games "+loadarray(5)+"  WHERE Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)+" GROUP BY Games.TeamNum"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while  rs.eof=false</SourceLine>
   <SourceLine>recstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL='W' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' AND Games.TeamNum='"+rs.idxfield(1).stringvalue+"' "+loadarray(3)</SourceLine>
   <SourceLine>rec=dbsqlselect(recstring)</SourceLine>
   <SourceLine>w=rec.IdxField(1).StringValue</SourceLine>
   <SourceLine>recstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL='L' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' AND Games.TeamNum='"+rs.idxfield(1).stringvalue+"' "+loadarray(3)</SourceLine>
   <SourceLine>rec=dbsqlselect(recstring)</SourceLine>
   <SourceLine>l=rec.IdxField(1).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>recstring="SELECT PRI.PR FROM Games, PRI WHERE Games.Season='"+mCurrentSeason+"' AND Games.TeamNum=PRI.TeamNum AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' AND Games.TeamNum='"+rs.idxfield(1).stringvalue+"' "+loadarray(3)</SourceLine>
   <SourceLine>rec=dbsqlselect(recstring)</SourceLine>
   <SourceLine>avgpr=rec.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>mainbox.addrow teams(rs.idxfield(1).integervalue-1), w, l, format(val(w)/(val(w)+val(l)), "#.000"), format(rs.IdxField(2).DoubleValue,"###.0"), format(rs.IdxField(3).DoubleValue, "###.0"), format(rec.IdxField(1).IntegerValue, "###")</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games "+loadarray(5)+"  WHERE Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>k=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>return k</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>LoadArray() as String</ItemParams>
  <ItemResult>integer</ItemResult>
 </Method>
 <Method>
