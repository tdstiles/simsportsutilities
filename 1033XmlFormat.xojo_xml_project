   <SourceLine>finish=mthdTournamentFinish(TN)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'used by me to generate sql statements for website</SourceLine>
   <SourceLine>if DoGamebyGame then</SourceLine>
   <SourceLine>mFinalString=mFinalString+"INSERT INTO TeamData (season, teamnum, wins, losses, cpr, pr, offense, ornk, defense, drnk, plusminus, plusminusrnk, sos, sosrnk, offtempo, defensetype, mvp, finalrankings, rpi, rpirnk, confw, confl, elo, elornk) VALUES ('"+mCurrentSeason+"', '"+tn+"', '"+ars.IdxField(1).StringValue+"', '"+ars.IdxField(2).StringValue+"', '"+rs.IdxField(2).StringValue+"','"+rs.IdxField(3).StringValue+"', '"+brs.IdxField(1).StringValue+"', '"+brs.IdxField(2).StringValue+"', '"+brs.IdxField(3).StringValue+"', '"+brs.IdxField(4).StringValue+"', '"+brs.IdxField(5).StringValue+"', '"+brs.IdxField(6).StringValue+"', '"+rs.IdxField(5).StringValue+"', '"+brs.IdxField(7).StringValue+"', '"+brs.IdxField(8).StringValue+"', '"+crs.IdxField(1).StringValue+"', '"+rs.idxfield(4).stringvalue+"', '"+ers.idxfield(1).stringvalue+"', '"+ers.idxfield(2).stringvalue+"', '"+frs.idxfield(1).stringvalue+"', '"+frs.idxfield(2).stringvalue+"', '"+str(ers.idxfield(3).doublevalue/10)+"', '"+ers.idxfield(4).stringvalue+"');"+EndOfLine</SourceLine>
   <SourceLine>'mFinalString=mFinalString+"UPDATE TeamData SET wins= '"+ars.IdxField(1).StringValue+"', losses='"+ars.idxfield(2).stringvalue+"', cpr='"+rs.IdxField(2).StringValue+"', pr='"+rs.IdxField(3).StringValue+"', offense='"+brs.IdxField(1).StringValue+"', ornk='"+brs.IdxField(2).StringValue+"', defense='"+brs.IdxField(3).StringValue+"', drnk='"+brs.IdxField(4).StringValue+"', plusminus='"+brs.IdxField(5).StringValue+"', plusminusrnk='"+brs.IdxField(6).StringValue+"', sos='"+rs.IdxField(5).StringValue+"',offtempo='"+brs.IdxField(7).StringValue+"', defensetype='"+brs.IdxField(8).StringValue+"', mvp='"+crs.IdxField(1).StringValue+"', finalrankings='"+rs.idxfield(4).stringvalue+"', rpi='"+ers.idxfield(1).stringvalue+"', rpirnk='"+ers.idxfield(2).stringvalue+"', confw='"+frs.idxfield(1).stringvalue+"', confl='"+frs.idxfield(2).stringvalue+"', elo='"+str(ers.idxfield(3).doublevalue/10)+"', elornk='"+ers.idxfield(4).stringvalue+"' WHERE Season='"+mCurrentSeason+"' AND  TeamNum='"+tn+"';"+EndOfLine</SourceLine>
   <SourceLine>wndMain.showfield.text=mFinalString</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Team,Record,Conf, Prev, fPR, PR,Off (Rnk),Def (Rnk),+/- (Rnk),SoS (Rnk),RPI (Rnk),Tempo,Defense,MVP</SourceLine>
