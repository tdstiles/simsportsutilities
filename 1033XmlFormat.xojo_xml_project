 <Method>
  <ItemName>ParsePRI</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1145092095</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParsePRI()</SourceLine>
   <SourceLine>dim teamarray(255) as string</SourceLine>
   <SourceLine>Dim n,k, i As Integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim short as string</SourceLine>
   <SourceLine>dim conf as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM PRI WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=10</SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>for n =1 to 256</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>short=lines(i)</SourceLine>
   <SourceLine>k=instr(short, "  ")</SourceLine>
   <SourceLine>short=left(short,k-1)</SourceLine>
   <SourceLine>k=teams.indexof(short)</SourceLine>
   <SourceLine>conf=GetConference(k+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO PRI (Season, TeamNum, TeamName, PR, Conference) VALUES ('"+mCurrentSeason+"','"+str(k+1)+"','"+short+"','"+str(n)+"', '"+str(conf)+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+7</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
