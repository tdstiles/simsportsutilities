 <Method>
  <ItemName>ReturningPlayers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>196038655</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ReturningPlayers(CN as integer)</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim a as double</SourceLine>
   <SourceLine>dim n as integer</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim teaminfo(-1) as string</SourceLine>
   <SourceLine>redim mPctDouble(-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.connect then</SourceLine>
   <SourceLine>sqlstring="CREATE TABLE returning (TeamNum, PPG, RPG, MPG, srPPG, srRPG, srMPG, APG, SPG, srAPG, srSPG, TotalReturningPct)"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Sum(PPG*GM), Sum(RPG*GM), Sum(MPG*GM), Sum(APG*GM), Sum(Stl*GM) FROM Players WHERE Season='"+str(val(mCurrentSeason)-1)+"' GROUP BY TeamNum ORDER BY TeamNum ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="INSERT INTO returning (TeamNum, PPG, RPG, MPG, APG, SPG) VALUES ('"+rs.IdxField(1).StringValue+"','"+rs.IdxField(2).StringValue+"','"+rs.IdxField(3).StringValue+"','"+rs.IdxField(4).StringValue+"', '"+rs.IdxField(5).StringValue+"', '"+rs.IdxField(6).StringValue+"')"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Sum(PPG*GM), Sum(RPG*GM), Sum(MPG*GM), Sum(APG*GM), Sum(Stl*GM) FROM Players WHERE YR='Sr' AND Season='"+str(val(mCurrentSeason)-1)+"' GROUP BY TeamNum ORDER BY TeamNum ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="UPDATE returning SET srPPG='"+rs.IdxField(2).StringValue+"', srRPG='"+rs.IdxField(3).StringValue+"', srMPG='"+rs.IdxField(4).StringValue+"', srAPG='"+rs.idxfield(5).stringvalue+"', srSPG='"+rs.idxfield(6).stringvalue+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, PPG, RPG, MPG, srPPG, srRPG, srMPG, APG, srAPG, SPG, srSPG FROM returning"</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>a=3*(rs.IdxField(5).DoubleValue/rs.IdxField(2).DoubleValue)+2*(rs.IdxField(6).DoubleValue/rs.IdxField(3).DoubleValue)+(rs.IdxField(7).DoubleValue/rs.IdxField(4).DoubleValue)+2*(rs.IdxField(9).DoubleValue/rs.IdxField(8).DoubleValue)+(rs.IdxField(11).DoubleValue/rs.IdxField(10).DoubleValue)</SourceLine>
   <SourceLine>mPctDouble.append a/9</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
