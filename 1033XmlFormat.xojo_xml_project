  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ReturnString() As string</SourceLine>
   <SourceLine>//this method returns a team preview string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if  seed&lt;&gt;0 then</SourceLine>
   <SourceLine>fTourn=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>fTourn=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if ftourn then</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;("+str(seed)+") "+htmllink(TN, 2)+"&lt;/b&gt; ("+conffinish(TN, Tournament)+")"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;A look at "+HTMLLink(TN,5)+":&lt;/b&gt;"+""+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;RPI:&lt;/b&gt;  "+RPI+"  "+"    &lt;b&gt;SoS:  &lt;/b&gt;"+sos+"     &lt;b&gt;Streak:  &lt;/b&gt;"+streak+"  "+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;AvgPts:&lt;/b&gt;  "+AvgScore+"  &lt;b&gt;AvgPtsAllowed:&lt;/b&gt;  "+AvgScoreAllowed+""+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim returnstring(3) as string=VsTopOpponents</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Record vs. Top 10:&lt;/b&gt;  "+returnstring(0)+"   &lt;b&gt;Record vs. Top 25:&lt;/b&gt;  "+returnstring(1)+""+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Record vs. Top 50:&lt;/b&gt;  "+returnstring(2)+"    &lt;b&gt;Record vs. Top 100:&lt;/b&gt;  "+returnstring(3)+""+EndofLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fTourn then</SourceLine>
   <SourceLine>sbstring.append RecordvsTourneyOpps(Tournament, mTourneyDB)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim pace(1) as string=GetDefenseAndTempo</SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Style of Play:  &lt;/b&gt;"+pace(0)+"/"+pace(1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fTourn then</SourceLine>
   <SourceLine>dim sztmp(1) as string=TeamStrengthAndWeakness</SourceLine>
   <SourceLine>sbstring.append "   &lt;b&gt;Team Strength:  &lt;/b&gt;"+sztmp(0)+"   &lt;b&gt;Team Weakness:  &lt;/b&gt;"+sztmp(1)+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;b&gt;Player to watch:  &lt;/b&gt;"+GetMVP+""+EndofLine+EndOfLine+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
