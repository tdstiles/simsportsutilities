 </Method>
 <Method>
  <ItemName>PlayerPMCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>284805119</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PlayerPMCalc(height as integer, avgheight as double) As double</SourceLine>
   <SourceLine>dim pm as double</SourceLine>
   <SourceLine>dim heightmod as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>pm=pm+attrs(n,2)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//adjust for height differential</SourceLine>
   <SourceLine>heightmod=(((height/avgheight)-1)*2)+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>pm=pm*heightmod</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//additional height bonus for big men</SourceLine>
   <SourceLine>if height&gt;=72 then</SourceLine>
   <SourceLine>pm=pm+0.2</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return pm</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>height as integer, avgheight as double</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
