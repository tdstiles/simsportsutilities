 <Method>
  <ItemName>mthdParseTournamentTeams</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1251012607</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthdParseTournamentTeams()</SourceLine>
   <SourceLine>//http://www.smartacre.com/bask/weekly/lg00027/nt1a.html</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tourneys(3,1) as string</SourceLine>
   <SourceLine>tourneys(0,0)="nt1a"</SourceLine>
   <SourceLine>tourneys(0,1)="NTT"</SourceLine>
   <SourceLine>tourneys(1,0)="nt2a"</SourceLine>
   <SourceLine>tourneys(1,1)="PTT"</SourceLine>
   <SourceLine>tourneys(2,0)="nt3a"</SourceLine>
   <SourceLine>tourneys(2,1)="RTT"</SourceLine>
   <SourceLine>tourneys(3,0)="nt4a"</SourceLine>
   <SourceLine>tourneys(3,1)="DTT"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine>DBSQLExecute("DELETE FROM PostSeasonResults WHERE Season="+mCurrentSeason)</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/weekly/lg000"+right("0"+league,2)+"/"+tourneys(n,0)+".html"</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if result&lt;&gt;"" then</SourceLine>
   <SourceLine>result=CleanHTMLForSeeding(result)</SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine>mthdLoadTournamentInfo(lines, tourneys(n,1))</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "Error downloading.  Check your connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>DBSQLExecute("VACUUM")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>CleanHTMLForSeeding</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1888088063</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CleanHTMLForSeeding(this as string) As string</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim spattern(-1) as string</SourceLine>
   <SourceLine>dim replacementpattern(-1) as string</SourceLine>
   <SourceLine>dim j as string</SourceLine>
   <SourceLine>j=""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spattern.append "&lt;TR VALIGN=middle&gt;(.*)&lt;/tr&gt;"</SourceLine>
   <SourceLine>replacementpattern.append "\1"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spattern.append "&lt;HTML&gt;.* CELLPADDING=4&gt;"</SourceLine>
   <SourceLine>replacementpattern.append ""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spattern.append "&lt;td nowrap align=left valign=center rowspan=(.*)&gt;(.*)&lt;/td&gt;"</SourceLine>
   <SourceLine>replacementpattern.append "\1--\2"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spattern.append "&lt;.*&gt;"</SourceLine>
   <SourceLine>replacementpattern.append ""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spattern.append "\(.*\)"</SourceLine>
   <SourceLine>replacementpattern.append ""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iMax as integer=UBound(spattern)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>r.SearchPattern = spattern(n)</SourceLine>
   <SourceLine>r.ReplacementPattern = replacementpattern(n)</SourceLine>
   <SourceLine>this= trim(r.Replace(this))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>this=RemoveBlankLines(this)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return this</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>this as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mthdLoadTournamentInfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1335039999</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthdLoadTournamentInfo(lines() as string, Tourney as String)</SourceLine>
   <SourceLine>//we have an array with all the teams from the bracket in it</SourceLine>
   <SourceLine>//let's go through one at a time.  we can look at the rowsize (first number or two) to figure out the round</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if 1--&gt;made the tourney</SourceLine>
   <SourceLine>//2--&gt;round of 32</SourceLine>
   <SourceLine>//4--&gt;Sweet 16</SourceLine>
   <SourceLine>//8--&gt;Elite 8</SourceLine>
   <SourceLine>//16--&gt;Final 4</SourceLine>
   <SourceLine>//32--&gt;Championship</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//using structures, with TeamNum/LastRound.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tm as struTournamentTeams</SourceLine>
   <SourceLine>dim tms(-1) as struTournamentTeams</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iMax as integer=UBound(lines)</SourceLine>
   <SourceLine>dim activestring as string</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>tm.Region=""</SourceLine>
   <SourceLine>tm.seed=0</SourceLine>
   <SourceLine>activestring=lines(n)</SourceLine>
   <SourceLine>k=instr(activestring,"--")</SourceLine>
   <SourceLine>tm.LastRound=val(left(activestring,len(activestring)-k))</SourceLine>
   <SourceLine>if tm.LastRound=32 then</SourceLine>
   <SourceLine>//see if we have the champion</SourceLine>
   <SourceLine>j=instr(activestring, "Champion:")</SourceLine>
   <SourceLine>if j&gt;0 then</SourceLine>
   <SourceLine>//is the champion</SourceLine>
   <SourceLine>activestring=ReplaceAll(activestring,"Champion:","")</SourceLine>
   <SourceLine>tm.LastRound=48</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>activestring=trim(mid(activestring,k+2))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we just want the city name</SourceLine>
   <SourceLine>//try to remove team name, just get city name</SourceLine>
   <SourceLine>k=instr(activestring," ")</SourceLine>
   <SourceLine>if k&gt;0 then</SourceLine>
   <SourceLine>line=activestring</SourceLine>
   <SourceLine>activestring=left(activestring,k-1)</SourceLine>
   <SourceLine>j=teams.IndexOf(activestring)</SourceLine>
   <SourceLine>while j=-1 //only first part of name, need second half of city</SourceLine>
   <SourceLine>k=instr(k+1,line," ")</SourceLine>
   <SourceLine>if k=0 then</SourceLine>
   <SourceLine>activestring=line</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>activestring=left(line,k-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>j=teams.IndexOf(activestring)</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tm.TeamNumber=teams.IndexOf(activestring)+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if tm.LastRound=1 then</SourceLine>
   <SourceLine>//we'll set the seed and region for inclusion</SourceLine>
   <SourceLine>tm=mthSetSeedAndRegion(tm,n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now that we have tm ready, let's see if it's already part of the list</SourceLine>
   <SourceLine>dim r as integer=ubound(tms)</SourceLine>
   <SourceLine>dim found as Boolean=false</SourceLine>
   <SourceLine>for l as integer=0 to r</SourceLine>
   <SourceLine>if tm.TeamNumber=tms(l).TeamNumber then</SourceLine>
   <SourceLine>//correct team</SourceLine>
   <SourceLine>if tm.LastRound=1 then</SourceLine>
   <SourceLine>tms(l).seed=tm.seed</SourceLine>
   <SourceLine>tms(l).Region=tm.Region</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if tm.LastRound&gt;tms(l).LastRound then</SourceLine>
   <SourceLine>tms(l).LastRound=tm.LastRound</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>found=true</SourceLine>
   <SourceLine>exit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if found=false then</SourceLine>
   <SourceLine>//not loaded, so let's add it</SourceLine>
   <SourceLine>tms.append tm</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//all of these are loaded.  at this point, we can go ahead and update the database</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>iMax=ubound(tms)</SourceLine>
   <SourceLine>for n as integer=0 to imax</SourceLine>
   <SourceLine>sqlstring="INSERT INTO PostSeasonResults (Season, TeamNum, Tournament, Round, Region, Seed) VALUES ('"+mCurrentSeason+"', '"+str(tms(n).TeamNumber)+"', '"+Tourney+"', '"+str(tms(n).LastRound)+"', '"+tms(n).Region+"', '"+str(tms(n).Seed)+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>lines() as string, Tourney as String</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>mthdDetermineRound</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>264376319</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthdDetermineRound(num as integer) As string</SourceLine>
   <SourceLine>if num=1 then</SourceLine>
   <SourceLine>return "First Round"</SourceLine>
   <SourceLine>elseif num=2 then</SourceLine>
   <SourceLine>return "Round of 32"</SourceLine>
   <SourceLine>elseif num=4 then</SourceLine>
   <SourceLine>return "Sweet 16"</SourceLine>
   <SourceLine>elseif num=8 then</SourceLine>
   <SourceLine>return "Elite 8"</SourceLine>
   <SourceLine>elseif num=16 then</SourceLine>
   <SourceLine>return "Final Four"</SourceLine>
   <SourceLine>elseif num=32 then</SourceLine>
   <SourceLine>return "Runner-up"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return "Champion"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>num as integer</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mthGenerateNTTRecapText</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1605009407</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthGenerateNTTRecapText(XTT as String) As string</SourceLine>
   <SourceLine>//this method creates data for the wiki that includes the breakdown of teams and how far they made it.</SourceLine>
   <SourceLine>dim sbstring as StringBuilder</SourceLine>
   <SourceLine>sbstring=new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim regions(-1) as string=split("NW,NE,SW,SE", ",")</SourceLine>
   <SourceLine>dim TourneyGame as  cTourneyGame</SourceLine>
   <SourceLine>dim winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine>dim Rd2winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine>dim Rd3Winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine>dim Rd4Winners(-1) as cTourneyTeam</SourceLine>
   <SourceLine>dim TmpSeeds(1) as integer</SourceLine>
   <SourceLine>iTT=XTT</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "{{LeagueCompass|LID="+League+"|minS="+mCurrentSeason+"}}"+EndOfLine</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>//do this for each region</SourceLine>
   <SourceLine>redim winners(-1)</SourceLine>
   <SourceLine>redim Rd2winners(-1)</SourceLine>
   <SourceLine>redim Rd3Winners(-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append "&lt;h2&gt;"+regions(n)+" Bracket&lt;/h2&gt;"+EndOfLine</SourceLine>
   <SourceLine>sbstring.append "{{16TeamBracket"+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=1</SourceLine>
   <SourceLine>TmpSeeds(1)=16</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,1)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=8</SourceLine>
   <SourceLine>TmpSeeds(1)=9</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,3)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=5</SourceLine>
   <SourceLine>TmpSeeds(1)=12</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,5)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=4</SourceLine>
   <SourceLine>TmpSeeds(1)=13</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,7)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=3</SourceLine>
   <SourceLine>TmpSeeds(1)=14</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,9)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=6</SourceLine>
   <SourceLine>TmpSeeds(1)=11</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n),1, TmpSeeds,11)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=7</SourceLine>
   <SourceLine>TmpSeeds(1)=10</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,13)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TmpSeeds(0)=2</SourceLine>
   <SourceLine>TmpSeeds(1)=15</SourceLine>
   <SourceLine>TourneyGame=new cTourneyGame(regions(n), 1,TmpSeeds,15)</SourceLine>
   <SourceLine>sbstring.append TourneyGame.ReturnString</SourceLine>
   <SourceLine>winners.append TourneyGame.GetWinner</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we move to round 2</SourceLine>
   <SourceLine>for nn as integer=0 to 1</SourceLine>
   <SourceLine>TmpSeeds(nn)=winners(nn).mSeed</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
