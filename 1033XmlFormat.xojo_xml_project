   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>//this class is used to create an "on the bubble" report</SourceLine>
   <SourceLine>//we run it right before the conference championship games are played</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we have one array, autobids</SourceLine>
   <SourceLine>//then a second, teams that will get in (tentatively, PR&lt;43, so should be in even with a loss)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//the last team in via PR is labeled the "cutoff" integer.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//1-seeds outside of top 63 put a dent in the bubble and push the mCutOff -1</SourceLine>
   <SourceLine>//then look at conf tourney final</SourceLine>
   <SourceLine>//if both outside mCutOff, then mCutOff-1</SourceLine>
   <SourceLine>//if both inside mCutOff, then no dent in double</SourceLine>
   <SourceLine>//if one out, then mark as possible</SourceLine>
   <SourceLine>//then use ELO to estimate additional hits to the bubble.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//bubble is anyone +/- 9 PR from final who isn't already in.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then we run a report with teams on the bubble projected IN and OUT</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
