 </Method>
 <Method>
  <ItemName>RemoveSpacesFromName</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1531871231</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function RemoveSpacesFromName(name as string) As string</SourceLine>
   <SourceLine>dim k, r as integer</SourceLine>
   <SourceLine>dim first, last as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>k=1</SourceLine>
   <SourceLine>r=len(name)</SourceLine>
   <SourceLine>for n as integer=1 to r</SourceLine>
   <SourceLine>if mid(name,k,1)=" " then</SourceLine>
   <SourceLine>first=left(name,k-1)</SourceLine>
   <SourceLine>last=mid(name,k+1)</SourceLine>
   <SourceLine>name=first+last</SourceLine>
   <SourceLine>k=k-1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>k=k+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return name</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>name as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>CreditsAwarded</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1385369599</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreditsAwarded()</SourceLine>
   <SourceLine>dim rs, ars,brs as recordset</SourceLine>
   <SourceLine>dim season as string</SourceLine>
   <SourceLine>dim awardstring as string</SourceLine>
   <SourceLine>dim firstlevelpts, ptdifferential as double</SourceLine>
   <SourceLine>dim owinscore as double</SourceLine>
   <SourceLine>dim x as string</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim pos(4) as string</SourceLine>
   <SourceLine>dim tablecolumns(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>pos(0)="PG"</SourceLine>
   <SourceLine>pos(1)="SG"</SourceLine>
   <SourceLine>pos(2)="SF"</SourceLine>
   <SourceLine>pos(3)="PF"</SourceLine>
   <SourceLine>pos(4)="C"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("CREATE TABLE PreNTT (TeamNum integer, FirstLevelPts integer)")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Max(Season) FROM PreNTT")</SourceLine>
   <SourceLine>season=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Distinct(TeamNum) FROM PreNTT WHERE Season='"+season+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>x=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>firstlevelpts=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT OppNum, OurScore-OppScore FROM PreNTT WHERE Season='"+season+"' AND TeamNum='"+x+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(ars) then</SourceLine>
   <SourceLine>while ars.eof=false</SourceLine>
   <SourceLine>ptdifferential=ars.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>if ptdifferential&gt;0 then //won</SourceLine>
   <SourceLine>ptdifferential=10+ptdifferential/4</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM PreNTT WHERE Season='"+season+"' AND WL='W' AND TeamNum='"+ars.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>owinscore=brs.IdxField(1).IntegerValue+3</SourceLine>
   <SourceLine>firstlevelpts=firstlevelpts+(ptdifferential*owinscore)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//lost</SourceLine>
   <SourceLine>ptdifferential=4+ptdifferential/4</SourceLine>
   <SourceLine>if ptdifferential&lt;=0 then</SourceLine>
   <SourceLine>ptdifferential=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM PreNTT WHERE Season='"+season+"' AND WL='W' AND TeamNum='"+ars.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>owinscore=brs.IdxField(1).IntegerValue+1</SourceLine>
   <SourceLine>firstlevelpts=firstlevelpts+(ptdifferential*owinscore)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>ars.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM PreNTT WHERE Season='"+season+"' AND WL='W' AND TeamNum='"+x+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(brs) then</SourceLine>
   <SourceLine>owinscore=brs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>owinscore=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>firstlevelpts=firstlevelpts*(owinscore+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO PreNTT (TeamNum, FirstLevelPts) VALUES ('"+x+"', '"+str(firstlevelpts)+"')"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>inmemdb.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tablecolumns=split("Finish,Team,Pts", ",")</SourceLine>
   <SourceLine>awardstring=TableGeneratorTitle("L"+league+"  PreSeason NTT", tablecolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>i=1</SourceLine>
   <SourceLine>dim columnstring(-1) as string</SourceLine>
   <SourceLine>//now prepare award string</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT TeamNum, FirstLevelPts FROM PreNTT ORDER BY FirstLevelPts DESC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>columnstring=split(str(i)+".,"+htmllink(rs.IdxField(1).IntegerValue)+","+format(rs.IdxField(2).DoubleValue, "####"), ",")</SourceLine>
   <SourceLine>awardstring=awardstring+ColumnGenerator(i,columnstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>awardstring=awardstring+CloseTable+"&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>awardstring=awardstring+BloggerEndofLine</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, AVG(OurScore) as A FROM PreNTT WHERE Season='"+season+"' GROUP BY TeamNum ORDER BY A DESC")</SourceLine>
   <SourceLine>awardstring=awardstring+"&lt;b&gt;Best scoring offense:&lt;/b&gt; "+htmllink(rs.IdxField(1).integerValue)+" ("+format(rs.IdxField(2).doubleValue, "###.0")+")&lt;br&gt;"+endofline</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, AVG(OppScore) as A FROM PreNTT WHERE Season='"+season+"' GROUP BY TeamNum ORDER BY A ASC")</SourceLine>
   <SourceLine>awardstring=awardstring+"&lt;b&gt;Best scoring defense:&lt;/b&gt; "+htmllink(rs.IdxField(1).integerValue)+" ("+format(rs.IdxField(2).doubleValue, "###.0")+")&lt;br&gt;"+endofline</SourceLine>
   <SourceLine>awardstring=awardstring+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get 1st team, 2nd team, MVP</SourceLine>
   <SourceLine>tablecolumns=split("Pos,Name,Team,PPG,RPG,APG,SPG,BPG,FG%,3%,FT%", ",")</SourceLine>
   <SourceLine>awardstring=awardstring+TableGeneratorTitle("Tourney MVP",tablecolumns)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//MVP</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Name, avg(pts), avg(reb), avg(ast), avg(stl), avg(blk), (avg(fgm)/avg(fga)), (avg(fg3m)/avg(fg3a)), (avg(ftm)/avg(fta)), teamnum, aposition, ((2*sum(fgm))+(1.2*sum(ftm))+(1.6*sum(fg3m))+(0.9*sum(reb))+(1.5*sum(ast))+(3*sum(stl))+(2*sum(blk))-(sum(fga)-sum(fgm))-(sum(fta)-sum(ftm))-(1.5*sum(tos))-(0.4*sum(fouls))) as A FROM Stats WHERE Season='"+season+"' GROUP BY Name ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>dim abstring as string</SourceLine>
   <SourceLine>abstring=""</SourceLine>
   <SourceLine>for j as integer=3 to 7</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>for j as integer=8 to 10</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>columnstring=split(rs.idxfield(12).stringvalue+","+rs.IdxField(2).StringValue+","+htmllink(rs.idxfield(11).integervalue)+abstring, ",")</SourceLine>
   <SourceLine>awardstring=awardstring+ColumnGenerator(0,columnstring)</SourceLine>
   <SourceLine>awardstring=awardstring+CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tablecolumns=split("Pos,Name,Team,PPG,RPG,APG,SPG,BPG,FG%,3%,FT%", ",")</SourceLine>
   <SourceLine>awardstring=awardstring+TableGeneratorTitle("Tourney 1st Team",tablecolumns)</SourceLine>
   <SourceLine>//1st team</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Name, avg(pts), avg(reb), avg(ast), avg(stl), avg(blk), (avg(fgm)/avg(fga)), (avg(fg3m)/avg(fg3a)), (avg(ftm)/avg(fta)), teamnum, ((2*sum(fgm))+(1.2*sum(ftm))+(1.6*sum(fg3m))+(0.9*sum(reb))+(1.5*sum(ast))+(3*sum(stl))+(2*sum(blk))-(sum(fga)-sum(fgm))-(sum(fta)-sum(ftm))-(1.5*sum(tos))-(0.4*sum(fouls))) as A FROM Stats WHERE Season='"+season+"' AND APosition LIKE '%"+pos(n)+"' GROUP BY Name ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>abstring=""</SourceLine>
   <SourceLine>for j as integer=3 to 7</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>for j as integer=8 to 10</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>columnstring=split(pos(n)+","+rs.IdxField(2).StringValue+","+htmllink(rs.idxfield(11).integervalue)+abstring, ",")</SourceLine>
   <SourceLine>awardstring=awardstring+ColumnGenerator(n,columnstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>awardstring=awardstring+CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tablecolumns=split("Pos,Name,Team,PPG,RPG,APG,SPG,BPG,FG%,3%,FT%", ",")</SourceLine>
   <SourceLine>awardstring=awardstring+TableGeneratorTitle("Tourney 2nd Team",tablecolumns)</SourceLine>
   <SourceLine>//2nd team</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Name, avg(pts), avg(reb), avg(ast), avg(stl), avg(blk), (avg(fgm)/avg(fga)), (avg(fg3m)/avg(fg3a)), (avg(ftm)/avg(fta)), teamnum, ((2*sum(fgm))+(1.2*sum(ftm))+(1.6*sum(fg3m))+(0.9*sum(reb))+(1.5*sum(ast))+(3*sum(stl))+(2*sum(blk))-(sum(fga)-sum(fgm))-(sum(fta)-sum(ftm))-(1.5*sum(tos))-(0.4*sum(fouls))) as A FROM Stats WHERE Season='"+season+"' AND APosition LIKE '%"+pos(n)+"' GROUP BY Name ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>abstring=""</SourceLine>
   <SourceLine>for j as integer=3 to 7</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "#0.0")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>for j as integer=8 to 10</SourceLine>
   <SourceLine>abstring=abstring+","+format(rs.IdxField(j).DoubleValue, "##0.0%")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>columnstring=split(pos(n)+","+rs.IdxField(2).StringValue+","+htmllink(rs.idxfield(11).integervalue)+abstring, ",")</SourceLine>
   <SourceLine>awardstring=awardstring+ColumnGenerator(n,columnstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>awardstring=awardstring+CloseTable</SourceLine>
   <SourceLine>awardstring=awardstring+AddFooter</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PostResults(awardstring)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
