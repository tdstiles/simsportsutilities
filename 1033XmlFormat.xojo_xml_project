  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthdConferenceStandingsFromPreviousYear(confnum as string) As struConfrecords()</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim k(-1) as struConfRecords</SourceLine>
   <SourceLine>dim nk as struConfRecords</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mCurrentSeason=str(val(mCurrentSeason)-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'sqlstring="SELECT Distinct(PRI.TeamNum), Sum(Games.WL='W')/4, Sum(Games.WL='L')/4 FROM Games LEFT JOIN PRI ON Pri.TeamNum=Games.TeamNum LEFT JOIN PRI as Opp ON Opp.TeamNum=Games.OpponentNum WHERE PRI.Conference=Opp.Conference AND PRI.Conference="+confnum+" AND Games.GameNum&lt;16 AND Games.Season="+mCurrentSeason+" GROUP BY PRI.TeamNum"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 8</SourceLine>
   <SourceLine>//for each team, get record</SourceLine>
   <SourceLine>dim tn as integer</SourceLine>
   <SourceLine>tn=(val(confnum)-1)*8+n</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Games.WL='W'), Sum(Games.WL='L') FROM Games, PRI WHERE Games.TeamNum='"+str(TN)+"' AND Games.Season='"+mCurrentSeason+"' AND Games.OpponentNum=PRI.TeamNum AND PRI.Season='"+mCurrentSeason+"' AND PRI.Conference='"+confnum+"' AND Games.GameNum&gt;3 AND Games.GameNum&lt;'16'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>nk.TeamNum=tn</SourceLine>
   <SourceLine>a="("+format(rs.IdxField(1).IntegerValue, "#0")+"-"+format(rs.IdxField(2).IntegerValue, "#0")+")"</SourceLine>
   <SourceLine>nk.wl=a</SourceLine>
   <SourceLine>k.Append nk</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>mCurrentSeason=str(val(mCurrentSeason)+1)</SourceLine>
   <SourceLine>return k</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
