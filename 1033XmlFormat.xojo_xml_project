 <Method>
  <ItemName>FindLastGame</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1437194239</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function FindLastGame() As string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim lastmeeting as string</SourceLine>
   <SourceLine>dim b as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT OurScore, OppScore, WL, GameNum FROM Games WHERE Games.Season='"+mCurrentSeason+"' AND TeamNum='"+str(mTeamNumbers(0))+"' AND OpponentNum='"+str(mTeamNumbers(1))+"' AND GameNum&lt;'"+str(mTeamNumbers(2))+"' ORDER BY GameNum DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>if rs.IdxField(3).StringValue="W" then</SourceLine>
   <SourceLine>b=teams(mTeamNumbers(0)-1)+" over "+teams(mTeamNumbers(1)-1)+" "+rs.IdxField(1).StringValue+"-"+rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>b=teams(mTeamNumbers(1)-1)+" over "+teams(mTeamNumbers(0)-1)+" "+rs.IdxField(2).StringValue+"-"+rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>lastmeeting="&lt;b&gt;Last Meeting:&lt;/b&gt;  Game #"+rs.IdxField(4).StringValue+" "+b+"&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return lastmeeting</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
