  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>GetConfPOTW</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1371621375</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetConfPOTW() As goTWRecapPlayers</SourceLine>
   <SourceLine>//POTW(-1) is an array of POTW.  Whichever has the highest nbs is our POTW</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim POG as new GOTWRecapPlayers</SourceLine>
   <SourceLine>POG=POTW(0)</SourceLine>
   <SourceLine>for n as integer=1 to UBound(POTW)</SourceLine>
   <SourceLine>if potw(n).NBS&gt;POG.NBS then</SourceLine>
   <SourceLine>POG=Potw(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return POG</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
