 <Method>
  <ItemName>LoadDatabase</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2100580351</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadDatabase()</SourceLine>
   <SourceLine>Dim file as FolderItem</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fAlreadyOpened then</SourceLine>
   <SourceLine>file=mAlreadyOpenedFile</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>Dim dlg as OpenDialog</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dlg=New OpenDialog</SourceLine>
   <SourceLine>dlg.InitialDirectory =GetFolderItem("")</SourceLine>
   <SourceLine>dlg.Title = "Select an XDB file"</SourceLine>
   <SourceLine>dlg.Filter = "XDB" // file type defined in File Types dialog</SourceLine>
   <SourceLine>file = dlg.ShowModal()</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if file&lt;&gt;nil and file.exists then</SourceLine>
   <SourceLine>dim db as new REALSQLDatabase</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>DBName=file.name</SourceLine>
   <SourceLine>DBPath=file.AbsolutePath</SourceLine>
   <SourceLine>DB.databasefile=file</SourceLine>
   <SourceLine>SDB=file</SourceLine>
   <SourceLine>if DBConnect then</SourceLine>
   <SourceLine>wndMain.loadleagueinfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check databaseschema</SourceLine>
   <SourceLine>checkdbschema</SourceLine>
   <SourceLine>dbsqlexecute "vacuum"</SourceLine>
   <SourceLine>XDBLoaded=TRUE</SourceLine>
   <SourceLine>wndmain.showfield.text=""</SourceLine>
   <SourceLine>wndMain.showfield.Refresh</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
