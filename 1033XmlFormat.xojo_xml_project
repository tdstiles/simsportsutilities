<block type="Module" ID="1085546495">
 <ObjName>cNullScolly</ObjName>
 <ObjContainerID>1987360767</ObjContainerID>
 <IsClass>1</IsClass>
 <ItemFlags>1</ItemFlags>
 <IsInterface>0</IsInterface>
 <Compatibility></Compatibility>
 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1557182463</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor()</SourceLine>
   <SourceLine>//this method calculates the Null-Scolly measure of competitive balance</SourceLine>
   <SourceLine>//http://wagesofwins.com/noll-scully/</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//First, calculate Idealized Standard Deviation</SourceLine>
   <SourceLine>//Idealized Std. Deviation = [Average wins]/[Schedule Length]^0.5</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iIdealizedSTD as integer=12/24^0.5</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Second, we have to find the actula standard deviation for wins</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim iTeamWins(-1) as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(WL='W') FROM Games WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>iTeamWins.append rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now figure the STD for wins</SourceLine>
   <SourceLine>dim iCounter as double</SourceLine>
   <SourceLine>dim iMax as integer=ubound(iTeamWins)</SourceLine>
   <SourceLine>for r as integer=0 to iMax</SourceLine>
   <SourceLine>iCounter=iCounter+iTeamWins(r)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim mean as double</SourceLine>
   <SourceLine>mean=iCounter/iMax</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now for the StD</SourceLine>
   <SourceLine>//Std=SQRT(1/N*Value1-Mean^2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>icounter=0</SourceLine>
   <SourceLine>for r as integer=0 to iMax</SourceLine>
   <SourceLine>iCounter=iCounter+(iTeamWins(r)-mean)^2</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iCounter=iCounter/iMax</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim StD as double</SourceLine>
   <SourceLine>StD=SQRT(ICounter)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iNS=StD/iIdealizedSTD</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
