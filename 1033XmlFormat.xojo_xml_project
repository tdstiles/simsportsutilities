   <SourceLine>Sub CreateNewDB()</SourceLine>
   <SourceLine>Dim f As FolderItem</SourceLine>
   <SourceLine>Dim sqlArray(-1),sqlString As String</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>myProgressBar1.maximum=100</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PRI (rowID INTEGER PRIMARY KEY autoincrement, Season integer, TeamNum integer, TeamName text, fPR integer, PR integer, RecruitSH integer, RecruitHW integer, WL integer, Last5WL integer, Coach text, CoachRating real, Conference integer, RPI double, elo double, KMoneyAve double, ConfFinish integer, SoS double, AdjustedELO double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Games (rowID INTEGER PRIMARY KEY autoincrement, Season integer, TeamNum integer, GameNum integer, OpponentNum Integer, OurScore integer, OppScore integer, WL varchar, Pace varchar, Defense varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Variables(ID varchar, Value varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PreNTT (rowID INTEGER PRIMARY KEY autoincrement, TeamNum integer, GameNum integer, OppNum integer, OurScore integer, OppScore integer, WL varchar, Season integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Stats (rowID INTEGER PRIMARY KEY autoincrement, Name varchar, Season Integer, TeamNum Integer,GameNum Integer, APosition varchar, FGM Integer, FGA Integer, FTM Integer, FTA Integer, FG3M Integer, FG3A Integer, Reb Integer, Ast Integer, Blk Integer, Stl Integer, TOs Integer, Fouls Integer, Pts Integer, Mins Integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX NameIndex on Stats(Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX TeamNumIndex on Games(TeamNum)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX PreNTTIndex on PreNTT(TeamNum)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PreNTTSchedule (rowID INTEGER PRIMARY KEY autoincrement, TeamNum integer, Season integer, Gm1 integer, Gm2 integer, Gm3 integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE Players (rowID INTEGER PRIMARY KEY autoincrement, Season integer, TeamNum integer, Pos varchar, Player varchar, HT varchar, YR varchar, GM integer, MPG integer, PPG double, RPG double, APG double, FGM double, FGA double, FG3M double, FG3A double, FTM double, FTA double, STL double, TOS double, BLK double, tendex double, WinsProduced double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX PlayersIndex on Players (TeamNum)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PostSeasonResults (rowID INTEGER PRIMARY KEY autoincrement, TeamNum integer, Season integer, Tournament varchar, Round varchar, Region varchar, Seed integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PreNTTPts (rowID INTEGER PRIMARY KEY autoincrement, TeamNum integer, Season integer, FirstLevelPts)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE VoteResults (rowID INTEGER PRIMARY KEY autoincrement, TeamNum integer, Season integer, Pollnum integer, Points integer, FirstPlace integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE TempVoteResults (rowID INTEGER PRIMARY KEY autoincrement, coachname varchar, teamnum integer, points integer, season integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE HSInfo (rowID INTEGER PRIMARY KEY autoincrement, Season integer, HSName varchar, Region integer, HSSHT varchar, HSDEF varchar, HSHND varchar, HSREB varchar, HSATH varchar, SumHS varchar, ThisWL Varchar, LastWL Varchar, Avgheight varchar, Powerranking integer, Ranking varchar, HSSOS double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PlayerInfo (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Name varchar, Region integer, HSName varchar, Height double, gpa varchar, test varchar, pos varchar, scout integer, sht integer, def integer, hnd integer, reb integer, ath integer, local integer, win integer, impact integer, ppg double, rpg double, apg double, spg double, tpg double, bpg double,  Tendex double, HSSOS double, NormTendex double, OppRatingPct double, StatPct double, AttPct double, FitPct double, MyRating double, MyRatingPct double, PlusMinusPct double, MyPosition varchar, estimatedattributes varchar, playerplusminus double , mratingpct double, t75rnk integer, Type varchar, RP integer, Maxt75rnk integer, StdDevPct double, BobbyRating double, BobbyRatingRank double, StdDevPctRank double, PlayerPlusMinusRank double, mratingpctrank double, BTPct double, BTPctRank double, BTAltPct double, BTAltPctRank double, PFPct double, PFPctRank double, MyRatingPctRank double)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE HSStats (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Game integer, Name varchar, HSName varchar, Pts integer, Reb integer, Ast integer, Stl integer, Blk integer, TOs integer, SOG varchar)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX PInfo on PlayerInfo (Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX HInfo on HSStats (Name)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE PollResults (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Game integer, TeamNum integer, Rank Integer)"</SourceLine>
   <SourceLine>sqlArray.append "CREATE TABLE  AllConfInfo (Season integer, TeamNum integer, PlayerName varchar, Score integer) "</SourceLine>
   <SourceLine>sqlArray.append "CREATE INDEX TInfo on AllConfInfo (TeamNum)"</SourceLine>
   <SourceLine>sqlarray.append "CREATE TABLE Tourney_Teams (rowID INTEGER PRIMARY KEY, TeamNum integer, Tourney varchar, StillAlive Boolean, Season integer)"</SourceLine>
   <SourceLine>sqlarray.append "CREATE TABLE Tourney_Stats (Season Integer, GameNum, TeamNum, PlayerName, Pos, FGM, FGA, FG3M, FG3A, FTM, FTA, REB, AST, BLK, STL, TOs, PFs, Pts)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f = New FolderItem(DBPath)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Create Database Object</SourceLine>
   <SourceLine>DB = New RealSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>// Set the Database File</SourceLine>
   <SourceLine>DB.DatabaseFile = f</SourceLine>
   <SourceLine>SDB = f</SourceLine>
   <SourceLine>DBName = f.name</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If DB.CreateDatabaseFile Then</SourceLine>
   <SourceLine>// Add Tables to the Database</SourceLine>
   <SourceLine>dim iCounter as integer=ubound(sqlArray)</SourceLine>
   <SourceLine>For i as integer= 0 To iCounter</SourceLine>
   <SourceLine>sqlString = sqlArray(i)</SourceLine>
   <SourceLine>dbsqlexecute(sqlString)</SourceLine>
   <SourceLine>myProgressBar1.Update(100/iCounter)</SourceLine>
   <SourceLine>Next</SourceLine>
   <SourceLine>DB.Commit</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>wndMain.title="League Commissioner "</SourceLine>
   <SourceLine>wndNewDB.Close</SourceLine>
   <SourceLine>End Sub</SourceLine>
