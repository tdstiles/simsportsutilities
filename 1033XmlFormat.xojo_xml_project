 </Method>
 <Method>
  <ItemName>PickGOTW</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1924732927</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PickGOTW()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim missedteams(-1) as integer</SourceLine>
   <SourceLine>dim missed as Boolean</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>GamesPlayed=val(wndMain.agamesplayed.text)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mGameCheckDB=new REALSQLDatabase</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mGameCheckDB.Connect then</SourceLine>
   <SourceLine>mGameCheckDB.SQLExecute("CREATE TABLE Games(Tm1 integer, Tm2 integer, GmScore double, GameNum integer)")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>missed=LoadTeamGamesB(n)</SourceLine>
   <SourceLine>if missed then</SourceLine>
   <SourceLine>missedteams.append(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while UBound(missedteams)&gt;-1</SourceLine>
   <SourceLine>missed=LoadTeamGamesB(missedteams(0))</SourceLine>
   <SourceLine>if missed=false then</SourceLine>
   <SourceLine>missedteams.Remove(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//time to parse mGameCheckDB to find best game</SourceLine>
   <SourceLine>rs=mGameCheckDB.SQLSelect("SELECT Tm1, Tm2, GameNum FROM Games ORDER BY GmScore DESC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mTeamNumbers(0)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>mTeamNumbers(1)=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>mTeamNumbers(2)=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
