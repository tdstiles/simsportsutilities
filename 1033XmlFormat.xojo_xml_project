 <Method>
  <ItemName>AdjustELO</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>513148927</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AdjustELO()</SourceLine>
   <SourceLine>//this method starts at 100 for the top team, and adjusts everyone else downward</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim prevelo, currentelo as double</SourceLine>
   <SourceLine>dim gp as double</SourceLine>
   <SourceLine>dim adjelo as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's check to see if column exists</SourceLine>
   <SourceLine>rs= db.SQLSelect("select * from PRI Limit 0")</SourceLine>
   <SourceLine>if rs &lt;&gt; nil then</SourceLine>
   <SourceLine>if rs.Field("AdjustedELO") = nil then</SourceLine>
   <SourceLine>//need to add in column</SourceLine>
   <SourceLine>DBSQLExecute("ALTER TABLE PRI ADD COLUMN adjustedelo double")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT TeamNum, ELO FROM PRI ORDER BY ELO DESC")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>//set the first team to 100</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE PRI SET AdjustedELO='100' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>prevelo=rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>adjelo=100</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>do until rs.EOF</SourceLine>
   <SourceLine>currentelo=rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>'1/(1+10^((Rb-Ra)/prefPredictionK))</SourceLine>
   <SourceLine>gp=1/(1+10^((currentelo-prevelo)/400))</SourceLine>
   <SourceLine>gp=9*(LOG(1-gp)/log(0.5))-9</SourceLine>
   <SourceLine>adjelo=adjelo-gp</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE PRI SET AdjustedELO='"+str(adjelo)+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>prevelo=rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>loop</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
