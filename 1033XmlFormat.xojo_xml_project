 <Method>
  <ItemName>CalcTop25</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1123112959</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalcTop25()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim ars as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim pollnum as string</SourceLine>
   <SourceLine>dim season as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Max(PollNum) FROM VoteResults WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil then</SourceLine>
   <SourceLine>pollnum=str(rs.IdxField(1).IntegerValue+1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>pollnum="1"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Distinct(TeamNum) FROM TempVoteResults")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(points), (SELECT Count(*) FROM TempVoteResults WHERE points='25' AND TeamNum='"+rs.idxfield(1).stringvalue+"'), season FROM TempVoteResults WHERE TeamNum='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(ars) then</SourceLine>
   <SourceLine>sqlstring="INSERT INTO VoteResults (TeamNum, Season, Points, FirstPlace, Pollnum) VALUES ('"+rs.IdxField(1).StringValue+"', '"+ars.idxfield(3).stringvalue+"', '"+ars.IdxField(1).StringValue+"', '"+ars.IdxField(2).StringValue+"', '"+pollnum+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>HST25</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>929200127</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function HST25() As string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim showstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim columninfo(-1) as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo=split("Rank,Team,Region,Record", ",")</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle("High School Top 25 for League "+League+" (after game "+str(GamesPlayed+3)+")", columninfo)</SourceLine>
   <SourceLine>sqlstring="SELECT HSName, Region, ThisWL FROM HSInfo WHERE Season='"+mCurrentSeason+"' ORDER BY PowerRanking DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>for n as integer=1 to 25</SourceLine>
   <SourceLine>columninfo=split(str(n)+".,"+rs.IdxField(1).StringValue+","+rs.IdxField(2).StringValue+","+rs.IdxField(3).StringValue, ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n, columninfo)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now add in others receiving votes</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;Other teams receiving votes:&lt;/i&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>for n as integer=1 to 9</SourceLine>
   <SourceLine>sbstring.append rs.IdxField(1).stringValue+", "</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>COLLT25</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1557170175</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function COLLT25() As string</SourceLine>
   <SourceLine>dim rs, crs as RecordSet</SourceLine>
   <SourceLine>dim showstring as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim c as string</SourceLine>
   <SourceLine>dim columninfo(-1) as string</SourceLine>
   <SourceLine>dim nLastRank as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//clear out old results</SourceLine>
   <SourceLine>dbsqlexecute("DELETE FROM PollResults WHERE Season="+mCurrentSeason+" AND Game="+str(GamesPlayed))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get game number from previous poll results</SourceLine>
   <SourceLine>sqlstring="SELECT Max(Game) FROM PollResults WHERE Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>dim nMaxSeason as integer</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>nMaxSeason=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//load up array</SourceLine>
   <SourceLine>columninfo=split("Rank,Team,Record, PrvRnk", ",")</SourceLine>
   <SourceLine>sbstring.append  tablegeneratortitle("SimSportsNews Top 25 Power Rankings for League "+League+" (after game "+str(GamesPlayed)+")", columninfo)</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum FROM PRI WHERE Season='"+mCurrentSeason+"' ORDER BY fPR ASC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>for n as integer=1 to 25</SourceLine>
   <SourceLine>crs=dbsqlselect("SELECT Sum(WL='W'), Sum(WL='L') FROM Games WHERE TeamNum='"+rs.idxfield(1).stringvalue+"' AND Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if IfRSGood(crs) then</SourceLine>
   <SourceLine>c=crs.IdxField(1).StringValue+"-"+crs.IdxField(2).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if nMaxSeason&gt;0 then</SourceLine>
   <SourceLine>crs=dbsqlselect("SELECT Rank FROM PollResults WHERE Season='"+mCurrentSeason+"' AND Game='"+str(nMaxSeason)+"' AND TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>if IfRSGood(crs) then</SourceLine>
   <SourceLine>if crs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>nLastRank=format(crs.IdxField(1).IntegerValue, "#0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>nLastRank="--"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>nLastRank="--"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo=split(str(n)+".*"+htmllink(rs.IdxField(1).integerValue,7)+"*"+c+"*"+nLastRank, "*")</SourceLine>
   <SourceLine>sbstring.append  ColumnGenerator(n, columninfo)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//put information into pollresults</SourceLine>
   <SourceLine>sqlstring="INSERT INTO PollResults (Season, Game, TeamNum, Rank) Values ('"+mCurrentSeason+"', '"+str(GamesPlayed)+"', '"+rs.IdxField(1).StringValue+"', '"+str(n)+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next </SourceLine>
   <SourceLine>sbstring.append  CloseTable</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now add in others receiving votes</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;Other teams receiving votes:  &lt;/i&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>for n as integer=1 to 9</SourceLine>
   <SourceLine>sbstring.append htmllink(rs.idxfield(1).integervalue,3)+", "</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append HTMLLink(rs.IdxField(1).IntegerValue,3)</SourceLine>
   <SourceLine>sbstring.append "&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim previousranks(24,1) as integer</SourceLine>
   <SourceLine>dim iMax as Integer=0</SourceLine>
   <SourceLine>//now get a list of the teams that have dropped out</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, Rank FROM PollResults WHERE Season="+mCurrentSeason+" AND Game="+str(nMaxSeason)+" ORDER BY Rank ASC")</SourceLine>
   <SourceLine>//this is all the old teams</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>previousranks(iMax,0)=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>previousranks(iMax,1)=rs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>iMax=iMax+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if nMaxSeason&gt;0 then</SourceLine>
   <SourceLine>dim droppedranks(-1) as string</SourceLine>
   <SourceLine>//now that we have a long list of these teams from the old system, let's look up each one and see if they've dropped</SourceLine>
   <SourceLine>for n as integer=0 to 24</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum FROM PollResults WHERE Season="+mCurrentSeason+" AND Game="+str(GamesPlayed)+" AND TeamNum="+str(previousranks(n,0))</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>//it's in there, so nothing</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//not in there, so this guy has dropped</SourceLine>
   <SourceLine>droppedranks.append htmllink(previousranks(n,0),7)+" ("+str(previousranks(n,1))+")"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim iShort as integer=ubound(droppedranks)-1</SourceLine>
   <SourceLine>if iShort&gt;-1 then</SourceLine>
   <SourceLine>sbstring.append "&lt;i&gt;Teams dropped from the rankings&lt;/i&gt;:  "+BloggerEndofLine</SourceLine>
   <SourceLine>for n as integer=0 to iShort</SourceLine>
   <SourceLine>sbstring.append droppedranks(n)+", "</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append droppedranks(iShort+1)+"&lt;br&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>sbstring.append  AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
