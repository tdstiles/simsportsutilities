   <SourceLine>Sub LoadListBoxes(list as listbox)</SourceLine>
   <SourceLine>dim rs, ars as recordset</SourceLine>
   <SourceLine>dim previousrnk as string</SourceLine>
   <SourceLine>dim haspreviousrnk as boolean</SourceLine>
   <SourceLine>dim season, pollnum as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
