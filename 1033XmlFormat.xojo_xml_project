 <Method>
  <ItemName>SSBCMCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1054474239</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SSBCMCalc()</SourceLine>
   <SourceLine>//this method generates the top prospects list</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim height as string</SourceLine>
   <SourceLine>dim feet, inches as integer</SourceLine>
   <SourceLine>dim hsinfo as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim columninfo(-1) as string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim StarString as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//how many players are we gettin?</SourceLine>
   <SourceLine>dim PlayersToPull as integer=val(popRecruitNumber.Text)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this puts the players in order by SSC% for star purposes</SourceLine>
   <SourceLine>dim StarArray() as string</SourceLine>
   <SourceLine>StarArray=SetStarArray</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//in what order are we ranking them?</SourceLine>
   <SourceLine>dim StatOrder as string</SourceLine>
   <SourceLine>'MyRating double, MyRatingPct double, PlusMinusPct double, MyPosition varchar, estimatedattributes varchar, playerplusminus double , mratingpct double, t75rnk integer)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'me.addrow "SSC%"</SourceLine>
   <SourceLine>'me.addrow "Player +/-"</SourceLine>
   <SourceLine>'me.addrow "StdDev%"</SourceLine>
   <SourceLine>'me.addrow "MyRating"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim fPlusMinus as boolean</SourceLine>
   <SourceLine>dim fStdDev as boolean</SourceLine>
   <SourceLine>dim position as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if popPosition.ListIndex=0 then</SourceLine>
   <SourceLine>//everyone</SourceLine>
   <SourceLine>position=" "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif popPosition.ListIndex=1 then</SourceLine>
   <SourceLine>//pg</SourceLine>
   <SourceLine>position=" AND Pos='PG' "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif popPosition.ListIndex=2 then</SourceLine>
   <SourceLine>//sg</SourceLine>
   <SourceLine>position=" AND Pos='SG' "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif popPosition.ListIndex=3 then</SourceLine>
   <SourceLine>//sf</SourceLine>
   <SourceLine>position=" AND Pos='SF' "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif popPosition.ListIndex=4 then</SourceLine>
   <SourceLine>//pf</SourceLine>
   <SourceLine>position=" AND Pos='PF' "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//c</SourceLine>
   <SourceLine>position=" AND Pos='C' "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine> if popSortBy.ListIndex=0 then</SourceLine>
   <SourceLine>StatOrder="mRatingPct"</SourceLine>
   <SourceLine>elseif popSortBy.ListIndex=1 then</SourceLine>
   <SourceLine>StatOrder="playerplusminus"</SourceLine>
   <SourceLine>fPlusMinus=true</SourceLine>
   <SourceLine>elseif popSortBy.ListIndex=2 then</SourceLine>
   <SourceLine>StatOrder="StdDevPct"</SourceLine>
   <SourceLine>fStdDev=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>StatOrder="MyRatingPct"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT * FROM PlayerInfo WHERE Season='"+mCurrentSeason+"' "+position+" ORDER BY "+statorder+" DESC")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//need to figure out what we're going to do about the other fields</SourceLine>
   <SourceLine>dim ColumnHeaders as string="#, Name,HT,HS,Region"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkStar.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+",Stars"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkper.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+",Rating"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkstats.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+",Stats"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if chkatts.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+",Atts"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo=split(columnheaders, ",")</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle("SimSportsNews Top Prospects:  "+popPosition.text, columninfo,0,1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim StattoDisplay as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to PlayersToPull</SourceLine>
   <SourceLine>feet=floor(rs.field("Height").IntegerValue/12)</SourceLine>
   <SourceLine>inches=rs.Field("Height").IntegerValue-(12*feet)</SourceLine>
   <SourceLine>height=str(feet)+"'"+str(inches)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>k=teams.IndexOf(rs.field("HSName").StringValue)+1</SourceLine>
   <SourceLine>hsinfo=rs.field("HSName").StringValue+",  r"+str(GetConference(k))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkstar.value=true then</SourceLine>
   <SourceLine>StarString=","+GetStarString(rs.field("Name").StringValue,StarArray)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if fPlusMinus then</SourceLine>
   <SourceLine>StattoDisplay=format(rs.Field("PlayerPlusminus").DoubleValue, "+##0.0")</SourceLine>
   <SourceLine>elseif fStdDev then</SourceLine>
   <SourceLine>StattoDisplay=format(rs.Field(StatOrder).DoubleValue/10, "##0.0%")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>StattoDisplay=format(rs.Field(StatOrder).DoubleValue, "+##0.0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>ColumnHeaders=str(n)+".,"+rs.field("Name").StringValue+","+height+","+hsinfo+StarString</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkper.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+","+StattoDisplay</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if chkstats.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+","+GenerateStatString(rs)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if chkatts.value=true then</SourceLine>
   <SourceLine>ColumnHeaders=ColumnHeaders+","+GenerateAttributeString(rs)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>columninfo=split(columnheaders, ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n+1, columninfo)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>PostResults(sbstring.ToString)</SourceLine>
   <SourceLine>self.close</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
