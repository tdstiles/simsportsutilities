  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(PlayerName as String, iTeam as String, AA as integer, AD as integer, POY as integer)</SourceLine>
   <SourceLine>//this method loads up the player info. you pass the name of the player and the team to which he is going</SourceLine>
   <SourceLine>//this constructor creates a new cSignedPlayer with the appropriate stat lines by pulling from Player_Info</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim T75Rnk as string</SourceLine>
   <SourceLine>mTeam=teams.IndexOf(iTeam)+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//the szReturn looks like</SourceLine>
   <SourceLine>//#26 Memphis:  6'11 C Jon Smith, r16/Sioux City (+8.0/82) 25.5ppg 10.6rpg 1.08bpg etc.</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT Height, Pos, Name, Region, HSName,mRatingPct, t75Rnk, PPG, RPG, APG, SPG, TPG, BPG FROM PlayerInfo WHERE Season='"+mCurrentSeason+"' AND Name='"+PlayerName+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>if rs.IdxField(7).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>T75Rnk=rs.IdxField(7).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>T75Rnk="NR"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PN=rs.IdxField(3).StringValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>szReturn=Teams(mTeam-1)+":  "+InchestoHT(rs.IdxField(1).IntegerValue)+" "+rs.IdxField(2).StringValue+" "+rs.IdxField(3).StringValue+" r"+rs.IdxField(4).StringValue+"/"+rs.IdxField(5).StringValue+" ("+Format(rs.IdxField(6).doubleValue, "##0.000")</SourceLine>
   <SourceLine>szReturn=szReturn+"/"+T75Rnk+") "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(8).DoubleValue, "#0.0")+"ppg "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(9).DoubleValue, "#0.0")+"rpg "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(10).DoubleValue, "#0.0")+"apg "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(11).DoubleValue, "#0.0")+"spg "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(12).DoubleValue, "#0.0")+"tpg "</SourceLine>
   <SourceLine>szReturn=szReturn+format(rs.IdxField(13).DoubleValue, "#0.0")+"bpg "</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mRating=rs.IdxField(6).DoubleValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see if all america</SourceLine>
   <SourceLine>if AA=1 then</SourceLine>
   <SourceLine>AwardString=" **1st Team AA"</SourceLine>
   <SourceLine>elseif aa=2 then</SourceLine>
   <SourceLine>AwardString=" **2nd Team AA"</SourceLine>
   <SourceLine>elseif AA=3 then</SourceLine>
   <SourceLine>AwardString=" **3rd Team AA"</SourceLine>
   <SourceLine>elseif AA=4 then</SourceLine>
   <SourceLine>AwardString=" **4th Team AA"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see if all defense</SourceLine>
   <SourceLine>if ad=1 then</SourceLine>
   <SourceLine>AwardString=AwardSTring+" **All-Defense"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to see if POY</SourceLine>
   <SourceLine>if poy=1 then</SourceLine>
   <SourceLine>AwardString=AwardSTring+" **POY"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>szReturn=szReturn+AwardString</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
