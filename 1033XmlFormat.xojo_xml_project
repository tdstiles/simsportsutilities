  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ScoreDifferential(MoV as integer) As string</SourceLine>
   <SourceLine>dim h as string</SourceLine>
   <SourceLine>dim scoretext(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sMinutes as Integer</SourceLine>
   <SourceLine>//find out if we have OT</SourceLine>
   <SourceLine>for n as integer=0 to 9</SourceLine>
   <SourceLine>sMinutes=sMinutes+RecapTeams(0).Players(n).minutes</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if sminutes&gt;210 then</SourceLine>
   <SourceLine>//we have OT</SourceLine>
   <SourceLine>h="needed OT to beat,had to go to OT to defeat,had to go to OT to vanquish,outlasted,used OT to sneak by"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>return scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if MoV&lt;=3 then</SourceLine>
   <SourceLine>h="sqeaked by,snuck by,barely beat,eeked out a win over,defeated,won a thriller over,snuck by,vanquished,outlasted"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>return scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>elseif MoV&lt;=12 then</SourceLine>
   <SourceLine>h="defeated,beat,won over,handled,was victorious over,triumphed over,defeated,beat,defeated,was victorious over,vanquished,defeated,beat"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>return scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>h="defeated,pummeled,crushed,smashed,trashed,beat,defeated,handled,drilled,smoked,beat,stmoped,defeated,crushed,handled,drilled"</SourceLine>
   <SourceLine>scoretext=split(h,",")</SourceLine>
   <SourceLine>return scoretext(r.InRange(0,ubound(scoretext)))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
