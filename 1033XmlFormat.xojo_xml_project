  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Open()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim tmpmargin as double</SourceLine>
   <SourceLine>dim diff as double</SourceLine>
   <SourceLine>dim rec as RecordSet</SourceLine>
   <SourceLine>dim mention(14), type(14) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.BackColor=prefWindowColor.colorvalue</SourceLine>
   <SourceLine>lb1.LoadHeader(split("Type,ProjRecord,Record,%Dif,PF,PA,Margin", ","))</SourceLine>
   <SourceLine>lb1.DeleteAllRows</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim TempoList(-1) as cTempoAndPace</SourceLine>
   <SourceLine>dim j as cTempoAndPace</SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Fast/*"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Fast'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Fast/Norm"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Fast' AND Defense='Norm'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Fast/Zone"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Fast' AND Defense='Zone'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Fast/Man"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Fast' AND Defense='Man'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Norm/*"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Norm'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Norm/Norm"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Norm' AND Defense='Norm'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Norm/Zone"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Norm' AND Defense='Zone'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Norm/Man"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Norm' AND Defense='Man'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Slow/*"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Slow'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Slow/Norm"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Slow' AND Defense='Norm'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Slow/Zone"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Slow' AND Defense='Zone'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="Slow/Man"</SourceLine>
   <SourceLine>j.SQLSearch=" Pace='Slow' AND Defense='Man'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="*/Norm"</SourceLine>
   <SourceLine>j.SQLSearch=" Defense='Norm'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="*/Zone"</SourceLine>
   <SourceLine>j.SQLSearch=" Defense='Zone'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=new cTempoAndPace</SourceLine>
   <SourceLine>j.Description="*/Man"</SourceLine>
   <SourceLine>j.SQLSearch=" Defense='Man'"</SourceLine>
   <SourceLine>TempoList.append j</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'mthdAddKmoneyInfo</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 14</SourceLine>
   <SourceLine>sqlstring="SELECT Avg(Games.OurScore), Avg(Games.OppScore), (SELECT Count(*) FROM Games WHERE Games.Season='"+mCurrentSeason+"' AND WL='W' AND "+TempoList(n).SQLSearch+"), (SELECT Count(*) FROM Games WHERE Games.Season='"+mCurrentSeason+"' AND WL='L' AND "+TempoList(n).SQLSearch+"), (SELECT avg(PRI.PR) FROM Games, PRI WHERE Games.Season='"+mCurrentSeason+"' AND PRI.TeamNum=Games.TeamNum AND "+TempoList(n).SQLSearch+") FROM Games WHERE Games.Season='"+mCurrentSeason+"' AND "+TempoList(n).SQLSearch</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>TempoList(n).AvgScore=rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>TempoList(n).AvgOppScore=rs.IdxField(2).DoubleValue</SourceLine>
   <SourceLine>TempoList(n).ActualW=rs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>TempoList(n).ActualL=rs.IdxField(4).IntegerValue</SourceLine>
   <SourceLine>TempoList(n).AvgPR=rs.IdxField(5).DoubleValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="select count(*) from games, pri as a, pri as b where games.season='"+mcurrentSeason+"' and a.season='"+mcurrentSeason+"' and b.season='"+mcurrentSeason+"' and games.teamnum=a.teamnum and games.opponentnum=b.teamnum and a.kmoneyave&gt;b.kmoneyave and "+TempoList(n).SQLSearch</SourceLine>
   <SourceLine>rec=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>TempoList(n).ProjW=rec.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="select count(*) from games, pri as a, pri as b where games.season='"+mcurrentSeason+"' and a.season='"+mcurrentSeason+"' and b.season='"+mcurrentSeason+"' and games.teamnum=a.teamnum and games.opponentnum=b.teamnum and a.kmoneyave&lt;b.kmoneyave and "+TempoList(n).SQLSearch</SourceLine>
   <SourceLine>rec=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>TempoList(n).ProjL=rec.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'Type,W,L,Pct,ProjW,ProjL,%Dif,PF,PA,Margin,AvgPR,</SourceLine>
   <SourceLine>tmpmargin=(TempoList(n).AvgScore-TempoList(n).AvgOppScore)/((TempoList(n).AvgOppScore+TempoList(n).AvgScore)/2)</SourceLine>
   <SourceLine>diff=(TempoList(n).actualw-TempoList(n).projw)/TempoList(n).projw</SourceLine>
   <SourceLine>lb1.addrow TempoList(n).Description, str(TempoList(n).projw)+"-"+str(TempoList(n).projl)+" ("+format(TempoList(n).projw/(TempoList(n).projw+TempoList(n).projl),"#.000")+")", str(TempoList(n).actualw)+"-"+str(TempoList(n).actuall)+" ("+format(TempoList(n).actualw/(TempoList(n).actualw+TempoList(n).actuall),"#.000")+")", format(diff,"+##.0%"),format(tempolist(n).avgscore, "###.0"), format(tempolist(n).avgoppscore, "###.0"),format(tmpmargin,"+##.0%")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
 </HookInstance>
