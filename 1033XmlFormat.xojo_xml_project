  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function LoadTeamGames(teamnum as integer) As boolean</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim j as boolean</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mResult=thissocket.Get("http://drivethelane.com/bask/runtime/sched.asp?league=league=lg000"+right("0"+league,2)+"&amp;team="+str(TeamNum), 60)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine>ParseSchedule(TeamNum)</SourceLine>
   <SourceLine>j=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>j=false //for error catching</SourceLine>
   <SourceLine>end</SourceLine>
