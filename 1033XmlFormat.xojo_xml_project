  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1035853823</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub SavePrefs()</SourceLine>
   <SourceLine>//this method writes all the preferences that are saved in memory (in the Preferences Module) to a binary file</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as folderitem</SourceLine>
   <SourceLine>dim stream as binarystream</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=SpecialFolder.Preferences</SourceLine>
   <SourceLine>f=f.child("LeagueCommish")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Prefs.bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If f &lt;&gt; Nil then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream=f.createbinaryfile("bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//let's write the menu items</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>stream.WritePString prefColors(n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream.WriteBoolean DoGamebyGame</SourceLine>
   <SourceLine>stream.WriteBoolean prefBlogger</SourceLine>
   <SourceLine>stream.writeUint8 prefElo</SourceLine>
   <SourceLine>stream.writeUint8 prefHistory</SourceLine>
   <SourceLine>stream.writeUint8 prefPR</SourceLine>
   <SourceLine>stream.writeUint8 prefRecruiting</SourceLine>
   <SourceLine>stream.WritePString prefWindowColor.StringValue</SourceLine>
   <SourceLine>stream.WritePString PrefListboxColor.StringValue</SourceLine>
   <SourceLine>stream.WriteBoolean prefAllNTT</SourceLine>
   <SourceLine>stream.WriteBoolean prefWiki</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's close it out</SourceLine>
   <SourceLine>stream.close</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
