    <SourceLine></SourceLine>
    <SourceLine>league=EditField1.text</SourceLine>
    <SourceLine>mCurrentSeason=EditField2.text</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>if league&lt;&gt;"" and mCurrentSeason&lt;&gt;"" then</SourceLine>
    <SourceLine>DBSQLExecute("DELETE FROM Variables WHERE ID='SeasonNum' OR ID='LeagueNum'")</SourceLine>
    <SourceLine>DBSQLExecute("INSERT INTO Variables (ID, Value) VALUES ('SeasonNum', '"+mCurrentSeason+"')")</SourceLine>
    <SourceLine>DBSQLExecute("INSERT INTO Variables (ID, Value) VALUES ('LeagueNum', '"+League+"')")</SourceLine>
    <SourceLine>db.Commit</SourceLine>
