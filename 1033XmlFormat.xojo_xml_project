 </Method>
 <Method>
  <ItemName>AddAssists</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1730916351</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AddAssists()</SourceLine>
   <SourceLine>//this method calculates the assists for each player and updates the WinsProduced accordingly</SourceLine>
   <SourceLine>''Players (rowID INTEGER PRIMARY KEY autoincrement, Season integer, Pos varchar, Player varchar,  GM integer, MPG integer, PPG double, RPG double, APG double, FGM double, FGA double, FG3M double, FG3A double, FTM double, FTA double, STL double, TOS double, BLK double, tendex double, WinsProduced double)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'Calculate for each player his Teammates’ Assists per Minute (TAPM). This is calculated as follows: TAPM = (Team Assists – Player Assists) / (Team Minutes – Player Minutes)</SourceLine>
   <SourceLine>'Multiply TAPM for each player by the coefficient on TAPM from the above model, or 0.725.</SourceLine>
   <SourceLine>'Multiply step (2) by 2.  This step allows us to see how TAPM impact a player’s points-per-field goal attempts (which is simply ADJ FG * 2).</SourceLine>
   <SourceLine>'Multiply step (3) by field goal attempts taken.  This allows us to see how many points a player scored should be credited to his teammates.</SourceLine>
   <SourceLine>'Multiply step (4) by the impact points have on wins 0.032586.  This allows us to see how much of a player’s production of wins should be credited to his teammates.</SourceLine>
   <SourceLine>'Sum step v across all players on a team.</SourceLine>
   <SourceLine>'Allocate the outcome of step #6 across all players on a team by the percentage of assists on the team that are credited to each player.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, get the team assists and put them in an array</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim iPlayer as cWPPlayer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have an array, iTeamAssists, that has all assists for each team</SourceLine>
   <SourceLine>//we also have an iMinutes array that has allt he minutes each team has played</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for i as integer=1 to 256</SourceLine>
   <SourceLine>dim iTmp as double</SourceLine>
   <SourceLine>dim iPlayers(-1) as cWPPlayer</SourceLine>
   <SourceLine>dim iTeamAssists as integer</SourceLine>
   <SourceLine>dim iTeamMinutes as integer</SourceLine>
   <SourceLine>dim iTeamScore as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT GM, FGA, APG, MPG, rowID, WinsProduced FROM Players WHERE TeamNum='"+str(i)+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>iPlayer= new cWPPlayer</SourceLine>
   <SourceLine>iPlayer.Games=rs.Field("GM").IntegerValue</SourceLine>
   <SourceLine>iPlayer.Minutes=rs.Field("MPG").DoubleValue*iPlayer.Games</SourceLine>
   <SourceLine>iPlayer.FGA=rs.Field("FGA").IntegerValue</SourceLine>
   <SourceLine>iPlayer.Assists=rs.Field("APG").DoubleValue*iPlayer.Games</SourceLine>
   <SourceLine>iPlayer.WinsProduced=rs.Field("WinsProduced").DoubleValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iTeamAssists=iTeamAssists+iPlayer.Assists</SourceLine>
   <SourceLine>iTeamMinutes=iTeamMinutes+iPlayer.Minutes</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>iPlayers.append iPlayer</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//calcuate the TAPM for each player</SourceLine>
   <SourceLine>for n as integer=0 to UBound(iPlayers)</SourceLine>
   <SourceLine>iTmp=(iTeamAssists-iPlayers(n).Assists)/(iTeamMinutes-iPlayers(n).Minutes)  //percentage of team assists for player</SourceLine>
   <SourceLine>iTmp=iTmp*0.725*2</SourceLine>
   <SourceLine>iTmp=iTmp*iPlayers(n).FGA*0.032586</SourceLine>
   <SourceLine>iPlayers(n).Score=iTmp</SourceLine>
   <SourceLine>iTeamScore=iTeamScore+iPlayers(n).Score</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now the percentage that goes to each player and is added to WP</SourceLine>
   <SourceLine>dim NewWP as double</SourceLine>
   <SourceLine>for n as integer=0 to UBound(iPlayers)</SourceLine>
   <SourceLine>NewWP=iPlayers(n).WinsProduced+iTeamScore*iPlayers(n).Assists/iTeamAssists</SourceLine>
   <SourceLine>sqlstring="UPDATE Players SET WinsProduced='"+str(iPlayers(n).WinsProduced)+"' WHERE rowID='"+str(iPlayers(n).rowID)+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
