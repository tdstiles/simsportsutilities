 <Method>
  <ItemName>PD</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1145794559</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PD(iProjection as integer=0) As string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim HPD as double</SourceLine>
   <SourceLine>dim t(1) as double</SourceLine>
   <SourceLine>dim returnstring as string</SourceLine>
   <SourceLine>dim fraction as Boolean</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//0=percentage</SourceLine>
   <SourceLine>//1=line</SourceLine>
   <SourceLine>//2=score</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT ELO FROM PRI WHERE TeamNum='"+str(mTeamNumbers(n))+"'")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>t(n)=rs.idxfield(1).doublevalue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first, figure out the expected GP for the home team</SourceLine>
   <SourceLine>HPD=t(1)-t(0)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>HPD = (round(HPD*2))/2</SourceLine>
   <SourceLine>if (HPD-round(HPD))=0 then</SourceLine>
   <SourceLine>fraction=false</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>fraction=true</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if HPD&gt;0 then</SourceLine>
   <SourceLine>//home team is favored.</SourceLine>
   <SourceLine>if fraction then</SourceLine>
   <SourceLine>returnstring=Teams(mTeamNumbers(1)-1)+" -"+format(hpd*-1, "#0.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>returnstring=Teams(mTeamNumbers(1)-1)+" -"+format(hpd*-1, "#0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//visitor is favored</SourceLine>
   <SourceLine>if fraction then</SourceLine>
   <SourceLine>returnstring=Teams(mTeamNumbers(0)-1)+" "+format(hpd, "-#0.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>returnstring=Teams(mTeamNumbers(0)-1)+" "+format(hpd, "-#0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return "&lt;b&gt;Prediction:&lt;/b&gt;  "+returnstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
