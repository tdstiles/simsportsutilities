<block type="Window" ID="760664063">
 <ObjName>wndFinalWrapUp</ObjName>
 <ObjContainerID>1987360767</ObjContainerID>
 <IsClass>1</IsClass>
 <Superclass>Window</Superclass>
 <ItemFlags>1</ItemFlags>
 <IsInterface>0</IsInterface>
 <Compatibility></Compatibility>
 <Method>
  <ItemName>Constructor</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1679028223</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Constructor(mConferenceNumber as Integer=0)</SourceLine>
   <SourceLine>// Calling the overridden superclass constructor.</SourceLine>
   <SourceLine>Super.Window</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//the ConferenceNumber defaults to zero.  If it's something else, we use that to generate just from one conference </SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>me.SetFocus</SourceLine>
   <SourceLine>me.BackColor=prefWindowColor.colorvalue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs, ars, brs, crs, ers, frs as recordset</SourceLine>
   <SourceLine>dim TN as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim pace, defense as string</SourceLine>
   <SourceLine>dim rpidb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim finish as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lb1.Visible=false</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rpidb.Connect then</SourceLine>
   <SourceLine>rpidb.SQLExecute("CREATE TABLE rpitable (TeamNum integer, RPI double, Rnk integer, elo double, fPR)")</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, RPI FROM PRI WHERE Season='"+mCurrentSeason+"' ORDER BY RPI DESC")</SourceLine>
   <SourceLine>k=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="INSERT INTO rpitable (TeamNum, RPI, Rnk) VALUES ('"+rs.IdxField(1).StringValue+"', '"+rs.IdxField(2).StringValue+"', '"+str(k)+"')"</SourceLine>
   <SourceLine>rpidb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>k=k+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, ELO, fPR FROM PRI WHERE Season='"+mCurrentSeason+"' ORDER BY ELO DESC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="UPDATE rpitable SET ELO='"+rs.IdxField(2).StringValue+"', fPR='"+rs.idxfield(3).stringvalue+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>rpidb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//PPG, aPPG, Possession Calcs, etc.</SourceLine>
   <SourceLine>//mPossessionScores(teamnum, 0 for O, 1 for D)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mInMemDB=new REALSQLDatabase</SourceLine>
   <SourceLine>if mInMemDB.Connect then</SourceLine>
   <SourceLine>mInMemDB.SQLExecute("CREATE TABLE DataHere (TeamNum integer, PPG double, PPGRank integer, aPPG double, aPPGRank integer, plusMinus double, PlusMinusRank integer, Tempo varchar, Defense varchar, Conference integer)")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim tmpO, tmpD, tmpPM as double</SourceLine>
   <SourceLine>//first, go through and set the data for each team</SourceLine>
   <SourceLine>CalcPossession //this sets the variable mPossessionScores with the data for each team</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>tmpO=mPossessionScores((n-1),0)</SourceLine>
   <SourceLine>tmpD=mPossessionScores((n-1),1)</SourceLine>
   <SourceLine>tmpPM=tmpO-tmpD</SourceLine>
   <SourceLine>dim TmpConf as integer=ceil(n/8)</SourceLine>
   <SourceLine>mInMemDB.SQLExecute("INSERT INTO DataHere (TeamNum, PPG, aPPG, PlusMinus, Conference) VALUES ('"+str(n)+"', '"+str(TmpO)+"', '"+str(tmpD)+"', '"+str(TmpPM)+"', '"+str(tmpConf)+"')")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we set the ranks for each</SourceLine>
   <SourceLine>rs=mInMemDB.SQLSelect("SELECT TeamNum FROM DataHere ORDER BY PPG DESC")</SourceLine>
   <SourceLine>dim tmpI as integer=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while  rs.EOF=false</SourceLine>
   <SourceLine>mInMemDB.SQLExecute("UPDATE DataHere SET PPGRank='"+str(tmpI)+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>tmpI=tmpI+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=mInMemDB.SQLSelect("SELECT TeamNum FROM DataHere ORDER BY aPPG ASC")</SourceLine>
   <SourceLine>tmpI=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while  rs.EOF=false</SourceLine>
   <SourceLine>mInMemDB.SQLExecute("UPDATE DataHere SET aPPGRank='"+str(tmpI)+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>tmpI=tmpI+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=mInMemDB.SQLSelect("SELECT TeamNum, PlusMinus FROM DataHere ORDER BY PlusMinus DESC")</SourceLine>
   <SourceLine>k=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>mInMemDB.SQLExecute("UPDATE DataHere SET PlusMinusRank='"+str(k)+"' WHERE TeamNum='"+rs.IdxField(1).StringValue+"'")</SourceLine>
   <SourceLine>k=k+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT (SELECT Count(*) FROM Games WHERE Pace='Fast' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'),(SELECT Count(*) FROM Games WHERE Pace='Norm' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'), (SELECT Count(*) FROM Games WHERE Pace='Slow' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'), (SELECT Count(*) FROM Games WHERE Defense='Man' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'),(SELECT Count(*) FROM Games WHERE Defense='Norm' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'), (SELECT Count(*) FROM Games WHERE Defense='Zone' AND Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"') FROM Games WHERE TeamNum='"+str(n)+"'")</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue&gt;rs.IdxField(2).IntegerValue AND rs.IdxField(1).IntegerValue&gt;rs.IdxField(3).IntegerValue then</SourceLine>
   <SourceLine>pace="Fast"</SourceLine>
   <SourceLine>elseif rs.IdxField(2).IntegerValue&gt;rs.IdxField(1).IntegerValue AND rs.IdxField(2).IntegerValue&gt;rs.IdxField(3).IntegerValue then</SourceLine>
   <SourceLine>pace="Norm"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>pace="Slow"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(4).IntegerValue&gt;rs.IdxField(5).IntegerValue AND rs.IdxField(4).IntegerValue&gt;rs.IdxField(6).IntegerValue then</SourceLine>
   <SourceLine>defense="Man"</SourceLine>
   <SourceLine>elseif rs.IdxField(5).IntegerValue&gt;rs.IdxField(4).IntegerValue AND rs.IdxField(5).IntegerValue&gt;rs.IdxField(6).IntegerValue then</SourceLine>
   <SourceLine>defense="Norm"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>defense="Zone"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mInMemDB.SQLExecute("UPDATE DataHere SET Tempo='"+pace+"', Defense='"+defense+"' WHERE TeamNum='"+str(n)+"'")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mInMemDB.Commit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mFinalString="DELETE FROM TeamData WHERE season='"+mCurrentSeason+"';"+EndOfLine</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT PRI.TeamNum, PRI.PR, PRI.Conference, PRI.fPR, PRI.SoS FROM PRI WHERE PRI.Season='"+mCurrentSeason+"' ORDER BY fPR ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>if mConferenceNumber=0 OR mConferenceNumber=rs.IdxField(3).IntegerValue then</SourceLine>
   <SourceLine>TN=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(WL='W'), Sum(WL='L') FROM Games WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+TN+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
