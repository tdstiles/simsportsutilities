 <Method>
  <ItemName>loadleagueinfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>694241279</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub loadleagueinfo()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Value FROM Variables WHERE ID='LeagueNum'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>league=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>prefLeague=league</SourceLine>
   <SourceLine>mLocationString="http://drivethelane.com/bask/runtime/whoibbjv.asp?lg=000"+right("0"+league,2)+"&amp;idno="</SourceLine>
   <SourceLine>mScheduleString="http://drivethelane.com/bask/runtime/sched.asp?league=league=lg000"+right("0"+league,2)+"&amp;team="</SourceLine>
   <SourceLine>mBoxScoreString="http://drivethelane.com/bask/runtime/boxscore.asp?league=000"+right("0"+league,2)+"&amp;game="</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Value FROM Variables WHERE ID='UserName'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mUsername=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Value FROM Variables WHERE ID='Password'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mPassword=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Value FROM Variables WHERE ID='SeasonNum'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mCurrentSeason=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Max(GameNum) FROM Games WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>agamesplayed.text=format(rs.IdxField(1).IntegerValue, "#0")</SourceLine>
   <SourceLine>agamesplayed.Refresh</SourceLine>
   <SourceLine>GamesPlayed=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>efSeason.text=mCurrentSeason</SourceLine>
   <SourceLine>me.title="League Commissioner:  L-"+league+"  S"+mCurrentSeason</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
