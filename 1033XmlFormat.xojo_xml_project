 <Method>
  <ItemName>CalculateRPI</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>849541119</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalculateRPI()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim brs as recordset</SourceLine>
   <SourceLine>dim ars as RecordSet</SourceLine>
   <SourceLine>dim inmemdb as new REALSQLDatabase</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim orec(0,1) as integer</SourceLine>
   <SourceLine>dim maxvalue as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if inmemdb.Connect then</SourceLine>
   <SourceLine>inmemdb.SQLExecute("CREATE TABLE firstlist (TeamNum integer, Wins double, OWins double, OOWins double)")</SourceLine>
   <SourceLine>inmemdb.Commit</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get team wins</SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, SUM(WL='W'), Sum(WL='L') FROM GAMES WHERE TeamNum='"+str(n)+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>inmemdb.SQLExecute("INSERT INTO firstlist (TeamNum, Wins) VALUES ('"+rs.IdxField(1).StringValue+"', '"+str(rs.IdxField(2).IntegerValue/(rs.idxfield(2).integervalue+rs.IdxField(3).IntegerValue))+"')")</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get opponent wins</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>orec(0,0)=0</SourceLine>
   <SourceLine>orec(0,1)=0</SourceLine>
   <SourceLine>sqlstring="SELECT OpponentNum FROM Games WHERE TeamNum='"+str(n)+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, SUM(WL='W'), Sum(WL='L') FROM GAMES WHERE TeamNum='"+rs.idxfield(1).stringvalue+"' AND Season='"+mCurrentSeason+"' ANd OpponentNum&lt;&gt;'"+str(n)+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if ars&lt;&gt;nil and ars.RecordCount&lt;&gt;0 and ars.eof=false then</SourceLine>
   <SourceLine>orec(0,0)=orec(0,0)+ars.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>orec(0,1)=orec(0,1)+ars.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE firstlist SET OWins='"+str(orec(0,0)/(orec(0,0)+orec(0,1)))+"' WHERE TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get opponents opponents wins</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>orec(0,0)=0</SourceLine>
   <SourceLine>orec(0,1)=0</SourceLine>
   <SourceLine>sqlstring="SELECT OpponentNum FROM Games WHERE TeamNum='"+str(n)+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT OpponentNum FROM Games WHERE TeamNum='"+rs.idxfield(1).stringvalue+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(ars) then</SourceLine>
   <SourceLine>while ars.eof=false</SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, (SELECT Count(*) FROM GAMES WHERE TeamNum='"+ars.idxfield(1).stringvalue+"' AND WL='W' AND Season='"+mCurrentSeason+"' AND OpponentNum&lt;&gt;'"+rs.idxfield(1).stringvalue+"'), (SELECT Count(*) FROM GAMES WHERE TeamNum='"+ars.idxfield(1).stringvalue+"' AND WL='L' AND Season='"+mCurrentSeason+"' AND OpponentNum&lt;&gt;'"+rs.idxfield(1).stringvalue+"') FROM GAMES WHERE TeamNum='"+ars.idxfield(1).stringvalue+"' AND Season='"+mCurrentSeason+"' ANd OpponentNum&lt;&gt;'"+rs.idxfield(1).stringvalue+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if brs&lt;&gt;nil and brs.RecordCount&lt;&gt;0 and brs.eof=false then</SourceLine>
   <SourceLine>orec(0,0)=orec(0,0)+brs.IdxField(2).IntegerValue</SourceLine>
   <SourceLine>orec(0,1)=orec(0,1)+brs.IdxField(3).IntegerValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>ars.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE firstlist SET OOWins='"+str(orec(0,0)/(orec(0,0)+orec(0,1)))+"' WHERE TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>inmemdb.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now determine RPI score</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT wins, owins,oowins FROM firstlist WHERE TeamNum='"+str(n)+"'")</SourceLine>
   <SourceLine>sqlstring="UPDATE PRI SET RPI='"+str(rs.IdxField(1).DoubleValue+2*rs.idxfield(2).doublevalue+rs.idxfield(3).doublevalue)+"' WHERE TeamNum='"+str(n)+"' AND Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Max(RPI) FROM PRI WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>maxvalue=rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT RPI, rowID FROM PRI WHERE TeamNum='"+str(n)+"' AND Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>sqlstring="UPDATE PRI SET RPI='"+str(100*rs.IdxField(1).DoubleValue/maxvalue)+"' WHERE rowID='"+rs.IdxField(2).StringValue+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
