  <PartID>573620223</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub Yield()</SourceLine>
   <SourceLine>If me.PauseFlag &lt;&gt; Nil and me.IsPaused then</SourceLine>
   <SourceLine>me.PauseFlag.Signal</SourceLine>
   <SourceLine>me.PauseFlag.Release</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>//no pause request has been made yet</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
