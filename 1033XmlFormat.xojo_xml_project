  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub DetermineRatingsFromStats(pos as string, ppg as double, rpg as double, apg as double, spg as double, bpg as double, tpg as double)</SourceLine>
   <SourceLine>dim absath as Double</SourceLine>
   <SourceLine>dim avgath as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>athleticismmodifier=0</SourceLine>
   <SourceLine>attrs(1,2)=(2.98*spg)+(0.1768*bpg)-2.825</SourceLine>
   <SourceLine>if tpg&gt;0 then</SourceLine>
   <SourceLine>attrs(2,2)=1.3463917*(apg/tpg)-1.7023074</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>attrs(2,2)=1.3463917*(apg/0.1)-1.7023074</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if pos="PG" then</SourceLine>
   <SourceLine>attrs(0,2)=0.1990428*(ppg)-2.5091331</SourceLine>
   <SourceLine>attrs(3,2)=1.9129603*(rpg)-4.2620756</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif pos="SG" then</SourceLine>
   <SourceLine>attrs(0,2)=0.2267136*(ppg)-3.2379234</SourceLine>
   <SourceLine>attrs(3,2)=2.3034232*(rpg)-6.8365599</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif pos="SF" then</SourceLine>
   <SourceLine>attrs(0,2)=0.247135*(ppg)-3.866597</SourceLine>
   <SourceLine>attrs(3,2)=1.7934277*(rpg)-7.4821802</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>elseif pos="PF" then</SourceLine>
   <SourceLine>attrs(0,2)=0.2304904*(ppg)-2.9469838</SourceLine>
   <SourceLine>attrs(3,2)=0.7142098*(rpg)-4.4538122</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //C</SourceLine>
   <SourceLine>attrs(0,2)=0.2640768*(ppg)-2.9501628</SourceLine>
   <SourceLine>attrs(3,2)=1.0388254*(rpg)-7.1275755</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//for each attribute, see if it falls within the scouted range</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>if attrs(n,2)&gt;attrs(n,1) then</SourceLine>
   <SourceLine>absath=abs(attrs(n,2)-attrs(n,1))</SourceLine>
   <SourceLine>athleticismmodifier=athleticismmodifier+absath</SourceLine>
   <SourceLine>attrs(n,2)=attrs(n,1)</SourceLine>
   <SourceLine>elseif attrs(n,2)&lt;attrs(n,0) then</SourceLine>
   <SourceLine>absath=abs(attrs(n,2)-attrs(n,0))</SourceLine>
   <SourceLine>athleticismmodifier=athleticismmodifier-absath</SourceLine>
   <SourceLine>attrs(n,2)=attrs(n,0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//calculate estimated athleticism</SourceLine>
   <SourceLine>avgath=(attrs(4,0)+attrs(4,1))/2</SourceLine>
   <SourceLine>avgath=avgath+athleticismmodifier</SourceLine>
   <SourceLine>if avgath&gt;attrs(4,1) then</SourceLine>
   <SourceLine>attrs(4,2)=attrs(4,1)</SourceLine>
   <SourceLine>elseif avgath&lt;attrs(4,0) then</SourceLine>
   <SourceLine>attrs(4,2)=attrs(4,0)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>attrs(4,2)=avgath</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
