  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function NBS(FGM as integer, FTM as integer, FG3M as integer, reb as integer, ast as integer, stl as integer, blk as integer, fga as integer, fta as integer, tos as integer, fouls as integer) As double</SourceLine>
