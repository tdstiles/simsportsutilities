  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PrepareTable(inmemdb as REALSQLDatabase)</SourceLine>
   <SourceLine>TableString=""</SourceLine>
   <SourceLine>if inmemdb.connect then</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim headingstring(-1) as string</SourceLine>
   <SourceLine>headingstring=split("Rank,Conference,Non-Conf Rec,Non-Con Win %,Rating Tri-Mean,Rating Simple,RPI Tri-Mean,RPI Simple,NTT Bids,NTT S16,Overall Strength", ",")</SourceLine>
   <SourceLine>TableString=TableString+TableGeneratorTitle("Conference Rankings",headingstring,0,1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim i as integer=1</SourceLine>
   <SourceLine>//now add in for each</SourceLine>
   <SourceLine>dim columnstring(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=inmemdb.SQLSelect("SELECT ConfNumber, OOCWins, OOCLosses, RatingTri, RatingSimple, RPITri, RPISimple, NTTBids, NTTS16, Strength FROM Conferences ORDER BY Strength DESC")</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>redim columnstring(-1)</SourceLine>
   <SourceLine>columnstring.append str(i)</SourceLine>
   <SourceLine>columnstring.append "C"+rs.idxfield(1).stringvalue</SourceLine>
   <SourceLine>columnstring.append rs.idxfield(2).stringvalue+"-"+ rs.idxfield(3).stringvalue</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(2).IntegerValue/(rs.IdxField(2).IntegerValue+rs.IdxField(3).IntegerValue), "#0.000")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(4).DoubleValue, "##0.00")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(5).DoubleValue, "##0.00")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(6).DoubleValue, "##0.00")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(7).DoubleValue, "##0.00")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(8).IntegerValue,"#0")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(9).IntegerValue,"#0")</SourceLine>
   <SourceLine>columnstring.append format(rs.IdxField(10).DoubleValue, "##0.000")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TableString=TableString+ColumnGenerator(i mod 2,columnstring)</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>TableString=TableString+CloseTable</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
