 <Method>
  <ItemName>mthdReturningLeaders</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>890867711</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthdReturningLeaders(ConferenceNum as String) As string</SourceLine>
   <SourceLine>dim sbstring as string</SourceLine>
   <SourceLine>dim fromtext as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if confnum=0, then all-league</SourceLine>
   <SourceLine>dim conftext as string</SourceLine>
   <SourceLine>if ConferenceNum&lt;&gt;"0" then</SourceLine>
   <SourceLine>conftext=" AND Players.TeamNum=PRI.TeamNum AND PRI.Conference="+ConferenceNum</SourceLine>
   <SourceLine>fromtext=" Players, PRI "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>conftext=""</SourceLine>
   <SourceLine>fromtext=" Players "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim statarray(-1) as string</SourceLine>
   <SourceLine>statarray.append "PPG"</SourceLine>
   <SourceLine>statarray.append "RPG"</SourceLine>
   <SourceLine>statarray.append "APG"</SourceLine>
   <SourceLine>statarray.append "STL"</SourceLine>
   <SourceLine>statarray.append "BLK"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim seasontext as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim formatting as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>seasontext=str(val(mCurrentSeason)-1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+ "===Returning Leaders==="+ endofline+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ "&lt;h3&gt;Returning Leaders&lt;/h3&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+"'''"+statarray(n)+" leaders''' "+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ "&lt;i&gt;"+statarray(n)+" leaders:  &lt;/i&gt;&lt;br&gt;"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Distinct(Players.Player), Players.TeamNum, Players."+statarray(n)+" as A FROM "+fromtext+" WHERE Players.Season='"+seasontext+"' AND Players.Yr&lt;&gt;'Sr' "+conftext+" ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if n&lt;4 then</SourceLine>
   <SourceLine>formatting="##0.0"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>formatting="#0"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim i as integer=1</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while i&lt;6</SourceLine>
   <SourceLine>if prefwiki then</SourceLine>
   <SourceLine>sbstring=sbstring+ str(i)+".  "+rs.IdxField(1).StringValue+", "+HTMLLink(rs.IdxField(2).IntegerValue,3)+" ("+format(rs.IdxField(3).DoubleValue, formatting)+")"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sbstring=sbstring+ str(i)+".  "+rs.IdxField(1).StringValue+", "+HTMLLink(rs.IdxField(2).IntegerValue,3)+" ("+format(rs.IdxField(3).DoubleValue, formatting)+")"+BloggerEndofLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring=sbstring+"&lt;br&gt;"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return sbstring</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>ConferenceNum as String</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>mthdAddKmoneyInfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>381220863</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthdAddKmoneyInfo()</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim tms(-1) as struTeamRecruiting</SourceLine>
   <SourceLine>dim tm as struTeamRecruiting</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the file from the web</SourceLine>
   <SourceLine>theurl="http://kwallace.echoechoplus.com/simrec/leagueRecruiting.php?l="+right("00"+league,2)+"&amp;f=ave&amp;s=ave"</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's clean up the html in it</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim searchstring(-1) as string</SourceLine>
   <SourceLine>dim replacementstring(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>searchstring.append "&lt;td.*&gt;(.*)&lt;/td&gt;"</SourceLine>
   <SourceLine>replacementstring.append "\1"+EndOfLine</SourceLine>
   <SourceLine>searchstring.append "&lt;a href=http://www.smartacres.com/bask/runtime/whoibbjv.asp?lg=(.*)&amp;idno=(.*)\starget=_blank&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>replacementstring.append "\2"+EndOfLine</SourceLine>
   <SourceLine>searchstring.append "&lt;.*&gt;"</SourceLine>
   <SourceLine>replacementstring.append ""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine>dim iMax as integer=ubound(searchstring)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>r.SearchPattern =searchstring(n)</SourceLine>
   <SourceLine>r.ReplacementPattern = replacementstring(n)</SourceLine>
   <SourceLine>result=Trim(r.Replace(result))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>result=removetabs(result)</SourceLine>
   <SourceLine>result=removeblanklines(result)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have our array</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//what line do we start on?</SourceLine>
   <SourceLine>dim i as integer=15</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim namefrag as string</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 8</SourceLine>
   <SourceLine>for nn as integer=1 to 32</SourceLine>
   <SourceLine>//let's loop through and add in info</SourceLine>
   <SourceLine>j=TeamNumberFromName(lines(i))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tm.TeamNum=j</SourceLine>
   <SourceLine>tm.Value=val(lines(i+9))</SourceLine>
   <SourceLine>i=i+11</SourceLine>
   <SourceLine>tms.append tm</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>i=i+11</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>iMax=ubound(tms)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>sqlstring="UPDATE PRI SET KMoneyAve="+str(tms(n).Value)+" WHERE TeamNum="+str(tms(n).TeamNum)+" AND Season="+mCurrentSeason</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
