 </Method>
 <Method>
  <ItemName>AdjForPosition</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1025652735</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AdjForPosition()</SourceLine>
   <SourceLine>//this method adjusts the P40s, which are saved in Players as WinsProduced, per position</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim rec as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim Positions(-1) as string</SourceLine>
   <SourceLine>Positions.append "PG"</SourceLine>
   <SourceLine>Positions.append "SG"</SourceLine>
   <SourceLine>Positions.append "SF"</SourceLine>
   <SourceLine>Positions.append "PF"</SourceLine>
   <SourceLine>Positions.append "C"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT Avg(WinsProduced) FROM Players WHERE Season='"+mCurrentSeason+"' AND Pos LIKE '%"+positions(n)+"'"</SourceLine>
   <SourceLine>rs=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>sqlstring="SELECT WinsProduced, rowID FROM Players WHERE Season='"+mCurrentSeason+"' AND Pos LIKE '%"+positions(n)+"'"</SourceLine>
   <SourceLine>rec=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rec) then</SourceLine>
   <SourceLine>while rec.EOF=false</SourceLine>
   <SourceLine>sqlstring="UPDATE Players SET WinsProduced='"+str(rec.IdxField(1).DoubleValue-rs.IdxField(1).DoubleValue)+"' WHERE rowID='"+rec.IdxField(2).StringValue+"'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>rec.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE Players SET WinsProduced='0' WHERE Season='"+mCurrentSeason+"' AND Pos LIKE 'NA'"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
