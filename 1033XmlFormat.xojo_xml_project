 <Method>
  <ItemName>AddGames</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1141059583</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub AddGames()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim anum, bnum as integer</SourceLine>
   <SourceLine>dim findfile(2,1) as string</SourceLine>
   <SourceLine>dim letterlist(2) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim aa,bb as string</SourceLine>
   <SourceLine>dim sqlstrings(19) as string</SourceLine>
   <SourceLine>letterlist(0)="c"</SourceLine>
   <SourceLine>letterlist(1)="b"</SourceLine>
   <SourceLine>letterlist(2)="a"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get recordset that goes through files and gets team and opponents</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, Gm1, Gm2, Gm3 FROM PreNTTSchedule")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>anum=rs.IdxField(1).integerValue</SourceLine>
   <SourceLine>aa=RemoveSpacesFromName(teams(anum-1))</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>mTeamInfo(n,0)=str(anum)</SourceLine>
   <SourceLine>mTeamInfo(n,2)=str(n+1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>bnum=rs.IdxField(n+2).integerValue</SourceLine>
   <SourceLine>mTeamInfo(n,1)=str(bnum)</SourceLine>
   <SourceLine>bb=RemoveSpacesFromName(Teams(bnum-1))</SourceLine>
   <SourceLine>if anum&gt;bnum then</SourceLine>
   <SourceLine>findfile(n,0)=mBoxScoreString+letterlist(n)+"&amp;team1="+bb+"&amp;team2="+aa</SourceLine>
   <SourceLine>findfile(n,1)="2"</SourceLine>
   <SourceLine>Else</SourceLine>
   <SourceLine>findfile(n,0)=mBoxScoreString+letterlist(n)+"&amp;team1="+aa+"&amp;team2="+bb</SourceLine>
   <SourceLine>findfile(n,1)="1"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//download file, parse file, update playerinfo</SourceLine>
   <SourceLine>//pass findfile string, return mPlayerStats string (10,17) or something; also return mTeamInfo string</SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//download info for both teams though we only need for one</SourceLine>
   <SourceLine>ParseGameInfo(findfile(n,0), n, findfile(n,1))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//whether first or second team listed</SourceLine>
   <SourceLine>k=val(findfile(n,1))-1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update playerinfo</SourceLine>
   <SourceLine>for y as integer=0 to 9</SourceLine>
   <SourceLine>sqlstrings(0)="INSERT INTO Stats (Name,  APosition, Mins, FGM, FGA, FG3M, FG3A, FTM, FTA, Reb, Ast, Blk, Stl, TOs, Fouls, Pts, TeamNum, GameNum, Season) VALUES ("</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 15</SourceLine>
   <SourceLine>sqlstrings(j+1)="'"+mPlayerStats(k,y,j)+"',"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sqlstrings(17)="'"+mTeamInfo(n,0)+"',"</SourceLine>
   <SourceLine>sqlstrings(18)="'"+mTeamInfo(n,2)+"',"</SourceLine>
   <SourceLine>sqlstrings(19)="'"+mCurrentSeason+"')"</SourceLine>
   <SourceLine>sqlstring=join(sqlstrings,"")</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update team info</SourceLine>
   <SourceLine>if val(mTeamInfo(n,3))&gt;val(mTeamInfo(n,4)) then</SourceLine>
   <SourceLine>mTeamInfo(n,5)="W"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mTeamInfo(n,5)="L"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO PreNTT (TeamNum, OppNum, GameNum, OurScore, OppScore, WL, Season) VALUES ("</SourceLine>
   <SourceLine>for y as integer=0 to 5</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+mTeamInfo(n,y)+"',"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+mCurrentSeason+"')"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if DoGamebyGame then</SourceLine>
   <SourceLine>PrepareSQLStatement</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ParseGameInfo</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2069241855</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseGameInfo(theurl as string, gamenumber as integer, firstorsecondteam as string)</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mResult=thissocket.Get(theurl, 60)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine>ReadfromTextFile(gamenumber, firstorsecondteam, mResult)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>MsgBox "Error downloading.  Please check your internet connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>theurl as string, gamenumber as integer, firstorsecondteam as string</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>ReadfromTextFile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1662035967</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ReadfromTextFile(gamenumber as integer, firstorsecondteam as string, mResult as string)</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim s as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine>s=19</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 1 //two teams</SourceLine>
   <SourceLine>i=0</SourceLine>
   <SourceLine>for y as integer=1 to 10 //starters</SourceLine>
   <SourceLine>//begin to load teams</SourceLine>
   <SourceLine>for n as integer=0 to 15</SourceLine>
   <SourceLine>line=trim(lines(s))</SourceLine>
   <SourceLine>mPlayerStats(j,i,n)=line</SourceLine>
   <SourceLine>s=s+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>s=s+14</SourceLine>
   <SourceLine>line=trim(lines(s))</SourceLine>
   <SourceLine>if firstorsecondteam=str(j+1) then</SourceLine>
   <SourceLine>mTeamInfo(gamenumber,3)=line</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>mTeamInfo(gamenumber,4)=line</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if j=0 then</SourceLine>
   <SourceLine>s=s+17</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
