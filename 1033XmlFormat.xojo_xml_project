  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>430899199</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetDefenseAndTempo() As string()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim pace, defense as string</SourceLine>
   <SourceLine>dim mystring(1) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT (SELECT Count(*) FROM Games WHERE Pace='Fast' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"'),(SELECT Count(*) FROM Games WHERE Pace='Norm' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"'), (SELECT Count(*) FROM Games WHERE Pace='Slow' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"'), (SELECT Count(*) FROM Games WHERE Defense='Man' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"'),(SELECT Count(*) FROM Games WHERE Defense='Norm' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"'), (SELECT Count(*) FROM Games WHERE Defense='Zone' AND Season='"+mSeason+"' AND TeamNum='"+str(TN)+"') FROM Games WHERE TeamNum='"+str(TN)+"'")</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue&gt;rs.IdxField(2).IntegerValue AND rs.IdxField(1).IntegerValue&gt;rs.IdxField(3).IntegerValue then</SourceLine>
   <SourceLine>pace="Fast"</SourceLine>
   <SourceLine>elseif rs.IdxField(2).IntegerValue&gt;rs.IdxField(1).IntegerValue AND rs.IdxField(2).IntegerValue&gt;rs.IdxField(3).IntegerValue then</SourceLine>
   <SourceLine>pace="Norm"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>pace="Slow"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(4).IntegerValue&gt;rs.IdxField(5).IntegerValue AND rs.IdxField(4).IntegerValue&gt;rs.IdxField(6).IntegerValue then</SourceLine>
   <SourceLine>defense="Man"</SourceLine>
   <SourceLine>elseif rs.IdxField(5).IntegerValue&gt;rs.IdxField(4).IntegerValue AND rs.IdxField(5).IntegerValue&gt;rs.IdxField(6).IntegerValue then</SourceLine>
   <SourceLine>defense="Norm"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>defense="Zone"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mystring(0)=pace</SourceLine>
   <SourceLine>mystring(1)=defense</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return mystring</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
