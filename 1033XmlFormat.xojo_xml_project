  <PartID>1616801791</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PowerRanking(lastpr as integer, pr2 as integer, pr3 as integer) As Double</SourceLine>
   <SourceLine>dim avgpr as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If lastpr &lt; pr2 AND pr2&lt; pr3 Then</SourceLine>
   <SourceLine>avgpr=.65*lastpr+.35*pr2</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>avgpr=.55*lastpr + .35*pr2+.1*pr3</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return avgpr</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Function</SourceLine>
