   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GetLeagueRatingModifier()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim pergame as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT ((2*Sum(FGM) + 1.2*Sum(FTM)+1.6*Sum(FG3M)+2*Sum(Blk)-(Sum(FGA)-Sum(FGM))-(0.8*(Sum(FTA)-Sum(FTM))))/GM)  FROM Players WHERE Season='"+mCurrentSeason+"'"</SourceLine>
