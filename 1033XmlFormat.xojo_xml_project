   <SourceLine>choices.append "had "+format(rs.IdxField(2).integerValue, "#0")+" swats"</SourceLine>
   <SourceLine>choices.append "sent "+format(rs.IdxField(2).integerValue, "#0")+" shots into the stands "</SourceLine>
   <SourceLine>choices.append "blocked "+format(rs.IdxField(2).integerValue, "#0")+" shots"</SourceLine>
   <SourceLine>choices.append "recorded "+format(rs.IdxField(2).integerValue, "#0")+" blocks"</SourceLine>
   <SourceLine>case "Reb"</SourceLine>
   <SourceLine>choices.append "pulled down "+format(rs.IdxField(2).integerValue, "#0")+" rebounds"</SourceLine>
   <SourceLine>choices.append "pulled down "+format(rs.IdxField(2).integerValue, "#0")+" boards"</SourceLine>
   <SourceLine>choices.append "garnered "+format(rs.IdxField(2).integerValue, "#0")+" rebounds"</SourceLine>
   <SourceLine>choices.append "garnered "+format(rs.IdxField(2).integerValue, "#0")+" boards"</SourceLine>
   <SourceLine>choices.append "gathered "+format(rs.IdxField(2).integerValue, "#0")+" rebounds"</SourceLine>
   <SourceLine>choices.append "tallied "+format(rs.IdxField(2).integerValue, "#0")+" boards"</SourceLine>
