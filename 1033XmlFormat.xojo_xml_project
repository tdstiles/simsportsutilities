 <Method>
  <ItemName>CalcPossession</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1050304511</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalcPossession()</SourceLine>
   <SourceLine>dim rs, brs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim possessions as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(FGA), Sum(GM*TOS), Sum(FTA), Sum(GM*RPG) FROM Players WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(OurScore), Sum(OppScore) FROM Games WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(n)+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>possessions=rs.IdxField(1).DoubleValue+rs.IdxField(2).DoubleValue+.4251*rs.IdxField(3).DoubleValue-.309*rs.IdxField(4).DoubleValue</SourceLine>
   <SourceLine>for j as integer=0 to 1</SourceLine>
   <SourceLine>mPossessionScores(n-1,j)=brs.IdxField(j+1).DoubleValue/possessions*100</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
