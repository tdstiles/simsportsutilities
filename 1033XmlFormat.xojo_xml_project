 <Method>
  <ItemName>LoadSchedule</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1956136959</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadSchedule()</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim stringline as string</SourceLine>
   <SourceLine>dim teamlist(-1) as string</SourceLine>
   <SourceLine>dim mLocationString as string</SourceLine>
   <SourceLine>dim teamshere(3) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//create list of teams needing scheduled</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT PreNTTSchedule.TeamNum FROM PreNTTSchedule, PRI WHERE PreNTTSchedule.TeamNum=PRI.TeamNum ORDER BY PRI.PR ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>teamlist.append rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//1v2, 3v4, etc</SourceLine>
   <SourceLine>dim iCounter as integer=ubound(teamlist)</SourceLine>
   <SourceLine>for n as integer=0 to iCounter step 2</SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm1='"+teamlist(n+1)+"' WHERE TeamNum='"+teamlist(n)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm1='"+teamlist(n)+"' WHERE TeamNum='"+teamlist(n+1)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//2v3, 4v5, 6v7, etc</SourceLine>
   <SourceLine>for n as integer=1 to (iCounter-1)</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, Gm2 FROM PreNTTSchedule WHERE TeamNum='"+teamlist(n)+"'")</SourceLine>
   <SourceLine>if rs.IdxField(2).Value=NIL then</SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm2='"+teamlist(n+1)+"' WHERE TeamNum='"+teamlist(n)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm2='"+teamlist(n)+"' WHERE TeamNum='"+teamlist(n+1)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>//cont--1 v last</SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm2='"+teamlist(ubound(teamlist))+"' WHERE TeamNum='"+teamlist(0)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm2='"+teamlist(0)+"' WHERE TeamNum='"+teamlist(ubound(teamlist))+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//find the halfway point and divide ...1v5, 2v6, 3v7,etc.</SourceLine>
   <SourceLine>j=ubound(teamlist)</SourceLine>
   <SourceLine>j=floor(j/2)</SourceLine>
   <SourceLine>for n as integer=0 to j</SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm3='"+teamlist(n+j+1)+"' WHERE TeamNum='"+teamlist(n)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="UPDATE PreNTTSchedule SET Gm3='"+teamlist(n)+"' WHERE TeamNum='"+teamlist(n+j+1)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now prepare string</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT PreNTTSchedule.TeamNum, PreNTTSchedule.Gm1, PreNTTSchedule.Gm2, PreNTTSchedule.Gm3 FROM PreNTTSchedule, PRI WHERE PreNTTSchedule.TeamNum=PRI.TeamNum ORDER BY PRI.TeamName ASC")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>teamshere(n)=MsgBoardLink(rs.IdxField(n+1).IntegerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+"Schedule for "+teamshere(0)+":"+EndofLine+EndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 3</SourceLine>
   <SourceLine>stringline=stringline+"Game "+str(n)+":  "+teamshere(n)+EndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+"------------------------"+EndofLine+EndofLine</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>stringline=stringline+"Please post when you have scheduled your games.  If you have any questions, e-mail me at webmaster@commonsenseonline.net."</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PostResults(stringline)</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>PrepareSQLStatement</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>54239231</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub PrepareSQLStatement()</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim abc as string</SourceLine>
   <SourceLine>dim iCounter as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT TeamNum, GameNum, OppNum, OurScore, OppScore, WL, Season FROM PreNTT WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring=""</SourceLine>
   <SourceLine>iCounter=rs.FieldCount-1</SourceLine>
   <SourceLine>for k as integer=1 to iCounter</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+rs.IdxField(k).StringValue+"',"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+rs.IdxField(rs.fieldCount).StringValue+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>abc=abc+"INSERT INTO MISResults (TeamNum, GameNum, OppNum, OurScore, OppScore, WL, Season) VALUES ("+sqlstring+");"+EndOfLine</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Name,  Season, GameNum, APosition, Mins, FGM, FGA, FG3M, FG3A, FTM, FTA, Reb, Ast, Blk, Stl, TOs, Fouls, Pts, TeamNum FROM Stats WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring=""</SourceLine>
   <SourceLine>for n as integer=1 to 18</SourceLine>
