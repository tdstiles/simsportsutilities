  <PartID>1363585023</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPlayer(rs as recordset, n as integer)</SourceLine>
   <SourceLine>dim height as string</SourceLine>
   <SourceLine>dim feet, inches as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=0 to 9 //load up the mPlayers set</SourceLine>
   <SourceLine>if x=0 then</SourceLine>
   <SourceLine>//name</SourceLine>
   <SourceLine>mPlayers(n,x)=rs.IdxField(x+1).StringValue</SourceLine>
   <SourceLine>elseif x&lt;&gt;2 then</SourceLine>
   <SourceLine>mPlayers(n,x)=rs.IdxField(x+1).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//height</SourceLine>
   <SourceLine>feet=floor(rs.IdxField(3).IntegerValue/12)</SourceLine>
   <SourceLine>inches=rs.IdxField(3).IntegerValue-(12*feet)</SourceLine>
   <SourceLine>height=str(feet)+"'"+str(inches)</SourceLine>
   <SourceLine>mPlayers(n,x)=height</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
