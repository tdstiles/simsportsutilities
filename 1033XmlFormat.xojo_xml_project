  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function SetStarArray() As string()</SourceLine>
   <SourceLine>//this method pulls a recordset that sets all the 768 recruits in order by SSC%</SourceLine>
   <SourceLine>//then sets their star rating</SourceLine>
   <SourceLine>//top 20--5*</SourceLine>
   <SourceLine>//next 20--4.5*</SourceLine>
   <SourceLine>//next 60 -- 4*</SourceLine>
   <SourceLine>//next 80 -- 3.5*</SourceLine>
   <SourceLine>//next 80 -- 3*</SourceLine>
   <SourceLine>//next 100 -- 2.5*</SourceLine>
   <SourceLine>//next 100 -- 2*</SourceLine>
   <SourceLine>//the rest -- 1*</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim PlayerArray(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect("Select Name from PlayerInfo Order By mRatingPct DESC")</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>playerarray.append rs.idxfield(1).stringvalue</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return PlayerArray</SourceLine>
   <SourceLine>&#32;</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
