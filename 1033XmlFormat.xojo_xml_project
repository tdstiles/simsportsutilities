  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub mthdLoadAllConf()</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine>dim sqlarray(-1) as string</SourceLine>
   <SourceLine>dim playername as string</SourceLine>
   <SourceLine>dim teamnum as integer</SourceLine>
   <SourceLine>dim j as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>DBSQLExecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine>DBSQLExecute("DELETE FROM AllConfInfo WHERE Season="+mCurrentSeason)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the file from the web</SourceLine>
   <SourceLine>for n as integer=1 to 32</SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/allstars.asp?league="+league+"&amp;conference="+str(n)</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine>result=CleanHTML(result)</SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now load the all-conference information</SourceLine>
   <SourceLine>//first line to pull info</SourceLine>
   <SourceLine>i=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CPOY</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '1')"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//CFOY</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '2')"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>//1st Team</SourceLine>
   <SourceLine>for r as integer=1 to 5</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '3')"</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//2nd Team</SourceLine>
   <SourceLine>for r as integer=1 to 5</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '4')"</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's get the all-league players</SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/allstars.asp?league="+league+"&amp;conference=33"</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine>result=CleanHTML(result)</SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//first line to pull from</SourceLine>
   <SourceLine>i=1</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//LPOY</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '5')"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//LFOY</SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>playername=escapequotes(lines(i))</SourceLine>
   <SourceLine>teamnum=TeamNumberFromName(lines(i+2))</SourceLine>
   <SourceLine>sqlarray.append "INSERT INTO AllConfInfo (Season, TeamNum, PlayerName, Score) VALUES ('"+mCurrentSeason+"', '"+str(TeamNum)+"', '"+playername+"', '6')"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+12</SourceLine>
   <SourceLine>//All-League Teams</SourceLine>
