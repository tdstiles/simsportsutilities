 <Method>
  <ItemName>TeamStrengthAndWeakness</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1897811967</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TeamStrengthAndWeakness() As string()</SourceLine>
   <SourceLine>dim szTmp(1) as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>sqlstring="SELECT PPG, aPPG, RPG, TOS, Experience, Depth, Height FROM StatTable WHERE TeamNum='"+str(TN)+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=mStatDB.SQLSelect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>dim StatMinMax(1) as integer</SourceLine>
   <SourceLine>StatMinMax(0)=1 //best field</SourceLine>
   <SourceLine>StatMinMax(1)=1 //worst field</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=2 to 7</SourceLine>
   <SourceLine>if rs.IdxField(n).IntegerValue&lt;rs.IdxField(StatMinMax(0)).IntegerValue then</SourceLine>
   <SourceLine>StatMinMax(0)=n</SourceLine>
   <SourceLine>elseif rs.IdxField(n).IntegerValue&gt;rs.IdxField(StatMinMax(1)).IntegerValue then</SourceLine>
   <SourceLine>StatMinMax(1)=n</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim statnames(1) as string</SourceLine>
   <SourceLine>for n as integer= 0 to 1</SourceLine>
   <SourceLine>if StatMinMax(n)=1 then</SourceLine>
   <SourceLine>statnames(n)="Offense"</SourceLine>
   <SourceLine>elseif StatMinMax(n)=2 then</SourceLine>
   <SourceLine>statnames(n)="Defense"</SourceLine>
   <SourceLine>elseif StatMinMax(n)=3 then</SourceLine>
   <SourceLine>statnames(n)="Rebounding"</SourceLine>
   <SourceLine>elseif StatMinMax(n)=4 then</SourceLine>
   <SourceLine>statnames(n)="Turnover Margin"</SourceLine>
   <SourceLine>elseif StatMinMax(n)=5 then</SourceLine>
   <SourceLine>statnames(n)="Experience"</SourceLine>
   <SourceLine>elseif StatMinMax(n)=6 then</SourceLine>
   <SourceLine>statnames(n)="Depth"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>statnames(n)="Size"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sztmp(0)=statnames(0) //strength</SourceLine>
   <SourceLine>szTmp(1)=statnames(1) //weakness</SourceLine>
   <SourceLine>return szTmp</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
