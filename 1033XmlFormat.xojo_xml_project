   <SourceLine></SourceLine>
   <SourceLine>ars=dbsqlselect("SELECT Distinct(Pollnum) FROM VoteResults WHERE Season='"+mCurrentSeason+"' ORDER BY PollNum DESC")</SourceLine>
   <SourceLine>if IfRSGood(ars) then</SourceLine>
   <SourceLine>pollnum=ars.IdxField(1).StringValue</SourceLine>
   <SourceLine>if ars.RecordCount&gt;1 then</SourceLine>
   <SourceLine>haspreviousrnk=true</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>haspreviousrnk=false</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT TeamNum, Points, Firstplace FROM VoteResults WHERE Season='"+mCurrentSeason+"' AND pollnum='"+pollnum+"' ORDER BY Points DESC"</SourceLine>
