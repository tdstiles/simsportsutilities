  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1030989823</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function StatsByConference(LoadArray() as String) As integer</SourceLine>
   <SourceLine>dim sqlstring, recstring, recbstring,w,l as string</SourceLine>
   <SourceLine>dim avgpr as Double</SourceLine>
   <SourceLine>dim rs,rec,recb as RecordSet</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mainbox.loadheader(split("Conf,W,L,Pct,PF,PA,PR", ","))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for x as integer=1 to 32</SourceLine>
   <SourceLine>sqlstring="SELECT Sum(Games.WL='W'), SUM(Games.WL='L'), avg(Games.OurScore), AVG(Games.OppScore), AVG(PRI.PR) FROM Games, PRI WHERE Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' AND Games.TeamNum=PRI.TeamNum AND PRI.Conference='"+str(x)+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>w=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>l=rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>mainbox.addrow str(x), w, l, format(val(w)/(val(w)+val(l)), "#.000"), format(rs.IdxField(3).DoubleValue,"###.0"), format(rs.IdxField(4).DoubleValue, "###.0"), format(rs.IdxField(5).doubleValue, "###.0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games, PRI  WHERE Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>k=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>return k</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
