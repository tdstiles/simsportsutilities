 <Method>
  <ItemName>ParseTeamSchedule</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>814051327</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParseTeamSchedule(teamnum as integer)</SourceLine>
   <SourceLine>dim j as Boolean</SourceLine>
   <SourceLine>dim teamstat as TeamArray</SourceLine>
   <SourceLine>Dim n,k As Integer</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim gamenumber as string</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>dim type,sqlstring as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim score1(1) as double</SourceLine>
   <SourceLine>dim gamestring as string</SourceLine>
   <SourceLine>dim r as integer</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim i as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine>teamstat.TeamNumbers(0)=TeamNum</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mGameCheckDB.Connect then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//set number of games left</SourceLine>
   <SourceLine>if GamesPlayed&lt;13 then</SourceLine>
   <SourceLine>r=3</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>r=1</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if gamesplayed&lt;15 then</SourceLine>
   <SourceLine>i=(gamesplayed+1)*9+34</SourceLine>
   <SourceLine>elseif gamesplayed&lt;18 then</SourceLine>
   <SourceLine>i=(gamesplayed+1)*9+35</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>i=(gamesplayed+1)*9+36</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mTeamNumbers(2)=GamesPlayed</SourceLine>
   <SourceLine>for y as integer=1 to r</SourceLine>
   <SourceLine>//load game info for next game to calculate game score</SourceLine>
   <SourceLine>mTeamNumbers(2)=mTeamNumbers(2)+1</SourceLine>
   <SourceLine>gamenumber=lines(i)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//try to remove team name, just get city name</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>n=TeamNumberFromName(lines(i))</SourceLine>
   <SourceLine>teamstat.TeamNumbers(1)=n</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>i=i+6</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for p as integer=0 to 1</SourceLine>
   <SourceLine>sqlstring="SELECT fPR FROM PRI WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(teamstat.TeamNumbers(p))+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>score1(p)=256-rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>teamstat.GameValue=score1(0)*score1(1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO Games (Tm1, Tm2, GmScore, GameNum) VALUES ('"+str(teamstat.TeamNumbers(0))+"','"+str(teamstat.TeamNumbers(1))+"','"+str(teamstat.gamevalue)+"','"+str(mTeamNumbers(2))+"')"</SourceLine>
   <SourceLine>mGameCheckDB.SQLExecute(sqlstring)</SourceLine>
   <SourceLine>mGameCheckDB.Commit</SourceLine>
   <SourceLine>if mGameCheckDB.error then</SourceLine>
   <SourceLine>msgbox "error"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
