   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>teamshere(n)=MsgBoardLink(rs.IdxField(n+1).IntegerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+"Schedule for "+teamshere(0)+":"+EndofLine+EndofLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 3</SourceLine>
   <SourceLine>stringline=stringline+"Game "+str(n)+":  "+teamshere(n)+EndofLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+"------------------------"+EndofLine+EndofLine</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//split by divisions, top heavy</SourceLine>
   <SourceLine>iCounter=ubound(hostteams)</SourceLine>
   <SourceLine>for n as integer=0 to iCounter</SourceLine>
   <SourceLine>stringline=stringline+"[b]"+teams(hostteams(n)-1)+" Bracket:  [/b]"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT PreNTTSchedule.TeamNum, PreNTTSchedule.Gm1, PreNTTSchedule.Gm2, PreNTTSchedule.Gm3 FROM PreNTTSchedule WHERE TeamNum='"+str(hostteams(n))+"' AND PreNTTSchedule.Season='"+misseason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for r as integer=0 to 3</SourceLine>
   <SourceLine>teamshere(r)=MsgBoardLink(rs.IdxField(r+1).IntegerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+endofline+endofline+"Schedule for "+teamshere(0)+":"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for r as integer=1 to 3</SourceLine>
   <SourceLine>stringline=stringline+"Game "+str(r)+":  "+teamshere(r)+EndOfLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for k as integer=1 to 3</SourceLine>
   <SourceLine>sqlstring="SELECT PreNTTSchedule.TeamNum, PreNTTSchedule.Gm1, PreNTTSchedule.Gm2, PreNTTSchedule.Gm3 FROM PreNTTSchedule WHERE TeamNum='"+rs.idxfield(k+1).stringvalue+"' AND PreNTTSchedule.Season='"+misseason+"'"</SourceLine>
   <SourceLine>ars=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for r as integer=0 to 3</SourceLine>
   <SourceLine>teamshere(r)=MsgBoardLink(ars.IdxField(r+1).IntegerValue)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+endofline+endofline+"Schedule for "+teamshere(0)+":"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for r as integer=1 to 3</SourceLine>
   <SourceLine>stringline=stringline+"Game "+str(r)+":  "+teamshere(r)+EndOfLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>stringline=stringline+"------------------------"+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>stringline=stringline+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stringline=stringline+EndOfLine+EndOfLine</SourceLine>
   <SourceLine>if ubound(leftoverteams)&gt;-1 then</SourceLine>
   <SourceLine>stringline=stringline+"The following teams could not be scheduled because of not having an even number of teams:"+EndOfLine</SourceLine>
   <SourceLine>iCounter=ubound(leftoverteams)</SourceLine>
   <SourceLine>for n as integer=0 to iCounter</SourceLine>
   <SourceLine>stringline=stringline+teams(leftoverteams(n)-1)+EndOfLine</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>stringline=stringline+" Please find additional teams to join the tournament so you can participate.  We apologize for the inconvenience."+EndOfLine</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>stringline=stringline+"Please post when you have scheduled your games.  If you have any questions, e-mail me at webmaster@commonsenseonline.net."+EndOfLine</SourceLine>
   <SourceLine>stringline=stringline+"This schedule has been automatically generated by the [url=http://sourceforge.net/projects/simsportsutils/]LeagueCommissioner  v"+str(app.MajorVersion)+"."+str(app.MinorVersion)+"."+str(app.BugVersion)+"[/url], a free SimSports utility courtesy of [url=http://simsportsnews.blogspot.com]http://simsportsnews.blogspot.com[/url]"+EndOfLine</SourceLine>
   <SourceLine>PostResults(stringline)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "You must Add Teams before generating a schedule for your tournament!"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>self.close</SourceLine>
   <SourceLine>End Sub</SourceLine>
