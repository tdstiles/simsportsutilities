 <Method>
  <ItemName>ParsePlayerfile</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>435826687</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub ParsePlayerfile(teamnum as integer)</SourceLine>
   <SourceLine>dim teamarray(4) as string</SourceLine>
   <SourceLine>Dim n,k As Integer</SourceLine>
   <SourceLine>dim line, sqlstring as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim short as string</SourceLine>
   <SourceLine>dim coachrating as double</SourceLine>
   <SourceLine>dim playerarray(18) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=1</SourceLine>
   <SourceLine>//get coach name</SourceLine>
   <SourceLine>teamarray(0)=lines(n)</SourceLine>
   <SourceLine>n=n+14</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get current wins</SourceLine>
   <SourceLine>for j as integer=1 to 2</SourceLine>
   <SourceLine>k=instr(lines(n),"-")</SourceLine>
   <SourceLine>line=trim(left(lines(n),k-1))</SourceLine>
   <SourceLine>teamarray(j)=line</SourceLine>
   <SourceLine>n=n+8</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get the freshman recruiting rankings</SourceLine>
   <SourceLine>n=n+29</SourceLine>
   <SourceLine>teamarray(3)=trim(lines(n))</SourceLine>
   <SourceLine>n=n+2</SourceLine>
   <SourceLine>teamarray(4)=trim(lines(n))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+32</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//get to players</SourceLine>
   <SourceLine>for qq as integer=1 to 2</SourceLine>
   <SourceLine>for q as integer=1 to 5</SourceLine>
   <SourceLine>for j as integer=0 to 17</SourceLine>
   <SourceLine>playerarray(j)=lines(n)</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>playerarray(18)=str(TendexCalc(val(playerarray(9)), val(playerarray(13)), val(playerarray(11)), val(playerarray(7)), val(playerarray(8)), val(playerarray(15)), val(playerarray(17)), val(playerarray(16)), val(playerarray(10)), val(playerarray(14)), val(playerarray(4))))</SourceLine>
   <SourceLine>playerarray(1)=EscapeQuotes(playerarray(1))</SourceLine>
   <SourceLine>short=""</SourceLine>
   <SourceLine>for nn as integer=0 to 17</SourceLine>
   <SourceLine>short=short+"'"+playerarray(nn)+"',"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>short=short+"'"+playerarray(18)+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO Players (Season, TeamNum, Pos, Player, HT, YR, GM, MPG, PPG, RPG, APG, FGM, FGA, FG3M, FG3A, FTM, FTA, STL, TOS, BLK, Tendex) VALUES ('"+trim(mCurrentSeason)+"','"+str(TeamNum)+"',"+short+")"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>n=n+19</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now on to NA players</SourceLine>
   <SourceLine>for q as integer=1 to 2</SourceLine>
   <SourceLine>for j as integer=0 to 17</SourceLine>
   <SourceLine>playerarray(j)=lines(n)</SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>playerarray(18)=str(TendexCalc(val(playerarray(9)), val(playerarray(13)), val(playerarray(11)), val(playerarray(7)), val(playerarray(8)), val(playerarray(15)), val(playerarray(17)), val(playerarray(16)), val(playerarray(10)), val(playerarray(14)), val(playerarray(4))))</SourceLine>
   <SourceLine>playerarray(1)=EscapeQuotes(playerarray(1))</SourceLine>
   <SourceLine>short=""</SourceLine>
   <SourceLine>for nn as integer=0 to 17</SourceLine>
   <SourceLine>short=short+"'"+playerarray(nn)+"',"</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>short=short+"'"+playerarray(18)+"'"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="INSERT INTO Players (Season, TeamNum, Pos, Player, HT, YR, GM, MPG, PPG, RPG, APG, FGM, FGA, FG3M, FG3A, FTM, FTA, STL, TOS, BLK, Tendex) VALUES ('"+trim(mCurrentSeason)+"','"+str(TeamNum)+"',"+short+")"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>n=n+1</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//update coach rankings</SourceLine>
   <SourceLine>coachrating=val(teamarray(1))*(val(teamarray(1))/12*(1-(val(teamarray(2))/120)))</SourceLine>
   <SourceLine>dbsqlexecute("UPDATE PRI Set WL='"+teamarray(1)+"', Last5WL='"+teamarray(2)+"', Coach='"+escapequotes(teamarray(0))+"', RecruitSH='"+teamarray(3)+"', RecruitHW='"+teamarray(4)+"', CoachRating='"+str(coachrating)+"' WHERE Season='"+trim(mCurrentSeason)+"' AND TeamNum='"+str(teamnum)+"'")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>teamnum as integer</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>TendexCalc</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2055315455</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function TendexCalc(fgm as integer, ftm as integer, fg3m as integer, reb as double, ast as double, stl as double, blk as integer, tos as double, fga as integer, fta as integer, games as integer) As double</SourceLine>
   <SourceLine>if games=0 then</SourceLine>
   <SourceLine>return 0</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return 2*FGM/games+1.2*FTM/games+1.6*FG3m/games+0.9*Reb+1.5*Ast+3*Stl+2*Blk/games-(FGA-FGM)/games-0.8*(FTA-FTM)/games-1.5*TOs</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>fgm as integer, ftm as integer, fg3m as integer, reb as double, ast as double, stl as double, blk as integer, tos as double, fga as integer, fta as integer, games as integer</ItemParams>
  <ItemResult>double</ItemResult>
 </Method>
 <Method>
  <ItemName>UpdateAllPlayers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1200125951</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub UpdateAllPlayers()</SourceLine>
   <SourceLine>dim rs, brs as RecordSet</SourceLine>
   <SourceLine>dim playertendex as double</SourceLine>
   <SourceLine>dim plusorminuspointsperminute as double</SourceLine>
   <SourceLine>dim pointsperminute as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>sqlstring="SELECT Players.rowID, PRI.PR, Players.Tendex, Players.MPG, Players.GM, PRI.TeamNum FROM Players, PRI WHERE PRI.Season='"+mCurrentSeason+"' AND Players.TeamNum=PRI.TeamNum AND Players.Season=PRI.Season"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>if rs.IdxField(5).IntegerValue&lt;&gt;0 then</SourceLine>
   <SourceLine>//first, divide player tendex by league modifier</SourceLine>
   <SourceLine>playertendex=rs.IdxField(3).DoubleValue*mLeagueModifier</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then, take team PR and get SoS modifier.  multiply first value by this</SourceLine>
   <SourceLine>playertendex=playertendex*(SQRT(1.7-(rs.idxfield(2).integervalue/256)^2))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>pointsperminute=playertendex/rs.IdxField(4).DoubleValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//then,  MINUS team opponent scoring average per that player's total minutes</SourceLine>
   <SourceLine>sqlstring="SELECT AVG(Games.OppScore) FROM Games WHERE Games.TeamNum='"+rs.IdxField(6).StringValue+"' AND Games.Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>brs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>plusorminuspointsperminute=pointsperminute-(brs.IdxField(1).DoubleValue/(GamesPlayed*40))</SourceLine>
   <SourceLine>playertendex=plusorminuspointsperminute*(rs.IdxField(4).DoubleValue*rs.IdxField(5).IntegerValue)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>playertendex=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//save mResult to tendex score and move to next player</SourceLine>
   <SourceLine>sqlstring="UPDATE Players SET Tendex='"+str(playertendex)+"' WHERE rowID='"+rs.IdxField(1).StringValue+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//might as well get winsproduced at this point</SourceLine>
   <SourceLine>dim i as new cCalcWinsProduced</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
