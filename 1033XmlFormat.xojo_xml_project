  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>2014601215</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadPrefs()</SourceLine>
   <SourceLine>//this method writes all the preferences that are saved in memory (in the Preferences Module) to a binary file</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim f as folderitem</SourceLine>
   <SourceLine>dim stream as binarystream</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>f=SpecialFolder.Preferences</SourceLine>
   <SourceLine>f=f.child("LeagueCommish")</SourceLine>
   <SourceLine>if f.exists=false then</SourceLine>
   <SourceLine>f.CreateAsFolder</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>f=f.child("Prefs.bin")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If f &lt;&gt; Nil then</SourceLine>
   <SourceLine>if f.exists then</SourceLine>
   <SourceLine>//already created, so load regular</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stream=f.OpenAsBinaryFile(False)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 2</SourceLine>
   <SourceLine>prefColors(n)=stream.ReadPString</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>DoGamebyGame=stream.ReadBoolean</SourceLine>
   <SourceLine>prefBlogger=stream.ReadBoolean</SourceLine>
   <SourceLine>prefELO=stream.ReadUInt8</SourceLine>
   <SourceLine>prefHistory=stream.ReadUInt8</SourceLine>
   <SourceLine>prefPR=stream.ReadUInt8</SourceLine>
   <SourceLine>prefRecruiting=stream.ReadUInt8</SourceLine>
   <SourceLine>prefWindowColor=stream.ReadPString</SourceLine>
   <SourceLine>PrefListboxColor=stream.ReadPString</SourceLine>
   <SourceLine>prefAllNTT=stream.ReadBoolean</SourceLine>
   <SourceLine>prefWiki=stream.ReadBoolean</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's close it out</SourceLine>
   <SourceLine>stream.close</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//not created, so create default prefs file</SourceLine>
   <SourceLine>CreateDefaultPrefFile</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//------------------------</SourceLine>
   <SourceLine>prefplayerpct=60</SourceLine>
   <SourceLine>prefScoutStat=5</SourceLine>
   <SourceLine>prefstats(0)=1</SourceLine>
   <SourceLine>prefstats(1)=3</SourceLine>
   <SourceLine>prefstats(2)=3</SourceLine>
   <SourceLine>prefstats(3)=1</SourceLine>
   <SourceLine>prefstats(4)=2</SourceLine>
