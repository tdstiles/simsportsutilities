 <Method>
  <ItemName>ConvertToMsgBoard</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>363395071</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function ConvertToMsgBoard() As string</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim type(8,1) as string</SourceLine>
   <SourceLine>dim a as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=FormattedText</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>type(0,0)="&lt;a href=""#(.*)"".*&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>type(0,1)="\2"</SourceLine>
   <SourceLine>type(1,0)="&lt;a href=""(.*)"".*&gt;(.*)&lt;/a&gt;"</SourceLine>
   <SourceLine>type(1,1)="[URL=\1]\2[/URL]"</SourceLine>
   <SourceLine>type(2,0)="&lt;br&gt;"</SourceLine>
   <SourceLine>type(2,1)=EndofLine</SourceLine>
   <SourceLine>type(3,0)="&lt;b&gt;(.*)&lt;/b&gt;"</SourceLine>
   <SourceLine>type(3,1)="[b]\1[/b]"</SourceLine>
   <SourceLine>type(4,0)="&lt;i&gt;(.*)&lt;/i&gt;"</SourceLine>
   <SourceLine>type(4,1)="[i]\1[/i]"</SourceLine>
   <SourceLine>type(5,0)="&lt;h2&gt;(.*)&lt;/h2&gt;"</SourceLine>
   <SourceLine>type(5,1)="[b][color=green]\1[/color][/b]"</SourceLine>
   <SourceLine>type(6,0)="&lt;/tr&gt;"</SourceLine>
   <SourceLine>type(6,1)=EndOfLine</SourceLine>
   <SourceLine>type(7,0)="&lt;/td&gt;"</SourceLine>
   <SourceLine>type(7,1)=chr(9)</SourceLine>
   <SourceLine>type(8,0)="&lt;.*&gt;"</SourceLine>
   <SourceLine>type(8,1)=""</SourceLine>
   <SourceLine></SourceLine>
