  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CalcSSCPct(AvgHeight as double)</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim mRatingPct as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT rowID, MyRatingPct, PlayerPlusMinus FROM PlayerInfo")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>mRatingPct=rs.IdxField(2).DoubleValue*(rs.IdxField(3).DoubleValue+18)*(rs.IdxField(3).DoubleValue+18)</SourceLine>
   <SourceLine>if mRatingPct&lt;0 then mRatingPct=0</SourceLine>
   <SourceLine>mRatingPct=sqrt(mRatingPct/AvgHeight)</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE PlayerInfo SET mRatingPct='"+str(mRatingPct)+"' WHERE rowID="+rs.IdxField(1).StringValue)</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we can to normalize these on a 100pt scale</SourceLine>
   <SourceLine>dim variances(-1) as double</SourceLine>
   <SourceLine>dim mNewPct as double</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=db.SQLSelect("SELECT mRatingPct FROM PlayerInfo ORDER BY RowID ASC")</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.EOF=false</SourceLine>
   <SourceLine>variances.append rs.IdxField(1).DoubleValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>variances=NormalizeSet(variances,1,.1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//redo rs select to divide and get myratingpct</SourceLine>
   <SourceLine>rs = DB.SQLSelect("SELECT rowID, mRatingPct FROM PlayerInfo IRDER BY RowID ASC")</SourceLine>
   <SourceLine>dim I as integer=0</SourceLine>
   <SourceLine>if rs&lt;&gt;nil and rs.RecordCount&lt;&gt;0 then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sqlstring="UPDATE PlayerInfo SET mRatingPct='"+str(variances(i))+"' WHERE  rowID="+rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>i=i+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
