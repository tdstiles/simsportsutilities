 <Method>
  <ItemName>CrunchNumbers</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>744747007</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CrunchNumbers(Team as string, Pace as String, Defense as String, OppRanking as Integer)</SourceLine>
   <SourceLine>dim loadarray(5), sqlstring as string</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim w,l as integer</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//check to make sure we have some info to pull</SourceLine>
   <SourceLine>sqlstring="SELECT Games.TeamNum FROM Games WHERE Season='"+mCurrentSeason+"'"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if team="All" then</SourceLine>
   <SourceLine>loadarray(0)="AND Games.TeamNum LIKE '%'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>k=teams.IndexOf(team)</SourceLine>
   <SourceLine>loadarray(0)=" AND Games.TeamNum='"+str(k+1)+"'"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if pace="All" then</SourceLine>
   <SourceLine>loadarray(1)="%"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>loadarray(1)=Pace</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if defense="All" then</SourceLine>
   <SourceLine>loadarray(2)="%"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>loadarray(2)=Defense</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case OppRanking</SourceLine>
   <SourceLine>case 0</SourceLine>
   <SourceLine>loadarray(3)=""</SourceLine>
   <SourceLine>case 1</SourceLine>
   <SourceLine>loadarray(5)=",PRI "</SourceLine>
   <SourceLine>loadarray(3)=" AND Games.OpponentNum=PRI.TeamNum and PRI.PR&lt;'11'"</SourceLine>
   <SourceLine>case 2</SourceLine>
   <SourceLine>loadarray(5)=",PRI "</SourceLine>
   <SourceLine>loadarray(3)=" AND Games.OpponentNum=PRI.TeamNum and PRI.PR&lt;'26'"</SourceLine>
   <SourceLine>case 3</SourceLine>
   <SourceLine>loadarray(5)=",PRI "</SourceLine>
   <SourceLine>loadarray(3)="  AND Games.OpponentNum=PRI.TeamNum and PRI.PR&lt;'51'"</SourceLine>
   <SourceLine>case 4</SourceLine>
   <SourceLine>loadarray(5)=",PRI "</SourceLine>
   <SourceLine>loadarray(3)=" AND Games.OpponentNum=PRI.TeamNum and PRI.PR&lt;'101'"</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>mainbox.DeleteAllRows</SourceLine>
   <SourceLine>avgbox.DeleteAllRows</SourceLine>
   <SourceLine>k=0</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mByGameOrTeam=0 then //done by every game</SourceLine>
   <SourceLine>//change headers on mainbox based on pace/def</SourceLine>
   <SourceLine>mainbox.LoadHeader(split("Team,Opponent,W/L,Score,OppScore,Pace,Defense", ","))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Games.TeamNum, Games.OpponentNum, Games.OurScore, Games.OppScore, Games.WL, Games.Pace, Games.Defense FROM Games "+loadarray(5)+" WHERE  Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>mainbox.addrow teams(rs.idxfield(1).integervalue-1), teams(rs.idxfield(2).integervalue-1), rs.idxfield(3).stringvalue, rs.idxfield(4).stringvalue, rs.idxfield(5).stringvalue, rs.idxfield(6).stringvalue, rs.idxfield(7).stringvalue</SourceLine>
   <SourceLine>rs.movenext</SourceLine>
   <SourceLine>k=k+1</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>elseif mByGameOrTeam=1 then //want stats by team</SourceLine>
   <SourceLine>k=StatsByTeam(loadarray)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>k=StatsByConference(loadarray)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="SELECT Avg(Games.OurScore), Avg(Games.OppScore) FROM Games "+loadarray(5)+" WHERE  Games.Season='"+mCurrentSeason+"' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>avgbox.addrow format(rs.idxfield(1).doublevalue, "###.0"), format(rs.idxfield(2).doublevalue, "###.0")</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if team="All" and Pace="All" and Defense="All" and OppRanking=0 then</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL LIKE '%W%'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL LIKE '%W%' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>w=rs.idxfield(1).Value</SourceLine>
   <SourceLine>avgbox.cell(0,2)=str(w)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if team="All" and Pace="All" and Defense="All" and OppRanking=0 then</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL LIKE '%L%'"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring="SELECT Count(*) FROM Games "+loadarray(5)+" WHERE Games.Season='"+mCurrentSeason+"' AND Games.WL LIKE '%L%' AND Games.Pace LIKE '"+loadarray(1)+"' AND  Games.Defense LIKE '"+loadarray(2)+"' "+loadarray(0)+loadarray(3)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>l=rs.idxfield(1).Value</SourceLine>
   <SourceLine>avgbox.cell(0,3)=str(l)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>avgbox.cell(0,4)=format(w/(w+l),"#.000")</SourceLine>
   <SourceLine>avgbox.cell(0,5)=str(k)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "No game info loaded for this season."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>Team as string, Pace as String, Defense as String, OppRanking as Integer</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
