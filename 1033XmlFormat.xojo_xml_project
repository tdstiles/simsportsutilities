  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function GetWinner() As cTourneyTeam</SourceLine>
   <SourceLine>//this method compares the two scores and returns the team that is the winner</SourceLine>
   <SourceLine>if rgTeams(0).mScore&gt;rgTeams(1).mScore then</SourceLine>
   <SourceLine>return rgTeams(0)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>return rgTeams(1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
