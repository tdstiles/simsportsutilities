   <SourceLine>RecapTeams(1)=TmpTeams</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>GOTWRecapGN=Gamenumber</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's download the box score and parse it</SourceLine>
   <SourceLine>LoadBoxScore</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we have the RecapTeams loaded with players</SourceLine>
   <SourceLine>dim MoV as integer= RecapTeams(0).points-RecapTeams(1).points</SourceLine>
   <SourceLine>if MoV&gt;0 then</SourceLine>
   <SourceLine>w=0</SourceLine>
   <SourceLine>l=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>w=1</SourceLine>
   <SourceLine>l=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
