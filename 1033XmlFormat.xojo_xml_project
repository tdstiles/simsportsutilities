    <SourceLine>prefelo=val(efPreseason(2).text)</SourceLine>
    <SourceLine>prefHistory=val(efPreseason(3).Text)</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>DoGamebyGame=chkGame.Value</SourceLine>
    <SourceLine>prefBlogger=chkBlogger.value</SourceLine>
    <SourceLine>'prefWindowColor="&amp;c"+j(3).text</SourceLine>
    <SourceLine>'PrefListboxColor="&amp;c"+j(4).text</SourceLine>
    <SourceLine>prefAllNTT=chkAllNTT.value</SourceLine>
    <SourceLine>prefWiki=chkWiki.Value</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>SavePrefs</SourceLine>
    <SourceLine>LoadPrefs</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>else</SourceLine>
    <SourceLine>msgbox "Please fill in both league and season name before submitting."</SourceLine>
    <SourceLine>end</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>wndMain.title="League Commissioner:  L-"+league+"  S"+mCurrentSeason</SourceLine>
    <SourceLine>self.close</SourceLine>
    <SourceLine></SourceLine>
    <SourceLine>End Sub</SourceLine>
   </ItemSource>
  </HookInstance>
