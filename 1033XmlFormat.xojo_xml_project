  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>GetConfFinish</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1795129343</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GetConfFinish()</SourceLine>
   <SourceLine>//this method is fired after game 15 is finished.  it downloads the conference tournament page and gets the finish for the teams.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT Max(ConfFinish) FROM PRI WHERE Season="+mCurrentSeason)</SourceLine>
   <SourceLine>if IfRSGood(rs) and rs.IdxField(1).IntegerValue&gt;0 then</SourceLine>
   <SourceLine>//we have a conf finish already, so no need</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//let's load 'em up</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim iInstr as integer</SourceLine>
   <SourceLine>dim iMax as integer</SourceLine>
   <SourceLine>dim szTeamName, szSeeding as string</SourceLine>
   <SourceLine>dim line as string</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim l as integer</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 32</SourceLine>
   <SourceLine>mResult=""</SourceLine>
   <SourceLine>mResult=thissocket.Get("http://drivethelane.com/bask/weekly/lg000"+right("0"+league,2)+"/cta"+right("0"+str(n),2)+".html", 60)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mResult &lt;&gt; "" then</SourceLine>
   <SourceLine>mResult=CleanHTML(mResult)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>lines=split(mResult, EndOfLine)</SourceLine>
   <SourceLine>iMax=ubound(lines)</SourceLine>
   <SourceLine>for j as integer=0 to iMax</SourceLine>
   <SourceLine>iInstr=instr(lines(j),"(")</SourceLine>
   <SourceLine>if iInstr&gt;0 then</SourceLine>
   <SourceLine>//we have a paren</SourceLine>
   <SourceLine>szSeeding=mid(lines(j),iInstr+1,1)</SourceLine>
   <SourceLine>if iInstr&gt;5 then</SourceLine>
   <SourceLine>//we're looking at the end of it</SourceLine>
   <SourceLine>szTeamName=left(lines(j),iInstr-1)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//we're looking at the beginning</SourceLine>
   <SourceLine>szTeamName=mid(lines(j), iInstr+4)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//we just want the city name</SourceLine>
   <SourceLine>//try to remove team name, just get city name</SourceLine>
   <SourceLine>k=instr(szTeamName," ")</SourceLine>
   <SourceLine>if k&gt;0 then</SourceLine>
   <SourceLine>line=szTeamName</SourceLine>
   <SourceLine>szTeamName=left(szTeamName,k-1)</SourceLine>
   <SourceLine>l=teams.IndexOf(szTeamName)</SourceLine>
   <SourceLine>while l=-1 //only first part of name, need second half of city</SourceLine>
   <SourceLine>k=instr(k+1,line," ")</SourceLine>
   <SourceLine>if k=0 then</SourceLine>
   <SourceLine>szTeamName=line</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>szTeamName=left(line,k-1)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>l=teams.IndexOf(szTeamName)</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>l=l+1</SourceLine>
   <SourceLine>sqlstring="UPDATE PRI SET ConfFinish="+szSeeding+" WHERE TeamNum="+str(l)+" AND Season="+mCurrentSeason</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
