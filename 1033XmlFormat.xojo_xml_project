 <Method>
  <ItemName>GamesUpdateOverview</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1576990719</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GamesUpdateOverview()</SourceLine>
   <SourceLine>dim setmissed(-1) as integer</SourceLine>
   <SourceLine>dim correct as boolean</SourceLine>
   <SourceLine>dim rs as RecordSet</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//delete all games higher than the game we want</SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>sqlstring="DELETE FROM Games WHERE Season='"+mCurrentSeason+"' AND GameNum&gt;='"+str(GamesPlayed)+"'"</SourceLine>
   <SourceLine>dbsqlexecute(sqlstring)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//figure out how many games have been played so far, what the highest game # is</SourceLine>
   <SourceLine>rs=dbsqlselect("SELECT Max(GameNum) FROM Games WHERE Season='"+mCurrentSeason+"'")</SourceLine>
   <SourceLine>mHighestGame=rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>correct=LoadTeamGames(n)</SourceLine>
   <SourceLine>if correct=false then</SourceLine>
   <SourceLine>setmissed.Append(n)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>while UBound(setmissed)&gt;-1</SourceLine>
   <SourceLine>correct=LoadTeamGames(setmissed(0))</SourceLine>
   <SourceLine>if correct then</SourceLine>
   <SourceLine>setmissed.Remove(0)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if we have more than 15 games, then let's check the conference finishes</SourceLine>
   <SourceLine>if GamesPlayed&gt;14 then</SourceLine>
   <SourceLine>GetConfFinish</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
