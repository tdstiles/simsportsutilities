 <Method>
  <ItemName>CreateTourneyDBs</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>720590847</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub CreateTourneyDBs()</SourceLine>
   <SourceLine>dim sqlarray(-1) as string</SourceLine>
   <SourceLine>mTourneys(0)="NTT"</SourceLine>
   <SourceLine>mTourneys(1)="PTT"</SourceLine>
   <SourceLine>mTourneys(2)="RTT"</SourceLine>
   <SourceLine>mTourneys(3)="DTT"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//First, create the main tables we'll use</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>DBSQLExecute(sqlarray(n))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Now, let's parse the tournament pages </SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>dim tourneys(3) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>tourneys(0)="nt1a"</SourceLine>
   <SourceLine>tourneys(1)="nt2a"</SourceLine>
   <SourceLine>tourneys(2)="nt3a"</SourceLine>
   <SourceLine>tourneys(3)="nt4a"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dbsqlexecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine>//go through for each individual tournament</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>theurl="http://www.drivethelane.com/bask/weekly/lg000"+right("0"+league,2)+"/"+tourneys(n)+".html"</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if result&lt;&gt;"" then</SourceLine>
   <SourceLine>result=CleanHTMLForSeeding(result)</SourceLine>
   <SourceLine>lines=split(result, EndOfLine)</SourceLine>
   <SourceLine>LoadInitialTournamentTeams(lines,n)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>msgbox "Error downloading.  Check your connection and try again."</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>DBSQLExecute("VACUUM")</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadTourneyGamesAndStats</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1459951615</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadTourneyGamesAndStats()</SourceLine>
   <SourceLine>//This method is run after every game greater than 18 (i.e. every tournament game).  It first checks the GAMES table to see which teams are still alive (that is, those who don't have a loss 2 games before).</SourceLine>
   <SourceLine>//Next, for those teams who are alive, we pull the box score and parse those stats.  We stick the stats in the Tourney_Stats Folder.</SourceLine>
   <SourceLine>//Finally, if this is after game 24, we generate the all-tourney teams.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'sqlarray.append "CREATE TABLE Tourney_Teams (rowID INTEGER PRIMARY KEY, TeamNum integer, Tourney varchar, StillAlive Boolean)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sStillAlive(-1) as integer</SourceLine>
   <SourceLine>DBSQLExecute("BEGIN TRANSACTION")</SourceLine>
   <SourceLine>DBSQLExecute("DELETE FROM Tourney_Stats WHERE Season='"+mCurrentSeason+"' AND GameNum="+str(GamesPlayed))</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>If GamesPlayed=19 then</SourceLine>
   <SourceLine>//first time, so everyone is still alive</SourceLine>
   <SourceLine>for n as integer=1 to 256</SourceLine>
   <SourceLine>sStillAlive.append n</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>//some teams may be knocked out.</SourceLine>
   <SourceLine>dim nPreviousGameNum as integer=GamesPlayed-1</SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT TeamNum FROM Tourney_Teams WHERE Season='"+mCurrentSeason+"' AND StillAlive=1")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//this is a list of all the teams still alive.  Let's get boxscores and stats for them.</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>while rs.eof=false</SourceLine>
   <SourceLine>sStillAlive.append rs.IdxField(1).IntegerValue</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>wend</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//Now, for each team that's still alive, we get the boxscore and update the stats</SourceLine>
   <SourceLine>dim iMax as integer=ubound(sStillAlive)</SourceLine>
   <SourceLine>for n as integer=0 to iMax</SourceLine>
   <SourceLine>GetTourneyBoxScore(sStillAlive(n))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//if this is game 24, let's get the all-tourney teams and then delete the tables</SourceLine>
   <SourceLine>if GamesPlayed=24 then</SourceLine>
   <SourceLine>dim sText as new StringBuilder</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim players(4) as string</SourceLine>
   <SourceLine>dim playerstring(-1) as string</SourceLine>
   <SourceLine>dim teaminfo as string</SourceLine>
   <SourceLine>dim columnstring(-1) as string</SourceLine>
   <SourceLine>playerstring=split("Pos,Name,PPG,RPG,APG,SPG,Blk,Team", ",")</SourceLine>
   <SourceLine>dim additions(1) as string</SourceLine>
   <SourceLine>additions(0)=""</SourceLine>
   <SourceLine>additions(1)=" AND Tourney_Stats.GameNum&gt;22 "</SourceLine>
   <SourceLine>dim tourneyname as string</SourceLine>
   <SourceLine>for n as integer=0 to 3</SourceLine>
   <SourceLine>//Go through for each tournament.</SourceLine>
   <SourceLine>//First, get the All-Tourney teams (r=0)</SourceLine>
   <SourceLine>//then, the Tourney Final Four teams (r=1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for r as integer=0 to 1</SourceLine>
   <SourceLine>for j as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT TS.PlayerName, TS.TeamNum, Count(*), 3*Sum(TS.FGM)+1.7*Sum(TS.FTM)+1.6*Sum(TS.FG3M)+0.9*Sum(TS.REB)+1.5*Sum(TS.AST)+3*Sum(TS.STL)+2*Sum(TS.BLK)-Sum(TS.FGA)-0.5*Sum(TS.FTA)-1.8*Sum(TS.TOs)-0.4*Sum(TS.PFs) as A FROM Tourney_Stats as TS, Tourney_Teams as TT WHERE TS.Season=TT.Season AND TT.Season='"+mCurrentSeason+"' AND TS.TeamNum=TT.TeamNum "+additions(r)+"AND TT.Tourney='"+mTourneys(n)+"' AND TS.Pos LIKE '%"+positions(j)+"%' GROUP BY TS.PlayerName ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>players(j)=rs.IdxField(1).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now, we can build the Tournament Team</SourceLine>
   <SourceLine>if r=0 then</SourceLine>
   <SourceLine>tourneyname="All-"+mTourneys(n)+" Team"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>tourneyname=mTourneys(n)+" All-Final Four Team"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>stext.Append TableGeneratorTitle(tourneyname, playerstring,1)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT Pos, PlayerName, Avg(Pts), Avg(Reb), Avg(Ast), Avg(Stl), Avg(Blk), TeamNum FROM Tourney_Stats WHERE Season='"+mCurrentSeason+"' AND PlayerName="+players(j)+additions(r)+" GROUP BY PlayerName"</SourceLine>
   <SourceLine>rs=DBSQLSELECT(sqlstring)</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>teaminfo=HTMLLink(rs.IdxField(8).IntegerValue, 3)</SourceLine>
   <SourceLine>columnstring=split(rs.idxfield(1).stringvalue+","+ rs.IdxField(2).stringValue+","+format(rs.IdxField(3).DoubleValue, "#0.0")+","+format(rs.IdxField(4).DoubleValue, "#0.0")+","+format(rs.IdxField(5).DoubleValue, "#0.0")+","+format(rs.IdxField(6).DoubleValue, "#0.0")+","+format(rs.IdxField(7).DoubleValue, "#0.0")+","+teaminfo, ",")</SourceLine>
   <SourceLine>stext.append ColumnGenerator(j,columnstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>stext.Append CloseTable</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now let's drop the old tables and clear out the space</SourceLine>
   <SourceLine>'DBSQLExecute("DROP TABLE Tourney_Stats")</SourceLine>
   <SourceLine>'DBSQLExecute("DROP TABLE Tourney_Teams")</SourceLine>
   <SourceLine>db.Commit</SourceLine>
   <SourceLine>DBSQLExecute("VACUUM")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>stext.append AddFooter</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>PostResults(stext.ToString)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>LoadInitialTournamentTeams</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1717708799</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub LoadInitialTournamentTeams(lines() as string, tourney as integer)</SourceLine>
   <SourceLine>//This method breaks out the lines and loads the teams into the initial tourney DB</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim iMax as integer=ubound(lines)</SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>for i as integer=0 to iMax</SourceLine>
   <SourceLine>if instr(lines(i),"&amp;nbsp")=0 then</SourceLine>
   <SourceLine>k=instr(lines(i), "--")</SourceLine>
   <SourceLine>if k&gt;0 then</SourceLine>
   <SourceLine>lines(i)=mid(lines(i), k+2)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>k=TeamNumberFromName(lines(i))</SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT TeamNum FROM Tourney_Teams WHERE Season='"+mCurrentSeason+"' AND TeamNum='"+str(k)+"'")</SourceLine>
   <SourceLine>if not IfRSGood(rs) then</SourceLine>
   <SourceLine>sqlstring= "INSERT INTO Tourney_Teams (TeamNum, Tourney, StillAlive, Season) VALUES ('"+str(k)+"', '"+mTourneys(tourney)+"', '1', '"+mCurrentSeason+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>lines() as string, tourney as integer</ItemParams>
  <ItemResult></ItemResult>
 </Method>
 <Method>
  <ItemName>GetTourneyBoxScore</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>832991231</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Sub GetTourneyBoxScore(TeamNum as Integer)</SourceLine>
   <SourceLine>//This method pulls box scores and stats for each team that is still alive.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim theurl as string</SourceLine>
   <SourceLine>dim thissocket as new HTTPSocket</SourceLine>
   <SourceLine>dim teamshere(1) as RecapTeams</SourceLine>
   <SourceLine>dim result as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>rs=DBSQLSELECT("SELECT OpponentNum, WL FROM Games WHERE TeamNum="+str(TeamNum)+" AND Season="+mCurrentSeason+" AND GameNum="+str(GamesPlayed))</SourceLine>
   <SourceLine>if IfRSGood(rs) then</SourceLine>
   <SourceLine>dim a,b as string</SourceLine>
   <SourceLine>a=replaceall(Teams(TeamNum-1)," ", "")</SourceLine>
   <SourceLine>b=replaceall(Teams(rs.idxfield(1).integervalue-1)," ", "")</SourceLine>
   <SourceLine>theurl="http://drivethelane.com/bask/runtime/boxscore.asp?league=000"+right("0"+league,2)+"&amp;game=a&amp;team1="+a+"&amp;team2="+b</SourceLine>
   <SourceLine>result=thissocket.Get(theurl, 45)</SourceLine>
   <SourceLine>if result&lt;&gt;"" then</SourceLine>
   <SourceLine>result=CleanHTML(result)</SourceLine>
   <SourceLine>dim lines(-1) as string</SourceLine>
   <SourceLine>lines=split(result,EndOfLine)</SourceLine>
   <SourceLine>dim shortstring as string</SourceLine>
   <SourceLine>dim thisplayer as RecapPlayers</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//after splitting out the array, we start to parse through it, line by line</SourceLine>
   <SourceLine>dim j as integer=3</SourceLine>
   <SourceLine>dim iMax as integer=ubound(lines)</SourceLine>
   <SourceLine>for n as integer=0 to 1</SourceLine>
   <SourceLine>j=j+15</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now get each player</SourceLine>
   <SourceLine>for t as integer=0 to 9</SourceLine>
   <SourceLine>if j+16&gt;iMax then exit //check in case we only have 9 players</SourceLine>
   <SourceLine>thisplayer.Name=lines(j+1)</SourceLine>
   <SourceLine>thisplayer.pos=lines(j+2)</SourceLine>
   <SourceLine>thisplayer.Minutes=val(lines(j+3))</SourceLine>
   <SourceLine>thisplayer.fgm=val(lines(j+4))</SourceLine>
   <SourceLine>thisplayer.fga=val(lines(j+5))</SourceLine>
   <SourceLine>thisplayer.FG3M=val(lines(j+6))</SourceLine>
   <SourceLine>thisplayer.fg3a=val(lines(j+7))</SourceLine>
   <SourceLine>thisplayer.ftm=val(lines(j+8))</SourceLine>
   <SourceLine>thisplayer.fta=val(lines(j+9))</SourceLine>
   <SourceLine>thisplayer.Reb=val(lines(j+10))</SourceLine>
   <SourceLine>thisplayer.ast=val(lines(j+11))</SourceLine>
   <SourceLine>thisplayer.blk=val(lines(j+12))</SourceLine>
   <SourceLine>thisplayer.stl=val(lines(j+13))</SourceLine>
   <SourceLine>thisplayer.TOs=val(lines(j+14))</SourceLine>
   <SourceLine>thisplayer.PFs=val(lines(j+15))</SourceLine>
   <SourceLine>thisplayer.points=val(lines(j+16))</SourceLine>
   <SourceLine>teamshere(n).Players(t)= thisplayer</SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j=j+16</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//alright.  now we have both teams loaded up.  Let's figure out which one is the active team and load up its stats.</SourceLine>
   <SourceLine>dim nSelectedTeam as Integer</SourceLine>
   <SourceLine>if rs.IdxField(1).IntegerValue&lt;TeamNum then</SourceLine>
   <SourceLine>//they're first, so we're team two</SourceLine>
   <SourceLine>nSelectedTeam=1</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>nSelectedTeam=0</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>for n as integer=0 to 9</SourceLine>
   <SourceLine>thisplayer=teamshere(nSelectedTeam).Players(n)</SourceLine>
   <SourceLine>sqlstring= "INSERT INTO Tourney_Stats (Season, GameNum, TeamNum, PlayerName, Pos, FGM, FGA, FG3M, FG3A, FTM, FTA, REB, AST, BLK, STL, TOs, PFs, Pts) VALUES ('"+mCurrentSeason+"', '"+str(GamesPlayed)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(TeamNum)+"',"</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+escapequotes(thisplayer.name)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+thisplayer.pos+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.fgm)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.fga)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.fg3m)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.fg3a)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.ftm)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.fta)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.reb)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.ast)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.blk)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.stl)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.TOs)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.pfs)+"', "</SourceLine>
   <SourceLine>sqlstring=sqlstring+"'"+str(thisplayer.points)+"')"</SourceLine>
   <SourceLine>DBSQLExecute(sqlstring)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now we update the "Still Alive" if the team lost</SourceLine>
   <SourceLine>if rs.IdxField(2).StringValue="L" then</SourceLine>
   <SourceLine>DBSQLExecute("UPDATE Tourney_Teams SET StillAlive='0' WHERE Season='"+mCurrentSeason+"' AND TeamNum="+str(TeamNum))</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>End Sub</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>33</ItemFlags>
  <IsShared>0</IsShared>
