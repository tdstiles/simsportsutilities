 <Method>
  <ItemName>CleanHTML</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>166754303</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function CleanHTML(a as string) As string</SourceLine>
   <SourceLine>Dim r As New RegEx</SourceLine>
   <SourceLine>dim j(5,1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>j(0,0)="&lt;td.*&gt;"</SourceLine>
   <SourceLine>j(0,1)=EndOfLine</SourceLine>
   <SourceLine>j(1,0)="&lt;!-- BEGIN LINKEXCHANGE CODE SS--&gt;.*&lt;!-- END LINKEXCHANGE CODE --&gt;"</SourceLine>
   <SourceLine>j(1,1)=""</SourceLine>
   <SourceLine>j(2,0)="&lt;!--.*--&gt;"</SourceLine>
   <SourceLine>j(2,1)=""</SourceLine>
   <SourceLine>j(3,0)="&lt;style.*/style&gt;"</SourceLine>
   <SourceLine>j(3,1)=""</SourceLine>
   <SourceLine>j(4,0)="&lt;/center&gt;"</SourceLine>
   <SourceLine>j(4,1)=EndOfLine</SourceLine>
   <SourceLine>j(5,0)="&lt;.*&gt;"</SourceLine>
   <SourceLine>j(5,1)=""</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>r.Options.Greedy = False</SourceLine>
   <SourceLine>r.Options.DotMatchAll = True</SourceLine>
   <SourceLine>r.Options.ReplaceAllMatches = True</SourceLine>
   <SourceLine>for n as integer=0 to 5</SourceLine>
   <SourceLine>r.SearchPattern =j(n,0)</SourceLine>
   <SourceLine>r.ReplacementPattern = j(n,1)</SourceLine>
   <SourceLine>a=Trim(r.Replace(a))</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>a=removetabs(a)</SourceLine>
   <SourceLine>a=removeblanklines(a)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return a</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>a as string</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
 <Method>
  <ItemName>PlayerString</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1248724991</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function PlayerString(rs as recordset, optional addayear as boolean) As string</SourceLine>
   <SourceLine>dim thisstring as string</SourceLine>
   <SourceLine>dim c as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim playeryear as string</SourceLine>
   <SourceLine>if addayear=false then</SourceLine>
   <SourceLine>playeryear=rs.IdxField(4).StringValue</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>playeryear=modAddAYear(rs.IdxField(4).StringValue)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim andstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if mJustPlayerStats then</SourceLine>
   <SourceLine>//this is from the GOTW POG method.  We just want his new averages after him</SourceLine>
   <SourceLine>thisstring=format(rs.IdxField(5).doubleValue,"##.0")+"ppg, "</SourceLine>
   <SourceLine>andstring="and "</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>thisstring=changeheight(rs.IdxField(3).StringValue)+" "+playeryear+" "+rs.IdxField(2).StringValue+" "+rs.IdxField(1).StringValue+"  ("+format(rs.IdxField(5).doubleValue,"##.0")+"ppg, "</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim k as integer</SourceLine>
   <SourceLine>dim positionstring as string</SourceLine>
   <SourceLine>k=Len(rs.IdxField(2).StringValue)</SourceLine>
   <SourceLine>if k&gt;2 or rs.idxfield(2).stringvalue="bC" then</SourceLine>
   <SourceLine>positionstring=mid(rs.IdxField(2).StringValue, 2)</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>positionstring=rs.IdxField(2).StringValue</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>select case positionstring //tailor stats by position</SourceLine>
   <SourceLine>case "PG"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(8).DoubleValue*2.5&gt;(rs.IdxField(6).IntegerValue) then</SourceLine>
   <SourceLine>c=format(rs.IdxField(8).doubleValue,"##.0")+"spg"</SourceLine>
   <SourceLine>thisstring=thisstring+format(rs.IdxField(7).doubleValue,"##.0")+"apg, "+andstring+c</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>c=format(rs.IdxField(6).doubleValue,"##.0")+"rpg"</SourceLine>
   <SourceLine>thisstring=thisstring+c+", "+andstring+format(rs.IdxField(7).doubleValue,"##.0")+"apg"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case "SG"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(7).DoubleValue*1.5&gt;(rs.IdxField(6).IntegerValue) then</SourceLine>
   <SourceLine>c=format(rs.IdxField(8).doubleValue,"##.0")+"apg"</SourceLine>
   <SourceLine>thisstring=thisstring+c+", "+andstring+format(rs.IdxField(8).doubleValue,"##.0")+"spg"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>c=format(rs.IdxField(6).doubleValue,"##.0")+"rpg"</SourceLine>
   <SourceLine>thisstring=thisstring+c+", "+andstring+format(rs.IdxField(8).doubleValue,"##.0")+"spg"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case "SF"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if rs.IdxField(8).DoubleValue*2&gt;(rs.IdxField(9).IntegerValue/rs.IdxField(10).IntegerValue) then</SourceLine>
   <SourceLine>c=format(rs.IdxField(8).doubleValue,"##.0")+"spg"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>if mJustPlayerStats then</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).integerValue/rs.idxfield(10).integervalue,"#0.0")+"bpg"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).IntegerValue, "#0")+"blk"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>thisstring=thisstring+format(rs.IdxField(6).doubleValue,"##.0")+"rpg, "+andstring+c</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>case "PF"</SourceLine>
   <SourceLine>if mJustPlayerStats then</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).integerValue/rs.idxfield(10).integervalue,"#0.0")+"bpg"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).IntegerValue, "#0")+"blk"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>thisstring=thisstring+format(rs.IdxField(6).doubleValue,"##.0")+"rpg, "+andstring+c</SourceLine>
   <SourceLine>case "C"</SourceLine>
   <SourceLine>if mJustPlayerStats then</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).integerValue/rs.idxfield(10).integervalue,"#0.0")+"bpg"</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>c=format(rs.IdxField(9).IntegerValue, "#0")+"blk"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>thisstring=thisstring+format(rs.IdxField(6).doubleValue,"##.0")+"rpg, "+andstring+c</SourceLine>
   <SourceLine>end select</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if not mJustPlayerStats then</SourceLine>
   <SourceLine>thisstring=thisstring+")"</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>return thisstring</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams>rs as recordset, optional addayear as boolean</ItemParams>
  <ItemResult>string</ItemResult>
 </Method>
