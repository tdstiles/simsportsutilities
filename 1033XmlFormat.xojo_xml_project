 <Method>
  <ItemName>mthHSAAAwardList</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>1659418623</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function mthHSAAAwardList() As string(,)</SourceLine>
   <SourceLine>//This method pulls the players and assigns them to teams.  In our module, we have mPlayers, which has the player name and info to build the string if we need it.</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>dim rs as recordset</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//awards(n,0)=Award Name</SourceLine>
   <SourceLine>//awards(n,1)=Stat to pull at end (i.e. OppRatingPct or Defensive stats)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>'opprating=sqrt(pts + 2*reb+4*blk+6*stl-4*tos+2*ast)</SourceLine>
   <SourceLine>'newopprating=pts/2+reb+blk+stl-tos+.7*ast</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>awards(0,0)="1st Team All-League"</SourceLine>
   <SourceLine>awards(0,1)="(PPG+1.4*RPG+2*BPG+5*SPG-2*TPG+3*APG)"</SourceLine>
   <SourceLine>awards(1,0)="2nd Team All-League"</SourceLine>
   <SourceLine>awards(1,1)="(PPG+1.4*RPG+2*BPG+5*SPG-2*TPG+3*APG)"</SourceLine>
   <SourceLine>awards(4,0)="All-Defense Team"</SourceLine>
   <SourceLine>awards(4,1)="(RPG/2+5*SPG+BPG)"</SourceLine>
   <SourceLine>awards(5,0)="Player of the Year"</SourceLine>
   <SourceLine>awards(5,1)="(PPG+1.4*RPG+2*BPG+5*SPG-2*TPG+3*APG)"</SourceLine>
   <SourceLine>awards(2,0)="3rd Team All-League"</SourceLine>
   <SourceLine>awards(2,1)="(PPG+1.4*RPG+2*BPG+5*SPG-2*TPG+3*APG)"</SourceLine>
   <SourceLine>awards(3,0)="4th Team All-League"</SourceLine>
   <SourceLine>awards(3,1)="(PPG+1.4*RPG+2*BPG+5*SPG-2*TPG+3*APG)"</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 5 //for each award</SourceLine>
   <SourceLine>if j&lt;&gt;5 then</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring="SELECT Name, HSName, Height, PPG, RPG, APG, SPG, BPG, TPG, Pos, "+awards(j,1)+" as A FROM PlayerInfo WHERE Pos='"+positions(n)+"' AND Season='"+mCurrentSeason+"' ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>if j=1 then //2nd team, so skip the first record</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>elseif j=2 then</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>elseif j=3 then</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>rs.MoveNext</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>LoadPlayer(rs, j*5+n)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //POY, so only once</SourceLine>
   <SourceLine>sqlstring="SELECT Name, HSName, Height, PPG, RPG, APG, SPG, BPG, TPG, Pos, "+awards(j,1)+" as A FROM PlayerInfo WHERE Season='"+mCurrentSeason+"' ORDER BY A DESC"</SourceLine>
   <SourceLine>rs=dbsqlselect(sqlstring)</SourceLine>
   <SourceLine>LoadPlayer(rs, 25)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>//now, we have a fully loaded mPlayers, so we can move on to building the thread if we need it</SourceLine>
   <SourceLine>return mPlayers</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
  <TextEncoding>134217984</TextEncoding>
  <AliasName></AliasName>
  <ItemFlags>0</ItemFlags>
  <IsShared>0</IsShared>
  <ItemParams></ItemParams>
  <ItemResult>string(,)</ItemResult>
 </Method>
 <Method>
  <ItemName>BuildHTML</ItemName>
  <Compatibility></Compatibility>
  <Visible>1</Visible>
  <PartID>89751551</PartID>
  <ItemSource>
   <TextEncoding>134217984</TextEncoding>
   <SourceLine>Function BuildHTML() As string</SourceLine>
   <SourceLine>dim sbstring as new StringBuilder</SourceLine>
   <SourceLine>dim playerinfo(-1) as string</SourceLine>
   <SourceLine>dim spacer as string</SourceLine>
   <SourceLine>dim sqlstring as string</SourceLine>
   <SourceLine>dim Columninfo(-1) as string</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>spacer="&lt;br&gt;&lt;br&gt;"+EndOfLine</SourceLine>
   <SourceLine>columninfo=split("Pos,Name,HS,HT,PPG,RPG,APG,SPG,BPG,TPG", ",")</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for j as integer=0 to 5</SourceLine>
   <SourceLine>//now we load on up</SourceLine>
   <SourceLine>sbstring.append TableGeneratorTitle(awards(j,0), columninfo,2)</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>if j&lt;&gt;5 then</SourceLine>
   <SourceLine>//regular awards, not player of the year</SourceLine>
   <SourceLine>for n as integer=0 to 4</SourceLine>
   <SourceLine>sqlstring=positions(n)+","</SourceLine>
   <SourceLine>for y as integer=0 to 8</SourceLine>
   <SourceLine>if y&gt;2 then</SourceLine>
   <SourceLine>sqlstring=sqlstring+format(val(mPlayers(j*5+n,y)),"##.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring=sqlstring+mPlayers(j*5+n,y)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if y&lt;8 then</SourceLine>
   <SourceLine>sqlstring=sqlstring+","</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>playerinfo=split(sqlstring, ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(n+1,playerinfo)</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>else //POY, so need position</SourceLine>
   <SourceLine>sqlstring=mPlayers(25,10)+","</SourceLine>
   <SourceLine></SourceLine>
   <SourceLine>for y as integer=0 to 8</SourceLine>
   <SourceLine>if y&gt;2 then</SourceLine>
   <SourceLine>sqlstring=sqlstring+format(val(mPlayers(25,y)),"##.0")</SourceLine>
   <SourceLine>else</SourceLine>
   <SourceLine>sqlstring=sqlstring+mPlayers(25,y)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>if y&lt;8 then</SourceLine>
   <SourceLine>sqlstring=sqlstring+","</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>playerinfo=split(sqlstring, ",")</SourceLine>
   <SourceLine>sbstring.append ColumnGenerator(1,playerinfo)</SourceLine>
   <SourceLine>end</SourceLine>
   <SourceLine>sbstring.append CloseTable</SourceLine>
   <SourceLine>next</SourceLine>
   <SourceLine>sbstring.append AddFooter</SourceLine>
   <SourceLine>return sbstring.ToString</SourceLine>
   <SourceLine>End Function</SourceLine>
  </ItemSource>
